#!/usr/bin/env bash
# scripts/repo-doctor

set -u
set -o pipefail

# shellcheck source=/dev/null
source "$(cd "$(dirname "$0")" && pwd)/lib/repo-automation-common.sh"

repo_doctor_mode="default"
repo_doctor_json=0
repo_doctor_skip_run_tests=0
repo_doctor_single_check=""
repo_doctor_stop_reason=""

repo_doctor_usage() {
  printf 'Usage: scripts/repo-doctor [--help] [--quick] [--full] [--json] [--no-run-tests] [--check NAME]\n'
}

repo_doctor_info() {
  [ "$repo_doctor_json" -eq 1 ] || repo_auto_info "$*"
}

repo_doctor_warn() {
  repo_auto_warn "$*"
}

repo_doctor_stop() {
  repo_doctor_stop_reason="$*"
  repo_auto_stop "$*"
  return 1
}

repo_doctor_json_escape() {
  local input="$1"
  input=${input//\\/\\\\}
  input=${input//\"/\\\"}
  input=${input//$'\n'/\\n}
  input=${input//$'\r'/\\r}
  input=${input//$'\t'/\\t}
  printf '%s' "$input"
}

repo_doctor_add_check() {
  local name="$1"
  local status="$2"
  local message="$3"
  checks+=("${name}|${status}|${message}")
}

repo_doctor_status_weight() {
  case "$1" in
    fail) printf '3' ;;
    warn) printf '2' ;;
    pass) printf '1' ;;
    *) printf '0' ;;
  esac
}

repo_doctor_print_json() {
  local overall_status="$1"
  local action_taken="$2"
  local checks_ref_name="$3"
  local pass_count="$4"
  local warn_count="$5"
  local fail_count="$6"
  local skipped_count="$7"
  local stop_reason="$8"
  local -n checks_ref="$checks_ref_name"
  local idx
  local name
  local status
  local message

  printf '{'
  printf '"mode":"%s",' "$(repo_doctor_json_escape "$repo_doctor_mode")"
  printf '"overall_status":"%s",' "$(repo_doctor_json_escape "$overall_status")"
  printf '"checks":['
  idx=0
  for entry in "${checks_ref[@]}"; do
    name="${entry%%|*}"
    rest="${entry#*|}"
    status="${rest%%|*}"
    message="${rest#*|}"
    if [ "$idx" -gt 0 ]; then
      printf ','
    fi
    printf '{"name":"%s","status":"%s","message":"%s"}' \
      "$(repo_doctor_json_escape "$name")" \
      "$(repo_doctor_json_escape "$status")" \
      "$(repo_doctor_json_escape "$message")"
    idx=$((idx + 1))
  done
  printf '],'
  printf '"pass_count":%s,' "$pass_count"
  printf '"warn_count":%s,' "$warn_count"
  printf '"fail_count":%s,' "$fail_count"
  printf '"skipped_count":%s,' "$skipped_count"
  printf '"action_taken":"%s",' "$(repo_doctor_json_escape "$action_taken")"
  printf '"stop_reason":"%s"' "$(repo_doctor_json_escape "$stop_reason")"
  printf '}\n'
}

repo_doctor_check_git() {
  local repo_root current_branch dirty_state remote_name remote_url expected_remote
  repo_root="$(repo_auto_repo_root)" || {
    repo_doctor_add_check "git-repo" "fail" "not inside a git repository"
    return 1
  }

  current_branch="$(git branch --show-current 2>/dev/null || true)"
  if [ -z "$current_branch" ]; then
    repo_doctor_add_check "git-branch" "warn" "unable to determine current branch"
  else
    repo_doctor_add_check "git-branch" "pass" "current branch: $current_branch"
  fi

  dirty_state="$(git status --porcelain 2>/dev/null || true)"
  if [ -n "$dirty_state" ]; then
    repo_doctor_add_check "git-worktree" "warn" "working tree is dirty"
  else
    repo_doctor_add_check "git-worktree" "pass" "working tree is clean"
  fi

  remote_name="${REMOTE_NAME:-origin}"
  remote_url="$(git remote get-url "$remote_name" 2>/dev/null || true)"
  if [ -z "$remote_url" ]; then
    repo_doctor_add_check "git-remote-url" "fail" "missing remote URL for $remote_name"
    return 1
  fi
  repo_doctor_add_check "git-remote-url" "pass" "remote $remote_name URL detected"

  expected_remote="${EXPECTED_REMOTE_URL:-}"
  if [ -n "$expected_remote" ]; then
    if [ "$remote_url" = "$expected_remote" ]; then
      repo_doctor_add_check "git-remote-match" "pass" "remote URL matches expected config"
    else
      repo_doctor_add_check "git-remote-match" "fail" "remote URL does not match expected config"
      return 1
    fi
  else
    repo_doctor_add_check "git-remote-match" "warn" "expected remote URL not configured"
  fi

  return 0
}

repo_doctor_check_config() {
  local config_path
  config_path="$(repo_auto_config_path)" || {
    repo_doctor_add_check "config-path" "fail" "unable to resolve config path"
    return 1
  }

  if [ ! -f "$config_path" ]; then
    repo_doctor_add_check "config-exists" "fail" "missing .repo-automation.conf"
    return 1
  fi
  repo_doctor_add_check "config-exists" "pass" "config file exists"

  if ! repo_auto_secret_scan_file "$config_path"; then
    repo_doctor_add_check "config-secret-scan" "fail" "config secret scan failed"
    return 1
  fi
  repo_doctor_add_check "config-secret-scan" "pass" "config secret scan passed"

  if ! repo_auto_load_config >/dev/null; then
    repo_doctor_add_check "config-load" "fail" "config failed to load"
    return 1
  fi
  repo_doctor_add_check "config-load" "pass" "config loaded"

  if ! repo_auto_validate_required_config >/dev/null; then
    repo_doctor_add_check "config-validate" "fail" "required config validation failed"
    return 1
  fi
  repo_doctor_add_check "config-validate" "pass" "required config validation passed"
  return 0
}

repo_doctor_check_script_one() {
  local path="$1"
  local name="$2"

  if [ ! -f "$path" ]; then
    repo_doctor_add_check "$name-exists" "fail" "missing $path"
    return 1
  fi
  repo_doctor_add_check "$name-exists" "pass" "$path exists"

  if [ "$path" != "scripts/lib/repo-automation-common.sh" ] && [ ! -x "$path" ]; then
    repo_doctor_add_check "$name-executable" "fail" "$path is not executable"
    return 1
  fi
  if [ "$path" != "scripts/lib/repo-automation-common.sh" ]; then
    repo_doctor_add_check "$name-executable" "pass" "$path is executable"
  fi

  if bash -n "$path" >/dev/null 2>&1; then
    repo_doctor_add_check "$name-syntax" "pass" "bash syntax ok"
  else
    repo_doctor_add_check "$name-syntax" "fail" "bash syntax check failed"
    return 1
  fi
  return 0
}

repo_doctor_check_scripts() {
  local status=0
  repo_doctor_check_script_one "scripts/branch-cleanup" "branch-cleanup" || status=1
  repo_doctor_check_script_one "scripts/codex-slice-preflight" "codex-slice-preflight" || status=1
  repo_doctor_check_script_one "scripts/pr-finish" "pr-finish" || status=1
  repo_doctor_check_script_one "scripts/add-doc-pr" "add-doc-pr" || status=1
  repo_doctor_check_script_one "scripts/repo-automation-report-upstream" "report-upstream" || status=1
  repo_doctor_check_script_one "scripts/repo-doctor" "repo-doctor" || status=1
  repo_doctor_check_script_one "scripts/repo-automation-install" "repo-automation-install" || status=1
  repo_doctor_check_script_one "scripts/run-tests" "run-tests" || status=1
  repo_doctor_check_script_one "scripts/lib/repo-automation-common.sh" "common-library" || status=1
  return "$status"
}

repo_doctor_check_json_contracts() {
  local status=0
  local branch_json preflight_json
  local temp_root="${TMPDIR:-$HOME/.cache}/repo-automation-template"

  mkdir -p "$temp_root" >/dev/null 2>&1 || true
  branch_json="$temp_root/repo-doctor-branch-cleanup.json"
  preflight_json="$temp_root/repo-doctor-preflight.json"

  if scripts/branch-cleanup --json --plan > "$branch_json" 2>/dev/null; then
    if command -v python >/dev/null 2>&1 && python -m json.tool "$branch_json" >/dev/null 2>&1; then
      repo_doctor_add_check "json-branch-cleanup" "pass" "branch-cleanup json parseable"
    elif command -v python >/dev/null 2>&1; then
      repo_doctor_add_check "json-branch-cleanup" "fail" "branch-cleanup json is not parseable"
      status=1
    else
      repo_doctor_add_check "json-branch-cleanup" "warn" "python missing; skipped parse check"
    fi
  else
    repo_doctor_add_check "json-branch-cleanup" "fail" "branch-cleanup json command failed"
    status=1
  fi

  if scripts/codex-slice-preflight --json --check-only --branch feature/doctor-smoke > "$preflight_json" 2>/dev/null; then
    if command -v python >/dev/null 2>&1 && python -m json.tool "$preflight_json" >/dev/null 2>&1; then
      repo_doctor_add_check "json-preflight" "pass" "preflight json parseable"
    elif command -v python >/dev/null 2>&1; then
      repo_doctor_add_check "json-preflight" "fail" "preflight json is not parseable"
      status=1
    else
      repo_doctor_add_check "json-preflight" "warn" "python missing; skipped parse check"
    fi
  else
    repo_doctor_add_check "json-preflight" "fail" "preflight json command failed"
    status=1
  fi

  rm -f "$branch_json" "$preflight_json" >/dev/null 2>&1 || true
  return "$status"
}

repo_doctor_check_run_tests() {
  if [ "$repo_doctor_skip_run_tests" -eq 1 ]; then
    repo_doctor_add_check "run-tests" "warn" "scripts/run-tests skipped"
    return 0
  fi

  if scripts/run-tests >/dev/null; then
    repo_doctor_add_check "run-tests" "pass" "scripts/run-tests passed"
    return 0
  fi

  repo_doctor_add_check "run-tests" "fail" "scripts/run-tests failed"
  return 1
}

repo_doctor_check_version_guard() {
  if [ ! -f tests/version-consistency.sh ]; then
    repo_doctor_add_check "version-consistency-script" "fail" "tests/version-consistency.sh missing"
    return 1
  fi

  if tests/version-consistency.sh >/dev/null; then
    repo_doctor_add_check "version-consistency" "pass" "version consistency guard passed"
    return 0
  fi

  repo_doctor_add_check "version-consistency" "fail" "version consistency guard failed"
  return 1
}

repo_doctor_check_ci_permissions() {
  local workflow=".github/workflows/ci.yml"
  if [ ! -f "$workflow" ]; then
    repo_doctor_add_check "ci-workflow-exists" "fail" "missing $workflow"
    return 1
  fi
  repo_doctor_add_check "ci-workflow-exists" "pass" "ci workflow exists"

  if grep -Eq '^[[:space:]]*contents:[[:space:]]*read[[:space:]]*$' "$workflow"; then
    repo_doctor_add_check "ci-permissions-read" "pass" "ci workflow uses contents: read"
  else
    repo_doctor_add_check "ci-permissions-read" "fail" "ci workflow missing contents: read"
    return 1
  fi

  if grep -Eq '^[[:space:]]*(contents:[[:space:]]*write|pull-requests:[[:space:]]*write|issues:[[:space:]]*write)[[:space:]]*$' "$workflow"; then
    repo_doctor_add_check "ci-permissions-write" "fail" "ci workflow requests disallowed write permissions"
    return 1
  fi
  repo_doctor_add_check "ci-permissions-write" "pass" "ci workflow avoids disallowed write permissions"
  return 0
}

repo_doctor_check_docs_index() {
  local path="docs/INDEX.md"
  local status=0

  if [ ! -f "$path" ]; then
    repo_doctor_add_check "docs-index-exists" "fail" "missing docs/INDEX.md"
    return 1
  fi
  repo_doctor_add_check "docs-index-exists" "pass" "docs index exists"

  for needle in \
    "repo-automation/branch-cleanup.md" \
    "repo-automation/codex-slice-preflight.md" \
    "repo-automation/pr-finish.md" \
    "repo-automation/add-doc-pr.md" \
    "repo-automation/repo-automation-report-upstream.md" \
    "repo-automation/repo-doctor.md" \
    "repo-automation/repo-automation-install.md" \
    "repo-automation/testing.md"
  do
    if grep -Fq "$needle" "$path"; then
      repo_doctor_add_check "docs-index-link-$needle" "pass" "docs index includes $needle"
    else
      repo_doctor_add_check "docs-index-link-$needle" "fail" "docs index missing $needle"
      status=1
    fi
  done
  return "$status"
}

repo_doctor_check_issue_templates() {
  local status=0
  if [ -f ".github/ISSUE_TEMPLATE/automation-bug.yml" ]; then
    repo_doctor_add_check "issue-template-bug" "pass" "automation bug template exists"
  else
    repo_doctor_add_check "issue-template-bug" "fail" "missing automation bug template"
    status=1
  fi

  if [ -f ".github/ISSUE_TEMPLATE/automation-feature.yml" ]; then
    repo_doctor_add_check "issue-template-feature" "pass" "automation feature template exists"
  else
    repo_doctor_add_check "issue-template-feature" "fail" "missing automation feature template"
    status=1
  fi
  return "$status"
}

repo_doctor_run_check() {
  local check_name="$1"
  case "$check_name" in
    git) repo_doctor_check_git ;;
    config) repo_doctor_check_config ;;
    scripts) repo_doctor_check_scripts ;;
    json) repo_doctor_check_json_contracts ;;
    tests) repo_doctor_check_run_tests ;;
    version) repo_doctor_check_version_guard ;;
    ci) repo_doctor_check_ci_permissions ;;
    docs) repo_doctor_check_docs_index ;;
    issue-templates) repo_doctor_check_issue_templates ;;
    *)
      repo_doctor_stop "unknown check name: $check_name"
      return 1
      ;;
  esac
}

repo_doctor_print_human_summary() {
  local overall_status="$1"
  local pass_count="$2"
  local warn_count="$3"
  local fail_count="$4"
  local skipped_count="$5"
  local -n checks_ref="$6"
  local name status message

  for entry in "${checks_ref[@]}"; do
    name="${entry%%|*}"
    rest="${entry#*|}"
    status="${rest%%|*}"
    message="${rest#*|}"
    case "$status" in
      pass) printf 'PASS: %s - %s\n' "$name" "$message" ;;
      warn) printf 'WARN: %s - %s\n' "$name" "$message" ;;
      fail) printf 'FAIL: %s - %s\n' "$name" "$message" ;;
      *) printf 'WARN: %s - %s\n' "$name" "$message" ;;
    esac
  done
  printf 'RESULT: %s (pass=%s warn=%s fail=%s skipped=%s)\n' \
    "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
}

repo_doctor_main() {
  local arg
  local command_status=0
  local overall_status="pass"
  local action_taken="read-only-diagnostics"
  local pass_count=0
  local warn_count=0
  local fail_count=0
  local skipped_count=0
  local status
  local checks_to_run=()
  checks=()

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --help)
        repo_doctor_usage
        return 0
        ;;
      --quick)
        repo_doctor_mode="quick"
        repo_doctor_skip_run_tests=1
        ;;
      --full)
        repo_doctor_mode="full"
        repo_doctor_skip_run_tests=0
        ;;
      --json)
        repo_doctor_json=1
        ;;
      --no-run-tests)
        repo_doctor_skip_run_tests=1
        ;;
      --check)
        shift
        if [ "$#" -eq 0 ]; then
          repo_doctor_stop "--check requires a name"
          command_status=1
          break
        fi
        repo_doctor_single_check="$1"
        ;;
      *)
        repo_doctor_stop "unknown argument: $arg"
        command_status=1
        break
        ;;
    esac
    shift
  done

  if [ "$command_status" -eq 0 ]; then
    repo_root="$(repo_auto_repo_root)" || command_status=1
  fi

  if [ "$command_status" -eq 0 ]; then
    cd "$repo_root" || {
      repo_doctor_stop "failed to enter repo root"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    if [ -n "$repo_doctor_single_check" ]; then
      checks_to_run=("$repo_doctor_single_check")
    else
      checks_to_run=(git config scripts json tests version ci docs issue-templates)
    fi

    for check_name in "${checks_to_run[@]}"; do
      repo_doctor_run_check "$check_name" || command_status=1
    done
  fi

  for entry in "${checks[@]}"; do
    rest="${entry#*|}"
    status="${rest%%|*}"
    case "$status" in
      pass) pass_count=$((pass_count + 1)) ;;
      warn) warn_count=$((warn_count + 1)) ;;
      fail) fail_count=$((fail_count + 1)) ;;
      *) skipped_count=$((skipped_count + 1)) ;;
    esac
  done

  if [ "$fail_count" -gt 0 ] || [ "$command_status" -ne 0 ]; then
    overall_status="fail"
  elif [ "$warn_count" -gt 0 ]; then
    overall_status="warn"
  else
    overall_status="pass"
  fi

  if [ "$repo_doctor_json" -eq 1 ]; then
    repo_doctor_print_json \
      "$overall_status" \
      "$action_taken" \
      checks \
      "$pass_count" \
      "$warn_count" \
      "$fail_count" \
      "$skipped_count" \
      "$repo_doctor_stop_reason"
  else
    repo_doctor_print_human_summary \
      "$overall_status" \
      "$pass_count" \
      "$warn_count" \
      "$fail_count" \
      "$skipped_count" \
      checks
  fi

  if [ "$overall_status" = "fail" ]; then
    return 1
  fi
  return 0
}

repo_doctor_main "$@"
# scripts/repo-doctor EOF
