#!/usr/bin/env bash
# repo-automation/bin/ci-watch

set -u
set -o pipefail

# shellcheck source=/dev/null
source "$(cd "$(dirname "$0")" && pwd)/../lib/common.sh"

ci_watch_pr=""
ci_watch_branch=""
ci_watch_poll_seconds=10
ci_watch_timeout_seconds=600
ci_watch_json=0
ci_watch_machine_json=0
ci_watch_quiet=0
ci_watch_explain=0
ci_watch_summary_json=""

ci_watch_usage() {
  printf 'Usage: repo-automation/bin/ci-watch [--pr=<number> | --branch=<name>] [--poll-seconds=<seconds>] [--timeout=<seconds>] [--json] [--machine-json] [--quiet] [--explain] [--help]\n'
}

ci_watch_flag_error() {
  local reason="$1"
  local flag="$2"
  local fix="$3"

  printf 'fail: %s\n' "$reason" >&2
  printf 'flag: %s\n' "$flag" >&2
  printf 'fix: %s\n' "$fix" >&2
}

ci_watch_json_escape() {
  local input="$1"
  input=${input//\\/\\\\}
  input=${input//"/\\"}
  input=${input//$'\n'/\\n}
  input=${input//$'\r'/\\r}
  input=${input//$'\t'/\\t}
  printf '%s' "$input"
}

ci_watch_status_value() {
  python3 - "$1" <<'PY'
import json
import sys

data = json.loads(sys.argv[1])
print(data.get('overall_status', 'fail'))
PY
}

ci_watch_json_field() {
  python3 - "$1" "$2" <<'PY'
import json
import sys

data = json.loads(sys.argv[1])
path = sys.argv[2].split('.')
cur = data
for key in path:
    if isinstance(cur, dict):
        cur = cur.get(key, '')
    else:
        cur = ''
        break
print(cur if cur is not None else '')
PY
}

ci_watch_print_failure_details() {
  local latest_run_id=""
  local failure_json=""
  local failure_status=0
  local failure_label=""
  local failure_log_path=""
  local failure_excerpt=""
  local failure_fix=""

  latest_run_id="$(ci_watch_json_field "$ci_watch_summary_json" latest_run.databaseId)"
  [ -n "$latest_run_id" ] || return 0

  failure_json="$(repo-automation/bin/ci-log-dump --run-id="$latest_run_id" --first-failure --machine-json 2>&1)" || failure_status=$?
  if [ "$failure_status" -ne 0 ] || [ -z "$failure_json" ]; then
    return 0
  fi

  failure_label="$(ci_watch_json_field "$failure_json" first_failure_label)"
  failure_log_path="$(ci_watch_json_field "$failure_json" log_path)"
  failure_excerpt="$(ci_watch_json_field "$failure_json" first_failure_excerpt)"
  failure_fix="$(ci_watch_json_field "$failure_json" recommended_fix)"

  [ -n "$failure_label" ] && printf 'actionable failure: %s\n' "$failure_label" >&2
  [ -n "$failure_log_path" ] && printf 'log path: %s\n' "$failure_log_path" >&2
  [ -n "$failure_excerpt" ] && printf 'excerpt: %s\n' "$failure_excerpt" >&2
  [ -n "$failure_fix" ] && printf 'fix: %s\n' "$failure_fix" >&2
}

ci_watch_poll() {
  local ci_status_out
  local ci_status_err

  ci_status_out="$(mktemp "${TMPDIR:-$HOME/.cache}/ci-watch-status.XXXXXX")"
  ci_status_err="$(mktemp "${TMPDIR:-$HOME/.cache}/ci-watch-status-stderr.XXXXXX")"

  if [ -n "$ci_watch_pr" ]; then
    "$(dirname "$0")/ci-status" --pr="$ci_watch_pr" --json >"$ci_status_out" 2>"$ci_status_err"
  else
    "$(dirname "$0")/ci-status" --branch="$ci_watch_branch" --json >"$ci_status_out" 2>"$ci_status_err"
  fi

  if [ ! -s "$ci_status_out" ] || ! python3 -m json.tool "$ci_status_out" >/dev/null 2>&1; then
    cat "$ci_status_err" >&2
    rm -f "$ci_status_out" "$ci_status_err" >/dev/null 2>&1 || true
    return 1
  fi

  ci_watch_summary_json="$(cat "$ci_status_out")"
  rm -f "$ci_status_out" "$ci_status_err" >/dev/null 2>&1 || true
  return 0
}

ci_watch_print_human() {
  local status="$1"
  local elapsed="$2"
  local mode="${3:-summary}"

  if [ "$mode" = "explain" ]; then
    printf 'CI watch status: %s after %ss\n' "$status" "$elapsed"
    return 0
  fi

  if [ "$status" = "pass" ] && [ "$ci_watch_quiet" -eq 1 ]; then
    return 0
  fi

  case "$status" in
    pass) printf 'pass\n' ;;
    fail) printf 'fail: CI checks failed\n' >&2 ;;
    pending) printf 'wait: CI checks still pending\n' ;;
    *) printf 'fail: CI watch ended with status %s\n' "$status" >&2 ;;
  esac
}

ci_watch_print_json() {
  local status="$1"
  local elapsed="$2"
  printf '{'
  printf '"script":"ci-watch",'
  printf '"machine_json":true,'
  printf '"pr":"%s",' "$(ci_watch_json_escape "$ci_watch_pr")"
  printf '"branch":"%s",' "$(ci_watch_json_escape "$ci_watch_branch")"
  printf '"poll_seconds":%s,' "$ci_watch_poll_seconds"
  printf '"timeout_seconds":%s,' "$ci_watch_timeout_seconds"
  printf '"elapsed_seconds":%s,' "$elapsed"
  printf '"overall_status":"%s",' "$(ci_watch_json_escape "$status")"
  printf '"ci_status":%s' "$ci_watch_summary_json"
  printf '}\n'
}

ci_watch_main() {
  local arg
  local started_at
  local elapsed
  local status

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --help)
        ci_watch_usage
        return 0
        ;;
      --pr=*)
        ci_watch_pr="${arg#--pr=}"
        if [ -z "$ci_watch_pr" ]; then
          ci_watch_flag_error "empty flag value" "--pr" "use --pr=<number>"
          return 1
        fi
        if ! repo_auto_is_positive_integer "$ci_watch_pr"; then
          repo_auto_stop "invalid --pr value: $ci_watch_pr"
          return 1
        fi
        ;;
      --pr)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          ci_watch_flag_error "flag format not accepted" "--pr" "use --pr=<number>"
        else
          ci_watch_flag_error "missing flag value" "--pr" "use --pr=<number>"
        fi
        return 1
        ;;
      --branch=*)
        ci_watch_branch="${arg#--branch=}"
        if [ -z "$ci_watch_branch" ]; then
          ci_watch_flag_error "empty flag value" "--branch" "use --branch=<name>"
          return 1
        fi
        if ! repo_auto_validate_branch_name "$ci_watch_branch"; then
          repo_auto_stop "invalid --branch value: $ci_watch_branch"
          return 1
        fi
        ;;
      --branch)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          ci_watch_flag_error "flag format not accepted" "--branch" "use --branch=<name>"
        else
          ci_watch_flag_error "missing flag value" "--branch" "use --branch=<name>"
        fi
        return 1
        ;;
      --poll-seconds=*)
        ci_watch_poll_seconds="${arg#--poll-seconds=}"
        if [ -z "$ci_watch_poll_seconds" ]; then
          ci_watch_flag_error "empty flag value" "--poll-seconds" "use --poll-seconds=<seconds>"
          return 1
        fi
        if ! repo_auto_is_positive_integer "$ci_watch_poll_seconds"; then
          repo_auto_stop "invalid --poll-seconds value: $ci_watch_poll_seconds"
          return 1
        fi
        ;;
      --poll-seconds)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          ci_watch_flag_error "flag format not accepted" "--poll-seconds" "use --poll-seconds=<seconds>"
        else
          ci_watch_flag_error "missing flag value" "--poll-seconds" "use --poll-seconds=<seconds>"
        fi
        return 1
        ;;
      --timeout=*)
        ci_watch_timeout_seconds="${arg#--timeout=}"
        if [ -z "$ci_watch_timeout_seconds" ]; then
          ci_watch_flag_error "empty flag value" "--timeout" "use --timeout=<seconds>"
          return 1
        fi
        if ! repo_auto_is_positive_integer "$ci_watch_timeout_seconds"; then
          repo_auto_stop "invalid --timeout value: $ci_watch_timeout_seconds"
          return 1
        fi
        ;;
      --timeout)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          ci_watch_flag_error "flag format not accepted" "--timeout" "use --timeout=<seconds>"
        else
          ci_watch_flag_error "missing flag value" "--timeout" "use --timeout=<seconds>"
        fi
        return 1
        ;;
      --machine-json)
        ci_watch_machine_json=1
        ;;
      --json)
        ci_watch_json=1
        ;;
      --quiet)
        ci_watch_quiet=1
        ;;
      --explain)
        ci_watch_explain=1
        ;;
      *)
        if [ "${arg#--}" != "$arg" ]; then
          ci_watch_flag_error "unknown flag" "$arg" "run repo-automation/bin/ci-watch --help"
        else
          repo_auto_stop "unknown argument: $arg"
        fi
        return 1
        ;;
    esac
    shift
  done

  if [ -z "$ci_watch_pr" ] && [ -z "$ci_watch_branch" ]; then
    repo_auto_stop 'provide --pr=NUMBER or --branch=NAME'
    return 1
  fi

  started_at="$(date +%s)"

  while :; do
    if ! ci_watch_poll; then
      return 1
    fi

    status="$(ci_watch_status_value "$ci_watch_summary_json")"
    elapsed="$(( $(date +%s) - started_at ))"

    case "$status" in
      pass)
        if [ "$ci_watch_json" -eq 1 ] || [ "$ci_watch_machine_json" -eq 1 ]; then
          ci_watch_print_json "$status" "$elapsed"
        else
          if [ "$ci_watch_explain" -eq 1 ]; then
            ci_watch_print_human "$status" "$elapsed" explain
          else
            ci_watch_print_human "$status" "$elapsed"
          fi
        fi
        return 0
        ;;
      fail)
        if [ "$ci_watch_json" -eq 0 ] && [ "$ci_watch_machine_json" -eq 0 ]; then
          ci_watch_print_failure_details
        fi
        if [ "$ci_watch_json" -eq 1 ] || [ "$ci_watch_machine_json" -eq 1 ]; then
          ci_watch_print_json "$status" "$elapsed"
        else
          if [ "$ci_watch_explain" -eq 1 ]; then
            ci_watch_print_human "$status" "$elapsed" explain
          else
            ci_watch_print_human "$status" "$elapsed"
          fi
        fi
        return 1
        ;;
      pending)
        if [ "$elapsed" -ge "$ci_watch_timeout_seconds" ]; then
          repo_auto_stop "timed out after ${ci_watch_timeout_seconds}s while waiting for CI"
          return 1
        fi
        sleep "$ci_watch_poll_seconds"
        ;;
      *)
        if [ "$ci_watch_json" -eq 1 ] || [ "$ci_watch_machine_json" -eq 1 ]; then
          ci_watch_print_json "$status" "$elapsed"
        else
          if [ "$ci_watch_explain" -eq 1 ]; then
            ci_watch_print_human "$status" "$elapsed" explain
          else
            ci_watch_print_human "$status" "$elapsed"
          fi
        fi
        return 1
        ;;
    esac
  done
}

ci_watch_main "$@"
# repo-automation/bin/ci-watch EOF
