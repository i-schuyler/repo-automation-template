#!/usr/bin/env bash
# repo-automation/bin/codex-slice-preflight

set -u
set -o pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
. "$script_dir/../lib/common.sh" || {
  printf 'STOP: failed to source shared library\n' >&2
  return 2 2>/dev/null || exit 2
}

preflight_json=0
preflight_explain=0
preflight_stop_reason=""
preflight_mode="run"
preflight_disk_guard_low_bytes=1610612736
preflight_disk_status="skip"
preflight_disk_guard_used_percent=""
preflight_disk_guard_available_percent=""
preflight_disk_guard_available_bytes=""
preflight_disk_guard_mountpoint=""
preflight_disk_guard_filesystem=""
preflight_cleanup_deleted_count=0
preflight_cleanup_deleted_paths=""
preflight_cleanup_skipped_paths=""
preflight_cleanup_preserved_path=""
preflight_cleanup_free_before_bytes=""
preflight_cleanup_free_after_bytes=""

preflight_usage() {
  printf 'Usage: repo-automation/bin/codex-slice-preflight --branch=<name> [--check-only] [--delete-safe-stale] [--clean-test-cache] [--preserve-path=<path>] [--json] [--explain] [--help]\n'
}

preflight_flag_error() {
  local reason="$1"
  local flag="$2"
  local fix="$3"

  repo_auto_flag_error "$reason" "$flag" "$fix" || true
  preflight_stop_reason="$reason"
  return 1
}

preflight_info() {
  printf 'INFO: %s\n' "$*" >&2
}

preflight_warn() {
  printf 'WARN: %s\n' "$*" >&2
}

preflight_stop() {
  preflight_stop_reason="$*"
  printf 'STOP: %s\n' "$*" >&2
  return 1
}

preflight_json_escape() {
  local value="${1:-}"
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "$value"
}

preflight_json_string_or_null() {
  local value="${1-}"

  if [ -n "$value" ]; then
    printf '"%s"' "$(preflight_json_escape "$value")"
  else
    printf 'null'
  fi
}

preflight_json_number_or_null() {
  local value="${1-}"

  if [ -n "$value" ]; then
    printf '%s' "$value"
  else
    printf 'null'
  fi
}

preflight_human_bytes() {
  local bytes="${1:-}"

  [ -n "$bytes" ] || return 0
  python3 - "$bytes" <<'PY'
import sys

bytes_value = int(sys.argv[1])
units = ["B", "KiB", "MiB", "GiB", "TiB", "PiB", "EiB"]
value = float(bytes_value)
for unit in units:
    if abs(value) < 1024.0 or unit == units[-1]:
        if unit == "B":
            print(f"{int(value)}B")
        else:
            print(f"{value:.1f}{unit}")
        break
    value /= 1024.0
PY
}

preflight_is_non_negative_integer() {
  case "${1:-}" in
    ''|*[!0-9]*)
      return 1
      ;;
  esac

  return 0
}

preflight_command_string() {
  local arg
  local quoted=""

  for arg in "$@"; do
    quoted+="$(printf '%q ' "$arg")"
  done

  printf '%s' "${quoted% }"
}

preflight_resolve_existing_path() {
  local input_path="$1"
  local resolved_path=""

  resolved_path="$(
    python3 - "$input_path" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1]).expanduser()
try:
    resolved = path.resolve(strict=True)
except OSError:
    print(f"fail: preserve path does not exist or is not accessible: {path}", file=sys.stderr)
    print("fix: provide an existing preserve path", file=sys.stderr)
    raise SystemExit(1)

print(resolved)
PY
  )" || return 1

  printf '%s\n' "$resolved_path"
}

preflight_paths_overlap() {
  local candidate_path="$1"
  local preserve_path="$2"

  python3 - "$candidate_path" "$preserve_path" <<'PY'
from pathlib import Path
import sys

candidate = Path(sys.argv[1]).expanduser().resolve(strict=False)
preserve = Path(sys.argv[2]).expanduser().resolve(strict=True)

def contains(parent, child):
    try:
        child.relative_to(parent)
    except ValueError:
        return False
    return True

if candidate == preserve or contains(candidate, preserve) or contains(preserve, candidate):
    raise SystemExit(0)
raise SystemExit(1)
PY
}

preflight_disk_guard_collect() {
  local path="$1"
  local df_bin="${PREFLIGHT_DF_BIN:-${REPO_AUTOMATION_DF_BIN:-df}}"
  local filesystem=""
  local available_blocks=""
  local use_percent=""
  local mountpoint=""

  if ! read -r filesystem _ _ available_blocks use_percent mountpoint <<EOF
$(LC_ALL=C "$df_bin" -Pk "$path" 2>/dev/null | sed -n '2p')
EOF
  then
    return 1
  fi

  available_blocks="${available_blocks:-}"
  use_percent="${use_percent%\%}"
  if ! preflight_is_non_negative_integer "$available_blocks"; then
    return 1
  fi
  if ! preflight_is_non_negative_integer "$use_percent"; then
    return 1
  fi

  preflight_disk_guard_filesystem="${filesystem:-unknown}"
  preflight_disk_guard_mountpoint="${mountpoint:-$path}"
  preflight_disk_guard_used_percent="$use_percent"
  preflight_disk_guard_available_bytes=$((available_blocks * 1024))
  preflight_disk_guard_available_percent=$((100 - use_percent))
  if [ "$preflight_disk_guard_available_percent" -lt 0 ]; then
    preflight_disk_guard_available_percent=0
  fi

  return 0
}

preflight_disk_guard_print() {
  local guard_path="${1:-/}"
  local human_free=""
  local human_threshold=""

  human_free="$(preflight_human_bytes "$preflight_disk_guard_available_bytes")"
  human_threshold="$(preflight_human_bytes "$preflight_disk_guard_low_bytes")"

  preflight_info "disk space: filesystem=${preflight_disk_guard_filesystem:-unknown} mount=${preflight_disk_guard_mountpoint:-$guard_path} used=${preflight_disk_guard_used_percent}% available=${preflight_disk_guard_available_percent}% free=${human_free:-unknown} threshold=${human_threshold:-unknown} free_bytes=${preflight_disk_guard_available_bytes} threshold_bytes=${preflight_disk_guard_low_bytes} path=$guard_path"
}

preflight_disk_guard_check() {
  local guard_path="$1"

  if ! preflight_disk_guard_collect "$guard_path"; then
    preflight_disk_status="fail"
    preflight_stop "failed to inspect disk space for $guard_path"
    return 1
  fi

  if [ "$preflight_disk_guard_available_bytes" -lt "$preflight_disk_guard_low_bytes" ]; then
    preflight_disk_status="fail"
    [ "$preflight_explain" -eq 1 ] && preflight_disk_guard_print "$guard_path"
    preflight_info "fix: repo-automation/bin/codex-slice-preflight --clean-test-cache --explain"
    preflight_stop "available disk space below threshold"
    return 1
  fi

  preflight_disk_status="pass"
  [ "$preflight_explain" -eq 1 ] && preflight_disk_guard_print "$guard_path"
  return 0
}

preflight_cleanup_root_candidates() {
  printf '%s\n' "${TMPDIR:-$HOME/.cache}/repo-automation-template-tests"
  printf '%s\n' "$HOME/.cache/repo-automation-template-tests"
  printf '%s\n' "${TMPDIR:-$HOME/.cache}/repo-automation-template"
  printf '%s\n' "$HOME/.cache/repo-automation-template"
  printf '%s\n' "${TMPDIR:-$HOME/.cache}/repo-automation"
  printf '%s\n' "$HOME/.cache/repo-automation"
  printf '%s\n' "${TMPDIR:-$HOME/.cache}/repo-automation-log-dump"
  printf '%s\n' "$HOME/.cache/repo-automation-log-dump"
}

preflight_cleanup_prefix_candidates() {
  local parent=""
  local resolved_parent=""
  local seen_parents=""
  local path=""
  local base=""

  while IFS= read -r parent; do
    [ -n "$parent" ] || continue
    resolved_parent="$(
      python3 - "$parent" <<'PY'
from pathlib import Path
import sys

print(Path(sys.argv[1]).expanduser().resolve(strict=False))
PY
    )" || continue
    case "$seen_parents" in
      *"$resolved_parent"$'\n'*)
        continue
        ;;
    esac
    seen_parents="${seen_parents}${resolved_parent}"$'\n'
    [ -d "$resolved_parent" ] || continue

    while IFS= read -r path; do
      [ -n "$path" ] || continue
      base="${path##*/}"
      case "$base" in
        repo-automation-slice-handoff-fixture.*|repo-automation-slice-handoff-dirty.*|clean-repo-automation-template.*)
          printf '%s\n' "$path"
          ;;
      esac
    done <<EOF
$(find "$resolved_parent" -mindepth 1 -maxdepth 1 -type d 2>/dev/null)
EOF
  done <<EOF
${TMPDIR:-$HOME/.cache}
$HOME/.cache/tmp
EOF
}

preflight_clean_test_cache() {
  local root="${TMPDIR:-$HOME/.cache}"
  local path=""
  local seen=""
  local preserve_path="${preflight_cleanup_preserved_path:-}"

  preflight_cleanup_deleted_count=0
  preflight_cleanup_deleted_paths=""
  preflight_cleanup_skipped_paths=""
  preflight_cleanup_preserved_path=""
  preflight_cleanup_free_before_bytes=""
  preflight_cleanup_free_after_bytes=""
  if [ -n "$preserve_path" ]; then
    preflight_cleanup_preserved_path="$preserve_path"
  fi
  preflight_disk_status="pass"

  if preflight_disk_guard_collect "$root"; then
    preflight_cleanup_free_before_bytes="$preflight_disk_guard_available_bytes"
  fi

  while IFS= read -r path; do
    [ -n "$path" ] || continue
    case "$seen" in
      *"$path"$'\n'*)
        continue
        ;;
    esac
    seen="${seen}${path}"$'\n'
    if [ -n "$preserve_path" ] && preflight_paths_overlap "$path" "$preserve_path"; then
      if [ -n "$preflight_cleanup_skipped_paths" ]; then
        preflight_cleanup_skipped_paths="$preflight_cleanup_skipped_paths, $path"
      else
        preflight_cleanup_skipped_paths="$path"
      fi
      continue
    fi
    if [ -e "$path" ]; then
      rm -rf -- "$path" || return 1
      if [ -n "$preflight_cleanup_deleted_paths" ]; then
        preflight_cleanup_deleted_paths="$preflight_cleanup_deleted_paths, $path"
      else
        preflight_cleanup_deleted_paths="$path"
      fi
      preflight_cleanup_deleted_count=$((preflight_cleanup_deleted_count + 1))
    fi
  done <<EOF
$(preflight_cleanup_root_candidates)
$(preflight_cleanup_prefix_candidates)
EOF

  if preflight_disk_guard_collect "$root"; then
    preflight_cleanup_free_after_bytes="$preflight_disk_guard_available_bytes"
  fi
}

preflight_append_cleanup_summary_lines() {
  local -n summary_lines_ref="$1"
  local include_details="${2:-1}"

  summary_lines_ref+=("cleanup_deleted_count=${preflight_cleanup_deleted_count:-0}")
  if [ "$include_details" -eq 1 ]; then
    summary_lines_ref+=("cleanup_preserved_path=${preflight_cleanup_preserved_path:-none}")
    summary_lines_ref+=("cleanup_skipped_paths=${preflight_cleanup_skipped_paths:-none}")
    summary_lines_ref+=("cleanup_deleted_paths=${preflight_cleanup_deleted_paths:-none}")
    if [ -n "${preflight_cleanup_free_before_bytes:-}" ]; then
      summary_lines_ref+=("cleanup_free_before_bytes=${preflight_cleanup_free_before_bytes:-}")
      summary_lines_ref+=("cleanup_free_before=$(preflight_human_bytes "$preflight_cleanup_free_before_bytes")")
    fi
    if [ -n "${preflight_cleanup_free_after_bytes:-}" ]; then
      summary_lines_ref+=("cleanup_free_after_bytes=${preflight_cleanup_free_after_bytes:-}")
      summary_lines_ref+=("cleanup_free_after=$(preflight_human_bytes "$preflight_cleanup_free_after_bytes")")
    fi
  fi
}

preflight_print_cleanup_info() {
  if [ "$preflight_explain" -ne 1 ]; then
    return 0
  fi

  preflight_info "clean-test-cache removed: ${preflight_cleanup_deleted_paths:-none}"
  preflight_info "clean-test-cache preserved: ${preflight_cleanup_preserved_path:-none}"
  preflight_info "clean-test-cache skipped: ${preflight_cleanup_skipped_paths:-none}"
  if [ -n "${preflight_cleanup_free_before_bytes:-}" ] && [ -n "${preflight_cleanup_free_after_bytes:-}" ]; then
    preflight_info "clean-test-cache free: before=$(preflight_human_bytes "$preflight_cleanup_free_before_bytes") after=$(preflight_human_bytes "$preflight_cleanup_free_after_bytes")"
  fi
}

preflight_print_json() {
  local branch="$1"
  local default_branch="$2"
  local remote_name="$3"
  local current_branch="$4"
  local divergence="$5"
  local cleanup_mode="$6"
  local cleanup_json="$7"
  local stop_reason="$8"
  local exit_code="$9"
  local disk_value="${10:-skip}"

  printf '{'
  printf '"branch":"%s",' "$(preflight_json_escape "$branch")"
  printf '"mode":"%s",' "$(preflight_json_escape "$preflight_mode")"
  printf '"rc":%s,' "$exit_code"
  printf '"disk":"%s",' "$(preflight_json_escape "$disk_value")"
  printf '"default_branch":"%s",' "$(preflight_json_escape "$default_branch")"
  printf '"remote_name":"%s",' "$(preflight_json_escape "$remote_name")"
  printf '"current_branch":"%s",' "$(preflight_json_escape "$current_branch")"
  printf '"divergence":"%s",' "$(preflight_json_escape "$divergence")"
  printf '"branch_cleanup_mode":"%s",' "$(preflight_json_escape "$cleanup_mode")"
  printf '"branch_cleanup_status":%s,' "${cleanup_json:-null}"
  printf '"cleanup_deleted_count":%s,' "${preflight_cleanup_deleted_count:-0}"
  printf '"cleanup_deleted_paths":%s,' "$(preflight_json_string_or_null "${preflight_cleanup_deleted_paths:-}")"
  printf '"cleanup_preserved_path":%s,' "$(preflight_json_string_or_null "${preflight_cleanup_preserved_path:-}")"
  printf '"cleanup_skipped_paths":%s,' "$(preflight_json_string_or_null "${preflight_cleanup_skipped_paths:-}")"
  printf '"cleanup_free_before_bytes":%s,' "$(preflight_json_number_or_null "${preflight_cleanup_free_before_bytes:-}")"
  printf '"cleanup_free_after_bytes":%s,' "$(preflight_json_number_or_null "${preflight_cleanup_free_after_bytes:-}")"
  printf '"stop_reason":"%s"' "$(preflight_json_escape "$stop_reason")"
  printf '}\n'
}

preflight_branch_exists_local() {
  local name="$1"
  git show-ref --verify --quiet "refs/heads/$name"
}

preflight_validate_branch_request() {
  local requested="$1"
  local default_branch="$2"

  repo_auto_validate_branch_name "$requested" || {
    preflight_stop "invalid --branch value: $requested"
    return 1
  }

  if [ "$requested" = "$default_branch" ]; then
    preflight_stop "requested branch must not equal default branch: $default_branch"
    return 1
  fi
}

preflight_main() {
  local requested_branch=""
  local branch_flag_seen=0
  local branch_value_set=0
  local check_only=0
  local delete_safe_stale=0
  local clean_test_cache=0
  local preserve_path=""
  local preserve_path_abs=""
  local command_status=0
  local repo_root=""
  local current_branch=""
  local default_branch=""
  local remote_name=""
  local expected_remote_url=""
  local preflight_require_clean="true"
  local active_cleanup_mode="plan"
  local remote_url=""
  local divergence=""
  local ahead_count=0
  local behind_count=0
  local branch_preexists=0
  local divergence_target=""
  local worktree_status=""
  local cleanup_json=""
  local branch_before=""
  local branch_after=""
  local status_count=0
  local arg

  while [ "$#" -gt 0 ]; do
    arg="$1"
    shift
    case "$arg" in
      --branch=)
        branch_flag_seen=1
        preflight_flag_error "empty flag value" "--branch" "use --branch=<name>" || command_status=1
        ;;
      --branch=*)
        branch_flag_seen=1
        requested_branch="${arg#--branch=}"
        if [ -n "$requested_branch" ]; then
          branch_value_set=1
        else
          preflight_flag_error "empty flag value" "--branch" "use --branch=<name>" || command_status=1
        fi
        ;;
      --branch)
        branch_flag_seen=1
        if [ "$#" -eq 0 ]; then
          preflight_flag_error "missing flag value" "--branch" "use --branch=<name>" || command_status=1
        elif [ "${1#-}" != "$1" ]; then
          shift
          preflight_flag_error "missing flag value" "--branch" "use --branch=<name>" || command_status=1
        else
          shift
          preflight_flag_error "flag format not accepted" "--branch" "use --branch=<name>" || command_status=1
        fi
        ;;
      --check-only)
        check_only=1
        preflight_mode="check-only"
        ;;
      --delete-safe-stale)
        delete_safe_stale=1
        ;;
      --clean-test-cache)
        clean_test_cache=1
        preflight_mode="clean-test-cache"
        ;;
      --preserve-path=)
        preflight_flag_error "empty flag value" "--preserve-path" "use --preserve-path=<path>" || command_status=1
        ;;
      --preserve-path=*)
        preserve_path="${arg#--preserve-path=}"
        if [ -z "$preserve_path" ]; then
          preflight_flag_error "empty flag value" "--preserve-path" "use --preserve-path=<path>" || command_status=1
        fi
        ;;
      --preserve-path)
        preflight_flag_error "missing flag value" "--preserve-path" "use --preserve-path=<path>" || command_status=1
        ;;
      --json)
        preflight_json=1
        ;;
      --explain)
        preflight_explain=1
        ;;
      --help)
        preflight_usage
        return 0
        ;;
      *)
        preflight_flag_error "unknown flag" "$arg" "run repo-automation/bin/codex-slice-preflight --help" || command_status=1
        ;;
    esac
  done

  if [ "$command_status" -eq 0 ] && [ "$clean_test_cache" -eq 1 ] && [ -n "$preserve_path" ]; then
    preserve_path_abs="$(preflight_resolve_existing_path "$preserve_path")" || {
      command_status=1
    }
    if [ "$command_status" -eq 0 ]; then
      preflight_cleanup_preserved_path="$preserve_path_abs"
    fi
  fi

  if [ "$command_status" -ne 0 ] && [ "$clean_test_cache" -eq 1 ] && [ -n "$preserve_path" ]; then
    return 1
  fi

  if [ "$command_status" -eq 0 ] && [ "$clean_test_cache" -eq 1 ]; then
    preflight_clean_test_cache || command_status=1
    if [ "$branch_value_set" -eq 0 ]; then
      if [ "$preflight_json" -eq 1 ]; then
        preflight_print_json \
          "" \
          "" \
          "" \
          "" \
          "" \
          "$preflight_mode" \
          "${cleanup_json:-null}" \
          "${preflight_stop_reason:-}" \
          "$command_status" \
          "${preflight_disk_status:-skip}"
      elif [ "$preflight_explain" -eq 1 ]; then
        preflight_print_cleanup_info
        local -a summary_lines=(
          "script=codex-slice-preflight"
          "mode=$preflight_mode"
          "rc=$command_status"
          "disk=${preflight_disk_status:-pass}"
        )
        preflight_append_cleanup_summary_lines summary_lines
        summary_lines+=("url_or_stop=${preflight_stop_reason:-pass}")
        repo_auto_print_final_summary "${summary_lines[@]}" >&2
      elif [ "$command_status" -eq 0 ]; then
        printf 'pass\n'
      fi
      return "$command_status"
    fi
    preflight_print_cleanup_info
  fi

  [ "$branch_value_set" -eq 1 ] || {
    if [ "$command_status" -eq 0 ] && [ "$branch_flag_seen" -eq 0 ]; then
      preflight_flag_error "missing flag value" "--branch" "use --branch=<name>" || command_status=1
    elif [ "$command_status" -eq 0 ] && [ "$branch_flag_seen" -eq 1 ] && [ -z "$requested_branch" ]; then
      preflight_flag_error "missing flag value" "--branch" "use --branch=<name>" || command_status=1
    fi
    command_status=1
  }

  repo_auto_require_command git || {
    preflight_stop "git is required"
    command_status=1
  }

  if [ "$command_status" -eq 0 ]; then
    repo_root=$(repo_auto_repo_root) || {
      preflight_stop "failed to determine repo root"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    cd "$repo_root" || {
      preflight_stop "failed to enter repo root: $repo_root"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    repo_auto_load_config || {
      preflight_stop "failed to load .repo-automation.conf"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    repo_auto_validate_required_config || {
      preflight_stop "invalid .repo-automation.conf"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    default_branch="${DEFAULT_BRANCH:-main}"
    remote_name="${REMOTE_NAME:-origin}"
    expected_remote_url="${EXPECTED_REMOTE_URL:-}"
    preflight_require_clean="${PREFLIGHT_REQUIRE_CLEAN_WORKTREE:-true}"
    active_cleanup_mode="plan"
    if [ "$delete_safe_stale" -eq 1 ]; then
      active_cleanup_mode="apply"
    fi
  fi

  if [ "$command_status" -eq 0 ] && ! preflight_disk_guard_check "/"; then
    command_status=1
  fi

  if [ "$command_status" -eq 0 ]; then
    preflight_validate_branch_request "$requested_branch" "$default_branch" || command_status=1
  fi

  if [ "$command_status" -eq 0 ]; then
    repo_auto_validate_branch_name "$remote_name" || {
      preflight_stop "invalid remote name in config: $remote_name"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    remote_url=$(git remote get-url "$remote_name" 2>/dev/null) || {
      preflight_stop "failed to read remote URL for $remote_name"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ] && ! repo_auto_remote_matches_upstream "$remote_url" "$expected_remote_url" "${UPSTREAM_REPO_FULL_NAME:-}"; then
    preflight_stop "remote URL mismatch for $remote_name: expected $expected_remote_url or GitHub SSH alias for ${UPSTREAM_REPO_FULL_NAME:-unknown}, got $remote_url"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ]; then
    current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || {
      preflight_stop "failed to determine current branch"
      command_status=1
    }
  fi

  branch_before="${current_branch:-}"

  if [ "$command_status" -eq 0 ]; then
    worktree_status=$(git status --porcelain)
    if [ -n "$worktree_status" ] && [ "$check_only" -eq 0 ]; then
      preflight_stop "working tree must be clean before preflight"
      command_status=1
    fi
    if [ -n "$worktree_status" ] && [ "$check_only" -eq 1 ]; then
      preflight_warn "working tree is dirty; normal preflight would stop before edits"
    fi
  fi

  if [ "$command_status" -eq 0 ]; then
    if [ "$active_cleanup_mode" = "apply" ]; then
      cleanup_json=$("$repo_root/repo-automation/bin/branch-cleanup" --json --apply 2>/dev/null) || {
        preflight_stop "branch-cleanup failed in apply mode"
        command_status=1
      }
    else
      cleanup_json=$("$repo_root/repo-automation/bin/branch-cleanup" --json --plan 2>/dev/null) || {
        preflight_stop "branch-cleanup failed in plan mode"
        command_status=1
      }
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$check_only" -eq 1 ]; then
    current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || current_branch=""
    divergence_target="HEAD"
    if preflight_branch_exists_local "$requested_branch"; then
      branch_preexists=1
      divergence_target="refs/heads/$requested_branch"
    fi
    divergence=$(git rev-list --left-right --count "$remote_name/$default_branch...$divergence_target" 2>/dev/null) || divergence="unknown"
    behind_count=$(printf '%s' "$divergence" | awk '{print $1}')
    ahead_count=$(printf '%s' "$divergence" | awk '{print $2}')
    if [ "$branch_preexists" -eq 1 ]; then
      if [ "${behind_count:-0}" -gt 0 ] && [ "${ahead_count:-0}" -gt 0 ]; then
        preflight_stop "branch diverged from $remote_name/$default_branch: $divergence"
        command_status=1
      elif [ "${behind_count:-0}" -gt 0 ]; then
        preflight_stop "existing branch is behind $remote_name/$default_branch: $divergence; recreate, reset, or rebase it"
        command_status=1
      fi
    fi
    if [ "$preflight_json" -eq 0 ] && [ "$preflight_explain" -eq 1 ]; then
      preflight_info "check-only complete"
      preflight_info "next step: repo-automation/bin/codex-slice-preflight --branch=$requested_branch"
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$check_only" -eq 0 ]; then
    git checkout "$default_branch" >/dev/null 2>&1 || {
      preflight_stop "failed to checkout $default_branch"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ] && [ "$check_only" -eq 0 ]; then
    git pull --ff-only >/dev/null || {
      preflight_stop "git pull --ff-only failed on $default_branch"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ] && [ "$check_only" -eq 0 ]; then
    git remote prune "$remote_name" >/dev/null || {
      preflight_stop "git remote prune failed for $remote_name"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ] && [ "$check_only" -eq 0 ]; then
    git fetch "$remote_name" --prune >/dev/null || {
      preflight_stop "git fetch --prune failed for $remote_name"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ] && [ "$check_only" -eq 0 ]; then
    if command -v gh >/dev/null 2>&1; then
      gh pr list --state open --json number,title,headRefName,baseRefName,isDraft,mergeable,statusCheckRollup >/dev/null 2>&1 || {
        preflight_warn "gh is available but open PR listing failed"
      }
    elif [ "${PR_PROVIDER:-none}" = "github" ]; then
      preflight_warn "gh not found; skipping open PR listing"
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$check_only" -eq 0 ]; then
    if preflight_branch_exists_local "$requested_branch"; then
      branch_preexists=1
      git checkout "$requested_branch" >/dev/null 2>&1 || {
        preflight_stop "failed to checkout existing branch: $requested_branch"
        command_status=1
      }
    else
      git switch -c "$requested_branch" >/dev/null 2>&1 || {
        preflight_stop "failed to create branch: $requested_branch"
        command_status=1
      }
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$check_only" -eq 0 ]; then
    current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || {
      preflight_stop "failed to determine current branch after checkout"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ] && [ "$check_only" -eq 0 ] && [ "$current_branch" = "$default_branch" ]; then
    preflight_stop "current branch is still default branch after preflight"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ] && [ "$check_only" -eq 0 ] && [ "$preflight_require_clean" = "true" ]; then
    worktree_status=$(git status --porcelain)
    if [ -n "$worktree_status" ]; then
      preflight_stop "working tree is dirty before edits begin"
      command_status=1
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$check_only" -eq 0 ]; then
    divergence=$(git rev-list --left-right --count "$remote_name/$default_branch...HEAD" 2>/dev/null) || {
      preflight_stop "failed to compute branch divergence"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ] && [ "$check_only" -eq 0 ]; then
    behind_count=$(printf '%s' "$divergence" | awk '{print $1}')
    ahead_count=$(printf '%s' "$divergence" | awk '{print $2}')

    if [ "${behind_count:-0}" -gt 0 ] && [ "${ahead_count:-0}" -gt 0 ]; then
      preflight_stop "branch diverged from $remote_name/$default_branch: $divergence"
      command_status=1
    fi

    if [ "${behind_count:-0}" -gt 0 ] && [ "$branch_preexists" -eq 1 ]; then
      preflight_stop "existing branch is behind $remote_name/$default_branch: $divergence; recreate, reset, or rebase it"
      command_status=1
    fi

    if [ "${ahead_count:-0}" -gt 0 ] && [ "$branch_preexists" -eq 0 ]; then
      preflight_stop "new branch has unexpected ahead commits before edits: $divergence"
      command_status=1
    fi
  fi

  branch_after="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || printf '')"
  status_count="$(git status --short --untracked-files=normal 2>/dev/null | awk 'END { print NR + 0 }')"

  if [ "$preflight_json" -eq 1 ]; then
    preflight_print_json \
      "$requested_branch" \
      "${default_branch:-}" \
      "${remote_name:-}" \
      "${current_branch:-}" \
      "${divergence:-}" \
      "${active_cleanup_mode:-}" \
      "${cleanup_json:-null}" \
      "$preflight_stop_reason" \
      "$command_status" \
      "${preflight_disk_status:-skip}"
  elif [ "$preflight_explain" -eq 1 ]; then
    local explain_mode="$preflight_mode"
    if [ "$clean_test_cache" -eq 1 ] && [ "$branch_value_set" -eq 1 ]; then
      explain_mode="preflight"
    fi
    local -a summary_lines=(
      "script=codex-slice-preflight"
      "mode=$explain_mode"
      "rc=$command_status"
      "disk=${preflight_disk_status:-skip}"
    )
    if [ -n "${preflight_disk_guard_available_bytes:-}" ]; then
      summary_lines+=("disk_free=$(preflight_human_bytes "$preflight_disk_guard_available_bytes")")
    fi
    summary_lines+=("disk_threshold=$(preflight_human_bytes "$preflight_disk_guard_low_bytes")")
    if [ -n "${preflight_disk_guard_used_percent:-}" ]; then
      summary_lines+=("disk_used=${preflight_disk_guard_used_percent}%")
    fi
    if [ -n "${preflight_disk_guard_available_percent:-}" ]; then
      summary_lines+=("disk_available=${preflight_disk_guard_available_percent}%")
    fi
    if [ -n "${preflight_disk_guard_available_bytes:-}" ]; then
      summary_lines+=("disk_free_bytes=${preflight_disk_guard_available_bytes:-}")
    fi
    summary_lines+=("disk_threshold_bytes=$preflight_disk_guard_low_bytes")
    if [ -n "${default_branch:-}" ]; then
      summary_lines+=("default_branch=$default_branch")
    fi
    if [ "$command_status" -eq 0 ] || [ -n "${branch_before:-}" ]; then
      if [ -n "${branch_before:-}" ]; then
        summary_lines+=("branch_before=$branch_before")
      fi
      if [ -n "${branch_after:-}" ]; then
        summary_lines+=("branch_after=$branch_after")
      fi
      if [ -n "${divergence:-}" ]; then
        summary_lines+=("divergence=$divergence")
      fi
      if [ -n "${status_count:-}" ]; then
        summary_lines+=("status_count=$status_count")
      fi
    fi
    if [ "$clean_test_cache" -eq 1 ]; then
      summary_lines+=("cleanup=cleaned")
      preflight_append_cleanup_summary_lines summary_lines 1
    fi
    summary_lines+=("url_or_stop=${preflight_stop_reason:-pass}")
    repo_auto_print_final_summary "${summary_lines[@]}" >&2
  elif [ "$command_status" -eq 0 ]; then
    printf 'pass\n'
  fi

  return "$command_status"
}

preflight_main "$@"
preflight_status=$?
return "$preflight_status" 2>/dev/null || exit "$preflight_status"
# repo-automation/bin/codex-slice-preflight EOF
