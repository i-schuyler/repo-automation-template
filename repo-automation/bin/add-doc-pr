#!/usr/bin/env bash
# repo-automation/bin/add-doc-pr

set -u
set -o pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
. "$script_dir/../lib/common.sh" || {
  printf 'STOP: failed to source shared library\n' >&2
  return 2 2>/dev/null || exit 2
}

add_doc_pr_json=0
add_doc_pr_stop_reason=""

add_doc_pr_usage() {
  printf 'Usage: repo-automation/bin/add-doc-pr [--help] [--plan] [--dry-run] [--json] [--branch=<name>] [--title=<text>] [--body-file=<path>] [--body=<text>] [--commit-message=<text>] [--allow=<path-prefix>] [--no-push] [--create-pr] [--base=<branch>]\n'
}

add_doc_pr_info() {
  printf 'INFO: %s\n' "$*" >&2
}

add_doc_pr_warn() {
  printf 'WARN: %s\n' "$*" >&2
}

add_doc_pr_flag_error() {
  local reason="$1"
  local flag="$2"
  local fix="$3"

  add_doc_pr_stop_reason="$reason"
  printf 'fail: %s\n' "$reason" >&2
  printf 'flag: %s\n' "$flag" >&2
  printf 'fix: %s\n' "$fix" >&2
}

add_doc_pr_stop() {
  add_doc_pr_stop_reason="$*"
  printf 'STOP: %s\n' "$*" >&2
  return 1
}

add_doc_pr_json_escape() {
  local value="${1:-}"
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "$value"
}

add_doc_pr_json_array_strings() {
  local first=1
  local value
  for value in "$@"; do
    if [ "$first" -eq 0 ]; then
      printf ','
    fi
    printf '"%s"' "$(add_doc_pr_json_escape "$value")"
    first=0
  done
}

add_doc_pr_branch_name_from_prefix() {
  local prefix="$1"
  local ts
  ts="$(date +%Y%m%d-%H%M%S)"
  printf '%s/%s\n' "$prefix" "doc-pr-$ts"
}

add_doc_pr_collect_changed_files() {
  local changed_ref_name="$1"
  local -n changed_ref="$changed_ref_name"
  local line
  local path
  local -A seen=()

  while IFS= read -r line; do
    [ -n "$line" ] || continue
    path="$line"
    changed_ref+=("$path")
    seen["$path"]=1
  done < <(git diff --name-only HEAD)

  while IFS= read -r line; do
    [ -n "$line" ] || continue
    if [ -z "${seen[$line]+x}" ]; then
      changed_ref+=("$line")
      seen["$line"]=1
    fi
  done < <(git ls-files --others --exclude-standard)
}

add_doc_pr_path_allowed() {
  local path="$1"
  shift
  local allow_entry

  for allow_entry in "$@"; do
    case "$allow_entry" in
      */)
        case "$path" in
          "$allow_entry"*)
            return 0
            ;;
        esac
        ;;
      *)
        if [ "$path" = "$allow_entry" ]; then
          return 0
        fi
        ;;
    esac
  done

  return 1
}

add_doc_pr_validate_changed_files() {
  local changed_ref_name="$1"
  local allowed_ref_name="$2"
  local blocked_ref_name="$3"
  # shellcheck disable=SC2178
  local -n changed_ref="$changed_ref_name"
  # shellcheck disable=SC2178
  local -n allowed_ref="$allowed_ref_name"
  # shellcheck disable=SC2178
  local -n blocked_ref="$blocked_ref_name"
  local path

  blocked_ref=()
  for path in "${changed_ref[@]}"; do
    if ! add_doc_pr_path_allowed "$path" "${allowed_ref[@]}"; then
      blocked_ref+=("$path")
    fi
  done
}

add_doc_pr_emit_human_summary() {
  local mode="$1"
  local branch="$2"
  local base_branch="$3"
  local allowed_ref_name="$4"
  local changed_ref_name="$5"
  local blocked_ref_name="$6"
  # shellcheck disable=SC2178
  local -n allowed_ref="$allowed_ref_name"
  # shellcheck disable=SC2178
  local -n changed_ref="$changed_ref_name"
  # shellcheck disable=SC2178
  local -n blocked_ref="$blocked_ref_name"

  add_doc_pr_info "mode: $mode"
  add_doc_pr_info "branch: $branch"
  add_doc_pr_info "base branch: $base_branch"
  add_doc_pr_info "allowed paths:"
  printf '  %s\n' "${allowed_ref[@]}" >&2

  if [ "${#changed_ref[@]}" -eq 0 ]; then
    add_doc_pr_info "changed files: none"
  else
    add_doc_pr_info "changed files:"
    printf '  %s\n' "${changed_ref[@]}" >&2
  fi

  if [ "${#blocked_ref[@]}" -eq 0 ]; then
    add_doc_pr_info "blocked files: none"
  else
    add_doc_pr_info "blocked files:"
    printf '  %s\n' "${blocked_ref[@]}" >&2
  fi
}

add_doc_pr_print_json() {
  local mode="$1"
  local branch="$2"
  local base_branch="$3"
  local commit_created="$4"
  local pushed="$5"
  local pr_created="$6"
  local pr_number="$7"
  local pr_url="$8"
  local action_taken="$9"
  local stop_reason="${10}"
  local checks_run="${11}"
  local allowed_ref_name="${12}"
  local changed_ref_name="${13}"
  local blocked_ref_name="${14}"
  # shellcheck disable=SC2178
  local -n allowed_ref="$allowed_ref_name"
  # shellcheck disable=SC2178
  local -n changed_ref="$changed_ref_name"
  # shellcheck disable=SC2178
  local -n blocked_ref="$blocked_ref_name"

  printf '{'
  printf '"mode":"%s",' "$(add_doc_pr_json_escape "$mode")"
  printf '"branch":"%s",' "$(add_doc_pr_json_escape "$branch")"
  printf '"base_branch":"%s",' "$(add_doc_pr_json_escape "$base_branch")"
  printf '"allowed_paths":['
  add_doc_pr_json_array_strings "${allowed_ref[@]}"
  printf '],'
  printf '"changed_files":['
  add_doc_pr_json_array_strings "${changed_ref[@]}"
  printf '],'
  printf '"blocked_files":['
  add_doc_pr_json_array_strings "${blocked_ref[@]}"
  printf '],'
  printf '"checks_run":%s,' "$checks_run"
  printf '"commit_created":%s,' "$commit_created"
  printf '"pushed":%s,' "$pushed"
  printf '"pr_created":%s,' "$pr_created"
  printf '"pr_number":"%s",' "$(add_doc_pr_json_escape "$pr_number")"
  printf '"pr_url":"%s",' "$(add_doc_pr_json_escape "$pr_url")"
  printf '"action_taken":"%s",' "$(add_doc_pr_json_escape "$action_taken")"
  printf '"stop_reason":"%s"' "$(add_doc_pr_json_escape "$stop_reason")"
  printf '}\n'
}

add_doc_pr_main() {
  local mode="plan"
  local create_pr=0
  local no_push=0
  local branch_arg=""
  local base_branch=""
  local title=""
  local body_file=""
  local body_text=""
  local commit_message=""
  local repo_root=""
  local current_branch=""
  local default_branch=""
  local doc_branch_prefix=""
  local target_branch=""
  local pr_number=""
  local pr_url=""
  local action_taken="none"
  local command_status=0
  local checks_run=false
  local commit_created=false
  local pushed=false
  local pr_created=false
  local remote_name=""
  local expected_remote_url=""
  local remote_url=""
  local worktree_status=""
  local arg
  local pr_output=""
  local body_temp_file=""
  local -a allowed_paths=(
    "README.md"
    "CHANGELOG.md"
    "CONTRIBUTING.md"
    "SUPPORT.md"
    "docs/"
    "examples/downstream/docs/"
    ".github/pull_request_template.md"
    ".github/ISSUE_TEMPLATE/"
  )
  local -a extra_allow_paths=()
  local -a changed_files=()
  local -a blocked_files=()

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --help)
        add_doc_pr_usage
        return 0
        ;;
      --plan)
        mode="plan"
        ;;
      --dry-run)
        mode="dry-run"
        ;;
      --json)
        add_doc_pr_json=1
        ;;
      --branch=*)
        branch_arg="${arg#--branch=}"
        if [ -z "$branch_arg" ]; then
          add_doc_pr_flag_error "empty flag value" "--branch" "use --branch=<name>"
          command_status=1
          break
        fi
        ;;
      --branch)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          add_doc_pr_flag_error "flag format not accepted" "--branch" "use --branch=<name>"
        else
          add_doc_pr_flag_error "missing flag value" "--branch" "use --branch=<name>"
        fi
        command_status=1
        break
        ;;
      --title=*)
        title="${arg#--title=}"
        if [ -z "$title" ]; then
          add_doc_pr_flag_error "empty flag value" "--title" "use --title=<text>"
          command_status=1
          break
        fi
        ;;
      --title)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          add_doc_pr_flag_error "flag format not accepted" "--title" "use --title=<text>"
        else
          add_doc_pr_flag_error "missing flag value" "--title" "use --title=<text>"
        fi
        command_status=1
        break
        ;;
      --body-file=*)
        body_file="${arg#--body-file=}"
        if [ -z "$body_file" ]; then
          add_doc_pr_flag_error "empty flag value" "--body-file" "use --body-file=<path>"
          command_status=1
          break
        fi
        ;;
      --body-file)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          add_doc_pr_flag_error "flag format not accepted" "--body-file" "use --body-file=<path>"
        else
          add_doc_pr_flag_error "missing flag value" "--body-file" "use --body-file=<path>"
        fi
        command_status=1
        break
        ;;
      --body=*)
        body_text="${arg#--body=}"
        if [ -z "$body_text" ]; then
          add_doc_pr_flag_error "empty flag value" "--body" "use --body=<text>"
          command_status=1
          break
        fi
        ;;
      --body)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          add_doc_pr_flag_error "flag format not accepted" "--body" "use --body=<text>"
        else
          add_doc_pr_flag_error "missing flag value" "--body" "use --body=<text>"
        fi
        command_status=1
        break
        ;;
      --commit-message=*)
        commit_message="${arg#--commit-message=}"
        if [ -z "$commit_message" ]; then
          add_doc_pr_flag_error "empty flag value" "--commit-message" "use --commit-message=<text>"
          command_status=1
          break
        fi
        ;;
      --commit-message)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          add_doc_pr_flag_error "flag format not accepted" "--commit-message" "use --commit-message=<text>"
        else
          add_doc_pr_flag_error "missing flag value" "--commit-message" "use --commit-message=<text>"
        fi
        command_status=1
        break
        ;;
      --allow=*)
        if [ -z "${arg#--allow=}" ]; then
          add_doc_pr_flag_error "empty flag value" "--allow" "use --allow=<path-prefix>"
          command_status=1
          break
        fi
        extra_allow_paths+=("${arg#--allow=}")
        ;;
      --allow)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          add_doc_pr_flag_error "flag format not accepted" "--allow" "use --allow=<path-prefix>"
        else
          add_doc_pr_flag_error "missing flag value" "--allow" "use --allow=<path-prefix>"
        fi
        command_status=1
        break
        ;;
      --base=*)
        base_branch="${arg#--base=}"
        if [ -z "$base_branch" ]; then
          add_doc_pr_flag_error "empty flag value" "--base" "use --base=<branch>"
          command_status=1
          break
        fi
        ;;
      --no-push)
        no_push=1
        ;;
      --create-pr)
        create_pr=1
        ;;
      --base)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          add_doc_pr_flag_error "flag format not accepted" "--base" "use --base=<branch>"
        else
          add_doc_pr_flag_error "missing flag value" "--base" "use --base=<branch>"
        fi
        command_status=1
        break
        ;;
      *)
        if [ "${arg#--}" != "$arg" ]; then
          add_doc_pr_flag_error "unknown flag" "$arg" "run repo-automation/bin/add-doc-pr --help"
        else
          add_doc_pr_stop "unknown argument: $arg"
        fi
        command_status=1
        break
        ;;
    esac
    shift
  done

  if [ "$no_push" -eq 1 ] && [ "$create_pr" -eq 1 ]; then
    add_doc_pr_stop "--no-push cannot be combined with --create-pr"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ]; then
    repo_auto_require_command git || {
      add_doc_pr_stop "git is required"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    repo_root=$(repo_auto_repo_root) || {
      add_doc_pr_stop "failed to determine repo root"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    cd "$repo_root" || {
      add_doc_pr_stop "failed to enter repo root: $repo_root"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    repo_auto_load_config || {
      add_doc_pr_stop "failed to load .repo-automation.conf"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    repo_auto_validate_required_config || {
      add_doc_pr_stop "invalid .repo-automation.conf"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    default_branch="${DEFAULT_BRANCH:-main}"
    doc_branch_prefix="${DOC_BRANCH_PREFIX:-docs}"
    remote_name="${REMOTE_NAME:-origin}"
    expected_remote_url="${EXPECTED_REMOTE_URL:-}"
  fi

  if [ "$command_status" -eq 0 ]; then
    if [ -n "$base_branch" ]; then
      repo_auto_validate_branch_name "$base_branch" || {
        add_doc_pr_stop "invalid --base value: $base_branch"
        command_status=1
      }
    else
      base_branch="$default_branch"
    fi
  fi

  if [ "$command_status" -eq 0 ]; then
    if [ -n "$branch_arg" ]; then
      repo_auto_validate_branch_name "$branch_arg" || {
        add_doc_pr_stop "invalid --branch value: $branch_arg"
        command_status=1
      }
      target_branch="$branch_arg"
    else
      target_branch="$(add_doc_pr_branch_name_from_prefix "$doc_branch_prefix")"
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$target_branch" = "$default_branch" ]; then
    add_doc_pr_stop "target branch must not equal default branch: $default_branch"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ]; then
    remote_url=$(git remote get-url "$remote_name" 2>/dev/null) || {
      add_doc_pr_stop "failed to read remote URL for $remote_name"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ] && [ -n "$expected_remote_url" ] && [ "$remote_url" != "$expected_remote_url" ]; then
    add_doc_pr_stop "remote URL mismatch for $remote_name: expected $expected_remote_url, got $remote_url"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ]; then
    for arg in "${extra_allow_paths[@]}"; do
      case "$arg" in
        ''|*..*|/*)
          add_doc_pr_stop "invalid --allow value: $arg"
          command_status=1
          break
          ;;
        *)
          allowed_paths+=("$arg")
          ;;
      esac
    done
  fi

  if [ "$command_status" -eq 0 ]; then
    add_doc_pr_collect_changed_files changed_files
  fi

  if [ "$command_status" -eq 0 ] && [ "${#changed_files[@]}" -eq 0 ]; then
    add_doc_pr_stop "no docs changes found"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ]; then
    add_doc_pr_validate_changed_files changed_files allowed_paths blocked_files
    if [ "${#blocked_files[@]}" -gt 0 ]; then
      add_doc_pr_stop "docs-only boundary violation"
      command_status=1
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$add_doc_pr_json" -eq 0 ]; then
    add_doc_pr_emit_human_summary "$mode" "$target_branch" "$base_branch" allowed_paths changed_files blocked_files
  fi

  if [ "$command_status" -eq 0 ] && [ "$create_pr" -eq 1 ]; then
    if [ -z "$title" ]; then
      add_doc_pr_stop "--title is required with --create-pr"
      command_status=1
    fi
    if [ -z "$commit_message" ]; then
      add_doc_pr_stop "--commit-message is required with --create-pr"
      command_status=1
    fi
    if [ -z "$body_file" ] && [ -z "$body_text" ]; then
      add_doc_pr_stop "either --body-file or --body is required with --create-pr"
      command_status=1
    fi
    if [ -n "$body_file" ] && [ -n "$body_text" ]; then
      add_doc_pr_stop "use either --body-file or --body, not both"
      command_status=1
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$create_pr" -eq 1 ] && [ "$mode" != "dry-run" ]; then
    worktree_status=$(git status --porcelain)
    if [ -z "$worktree_status" ]; then
      add_doc_pr_stop "no local changes to commit"
      command_status=1
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$create_pr" -eq 1 ]; then
    if [ "$mode" = "dry-run" ]; then
      add_doc_pr_info "dry-run: would validate checks and create docs PR on branch $target_branch"
      action_taken="dry-run"
    else
      current_branch=$(git branch --show-current) || current_branch=""
      if [ "$current_branch" != "$target_branch" ]; then
        if git show-ref --verify --quiet "refs/heads/$target_branch"; then
          git checkout "$target_branch" >/dev/null 2>&1 || {
            add_doc_pr_stop "failed to checkout existing branch: $target_branch"
            command_status=1
          }
        else
          git switch -c "$target_branch" >/dev/null 2>&1 || {
            add_doc_pr_stop "failed to create branch: $target_branch"
            command_status=1
          }
        fi
      fi
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$create_pr" -eq 1 ]; then
    git diff --check || {
      add_doc_pr_stop "git diff --check failed"
      command_status=1
    }

    if [ "$command_status" -eq 0 ]; then
      repo-automation/bin/run-tests || {
        add_doc_pr_stop "repo-automation/bin/run-tests failed"
        command_status=1
      }
    fi
    checks_run=true
  fi

  if [ "$command_status" -eq 0 ] && [ "$create_pr" -eq 1 ] && [ "$mode" != "dry-run" ]; then
    git add -- "${changed_files[@]}" || {
      add_doc_pr_stop "failed to stage changed files"
      command_status=1
    }

    if [ "$command_status" -eq 0 ] && ! git diff --cached --quiet; then
      git commit -m "$commit_message" >/dev/null 2>&1 || {
        add_doc_pr_stop "failed to create commit"
        command_status=1
      }
      [ "$command_status" -eq 0 ] && commit_created=true
    elif [ "$command_status" -eq 0 ]; then
      add_doc_pr_stop "no staged changes to commit"
      command_status=1
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$create_pr" -eq 1 ] && [ "$mode" != "dry-run" ] && [ "$no_push" -eq 0 ]; then
    git push -u "$remote_name" "$target_branch" >/dev/null 2>&1 || {
      add_doc_pr_stop "failed to push branch: $target_branch"
      command_status=1
    }
    [ "$command_status" -eq 0 ] && pushed=true
  fi

  if [ "$command_status" -eq 0 ] && [ "$create_pr" -eq 1 ] && [ "$mode" != "dry-run" ]; then
    repo_auto_require_command gh || {
      add_doc_pr_stop "gh is required for --create-pr"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ] && [ "$create_pr" -eq 1 ] && [ "$mode" != "dry-run" ]; then
    if [ -n "$body_text" ]; then
      body_temp_file="$(mktemp "${TMPDIR:-$HOME/.cache}/add-doc-pr-body.XXXXXX")" || {
        add_doc_pr_stop "failed to create temporary body file"
        command_status=1
      }
      if [ "$command_status" -eq 0 ]; then
        printf '%s\n' "$body_text" > "$body_temp_file" || {
          add_doc_pr_stop "failed to write temporary body file"
          command_status=1
        }
        body_file="$body_temp_file"
      fi
    fi

    if [ "$command_status" -eq 0 ] && [ ! -f "$body_file" ]; then
      add_doc_pr_stop "body file does not exist: $body_file"
      command_status=1
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$create_pr" -eq 1 ] && [ "$mode" != "dry-run" ]; then
    pr_output=$(gh pr create --title "$title" --body-file "$body_file" --base "$base_branch" --head "$target_branch" 2>&1) || {
      add_doc_pr_stop "gh pr create failed: $pr_output"
      command_status=1
    }

    if [ "$command_status" -eq 0 ]; then
      pr_url=$(printf '%s\n' "$pr_output" | tail -n 1)
      pr_number=$(gh pr view "$target_branch" --json number --jq '.number' 2>/dev/null) || pr_number=""
      pr_created=true
      action_taken="created-pr"
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$create_pr" -eq 0 ]; then
    action_taken="$mode"
  fi

  if [ -n "$body_temp_file" ] && [ -f "$body_temp_file" ]; then
    rm -f "$body_temp_file"
  fi

  if [ "$add_doc_pr_json" -eq 1 ]; then
    add_doc_pr_print_json \
      "$mode" \
      "$target_branch" \
      "$base_branch" \
      "$commit_created" \
      "$pushed" \
      "$pr_created" \
      "$pr_number" \
      "$pr_url" \
      "$action_taken" \
      "$add_doc_pr_stop_reason" \
      "$checks_run" \
      allowed_paths \
      changed_files \
      blocked_files
  elif [ "$command_status" -eq 0 ]; then
    if [ "$create_pr" -eq 0 ]; then
      add_doc_pr_info "plan complete; no commit, push, or PR creation executed"
    elif [ "$mode" = "dry-run" ]; then
      add_doc_pr_info "dry-run complete; no commit, push, or PR creation executed"
    else
      add_doc_pr_info "PR created: #$pr_number $pr_url"
    fi
  fi

  return "$command_status"
}

add_doc_pr_main "$@"
add_doc_pr_status=$?
return "$add_doc_pr_status" 2>/dev/null || exit "$add_doc_pr_status"
# repo-automation/bin/add-doc-pr EOF
