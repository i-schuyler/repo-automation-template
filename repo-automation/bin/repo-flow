  return 2 2>/dev/null || exit 2
}

# shellcheck source=/dev/null
. "$script_dir/../lib/repo-flow-merge.sh" || {
  printf 'STOP: failed to source repo-flow merge library\n' >&2
  return 2 2>/dev/null || exit 2
}

repo_flow_json=0
repo_flow_explain=0
# shellcheck disable=SC2034
repo_flow_stop_reason=""

repo_flow_usage() {
  printf 'Usage: repo-automation/bin/repo-flow [--dry-run|--plan] [--watch] [--timeout=<seconds>] [--diagnose-on-fail] [--json] [--explain] [--help]\n'
  printf '       repo-automation/bin/repo-flow submit [--all|--modified|--paths=<path[,path...]>|--staged] --message=<text> [--body-file=<path>] [--replace-body] [--review-request-file=<path>|--review-request-id=<id>] [--watch] [--timeout=<seconds>] [--diagnose-on-fail] [--explain] [--help]\n'
  printf '       repo-automation/bin/repo-flow merge [--pr=<number|current|latest>] [--timeout=<seconds>] [--diagnose-on-fail] [--json] [--explain] [--help]\n'
}

repo_flow_submit_usage() {
  printf 'Usage: repo-automation/bin/repo-flow submit [--all|--modified|--paths=<path[,path...]>|--staged] --message=<text> [--body-file=<path>] [--replace-body] [--review-request-file=<path>|--review-request-id=<id>] [--watch] [--timeout=<seconds>] [--diagnose-on-fail] [--explain] [--help]\n'
}

repo_flow_merge_usage() {
  printf 'Usage: repo-automation/bin/repo-flow merge [--pr=<number|current|latest>] [--timeout=<seconds>] [--diagnose-on-fail] [--json] [--explain] [--help]\n'
}

repo_flow_info() {
  [ "$repo_flow_explain" -eq 1 ] || return 0
  printf 'INFO: %s\n' "$*" >&2
}

# shellcheck disable=SC2034
repo_flow_stop() {
  repo_flow_stop_reason="$*"
  printf 'STOP: %s\n' "$*" >&2
  return 1
}

# shellcheck disable=SC2034,SC2154
repo_flow_submit_main() {
  local watch=0
  local watch_timeout_seconds=900
  local diagnose_on_fail=0
  local explain=0
  local all=0
  local staged=0
  local modified=0
  local paths_csv=""
  local -a modified_paths=()
  local modified_paths_csv=""
  local message=""
  local custom_body_file=""
  local replace_body=0
  local review_request_file=""
  local review_request_id=""
  local review_request_source_file=""
  local review_request_text_path=""
  local review_request_block_path=""
  local review_request_problem=""
  # shellcheck disable=SC2034
  local repo_root=""
  local current_branch=""
  local default_branch=""
  # shellcheck disable=SC2034
  local remote_name=""
  # shellcheck disable=SC2034
  local expected_remote_url=""
  # shellcheck disable=SC2034
  local remote_url=""
  local command_status=0
  local arg=""
  local staged_files=""
  local requested_paths_csv=""
  local branch_before=""
  # shellcheck disable=SC2034
  local branch_after=""
  local commit_sha="none"
  local pushed="false"
  # shellcheck disable=SC2034
  local merged="false"
  # shellcheck disable=SC2034
  local status_count=0
  local staged_count=0
  local submit_mode=""
  local repo_flow_submit_child_stdout=""
  local repo_flow_submit_child_summary_value=""
  local repo_flow_submit_child_pr_status=""
  local repo_flow_submit_child_pr_url=""
  local repo_flow_submit_child_pr_number=""
  local existing_pr_number=""
  local watched="false"
  # shellcheck disable=SC2034
  local ci_state="unknown"

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --help)
        repo_flow_submit_usage
        return 0
        ;;
      --watch)
        watch=1
        ;;
      --timeout=*)
        watch_timeout_seconds="${arg#--timeout=}"
        if [ -z "$watch_timeout_seconds" ]; then
          repo_auto_flag_error "empty flag value" "--timeout" "use --timeout=<seconds>" || command_status=1
        elif ! repo_auto_is_positive_integer "$watch_timeout_seconds"; then
          repo_auto_stop "invalid --timeout value: $watch_timeout_seconds"
          command_status=1
        fi
        ;;
      --timeout)
        repo_auto_flag_error "flag format not accepted" "--timeout" "use --timeout=<seconds>" || command_status=1
        ;;
      --diagnose-on-fail)
        diagnose_on_fail=1
        ;;
      --explain)
        explain=1
        # shellcheck disable=SC2034
        repo_flow_explain=1
        ;;
      --paths=*)
        paths_csv="${arg#--paths=}"
        if [ -z "$paths_csv" ]; then
          repo_auto_flag_error "empty flag value" "--paths" "use --paths=<path[,path...]>" || command_status=1
        fi
        ;;
      --paths)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          repo_auto_flag_error "flag format not accepted" "--paths" "use --paths=<path[,path...]>" || command_status=1
        else
          repo_auto_flag_error "missing flag value" "--paths" "use --paths=<path[,path...]>" || command_status=1
        fi
        ;;
      --all)
        all=1
        ;;
      --staged)
        staged=1
        ;;
      --modified)
        modified=1
        ;;
      --message=*)
        message="${arg#--message=}"
        if [ -z "$message" ]; then
          repo_auto_flag_error "empty flag value" "--message" "use --message=<text>" || command_status=1
        fi
        ;;
      --message)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          repo_auto_flag_error "flag format not accepted" "--message" "use --message=<text>" || command_status=1
        else
          repo_auto_flag_error "missing flag value" "--message" "use --message=<text>" || command_status=1
        fi
        ;;
      --body-file=*)
        custom_body_file="${arg#--body-file=}"
        if [ -z "$custom_body_file" ]; then
          repo_auto_flag_error "empty flag value" "--body-file" "use --body-file=<path>" || command_status=1
        fi
        ;;
      --body-file)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          repo_auto_flag_error "flag format not accepted" "--body-file" "use --body-file=<path>" || command_status=1
        else
          repo_auto_flag_error "missing flag value" "--body-file" "use --body-file=<path>" || command_status=1
        fi
        ;;
      --replace-body)
        replace_body=1
        ;;
      --replace-body=*)
        repo_auto_flag_error "flag format not accepted" "--replace-body" "use --replace-body" || command_status=1
        ;;
      --review-request-file=*)
        review_request_file="${arg#--review-request-file=}"
        if [ -z "$review_request_file" ]; then
          repo_auto_flag_error "empty flag value" "--review-request-file" "use --review-request-file=<path>" || command_status=1
        fi
        ;;
      --review-request-file)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          repo_auto_flag_error "flag format not accepted" "--review-request-file" "use --review-request-file=<path>" || command_status=1
        else
          repo_auto_flag_error "missing flag value" "--review-request-file" "use --review-request-file=<path>" || command_status=1
        fi
        ;;
      --review-request-id=*)
        review_request_id="${arg#--review-request-id=}"
        if [ -z "$review_request_id" ]; then
          repo_auto_flag_error "empty flag value" "--review-request-id" "use --review-request-id=<id>" || command_status=1
        fi
        ;;
      --review-request-id)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          repo_auto_flag_error "flag format not accepted" "--review-request-id" "use --review-request-id=<id>" || command_status=1
        else
          repo_auto_flag_error "missing flag value" "--review-request-id" "use --review-request-id=<id>" || command_status=1
        fi
        ;;
      *)
        if [ "${arg#--}" != "$arg" ]; then
          repo_auto_flag_error "unknown flag" "$arg" "run repo-automation/bin/repo-flow submit --help" || command_status=1
        else
          repo_flow_submit_stop "unknown argument: $arg"
          command_status=1
        fi
        ;;
    esac
    shift
  done

  if [ "$command_status" -eq 0 ] && [ -z "$message" ]; then
    repo_flow_submit_stop "missing required --message"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ] && [ -n "$custom_body_file" ]; then
    if ! repo_flow_submit_validate_custom_body_file "$custom_body_file"; then
      command_status=1
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ -n "$review_request_file" ] && [ -n "$review_request_id" ]; then
    repo_flow_submit_stop "use either --review-request-file or --review-request-id, not both"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ] && [ -n "$review_request_file" ]; then
    review_request_problem=""
    if ! review_request_problem="$(repo_review_request_template_problem "$review_request_file" "review request file")"; then
      repo_flow_submit_stop "$review_request_problem"
      printf 'fix: provide a regular readable non-empty review request template file\n' >&2
      command_status=1
    else
      review_request_file="$(python3 - "$review_request_file" <<'PY'
from pathlib import Path
import sys

print(Path(sys.argv[1]).expanduser().resolve(strict=True))
PY
)" || command_status=1
      review_request_source_file="$review_request_file"
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ -n "$review_request_id" ] && ! repo_review_request_is_valid_id "$review_request_id"; then
    repo_flow_submit_stop "invalid review request id: $review_request_id"
    printf 'fix: use a basename ID like repo-automation-template-pr-review (letters, digits, underscore, hyphen; no slashes, whitespace, leading dot, leading dash, shell metacharacters, or ..)\n' >&2
    command_status=1
  fi

  if [ "$command_status" -eq 0 ] && [ "$all" -eq 1 ] && [ "$modified" -eq 1 ]; then
    repo_flow_submit_stop "use either --all or --modified, not both"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ] && [ "$all" -eq 1 ] && [ -n "$paths_csv" ]; then
    repo_flow_submit_stop "use either --all or --paths, not both"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ] && [ "$all" -eq 1 ] && [ "$staged" -eq 1 ]; then
    repo_flow_submit_stop "use either --all or --staged, not both"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ] && [ "$staged" -eq 1 ] && [ -n "$paths_csv" ]; then
    repo_flow_submit_stop "use either --paths or --staged, not both"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ] && [ "$modified" -eq 1 ] && [ -n "$paths_csv" ]; then
    repo_flow_submit_stop "use either --modified or --paths, not both"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ] && [ "$modified" -eq 1 ] && [ "$staged" -eq 1 ]; then
    repo_flow_submit_stop "use either --modified or --staged, not both"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ] && [ "$all" -eq 0 ] && [ "$modified" -eq 0 ] && [ "$staged" -eq 0 ] && [ -z "$paths_csv" ]; then
    repo_flow_submit_stop "either --all, --modified, --paths or --staged is required"
    command_status=1
  fi

  repo_flow_submit_flow
  return "$?"
}

repo_flow_merge_main() {
  local watch_timeout_seconds=900
  local diagnose_on_fail=0
  local explain=0
  local json=0
  local pr_selector="current"
  local repo_root=""
  local current_branch=""
  local default_branch=""
  local remote_name=""
  local expected_remote_url=""
  local remote_url=""
  local command_status=0
  local arg=""
  # shellcheck disable=SC2034
  local branch_before=""
  # shellcheck disable=SC2034
  local branch_after=""
  local pr_status="merged"
  local pr_number=""
  local pr_url=""
  # shellcheck disable=SC2034
  local ci_state="unknown"
  local final_status="blocked"
  local action_taken="none"
  # shellcheck disable=SC2034
  local merged="false"
  local mode="merge"
  # shellcheck disable=SC2034
  local pr_finish_args=()
  # shellcheck disable=SC2034
  local pr_finish_state_file=""
  # shellcheck disable=SC2034
  local pr_finish_state_pr_number=""
  # shellcheck disable=SC2034
  local pr_finish_state_pr_url=""
  # shellcheck disable=SC2034
  local pr_finish_state_merged=""
  # shellcheck disable=SC2034
  local pr_finish_state_elapsed_seconds=""

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --help)
        repo_flow_merge_usage
        return 0
        ;;
      --watch)
        repo_auto_flag_error "unknown flag" "$arg" "run repo-automation/bin/repo-flow merge --help" || command_status=1
        ;;
      --timeout=*)
        watch_timeout_seconds="${arg#--timeout=}"
        if [ -z "$watch_timeout_seconds" ]; then
          repo_auto_flag_error "empty flag value" "--timeout" "use --timeout=<seconds>" || command_status=1
        elif ! repo_auto_is_positive_integer "$watch_timeout_seconds"; then
          repo_auto_stop "invalid --timeout value: $watch_timeout_seconds"
          command_status=1
        fi
        ;;
      --timeout)
        repo_auto_flag_error "flag format not accepted" "--timeout" "use --timeout=<seconds>" || command_status=1
        ;;
      --diagnose-on-fail)
        diagnose_on_fail=1
        ;;
      --explain)
        # shellcheck disable=SC2034
        explain=1
        repo_flow_explain=1
        ;;
      --json)
        json=1
        repo_flow_json=1
        ;;
      --pr=*)
        pr_selector="${arg#--pr=}"
        if [ -z "$pr_selector" ]; then
          repo_auto_flag_error "empty flag value" "--pr" "use --pr=<number|current|latest>" || command_status=1
        fi
        ;;
      --pr)
        repo_auto_flag_error "flag format not accepted" "--pr" "use --pr=<number|current|latest>" || command_status=1
        ;;
      *)
        if [ "${arg#--}" != "$arg" ]; then
          repo_auto_flag_error "unknown flag" "$arg" "run repo-automation/bin/repo-flow merge --help" || command_status=1
        else
          repo_flow_stop "unknown argument: $arg"
          command_status=1
        fi
        ;;
    esac
    shift
  done

  repo_flow_merge_preflight

  if [ "$command_status" -eq 0 ]; then
    repo_flow_merge_finish_pr
  fi
  repo_flow_merge_render_result

  return "$command_status"
}

# shellcheck disable=SC2034,SC2154
repo_flow_main() {
  local mode="apply"
  local json=0
  local dry_run=0
  local watch=0
  local watch_timeout_seconds=900
  local diagnose_on_fail=0
  # shellcheck disable=SC2034
  local repo_root=""
  local current_branch=""
  local default_branch=""
  local remote_name=""
  # shellcheck disable=SC2034
  local expected_remote_url=""
  # shellcheck disable=SC2034
  local remote_url=""
  local worktree_status=""
  # shellcheck disable=SC2034
  local ahead_count=""
  # shellcheck disable=SC2034
  local behind_count=""
  # shellcheck disable=SC2034
  local push_status="skipped"
  local pr_status="none"
  local pr_number=""
  local pr_url=""
  local final_status="blocked"
  local action_taken="none"
  local command_status=0
  local arg=""
  # shellcheck disable=SC2034
  local branch_head=""
  # shellcheck disable=SC2034
  local remote_head=""
  # shellcheck disable=SC2034
  local branch_ahead_behind=""
  # shellcheck disable=SC2034
  local staged_files=""

  if [ "${1:-}" = "status-card" ]; then
    shift
    repo_flow_status_card_main "$@"
    return $?
  elif [ "${1:-}" = "merge" ]; then
    shift
    repo_flow_merge_main "$@"
    return $?
  elif [ "${1:-}" = "submit" ]; then
    shift
    repo_flow_submit_main "$@"
    return $?
  fi

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --help)
        repo_flow_usage
        return 0
        ;;
      --dry-run|--plan)
        dry_run=1
        mode="plan"
        ;;
      --watch)
        watch=1
        ;;
      --timeout=*)
        watch_timeout_seconds="${arg#--timeout=}"
        if [ -z "$watch_timeout_seconds" ]; then
          repo_auto_flag_error "empty flag value" "--timeout" "use --timeout=<seconds>" || command_status=1
        elif ! repo_auto_is_positive_integer "$watch_timeout_seconds"; then
          repo_auto_stop "invalid --timeout value: $watch_timeout_seconds"
          command_status=1
        fi
        ;;
      --timeout)
        repo_auto_flag_error "flag format not accepted" "--timeout" "use --timeout=<seconds>" || command_status=1
        ;;
      --diagnose-on-fail)
        diagnose_on_fail=1
        ;;
      --json)
        json=1
        repo_flow_json=1
        ;;
      --explain)
        repo_flow_explain=1
        ;;
      *)
        if [ "${arg#--}" != "$arg" ]; then
          repo_auto_flag_error "unknown flag" "$arg" "run repo-automation/bin/repo-flow --help" || command_status=1
        else
          repo_flow_stop "unknown argument: $arg"
        fi
        command_status=1
        ;;
    esac
    shift
  done

  repo_flow_main_preflight

  repo_flow_main_branch

  repo_flow_main_pr

  repo_flow_main_watch_completion
  repo_flow_main_render_result

  return "$command_status"
}

repo_flow_main "$@"
repo_flow_status=$?
return "$repo_flow_status" 2>/dev/null || exit "$repo_flow_status"
# repo-automation/bin/repo-flow EOF
