    "repo-automation/tests/lib/contracts/repo-doctor.sh"
    "repo-automation/tests/lib/contracts/artifacts.sh"
    "repo-automation/tests/lib/contracts/install-release.sh"
    "repo-automation/tests/docs-check.sh"
    "repo-automation/tests/smoke.sh"
    "repo-automation/tests/contracts/add-doc-pr.sh"
    "repo-automation/tests/contracts/pr-create.sh"
    "repo-automation/tests/contracts/pr-body-check.sh"
    "repo-automation/tests/contracts/report-upstream.sh"
    "repo-automation/tests/contracts/failure-log.sh"
    "repo-automation/tests/contracts/run-tests.sh"
    "repo-automation/tests/contracts/run-tests-failure.sh"
    "repo-automation/tests/contracts/run-tests-results.sh"
    "repo-automation/tests/contracts/run-tests-json.sh"
    "repo-automation/tests/contracts/test-timeout.sh"
    "repo-automation/tests/contracts/run-tests-routing.sh"
    "repo-automation/tests/contracts/touched-files.sh"
    "repo-automation/tests/contracts/ci-status-watch.sh"
    "repo-automation/tests/contracts/ci-log-dump.sh"
    "repo-automation/tests/contracts/ci-failure-artifacts.sh"
    "repo-automation/tests/contracts/contract-debt-report.sh"
    "repo-automation/tests/contracts/repo-doctor.sh"
    "repo-automation/tests/contracts/check-tooling.sh"
    "repo-automation/tests/contracts/check-portability.sh"
    "repo-automation/tests/contracts/status-packet.sh"
    "repo-automation/tests/contracts/post-codex-packet.sh"
    "repo-automation/tests/contracts/post-codex-review.sh"
    "repo-automation/tests/contracts/repair-prompt.sh"
    "repo-automation/tests/contracts/review-pack.sh"
    "repo-automation/tests/contracts/pr-finish-watch.sh"
    "repo-automation/tests/contracts/pr-finish-extensions.sh"
    "repo-automation/tests/contracts/repo-flow.sh"
    "repo-automation/tests/contracts/repo-zip.sh"
    "repo-automation/tests/contracts/evidence-bundle.sh"
    "repo-automation/tests/contracts/github-settings-check.sh"
    "repo-automation/tests/contracts/managed-file-tools.sh"
    "repo-automation/tests/contracts/shellcheck-ci-parity.sh"
    "repo-automation/tests/contracts/installer.sh"
    "repo-automation/tests/contracts/starter-template.sh"
    "repo-automation/tests/contracts/branch-cleanup-preflight.sh"
    "repo-automation/tests/contracts/codex-slice-preflight.sh"
    "repo-automation/tests/contracts/prepare-release.sh"
    "repo-automation/tests/contracts/automation-freshness.sh"
    "repo-automation/tests/version-consistency.sh"
    "repo-automation/bin/run-tests"
  )
  local -a optional_ci_files=(
    ".github/workflows/ci.yml"
  )
  local -a files_to_add=()
  local -a files_to_update=()
  local -a files_to_skip=()
  local -a blocked_files=()
  local -a generated_files=(
    ".repo-automation.conf"
    "repo-automation/docs/README.md"
    "AGENTS.md"
  )
  local -a files_to_process=()

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --help)
        repo_install_usage
        return 0
        ;;
      --target=*)
        target_root="${arg#--target=}"
        if [ -z "$target_root" ]; then
          repo_auto_flag_error "empty flag value" "--target" "use --target=<path>" || return 1
          return 1
        fi
        ;;
      --target)
        repo_install_value_flag_error "--target" "use --target=<path>" "${2:-}" || return 1
        return 1
        ;;
      --install)
        mode_flag="install"
        ;;
      --update)
        mode_flag="update"
        ;;
      --apply)
        apply=true
        ;;
      --dry-run)
        dry_run=true
        ;;
      --json)
        repo_install_json=1
        ;;
      --explain)
        repo_install_explain=1
        ;;
      --include-ci)
        include_ci=true
        ;;
      --include-tests)
        include_tests=true
        ;;
      --starter-template)
        profile="starter-template"
        ;;
      --overwrite)
        overwrite=true
        ;;
      --no-overwrite)
        overwrite=false
        ;;
      --installed-version=*)
        installed_version_arg="${arg#--installed-version=}"
        if [ -z "$installed_version_arg" ]; then
          repo_auto_flag_error "empty flag value" "--installed-version" "use --installed-version=<ref>" || return 1
          return 1
        fi
        ;;
      --installed-version)
        repo_install_value_flag_error "--installed-version" "use --installed-version=<ref>" "${2:-}" || return 1
        return 1
        ;;
      --installed-at=*)
        installed_at_arg="${arg#--installed-at=}"
        if [ -z "$installed_at_arg" ]; then
          repo_auto_flag_error "empty flag value" "--installed-at" "use --installed-at=<YYYY-MM-DD>" || return 1
          return 1
        fi
        ;;
      --installed-at)
        repo_install_value_flag_error "--installed-at" "use --installed-at=<YYYY-MM-DD>" "${2:-}" || return 1
        return 1
        ;;
      --local-overrides-doc=*)
        local_overrides_doc_arg="${arg#--local-overrides-doc=}"
        if [ -z "$local_overrides_doc_arg" ]; then
          repo_auto_flag_error "empty flag value" "--local-overrides-doc" "use --local-overrides-doc=<path>" || return 1
          return 1
        fi
        ;;
      --local-overrides-doc)
        repo_install_value_flag_error "--local-overrides-doc" "use --local-overrides-doc=<path>" "${2:-}" || return 1
        return 1
        ;;
      --source-root=*)
        source_root="${arg#--source-root=}"
        if [ -z "$source_root" ]; then
          repo_auto_flag_error "empty flag value" "--source-root" "use --source-root=<path>" || return 1
          return 1
        fi
        ;;
      --source-root)
        repo_install_value_flag_error "--source-root" "use --source-root=<path>" "${2:-}" || return 1
        return 1
        ;;
      *)
        if [ "${arg#--}" != "$arg" ]; then
          repo_auto_flag_error "unknown flag" "$arg" "run repo-automation/bin/repo-automation-install --help" || return 1
        else
          repo_install_stop "unknown argument: $arg"
        fi
        command_status=1
        ;;
    esac
    shift
  done

  if [ -z "$target_root" ]; then
    repo_install_stop "--target PATH is required"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ] && [ -z "$source_root" ]; then
    repo_root="$(repo_auto_repo_root)" || command_status=1
    source_root="$repo_root"
  fi

  if [ "$command_status" -eq 0 ]; then
    cd "$source_root" || {
      repo_install_stop "unable to access source root: $source_root"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    repo_auto_load_config || {
      repo_install_stop "failed to load source .repo-automation.conf"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    repo_auto_validate_required_config || {
      repo_install_stop "source config validation failed"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    if [ ! -d "$target_root" ]; then
      repo_install_stop "target path does not exist: $target_root"
      command_status=1
    fi
  fi

  if [ "$command_status" -eq 0 ]; then
    if ! git -C "$target_root" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      repo_install_stop "target is not a git repository: $target_root"
      command_status=1
    fi
  fi

  if [ "$command_status" -eq 0 ]; then
    if [ -n "$mode_flag" ]; then
      inferred_mode="$mode_flag"
    elif [ -f "$target_root/.repo-automation.conf" ]; then
      inferred_mode="update"
    else
      inferred_mode="install"
    fi
    mode="$inferred_mode"
  fi

  if [ "$command_status" -eq 0 ]; then
    source_version="$(cat "$source_root/VERSION" 2>/dev/null)" || source_version=""
    if [ -z "$source_version" ]; then
      source_version="$REPO_AUTOMATION_VERSION"
    fi
    installed_version_or_ref="${installed_version_arg:-$source_version}"
    installed_at="${installed_at_arg:-$(date +%Y-%m-%d)}"
    local_overrides_doc="${local_overrides_doc_arg:-repo-automation/docs/local-overrides.md}"
    target_default_branch="$(git -C "$target_root" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##')"
    if [ -z "$target_default_branch" ]; then
      target_default_branch="$(git -C "$target_root" ls-remote --symref origin HEAD 2>/dev/null | awk '/^ref:/ { sub("refs/heads/", "", $2); print $2; exit }')"
    fi
    if [ -z "$target_default_branch" ]; then
      target_default_branch="$(git -C "$target_root" symbolic-ref --quiet --short HEAD 2>/dev/null)" || target_default_branch=""
    fi
    if [ -z "$target_default_branch" ]; then
      target_default_branch="main"
    fi
    target_remote_url="$(git -C "$target_root" remote get-url origin 2>/dev/null)" || target_remote_url=""
    target_remote_status="$(repo_install_target_remote_status "$target_remote_url")"
    if [ "$target_remote_status" = "present" ]; then
      target_expected_remote_url="$target_remote_url"
    else
      target_expected_remote_url=""
    fi
    target_state_dir_name="$(basename "$target_root")"
  fi

  if [ "$command_status" -eq 0 ]; then
    files_to_process=("${managed_files[@]}")
    if [ "$profile" = "starter-template" ]; then
      files_to_process+=("${starter_template_files[@]}")
      check_profile_default="starter-template"
    fi
    if [ "$include_tests" = true ]; then
      files_to_process+=("${optional_test_files[@]}")
    fi
    if [ "$include_ci" = true ]; then
      files_to_process+=("${optional_ci_files[@]}")
      repo_install_warn "--include-ci requested; downstream CI may require repo-specific adaptation"
    fi
  fi

  if [ "$command_status" -eq 0 ]; then
    for line in "${files_to_process[@]}"; do
      source_file="$source_root/$line"
      target_file="$target_root/$line"
      if [ ! -f "$source_file" ]; then
        blocked_files+=("$line:missing-in-source")
        continue
      fi

      if [ ! -e "$target_file" ]; then
        files_to_add+=("$line")
        continue
      fi

      if cmp -s "$source_file" "$target_file"; then
        files_to_skip+=("$line:unchanged")
        continue
      fi

      if [ "$mode" = "update" ]; then
        files_to_update+=("$line")
      elif [ "$overwrite" = true ]; then
        files_to_update+=("$line")
      else
        blocked_files+=("$line:exists-no-overwrite")
      fi
    done
  fi

  if [ "$command_status" -eq 0 ]; then
    if [ -f "$target_root/$local_overrides_doc" ]; then
      local_overrides_present="yes"
      files_to_skip+=("$local_overrides_doc:preserved")
    else
      local_overrides_present="no"
      generated_files+=("$local_overrides_doc")
    fi

    if [ -f "$target_root/repo-automation/docs/README.md" ]; then
      files_to_update+=("repo-automation/docs/README.md")
    else
      files_to_add+=("repo-automation/docs/README.md")
    fi
    if [ -f "$target_root/.repo-automation.conf" ]; then
      files_to_update+=(".repo-automation.conf")
    else
      files_to_add+=(".repo-automation.conf")
    fi
  fi

  if [ "$command_status" -eq 0 ]; then
    target_status="$(git -C "$target_root" status --porcelain)"
    if [ -n "$target_status" ]; then
      target_dirty=true
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$apply" = true ] && [ "$dry_run" = false ] && [ "${#blocked_files[@]}" -gt 0 ]; then
    repo_install_stop "apply blocked by existing conflicts; rerun with --overwrite or resolve manually"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ] && [ "$repo_install_json" -eq 0 ] && [ "$repo_install_explain" -eq 1 ]; then
    repo_install_info "source root: $source_root"
    repo_install_info "target root: $target_root"
    repo_install_info "mode: $mode"
    repo_install_info "install profile: $profile"
    repo_install_info "target dirty: $target_dirty"
    repo_install_info "apply requested: $apply"
    repo_install_info "dry-run: $dry_run"
    repo_install_info "include tests: $include_tests"
    repo_install_info "include ci: $include_ci"
    repo_install_info "installed automation version/ref: $installed_version_or_ref"
    repo_install_info "target remote status: $target_remote_status"
    if [ "${#files_to_add[@]}" -gt 0 ]; then
      repo_install_info "files to add:"
      printf '  %s\n' "${files_to_add[@]}" >&2
    fi
    if [ "${#files_to_update[@]}" -gt 0 ]; then
      repo_install_info "files to update:"
      printf '  %s\n' "${files_to_update[@]}" >&2
    fi
    if [ "${#files_to_skip[@]}" -gt 0 ]; then
      repo_install_info "files to skip:"
      printf '  %s\n' "${files_to_skip[@]}" >&2
    fi
    if [ "${#blocked_files[@]}" -gt 0 ]; then
      repo_install_warn "blocked files:"
      printf '  %s\n' "${blocked_files[@]}" >&2
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$apply" = true ] && [ "$dry_run" = false ]; then
    for line in "${files_to_process[@]}"; do
      source_file="$source_root/$line"
      target_file="$target_root/$line"
      if [ ! -f "$source_file" ]; then
        continue
      fi
      if [ ! -e "$target_file" ]; then
        repo_install_make_parent "$target_file" || {
          repo_install_stop "failed to create parent path for $line"
          command_status=1
          break
        }
        cp "$source_file" "$target_file" || {
          repo_install_stop "failed to copy $line"
          command_status=1
          break
        }
        if repo_install_is_script_path "$line"; then
          chmod +x "$target_file" || {
            repo_install_stop "failed to set executable mode on $line"
            command_status=1
            break
          }
        fi
      elif [ "$mode" = "update" ] || [ "$overwrite" = true ]; then
        if ! cmp -s "$source_file" "$target_file"; then
          cp "$source_file" "$target_file" || {
            repo_install_stop "failed to update $line"
            command_status=1
            break
          }
          if repo_install_is_script_path "$line"; then
            chmod +x "$target_file" || {
              repo_install_stop "failed to set executable mode on $line"
              command_status=1
              break
            }
          fi
        fi
      fi
    done

    if [ "$command_status" -eq 0 ]; then
      repo_install_make_parent "$target_root/.repo-automation.conf" || {
        repo_install_stop "failed to prepare target config path"
        command_status=1
      }
    fi
    if [ "$command_status" -eq 0 ]; then
      repo_install_write_config \
        "$target_root/.repo-automation.conf" \
        "$source_version" \
        "$installed_version_or_ref" \
        "$installed_at" \
        "$local_overrides_doc" \
        "$target_default_branch" \
        "$target_state_dir_name" \
        "$check_profile_default" \
        "$target_expected_remote_url" || {
          repo_install_stop "failed to write target .repo-automation.conf"
          command_status=1
        }
    fi
    if [ "$command_status" -eq 0 ]; then
      repo_install_make_parent "$target_root/repo-automation/docs/README.md" || {
        repo_install_stop "failed to prepare downstream docs path"
        command_status=1
      }
    fi
    if [ "$command_status" -eq 0 ]; then
      repo_install_write_downstream_readme \
        "$target_root/repo-automation/docs/README.md" \
        "$UPSTREAM_REPO_FULL_NAME" \
        "$installed_version_or_ref" \
        "$installed_at" \
        "$local_overrides_doc" \
        "$local_overrides_present" || {
          repo_install_stop "failed to write downstream install context README"
          command_status=1
        }
    fi
    if [ "$command_status" -eq 0 ] && [ ! -f "$target_root/$local_overrides_doc" ]; then
      repo_install_make_parent "$target_root/$local_overrides_doc" || {
        repo_install_stop "failed to prepare local overrides path"
        command_status=1
      }
    fi
    if [ "$command_status" -eq 0 ] && [ ! -f "$target_root/$local_overrides_doc" ]; then
      repo_install_write_local_overrides_stub "$target_root/$local_overrides_doc" || {
        repo_install_stop "failed to create local overrides doc"
        command_status=1
      }
    fi
    if [ "$command_status" -eq 0 ]; then
      repo_install_make_parent "$target_root/AGENTS.md" || {
        repo_install_stop "failed to prepare AGENTS.md path"
        command_status=1
      }
    fi
    if [ "$command_status" -eq 0 ]; then
      repo_install_write_agents_md "$source_root/AGENTS.md" "$target_root/AGENTS.md" || {
        repo_install_stop "failed to write AGENTS.md"
        command_status=1
      }
    fi

    if [ "$command_status" -eq 0 ]; then
      action_taken="applied"
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$apply" = false ]; then
    action_taken="planned"
  fi
  if [ "$command_status" -eq 0 ] && [ "$dry_run" = true ]; then
    action_taken="dry-run"
  fi

  if [ "$repo_install_json" -eq 1 ]; then
    repo_install_print_json \
      "$mode" \
      "$source_root" \
      "$target_root" \
      "$apply" \
      "$dry_run" \
      "$profile" \
      "$include_ci" \
      "$include_tests" \
      "$installed_version_or_ref" \
      "$target_remote_status" \
      "$action_taken" \
      "$repo_install_stop_reason" \
      "$target_dirty" \
      files_to_add \
      files_to_update \
      files_to_skip \
      blocked_files \
      generated_files
  elif [ "$command_status" -eq 0 ] && [ "$repo_install_explain" -eq 1 ] && [ "$apply" = false ]; then
    repo_install_info "plan-only mode: no files were written"
    repo_install_info "rerun with --apply to write files"
  elif [ "$command_status" -eq 0 ] && [ "$repo_install_explain" -eq 1 ]; then
    repo_install_info "apply complete"
  elif [ "$command_status" -eq 0 ] && [ "$apply" = false ]; then
    printf 'plan\n'
  else
    printf 'pass\n'
  fi

  return "$command_status"
}

repo_install_main "$@"
# repo-automation/bin/repo-automation-install EOF
