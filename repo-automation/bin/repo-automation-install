    "repo-automation/tests/lib/contracts/failure-log.sh"
    "repo-automation/tests/lib/contracts/touched-files.sh"
    "repo-automation/tests/lib/contracts/status-packet.sh"
    "repo-automation/tests/lib/contracts/parser-args.sh"
    "repo-automation/tests/lib/contracts/portability.sh"
