#!/usr/bin/env bash
# repo-automation/bin/repo-automation-install

set -u
set -o pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
. "$script_dir/../lib/common.sh" || {
  printf 'STOP: failed to source shared library\n' >&2
  return 2 2>/dev/null || exit 2
}

repo_install_json=0
repo_install_explain=0
repo_install_stop_reason=""

repo_install_usage() {
  printf 'Usage: repo-automation/bin/repo-automation-install --target=<path> [--help] [--install] [--update] [--apply] [--dry-run] [--json] [--explain] [--include-ci] [--include-tests] [--starter-template] [--overwrite] [--no-overwrite] [--installed-version=<ref>] [--installed-at=<YYYY-MM-DD>] [--local-overrides-doc=<path>] [--source-root=<path>]\n'
}

repo_install_info() {
  printf 'INFO: %s\n' "$*" >&2
}

repo_install_warn() {
  printf 'WARN: %s\n' "$*" >&2
}

repo_install_stop() {
  repo_install_stop_reason="$*"
  printf 'STOP: %s\n' "$*" >&2
  return 1
}

repo_install_value_flag_error() {
  local flag="$1"
  local fix="$2"
  local next="${3:-}"

  if [ -n "$next" ] && [ "${next#-}" = "$next" ]; then
    repo_auto_flag_error "flag format not accepted" "$flag" "$fix"
  else
    repo_auto_flag_error "missing flag value" "$flag" "$fix"
  fi
}

repo_install_json_escape() {
  local value="${1:-}"
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "$value"
}

repo_install_json_array() {
  local first=1
  local value
  for value in "$@"; do
    if [ "$first" -eq 0 ]; then
      printf ','
    fi
    printf '"%s"' "$(repo_install_json_escape "$value")"
    first=0
  done
}

repo_install_target_remote_status() {
  local remote_url="${1:-}"

  if [ -z "$remote_url" ]; then
    printf 'missing\n'
    return 0
  fi

  if [[ "$remote_url" =~ ^git@github.com:[^[:space:]]+/.+\.git$ ]]; then
    printf 'present\n'
    return 0
  fi

  printf 'unsupported\n'
}

repo_install_print_json() {
  local mode="$1"
  local source_root="$2"
  local target_root="$3"
  local apply="$4"
  local dry_run="$5"
  local profile="$6"
  local include_ci="$7"
  local include_tests="$8"
  local installed_version_or_ref="$9"
  local target_remote_status="${10}"
  local action_taken="${11}"
  local stop_reason="${12}"
  local target_dirty="${13}"
  local files_to_add_name="${14}"
  local files_to_update_name="${15}"
  local files_to_skip_name="${16}"
  local blocked_files_name="${17}"
  local generated_files_name="${18}"
  # shellcheck disable=SC2178
  local -n files_to_add_ref="$files_to_add_name"
  # shellcheck disable=SC2178
  local -n files_to_update_ref="$files_to_update_name"
  # shellcheck disable=SC2178
  local -n files_to_skip_ref="$files_to_skip_name"
  # shellcheck disable=SC2178
  local -n blocked_files_ref="$blocked_files_name"
  # shellcheck disable=SC2178
  local -n generated_files_ref="$generated_files_name"

  printf '{'
  printf '"mode":"%s",' "$(repo_install_json_escape "$mode")"
  printf '"source_root":"%s",' "$(repo_install_json_escape "$source_root")"
  printf '"target_root":"%s",' "$(repo_install_json_escape "$target_root")"
  printf '"apply":%s,' "$apply"
  printf '"dry_run":%s,' "$dry_run"
  printf '"profile":"%s",' "$(repo_install_json_escape "$profile")"
  printf '"include_ci":%s,' "$include_ci"
  printf '"include_tests":%s,' "$include_tests"
  printf '"installed_version_or_ref":"%s",' "$(repo_install_json_escape "$installed_version_or_ref")"
  printf '"target_remote_status":"%s",' "$(repo_install_json_escape "$target_remote_status")"
  printf '"files_to_add":['
  repo_install_json_array "${files_to_add_ref[@]}"
  printf '],'
  printf '"files_to_update":['
  repo_install_json_array "${files_to_update_ref[@]}"
  printf '],'
  printf '"files_to_skip":['
  repo_install_json_array "${files_to_skip_ref[@]}"
  printf '],'
  printf '"blocked_files":['
  repo_install_json_array "${blocked_files_ref[@]}"
  printf '],'
  printf '"generated_files":['
  repo_install_json_array "${generated_files_ref[@]}"
  printf '],'
  printf '"target_dirty":%s,' "$target_dirty"
  printf '"action_taken":"%s",' "$(repo_install_json_escape "$action_taken")"
  printf '"stop_reason":"%s"' "$(repo_install_json_escape "$stop_reason")"
  printf '}\n'
}

repo_install_is_script_path() {
  case "${1:-}" in
    repo-automation/bin/*|repo-automation/tests/*.sh)
      return 0
      ;;
  esac
  return 1
}

repo_install_make_parent() {
  local path="$1"
  local parent
  parent="$(dirname "$path")"
  mkdir -p "$parent"
}

repo_install_write_config() {
  local path="$1"
  local source_version="$2"
  local installed_version_or_ref="$3"
  local installed_at="$4"
  local local_overrides_doc="$5"
  local default_branch="$6"
  local state_dir_name="$7"
  local check_profile_default="$8"
  local expected_remote_url="$9"

  cat > "$path" <<EOF
# .repo-automation.conf
REPO_AUTOMATION_CONF_VERSION="0.1"
REPO_AUTOMATION_VERSION="$source_version"
UPSTREAM_REPO_FULL_NAME="$UPSTREAM_REPO_FULL_NAME"
UPSTREAM_ISSUE_URL="$UPSTREAM_ISSUE_URL"
INSTALLED_FROM="$INSTALLED_FROM"
INSTALLED_VERSION_OR_REF="$installed_version_or_ref"
INSTALLED_AT="$installed_at"
LOCAL_OVERRIDES_DOC="$local_overrides_doc"

DEFAULT_BRANCH="$default_branch"
DOCS_DIR="docs"
DOCS_INDEX="docs/INDEX.md"
STATE_DIR_NAME="$state_dir_name"
CI_PROVIDER="github"
PR_PROVIDER="github"
MERGE_MODE="squash"
REMOTE_NAME="origin"
EXPECTED_REMOTE_URL="$expected_remote_url"
PREFLIGHT_REQUIRE_CLEAN_WORKTREE="true"

DOC_PR_TIMEOUT_SECONDS=60
DOC_PR_POLL_SECONDS=10
IMPLEMENTATION_PR_TIMEOUT_SECONDS=300
IMPLEMENTATION_PR_POLL_SECONDS=15

REPO_AUTOMATION_TEST_TEMP_ROOT=""
REPO_AUTOMATION_CLEAN_STALE_TEMP=1
REPO_AUTOMATION_STALE_TEMP_HOURS=12
REPO_AUTOMATION_RUN_TESTS_DISK_GUARD_PATH="/"
REPO_AUTOMATION_RUN_TESTS_DISK_LOW_BYTES=1610612736
REPO_AUTOMATION_RUN_TESTS_DISK_LOW_PERCENT=15
REPO_AUTOMATION_RUN_TESTS_TEMP_WARN_KIB=1048576
REPO_AUTOMATION_DF_BIN="df"

DOC_BRANCH_PREFIX="docs"
FEATURE_BRANCH_PREFIX="feature"
FIX_BRANCH_PREFIX="fix"

CHECK_PROFILE_DEFAULT="$check_profile_default"
CHECK_PROFILE_DOCS_COMMANDS=("git diff --check")
CHECK_PROFILE_NONE_COMMANDS=()
# .repo-automation.conf EOF
EOF
}

repo_install_write_downstream_readme() {
  local path="$1"
  local upstream_repo="$2"
  local installed_version_or_ref="$3"
  local installed_at="$4"
  local local_overrides_doc="$5"
  local local_overrides_present="$6"

  cat > "$path" <<EOF
# Repo Automation Install Context

This repo has an installed copy of shared repo automation helpers.

Repo automation installed context:
- Upstream repo: $upstream_repo
- Installed automation version/ref: $installed_version_or_ref
- Installed at: $installed_at
- Local overrides doc: $local_overrides_doc
- Local overrides present: $local_overrides_present
- Run health check: repo-automation/bin/repo-doctor --quick
- Report upstream: repo-automation/bin/repo-automation-report-upstream --type=bug --title="Short title" --dry-run
EOF
}

repo_install_write_local_overrides_stub() {
  local path="$1"
  cat > "$path" <<'EOF'
# Local Overrides

Use this file for downstream-only behavior notes and local policy exceptions.
Do not store secrets, credentials, or private keys in this file.
EOF
}

repo_install_write_agents_md() {
  local source_path="$1"
  local target_path="$2"

  if [ ! -f "$source_path" ]; then
    repo_install_stop "missing source AGENTS.md: $source_path"
    return 1
  fi

  cp "$source_path" "$target_path" || return 1
}

