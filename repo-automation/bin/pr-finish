#!/usr/bin/env bash
# repo-automation/bin/pr-finish

set -u
set -o pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
. "$script_dir/../lib/common.sh" || {
  printf 'STOP: failed to source shared library\n' >&2
  return 2 2>/dev/null || exit 2
}

pr_finish_json=0
pr_finish_explain=0
pr_finish_stop_reason=""
pr_finish_watch_timeout_seconds=900

pr_finish_usage() {
  printf 'Usage: repo-automation/bin/pr-finish [--plan|--status] [--watch] [--merge] [--timeout=<seconds>] [--pr=<number|current|latest>] [--json] [--explain] [--squash|--merge-commit|--rebase] [--delete-branch|--no-delete-branch] [--sync-main] [--diagnose-on-fail] [--help]\n'
}

pr_finish_flag_error() {
  local reason="$1"
  local flag="$2"
  local fix="$3"

  repo_auto_flag_error "$reason" "$flag" "$fix" || true
  pr_finish_stop_reason="$reason"
  return 1
}

pr_finish_info() {
  [ "$pr_finish_explain" -eq 1 ] || return 0
  printf 'INFO: %s\n' "$*" >&2
}

pr_finish_warn() {
  printf 'WARN: %s\n' "$*" >&2
}

pr_finish_stop() {
  pr_finish_stop_reason="$*"
  printf 'STOP: %s\n' "$*" >&2
  return 1
}

pr_finish_json_escape() {
  local value="${1:-}"
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "$value"
}

pr_finish_json_array_strings() {
  local first=1
  local value
  for value in "$@"; do
    if [ "$first" -eq 0 ]; then
      printf ','
    fi
    printf '"%s"' "$(pr_finish_json_escape "$value")"
    first=0
  done
}

pr_finish_now_seconds() {
  date +%s
}

pr_finish_resolve_latest_pr_number() {
  gh pr list --state open --limit 1 --json number --jq 'if length == 0 then empty else .[0].number end' 2>/dev/null
}

pr_finish_write_state_file() {
  local state_file="${PR_FINISH_STATE_FILE:-}"

  [ -n "$state_file" ] || return 0

  {
    printf 'pr_number=%s\n' "${pr_number:-}"
    printf 'pr_url=%s\n' "${pr_url:-}"
    printf 'checks_status=%s\n' "${checks_status:-}"
    printf 'action_taken=%s\n' "${action_taken:-}"
    printf 'head_sha=%s\n' "${pr_head_sha:-}"
    printf 'merged=%s\n' "${merged:-false}"
    printf 'elapsed_seconds=%s\n' "${pr_finish_elapsed_seconds:-0}"
    printf 'timing_pr_lookup_seconds=%s\n' "${pr_finish_timing_pr_lookup_seconds:-0}"
    printf 'timing_ci_watch_seconds=%s\n' "${pr_finish_timing_ci_watch_seconds:-0}"
    printf 'timing_checks_reuse_seconds=%s\n' "${pr_finish_timing_checks_reuse_seconds:-0}"
    printf 'timing_merge_seconds=%s\n' "${pr_finish_timing_merge_seconds:-0}"
    printf 'timing_sync_main_seconds=%s\n' "${pr_finish_timing_sync_main_seconds:-0}"
  } >"$state_file" 2>/dev/null || true
}

pr_finish_checks_collect() {
  local pr_number="$1"
  local checks_json_ref="$2"
  local checks_status_ref="$3"
  local checks_summary_ref="$4"
  local rc=0
  local checks_json=""
  local checks_summary=""

  checks_json="$(repo-automation/bin/ci-status --pr="$pr_number" --machine-json 2>/dev/null)" || rc=$?
  if [ -n "$checks_json" ]; then
    checks_status="$(python3 - "$checks_json" <<'PY'
import json
import sys

summary = json.loads(sys.argv[1])
overall = summary.get('overall_status', 'warn')
mapping = {'pass': 'green', 'pending': 'pending', 'fail': 'blocked', 'warn': 'unknown'}
print(mapping.get(overall, 'unknown'))
PY
)"
    checks_summary="$(python3 - "$checks_json" <<'PY'
import json
import sys

summary = json.loads(sys.argv[1])
overall = summary.get('overall_status', 'warn')
latest = summary.get('latest_run', {}) or {}
head_sha = summary.get('head_sha', '')
if latest:
    pieces = [
        f"#{latest.get('number', '')}",
        latest.get('workflowName', '') or latest.get('name', ''),
        latest.get('status', ''),
        latest.get('conclusion', ''),
    ]
    print(' '.join(part for part in pieces if part).strip())
elif head_sha:
    print(f'waiting for checks on head {head_sha}')
else:
    print(overall)
PY
)"
    printf -v "$checks_status_ref" '%s' "$checks_status"
  else
    printf -v "$checks_status_ref" '%s' "blocked"
  fi

  if [ -z "$checks_summary" ]; then
    checks_summary="no checks returned"
  fi

  printf -v "$checks_json_ref" '%s' "$checks_json"
  printf -v "$checks_summary_ref" '%s' "$checks_summary"
  return "$rc"
}

pr_finish_diagnose_on_fail() {
  local pr_number="$1"
  local run_id="${2:-}"
  local diagnosis_json=""
  local diagnosis_status=0
  local diagnosis_label=""
  local diagnosis_log_path=""
  local diagnosis_excerpt=""
  local diagnosis_fix=""
  local diagnosis_reason=""

  if [ -n "$run_id" ]; then
    diagnosis_json="$(repo-automation/bin/ci-log-dump --run-id="$run_id" --first-failure --machine-json 2>&1)" || diagnosis_status=$?
  else
    diagnosis_json="$(repo-automation/bin/ci-log-dump --pr="$pr_number" --first-failure --machine-json 2>&1)" || diagnosis_status=$?
  fi

  if [ "$diagnosis_status" -eq 0 ]; then
    diagnosis_label="$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("first_failure_label",""))' "$diagnosis_json" 2>/dev/null || printf '')"
    diagnosis_log_path="$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("log_path",""))' "$diagnosis_json" 2>/dev/null || printf '')"
    diagnosis_excerpt="$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("first_failure_excerpt",""))' "$diagnosis_json" 2>/dev/null || printf '')"
    diagnosis_fix="$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("recommended_fix",""))' "$diagnosis_json" 2>/dev/null || printf '')"
    [ -n "$diagnosis_label" ] && pr_finish_warn "diagnosis label: $diagnosis_label"
    [ -n "$diagnosis_log_path" ] && pr_finish_warn "diagnosis log path: $diagnosis_log_path"
    [ -n "$diagnosis_excerpt" ] && pr_finish_warn "diagnosis excerpt: $diagnosis_excerpt"
    [ -n "$diagnosis_fix" ] && pr_finish_warn "diagnosis recommended fix: $diagnosis_fix"
    return 0
  fi

  if [ "${diagnosis_json#\{}" != "$diagnosis_json" ]; then
    diagnosis_reason="$(python3 -c 'import json,sys; data=json.loads(sys.argv[1]); print(data.get("stop_reason","") or data.get("overall_status","fail"))' "$diagnosis_json" 2>/dev/null || printf 'unknown diagnosis failure')"
  else
    diagnosis_reason="$(printf '%s' "$diagnosis_json" | sed -n '1p')"
  fi
  diagnosis_reason="${diagnosis_reason:-ci-log-dump failed}"
  case "$diagnosis_reason" in
    *'GitHub API failure'*|*'gh is required'*|*'auth'*|*'TLS'*|*'timeout'*|*'network'*|*'connection'*|*'rate limit'*)
      pr_finish_warn "diagnosis access failure: $diagnosis_reason"
      ;;
    *)
      pr_finish_warn "diagnosis failed for PR #$pr_number: $diagnosis_reason"
      ;;
  esac
  return 1
}

pr_finish_print_human_status() {
  local mode="$1"
  local current_branch="$2"
  local pr_number="$3"
  local pr_title="$4"
  local pr_url="$5"
  local pr_state="$6"
  local is_draft="$7"
  local mergeable="$8"
  local checks_status="$9"
  local checks_summary="${10}"
  local merge_mode="${11}"
  local delete_branch="${12}"
  local can_merge="${13}"
  local -n block_reasons_ref="${14}"

  pr_finish_info "mode: $mode"
  pr_finish_info "current branch: $current_branch"
  pr_finish_info "pr: #$pr_number $pr_title"
  pr_finish_info "pr url: $pr_url"
  pr_finish_info "pr state: $pr_state"
  pr_finish_info "draft: $is_draft"
  pr_finish_info "mergeable: $mergeable"
  pr_finish_info "checks status: $checks_status"
  pr_finish_info "checks summary: $checks_summary"
  pr_finish_info "merge mode: $merge_mode"
  pr_finish_info "delete branch after merge: $delete_branch"
  pr_finish_info "can merge now: $can_merge"
  if [ "${#block_reasons_ref[@]}" -gt 0 ]; then
    pr_finish_info "merge blocked reasons:"
    printf '  %s\n' "${block_reasons_ref[@]}" >&2
  fi
}

pr_finish_print_json() {
  local mode="$1"
  local current_branch="$2"
  local pr_number="$3"
  local pr_url="$4"
  local pr_state="$5"
  local is_draft="$6"
  local mergeable="$7"
  local checks_status="$8"
  local checks_summary="$9"
  local merge_mode="${10}"
  local delete_branch="${11}"
  local can_merge="${12}"
  local action_taken="${13}"
  local stop_reason="${14}"
  local -n block_reasons_ref="${15}"

  printf '{'
  printf '"mode":"%s",' "$(pr_finish_json_escape "$mode")"
  printf '"current_branch":"%s",' "$(pr_finish_json_escape "$current_branch")"
  printf '"pr_number":"%s",' "$(pr_finish_json_escape "$pr_number")"
  printf '"pr_url":"%s",' "$(pr_finish_json_escape "$pr_url")"
  printf '"pr_state":"%s",' "$(pr_finish_json_escape "$pr_state")"
  printf '"is_draft":"%s",' "$(pr_finish_json_escape "$is_draft")"
  printf '"mergeable":"%s",' "$(pr_finish_json_escape "$mergeable")"
  printf '"checks_status":"%s",' "$(pr_finish_json_escape "$checks_status")"
  printf '"checks_summary":"%s",' "$(pr_finish_json_escape "$checks_summary")"
  printf '"merge_mode":"%s",' "$(pr_finish_json_escape "$merge_mode")"
  printf '"delete_branch":"%s",' "$(pr_finish_json_escape "$delete_branch")"
  printf '"can_merge":"%s",' "$(pr_finish_json_escape "$can_merge")"
  printf '"block_reasons":['
  pr_finish_json_array_strings "${block_reasons_ref[@]}"
  printf '],'
  printf '"action_taken":"%s",' "$(pr_finish_json_escape "$action_taken")"
  printf '"stop_reason":"%s"' "$(pr_finish_json_escape "$stop_reason")"
  printf '}\n'
}

pr_finish_main() {
  local mode="plan"
  local do_watch=0
  local do_merge=0
  local json=0
  local pr_selector=""
  local delete_branch=0
  local sync_main=0
  local diagnose_on_fail=0
  local watch_timeout_seconds="$pr_finish_watch_timeout_seconds"
  local merge_mode_override=""
  local merge_mode=""
  local command_status=0
  local repo_root=""
  local current_branch=""
  local default_branch=""
  local remote_name=""
  local expected_remote_url=""
  local remote_url=""
  local pr_number=""
  local pr_target=""
  local pr_title=""
  local pr_url=""
  local pr_state=""
  local is_draft=""
  local mergeable=""
  local checks_status="unknown"
  local checks_summary="no checks returned"
  local checks_json="[]"
  local can_merge="false"
  local action_taken="none"
  local merged="false"
  local worktree_status=""
  local merge_flag=""
  local arg
  local merge_output=""
  local watch_output_file=""
  local pr_head_sha=""
  local watch_output=""
  local -a block_reasons=()
  local pr_finish_started_at=""
  local pr_finish_lookup_started_at=""
  local pr_finish_watch_started_at=""
  local pr_finish_merge_started_at=""
  local pr_finish_sync_started_at=""
  local pr_finish_elapsed_seconds=0
  local pr_finish_timing_pr_lookup_seconds=0
  local pr_finish_timing_ci_watch_seconds=0
  local pr_finish_timing_checks_reuse_seconds=0
  local pr_finish_timing_merge_seconds=0
  local pr_finish_timing_sync_main_seconds=0
  local pr_view_json=""
  local pr_view_assignments=""
  local pr_view_selector=""

  pr_finish_started_at="$(pr_finish_now_seconds)"

  while [ "$#" -gt 0 ]; do
    arg="$1"
    shift
    case "$arg" in
      --help)
        pr_finish_usage
        return 0
        ;;
      --plan)
        mode="plan"
        do_watch=0
        do_merge=0
        ;;
      --status)
        mode="status"
        do_watch=0
        do_merge=0
        ;;
      --watch)
        do_watch=1
        ;;
      --merge)
        do_merge=1
        ;;
      --pr)
        if [ "$#" -eq 0 ]; then
          pr_finish_flag_error "missing flag value" "--pr" "use --pr=<number|current|latest>" || command_status=1
        elif [ "${1#-}" != "$1" ]; then
          pr_finish_flag_error "missing flag value" "--pr" "use --pr=<number|current|latest>" || command_status=1
        else
          pr_finish_flag_error "flag format not accepted" "--pr" "use --pr=<number|current|latest>" || command_status=1
          shift
        fi
        ;;
      --pr=)
        pr_finish_flag_error "empty flag value" "--pr" "use --pr=<number|current|latest>" || command_status=1
        ;;
      --pr=*)
        pr_selector="${arg#--pr=}"
        ;;
      --json)
        json=1
        pr_finish_json=1
        ;;
      --explain)
        pr_finish_explain=1
        ;;
      --squash)
        merge_mode_override="squash"
        ;;
      --merge-commit)
        merge_mode_override="merge"
        ;;
      --rebase)
        merge_mode_override="rebase"
        ;;
      --delete-branch)
        delete_branch=1
        ;;
      --no-delete-branch)
        delete_branch=0
        ;;
      --sync-main)
        sync_main=1
        ;;
      --timeout=*)
        watch_timeout_seconds="${arg#--timeout=}"
        if [ -z "$watch_timeout_seconds" ]; then
          pr_finish_flag_error "empty flag value" "--timeout" "use --timeout=<seconds>" || command_status=1
        elif ! repo_auto_is_positive_integer "$watch_timeout_seconds"; then
          repo_auto_stop "invalid --timeout value: $watch_timeout_seconds"
          command_status=1
        fi
        ;;
      --timeout)
        pr_finish_flag_error "flag format not accepted" "--timeout" "use --timeout=<seconds>" || command_status=1
        ;;
      --diagnose-on-fail)
        diagnose_on_fail=1
        ;;
      *)
        pr_finish_flag_error "unknown flag" "$arg" "run repo-automation/bin/pr-finish --help" || command_status=1
        command_status=1
        ;;
    esac
  done

  if [ "$do_merge" -eq 1 ]; then
    mode="merge"
  elif [ "$do_watch" -eq 1 ]; then
    mode="watch"
  fi

  repo_auto_require_command git || {
    pr_finish_stop "git is required"
    command_status=1
  }

  if [ "$command_status" -eq 0 ]; then
    repo_root=$(repo_auto_repo_root) || {
      pr_finish_stop "failed to determine repo root"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    cd "$repo_root" || {
      pr_finish_stop "failed to enter repo root: $repo_root"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    repo_auto_load_config || {
      pr_finish_stop "failed to load .repo-automation.conf"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    repo_auto_validate_required_config || {
      pr_finish_stop "invalid .repo-automation.conf"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    default_branch="${DEFAULT_BRANCH:-main}"
    remote_name="${REMOTE_NAME:-origin}"
    expected_remote_url="${EXPECTED_REMOTE_URL:-}"
    merge_mode="${MERGE_MODE:-squash}"
  fi

  if [ -n "$merge_mode_override" ]; then
    merge_mode="$merge_mode_override"
  fi

  if [ "$command_status" -eq 0 ]; then
    repo_auto_validate_merge_mode "$merge_mode" || {
      pr_finish_stop "invalid merge mode: $merge_mode"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ] && [ "${PR_PROVIDER:-none}" != "github" ]; then
    pr_finish_stop "PR_PROVIDER must be github for repo-automation/bin/pr-finish"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ]; then
    repo_auto_require_command gh || {
      pr_finish_stop "gh is required for pr-finish"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    remote_url=$(git remote get-url "$remote_name" 2>/dev/null) || {
      pr_finish_stop "failed to read remote URL for $remote_name"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ] && ! repo_auto_remote_matches_upstream "$remote_url" "$expected_remote_url" "${UPSTREAM_REPO_FULL_NAME:-}"; then
    pr_finish_stop "remote URL mismatch for $remote_name: expected $expected_remote_url or GitHub SSH alias for ${UPSTREAM_REPO_FULL_NAME:-unknown}, got $remote_url"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ]; then
    current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || {
      pr_finish_stop "failed to determine current branch"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    repo_auto_validate_branch_name "$current_branch" || {
      pr_finish_stop "invalid current branch name: $current_branch"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    pr_finish_lookup_started_at="$(pr_finish_now_seconds)"
    case "$pr_selector" in
      "")
        if [ "$current_branch" = "$default_branch" ]; then
          pr_finish_stop "current branch is default branch; use --pr=<number|current|latest>"
          command_status=1
        else
          pr_target="$current_branch"
        fi
        ;;
      latest)
        pr_target="latest open PR"
        pr_number=$(pr_finish_resolve_latest_pr_number) || pr_number=""
        if ! repo_auto_is_positive_integer "$pr_number"; then
          pr_finish_stop "unable to find latest open PR"
          command_status=1
        fi
        ;;
      current)
        pr_target="$current_branch"
        ;;
      *)
        repo_auto_is_positive_integer "$pr_selector" || {
          pr_finish_stop "invalid --pr value: $pr_selector"
          command_status=1
        }
        pr_target="$pr_selector"
        pr_number="$pr_selector"
        ;;
    esac
  fi

  if [ "$command_status" -eq 0 ]; then
    pr_view_selector=""
    if [ -n "$pr_number" ]; then
      pr_view_selector="$pr_number"
    fi

    if [ -n "$pr_view_selector" ]; then
      pr_view_json="$(gh pr view "$pr_view_selector" --json number,title,url,state,isDraft,mergeable,headRefOid,headRefName 2>/dev/null)" || pr_view_json=""
    else
      pr_view_json="$(gh pr view --json number,title,url,state,isDraft,mergeable,headRefOid,headRefName 2>/dev/null)" || pr_view_json=""
    fi

    if [ -z "$pr_view_json" ]; then
      pr_finish_stop "failed to load PR metadata for ${pr_target:-$current_branch}"
      command_status=1
    else
      pr_view_assignments="$(python3 - "$pr_view_json" <<'PY'
import json
import shlex
import sys

data = json.loads(sys.argv[1])
fields = [
    ("pr_number", data.get("number", "")),
    ("pr_title", data.get("title", "")),
    ("pr_url", data.get("url", "")),
    ("pr_state", data.get("state", "")),
    ("is_draft", "true" if data.get("isDraft", False) else "false"),
    ("mergeable", data.get("mergeable", "")),
    ("pr_head_sha", data.get("headRefOid", "")),
]
for name, value in fields:
    if value is None:
        value = ""
    print(f"{name}={shlex.quote(str(value))}")
PY
)"
      if [ -z "$pr_view_assignments" ]; then
        pr_finish_stop "failed to parse PR metadata for ${pr_target:-$current_branch}"
        command_status=1
      else
        eval "$pr_view_assignments"
        pr_finish_timing_pr_lookup_seconds="$(( $(pr_finish_now_seconds) - pr_finish_lookup_started_at ))"
        if [ -z "$pr_number" ] || ! repo_auto_is_positive_integer "$pr_number"; then
          pr_finish_stop "unable to find PR for target: ${pr_target:-$current_branch}"
          command_status=1
        fi
      fi
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ -z "$pr_head_sha" ]; then
    pr_finish_stop "unable to determine current PR head SHA"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ] && [ "$do_watch" -eq 1 ]; then
    watch_output_file="$(mktemp "${TMPDIR:-$HOME/.cache}/pr-finish-watch.XXXXXX.log")" || {
      pr_finish_stop "failed to create temporary watch output file"
      command_status=1
    }
    if [ "$command_status" -eq 0 ]; then
      pr_finish_watch_started_at="$(pr_finish_now_seconds)"
    fi
    if [ "$command_status" -eq 0 ] && ! CI_STATUS_EXPECTED_HEAD_SHA="$pr_head_sha" "$script_dir/ci-watch" --pr="$pr_number" --poll-seconds=5 --timeout="$watch_timeout_seconds" >"$watch_output_file" 2>&1; then
      pr_finish_timing_ci_watch_seconds="$(( $(pr_finish_now_seconds) - pr_finish_watch_started_at ))"
      watch_output="$(cat "$watch_output_file" 2>/dev/null || true)"
      if printf '%s' "$watch_output" | grep -Eq 'timed out after [0-9]+s while waiting for CI'; then
        checks_status="pending"
        checks_summary="timed out after ${watch_timeout_seconds}s while waiting for CI"
        pr_finish_stop "timed out after ${watch_timeout_seconds}s while waiting for CI"
      else
        checks_status="blocked"
        checks_summary="CI failed during watch"
        pr_finish_stop "CI failed for PR #$pr_number"
      fi
      command_status=1
    else
      pr_finish_timing_ci_watch_seconds="$(( $(pr_finish_now_seconds) - pr_finish_watch_started_at ))"
      pr_finish_timing_checks_reuse_seconds=0
      checks_status="green"
      checks_summary="watch confirmed current head green"
      action_taken="watched"
    fi
  fi

  if [ "$command_status" -eq 0 ]; then
    if [ "$do_watch" -eq 1 ] && [ "$checks_status" = "green" ]; then
      :
    else
      pr_finish_checks_collect "$pr_number" checks_json checks_status checks_summary || true
    fi
  fi

  if [ "$command_status" -eq 0 ]; then
    if [ "$pr_state" != "OPEN" ]; then
      block_reasons+=("pr-not-open:$pr_state")
    fi

    if [ "$is_draft" = "true" ]; then
      block_reasons+=("pr-is-draft")
    fi

    if [ "$mergeable" != "MERGEABLE" ]; then
      block_reasons+=("pr-not-mergeable:$mergeable")
    fi

    case "$checks_status" in
      green)
        ;;
      pending)
        block_reasons+=("checks-pending")
        ;;
      blocked)
        block_reasons+=("checks-failed")
        ;;
      missing)
        block_reasons+=("checks-missing")
        ;;
      *)
        block_reasons+=("checks-unknown")
        ;;
    esac

    if [ "$do_merge" -eq 1 ] && [ "$json" -eq 0 ] && [ "$pr_finish_explain" -eq 0 ] && [ "$checks_status" != "green" ]; then
      pr_finish_warn "checks-$checks_status"
    fi

    if [ "$do_watch" -eq 1 ] && [ "$checks_status" != "green" ]; then
      pr_finish_warn "watch completed with checks status: $checks_status"
      if [ "$checks_status" = "blocked" ] && [ "$diagnose_on_fail" -eq 1 ]; then
        latest_run_id="$(python3 - "$checks_json" <<'PY'
import json
import sys

summary = json.loads(sys.argv[1])
latest = summary.get('latest_run', {}) or {}
print(latest.get('databaseId', ''))
PY
)"
        pr_finish_diagnose_on_fail "$pr_number" "$latest_run_id" || true
      fi
      command_status=1
    elif [ "$do_watch" -eq 1 ] && [ "$checks_status" = "green" ]; then
      pr_finish_info "watch completed with checks status: green"
    fi

    worktree_status=$(git status --porcelain)
    if [ -n "$worktree_status" ]; then
      block_reasons+=("working-tree-dirty")
    fi

    if [ "${#block_reasons[@]}" -eq 0 ]; then
      can_merge="true"
    fi
  fi

  if [ "$do_watch" -eq 1 ] && [ -n "$watch_output_file" ] && [ -f "$watch_output_file" ]; then
    if [ "$pr_finish_explain" -eq 1 ] || [ "$command_status" -ne 0 ] || [ "$checks_status" != "green" ]; then
      cat "$watch_output_file" >&2
    fi
    rm -f "$watch_output_file"
  fi

  if [ "$command_status" -eq 0 ] && [ "$do_merge" -eq 1 ]; then
    if [ "$can_merge" != "true" ]; then
      pr_finish_stop "merge blocked by current PR state/check gates"
      command_status=1
    else
      case "$merge_mode" in
        squash)
          merge_flag="--squash"
          ;;
        merge)
          merge_flag="--merge"
          ;;
        rebase)
          merge_flag="--rebase"
          ;;
      esac

      pr_finish_merge_started_at="$(pr_finish_now_seconds)"
      if [ "$delete_branch" -eq 1 ]; then
        merge_output=$(gh pr merge "$pr_number" "$merge_flag" --delete-branch 2>&1) || {
          pr_finish_timing_merge_seconds="$(( $(pr_finish_now_seconds) - pr_finish_merge_started_at ))"
          pr_finish_stop "gh pr merge failed: $merge_output"
          command_status=1
        }
      else
        merge_output=$(gh pr merge "$pr_number" "$merge_flag" 2>&1) || {
          pr_finish_timing_merge_seconds="$(( $(pr_finish_now_seconds) - pr_finish_merge_started_at ))"
          pr_finish_stop "gh pr merge failed: $merge_output"
          command_status=1
        }
      fi

      if [ "$command_status" -eq 0 ]; then
        pr_finish_timing_merge_seconds="$(( $(pr_finish_now_seconds) - pr_finish_merge_started_at ))"
        action_taken="merged"
        merged="true"
        [ "$json" -eq 1 ] || pr_finish_info "merge completed for PR #$pr_number"
      fi
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$do_merge" -eq 1 ] && [ "$sync_main" -eq 1 ]; then
    pr_finish_sync_started_at="$(pr_finish_now_seconds)"
    git checkout "$default_branch" >/dev/null 2>&1 || {
      pr_finish_stop "failed to checkout $default_branch"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ] && [ "$do_merge" -eq 1 ] && [ "$sync_main" -eq 1 ]; then
    git pull --ff-only >/dev/null 2>&1 || {
      pr_finish_stop "git pull --ff-only failed on $default_branch"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ] && [ "$do_merge" -eq 1 ] && [ "$sync_main" -eq 1 ]; then
    pr_finish_timing_sync_main_seconds="$(( $(pr_finish_now_seconds) - pr_finish_sync_started_at ))"
    [ "$json" -eq 1 ] || pr_finish_info "synced $default_branch with git pull --ff-only"
  fi

  pr_finish_elapsed_seconds="$(( $(pr_finish_now_seconds) - pr_finish_started_at ))"
  pr_finish_write_state_file

  if [ "$pr_finish_json" -eq 1 ]; then
    pr_finish_print_json \
      "$mode" \
      "${current_branch:-}" \
      "${pr_number:-}" \
      "${pr_url:-}" \
      "${pr_state:-}" \
      "${is_draft:-}" \
      "${mergeable:-}" \
      "${checks_status:-}" \
      "${checks_summary:-}" \
      "${merge_mode:-}" \
      "$delete_branch" \
      "${can_merge:-false}" \
      "$action_taken" \
      "$pr_finish_stop_reason" \
      block_reasons
  elif [ "$json" -eq 0 ]; then
    if [ "$pr_finish_explain" -eq 1 ]; then
      pr_finish_info "timing: pr_lookup=${pr_finish_timing_pr_lookup_seconds}s ci_watch=${pr_finish_timing_ci_watch_seconds}s checks_reuse=${pr_finish_timing_checks_reuse_seconds}s merge=${pr_finish_timing_merge_seconds}s sync_main=${pr_finish_timing_sync_main_seconds}s total=${pr_finish_elapsed_seconds}s"
      pr_finish_print_human_status \
        "$mode" \
        "$current_branch" \
        "$pr_number" \
        "$pr_title" \
        "$pr_url" \
        "$pr_state" \
        "$is_draft" \
        "$mergeable" \
        "$checks_status" \
        "$checks_summary" \
        "$merge_mode" \
        "$delete_branch" \
        "$can_merge" \
        block_reasons
      if [ "${PR_FINISH_SUPPRESS_FINAL_SUMMARY:-0}" != 1 ]; then
        repo_auto_print_final_summary \
          "branch=$current_branch" \
          "rc=$command_status" \
          "mode=$mode" \
          "url_or_stop=${pr_url:-${pr_finish_stop_reason:-$checks_status}}" >&2
      fi
    elif [ "$command_status" -eq 0 ]; then
      if [ "$mode" = "watch" ]; then
        if [ "$checks_status" = "green" ]; then
          printf 'pass\n'
        else
          pr_finish_warn "watch completed with checks status: $checks_status"
        fi
      elif [ "$do_merge" -eq 1 ]; then
        [ "$json" -eq 1 ] || pr_finish_info "merge completed for PR #$pr_number"
        if [ -n "$pr_url" ]; then
          printf '%s\n' "$pr_url"
        else
          printf 'pass\n'
        fi
      else
        printf 'pass\n'
      fi
    fi
  fi

  return "$command_status"
}

pr_finish_main "$@"
pr_finish_status=$?
return "$pr_finish_status" 2>/dev/null || exit "$pr_finish_status"
# repo-automation/bin/pr-finish EOF
