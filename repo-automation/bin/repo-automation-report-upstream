#!/usr/bin/env bash
# repo-automation/bin/repo-automation-report-upstream

set -u
set -o pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
. "$script_dir/../lib/common.sh" || {
  printf 'STOP: failed to source shared library\n' >&2
  return 2 2>/dev/null || exit 2
}

report_upstream_json=0
report_upstream_stop_reason=""

report_upstream_usage() {
  printf 'Usage: repo-automation/bin/repo-automation-report-upstream [--help] [--plan] [--dry-run] [--json] [--type=<bug|feature>] [--title=<text>] [--command=<text>] [--expected=<text>] [--actual=<text>] [--use-case=<text>] [--proposed=<text>] [--why-upstream=<text>] [--logs-file=<path>] [--body-file=<path>] [--preview-file=<path>] [--submit] [--yes] [--label=<name>] [--repo=<owner/repo>]\n'
}

report_upstream_info() {
  printf 'INFO: %s\n' "$*" >&2
}

report_upstream_warn() {
  printf 'WARN: %s\n' "$*" >&2
}

report_upstream_stop() {
  report_upstream_stop_reason="$*"
  printf 'STOP: %s\n' "$*" >&2
  return 1
}

report_upstream_value_flag_error() {
  local flag="$1"
  local fix="$2"
  local next="${3:-}"

  if [ -n "$next" ] && [ "${next#-}" = "$next" ]; then
    repo_auto_flag_error "flag format not accepted" "$flag" "$fix"
  else
    repo_auto_flag_error "missing flag value" "$flag" "$fix"
  fi
}

report_upstream_json_escape() {
  local value="${1:-}"
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "$value"
}

report_upstream_json_array() {
  local first=1
  local value
  for value in "$@"; do
    if [ "$first" -eq 0 ]; then
      printf ','
    fi
    printf '"%s"' "$(report_upstream_json_escape "$value")"
    first=0
  done
}

report_upstream_extract_issue_number() {
  local url="$1"
  local issue_number=""
  issue_number="${url##*/}"
  case "$issue_number" in
    ''|*[!0-9]*)
      printf ''
      ;;
    *)
      printf '%s' "$issue_number"
      ;;
  esac
}

report_upstream_build_preview() {
  local type="$1"
  local title="$2"
  local upstream_repo="$3"
  local installed_version_or_ref="$4"
  local installed_at="$5"
  local local_overrides_doc="$6"
  local local_overrides_present="$7"
  local repo_name="$8"
  local command_text="$9"
  local expected_text="${10}"
  local actual_text="${11}"
  local use_case_text="${12}"
  local proposed_text="${13}"
  local why_upstream_text="${14}"
  local logs_note="${15}"
  local body_appendix="${16}"
  local preview_file="${17}"

  {
    printf '# %s\n\n' "$title"
    printf 'Type: %s\n' "$type"
    printf 'Upstream repo target: %s\n\n' "$upstream_repo"
    printf '## Installed context\n\n'
    printf -- '- Upstream repo: %s\n' "$upstream_repo"
    printf -- '- Installed version/ref: %s\n' "$installed_version_or_ref"
    printf -- '- Installed at: %s\n' "$installed_at"
    printf -- '- Local overrides doc: %s\n' "$local_overrides_doc"
    printf -- '- Local overrides present: %s\n' "$local_overrides_present"
    printf -- '- Current repo root name: %s\n\n' "$repo_name"

    if [ "$type" = "bug" ]; then
      printf '## Bug details\n\n'
      printf 'Command run:\n\n'
      printf '%s\n\n' "${command_text:-not provided}"
      printf 'Expected behavior:\n\n'
      printf '%s\n\n' "${expected_text:-not provided}"
      printf 'Actual behavior:\n\n'
      printf '%s\n\n' "${actual_text:-not provided}"
    else
      printf '## Feature details\n\n'
      printf 'Use case:\n\n'
      printf '%s\n\n' "${use_case_text:-not provided}"
      printf 'Proposed behavior:\n\n'
      printf '%s\n\n' "${proposed_text:-not provided}"
      printf 'Why this belongs upstream:\n\n'
      printf '%s\n\n' "${why_upstream_text:-not provided}"
    fi

    printf '## Redaction check\n\n'
    printf '%s\n\n' "$logs_note"
    printf -- '- [ ] I confirm logs and context are redacted and contain no tokens, API keys, private keys, passwords, passphrases, or sensitive host identifiers.\n\n'

    if [ -n "$body_appendix" ]; then
      printf '## Additional context\n\n'
      printf '%s\n\n' "$body_appendix"
    fi
  } > "$preview_file"
}

report_upstream_main() {
  local mode="plan"
  local report_type=""
  local title=""
  local command_text=""
  local expected_text=""
  local actual_text=""
  local use_case_text=""
  local proposed_text=""
  local why_upstream_text=""
  local logs_file=""
  local body_file=""
  local preview_file=""
  local submit=0
  local assume_yes=0
  local repo_override=""
  local arg=""
  local action_taken="preview"
  local submitted=false
  local redaction_scan="pass"
  local issue_number=""
  local issue_url=""
  local command_status=0
  local repo_root=""
  local repo_name=""
  local upstream_repo=""
  local installed_version_or_ref=""
  local installed_at=""
  local local_overrides_doc=""
  local local_overrides_present="unknown"
  local logs_note="Redacted logs attached/pasted: no"
  local body_appendix=""
  local confirm_input=""
  local default_bug_label="automation-bug"
  local default_feature_label="automation-feature"
  local -a labels=()

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --help)
        report_upstream_usage
        return 0
        ;;
      --plan)
        mode="plan"
        ;;
      --dry-run)
        mode="dry-run"
        ;;
      --json)
        report_upstream_json=1
        ;;
      --type=*)
        report_type="${arg#--type=}"
        if [ -z "$report_type" ]; then
          repo_auto_flag_error "empty flag value" "--type" "use --type=<bug|feature>" || return 1
          command_status=1
          break
        fi
        ;;
      --type)
        report_upstream_value_flag_error "--type" "use --type=<bug|feature>" "${2:-}" || return 1
        return 1
        ;;
      --title=*)
        title="${arg#--title=}"
        if [ -z "$title" ]; then
          repo_auto_flag_error "empty flag value" "--title" "use --title=<text>" || return 1
          command_status=1
          break
        fi
        ;;
      --title)
        report_upstream_value_flag_error "--title" "use --title=<text>" "${2:-}" || return 1
        return 1
        ;;
      --command=*)
        command_text="${arg#--command=}"
        if [ -z "$command_text" ]; then
          repo_auto_flag_error "empty flag value" "--command" "use --command=<text>" || return 1
          command_status=1
          break
        fi
        ;;
      --command)
        report_upstream_value_flag_error "--command" "use --command=<text>" "${2:-}" || return 1
        return 1
        ;;
      --expected=*)
        expected_text="${arg#--expected=}"
        if [ -z "$expected_text" ]; then
          repo_auto_flag_error "empty flag value" "--expected" "use --expected=<text>" || return 1
          command_status=1
          break
        fi
        ;;
      --expected)
        report_upstream_value_flag_error "--expected" "use --expected=<text>" "${2:-}" || return 1
        return 1
        ;;
      --actual=*)
        actual_text="${arg#--actual=}"
        if [ -z "$actual_text" ]; then
          repo_auto_flag_error "empty flag value" "--actual" "use --actual=<text>" || return 1
          command_status=1
          break
        fi
        ;;
      --actual)
        report_upstream_value_flag_error "--actual" "use --actual=<text>" "${2:-}" || return 1
        return 1
        ;;
      --use-case=*)
        use_case_text="${arg#--use-case=}"
        if [ -z "$use_case_text" ]; then
          repo_auto_flag_error "empty flag value" "--use-case" "use --use-case=<text>" || return 1
          command_status=1
          break
        fi
        ;;
      --use-case)
        report_upstream_value_flag_error "--use-case" "use --use-case=<text>" "${2:-}" || return 1
        return 1
        ;;
      --proposed=*)
        proposed_text="${arg#--proposed=}"
        if [ -z "$proposed_text" ]; then
          repo_auto_flag_error "empty flag value" "--proposed" "use --proposed=<text>" || return 1
          command_status=1
          break
        fi
        ;;
      --proposed)
        report_upstream_value_flag_error "--proposed" "use --proposed=<text>" "${2:-}" || return 1
        return 1
        ;;
      --why-upstream=*)
        why_upstream_text="${arg#--why-upstream=}"
        if [ -z "$why_upstream_text" ]; then
          repo_auto_flag_error "empty flag value" "--why-upstream" "use --why-upstream=<text>" || return 1
          command_status=1
          break
        fi
        ;;
      --why-upstream)
        report_upstream_value_flag_error "--why-upstream" "use --why-upstream=<text>" "${2:-}" || return 1
        return 1
        ;;
      --logs-file=*)
        logs_file="${arg#--logs-file=}"
        if [ -z "$logs_file" ]; then
          repo_auto_flag_error "empty flag value" "--logs-file" "use --logs-file=<path>" || return 1
          command_status=1
          break
        fi
        ;;
      --logs-file)
        report_upstream_value_flag_error "--logs-file" "use --logs-file=<path>" "${2:-}" || return 1
        return 1
        ;;
      --body-file=*)
        body_file="${arg#--body-file=}"
        if [ -z "$body_file" ]; then
          repo_auto_flag_error "empty flag value" "--body-file" "use --body-file=<path>" || return 1
          command_status=1
          break
        fi
        ;;
      --body-file)
        report_upstream_value_flag_error "--body-file" "use --body-file=<path>" "${2:-}" || return 1
        return 1
        ;;
      --preview-file=*)
        preview_file="${arg#--preview-file=}"
        if [ -z "$preview_file" ]; then
          repo_auto_flag_error "empty flag value" "--preview-file" "use --preview-file=<path>" || return 1
          command_status=1
          break
        fi
        ;;
      --preview-file)
        report_upstream_value_flag_error "--preview-file" "use --preview-file=<path>" "${2:-}" || return 1
        return 1
        ;;
      --submit)
        submit=1
        ;;
      --yes)
        assume_yes=1
        ;;
      --label=*)
        label_value="${arg#--label=}"
        if [ -z "$label_value" ]; then
          repo_auto_flag_error "empty flag value" "--label" "use --label=<name>" || return 1
          command_status=1
          break
        fi
        labels+=("$label_value")
        ;;
      --label)
        report_upstream_value_flag_error "--label" "use --label=<name>" "${2:-}" || return 1
        return 1
        ;;
      --repo=*)
        repo_override="${arg#--repo=}"
        if [ -z "$repo_override" ]; then
          repo_auto_flag_error "empty flag value" "--repo" "use --repo=<owner/repo>" || return 1
          command_status=1
          break
        fi
        ;;
      --repo)
        report_upstream_value_flag_error "--repo" "use --repo=<owner/repo>" "${2:-}" || return 1
        return 1
        ;;
      *)
        if [ "${arg#--}" != "$arg" ]; then
          repo_auto_flag_error "unknown flag" "$arg" "run repo-automation/bin/repo-automation-report-upstream --help" || return 1
        else
          report_upstream_stop "unknown argument: $arg"
        fi
        command_status=1
        ;;
    esac
    shift
  done

  if [ "$submit" -eq 1 ] && [ "$mode" = "dry-run" ]; then
    report_upstream_warn "--dry-run active; issue will not be submitted"
    submit=0
  fi

  if [ "$command_status" -eq 0 ]; then
    repo_root=$(repo_auto_repo_root) || {
      report_upstream_stop "failed to determine repo root"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    cd "$repo_root" || {
      report_upstream_stop "failed to enter repo root: $repo_root"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    repo_auto_load_config || {
      report_upstream_stop "failed to load .repo-automation.conf"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    repo_auto_validate_required_config || {
      report_upstream_stop "invalid .repo-automation.conf"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    case "$report_type" in
      bug|feature)
        ;;
      *)
        report_upstream_stop "--type must be exactly bug or feature"
        command_status=1
        ;;
    esac
  fi

  if [ "$command_status" -eq 0 ] && [ -z "$title" ]; then
    report_upstream_stop "--title is required"
    command_status=1
  fi

  if [ "$command_status" -eq 0 ]; then
    if [ -n "$repo_override" ]; then
      upstream_repo="$repo_override"
    else
      upstream_repo="$UPSTREAM_REPO_FULL_NAME"
    fi
  fi

  if [ "$command_status" -eq 0 ]; then
    [[ "$upstream_repo" =~ ^[^[:space:]/]+/[^[:space:]/]+$ ]] || {
      report_upstream_stop "invalid target repo: $upstream_repo"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    # shellcheck disable=SC2153
    installed_version_or_ref="$INSTALLED_VERSION_OR_REF"
    # shellcheck disable=SC2153
    installed_at="$INSTALLED_AT"
    # shellcheck disable=SC2153
    local_overrides_doc="$LOCAL_OVERRIDES_DOC"
    repo_name="$(basename "$repo_root")"
    if [ -f "$local_overrides_doc" ]; then
      local_overrides_present="yes"
    else
      local_overrides_present="no"
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ -n "$logs_file" ]; then
    if [ ! -f "$logs_file" ]; then
      report_upstream_stop "logs file does not exist: $logs_file"
      command_status=1
    elif ! repo_auto_secret_scan_file "$logs_file"; then
      redaction_scan="blocked"
      report_upstream_stop "likely secret markers found in logs file"
      command_status=1
    else
      logs_note="Redacted logs attached/pasted: yes (from logs file)"
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ -n "$body_file" ]; then
    if [ ! -f "$body_file" ]; then
      report_upstream_stop "body file does not exist: $body_file"
      command_status=1
    elif ! repo_auto_secret_scan_file "$body_file"; then
      redaction_scan="blocked"
      report_upstream_stop "likely secret markers found in body file"
      command_status=1
    else
      body_appendix="$(cat "$body_file")"
    fi
  fi

  if [ "$command_status" -eq 0 ]; then
    if [ -z "$preview_file" ]; then
      preview_file="${TMPDIR:-$HOME/.cache}/repo-automation-template/report-upstream-preview.md"
    fi
    mkdir -p "$(dirname "$preview_file")" || {
      report_upstream_stop "failed to create preview directory"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ]; then
    if [ "$report_type" = "bug" ]; then
      labels=("$default_bug_label" "${labels[@]}")
    else
      labels=("$default_feature_label" "${labels[@]}")
    fi
  fi

  if [ "$command_status" -eq 0 ]; then
    report_upstream_build_preview \
      "$report_type" \
      "$title" \
      "$upstream_repo" \
      "$installed_version_or_ref" \
      "$installed_at" \
      "$local_overrides_doc" \
      "$local_overrides_present" \
      "$repo_name" \
      "$command_text" \
      "$expected_text" \
      "$actual_text" \
      "$use_case_text" \
      "$proposed_text" \
      "$why_upstream_text" \
      "$logs_note" \
      "$body_appendix" \
      "$preview_file" || {
      report_upstream_stop "failed to build preview body"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ] && [ "$report_upstream_json" -eq 0 ]; then
    report_upstream_info "issue body preview generated"
    report_upstream_info "preview file: $preview_file"
    report_upstream_info "upstream repo target: $upstream_repo"
    report_upstream_info "issue type: $report_type"
    report_upstream_info "installed automation version/ref: $installed_version_or_ref"
    report_upstream_info "local overrides present: $local_overrides_present"
    report_upstream_info "redact secrets before submission"
  fi

  if [ "$command_status" -eq 0 ] && [ "$submit" -eq 1 ]; then
    repo_auto_require_command gh || {
      report_upstream_stop "gh is required for --submit"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ] && [ "$submit" -eq 1 ] && [ "$assume_yes" -eq 0 ]; then
    if [ "$report_upstream_json" -eq 0 ]; then
      printf 'Confirm submission to %s? Type yes to continue: ' "$upstream_repo" >&2
      IFS= read -r confirm_input
      if [ "$confirm_input" != "yes" ]; then
        report_upstream_stop "submission not confirmed"
        command_status=1
      fi
    else
      report_upstream_stop "--submit without --yes is not supported in --json mode"
      command_status=1
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$submit" -eq 1 ]; then
    local -a label_flags=()
    local label
    for label in "${labels[@]}"; do
      [ -n "$label" ] || continue
      label_flags+=(--label "$label")
    done

    issue_url=$(gh issue create --repo "$upstream_repo" --title "$title" --body-file "$preview_file" "${label_flags[@]}" 2>&1) || {
      report_upstream_stop "gh issue create failed: $issue_url"
      command_status=1
    }
    if [ "$command_status" -eq 0 ]; then
      issue_number="$(report_upstream_extract_issue_number "$issue_url")"
      submitted=true
      action_taken="submitted"
      [ "$report_upstream_json" -eq 1 ] || report_upstream_info "issue submitted: $issue_url"
    fi
  fi

  if [ "$command_status" -eq 0 ] && [ "$submit" -eq 0 ]; then
    action_taken="preview"
    [ "$report_upstream_json" -eq 1 ] || report_upstream_info "preview-only mode; no issue was submitted"
  fi

  if [ "$report_upstream_json" -eq 1 ]; then
    printf '{'
    printf '"mode":"%s",' "$(report_upstream_json_escape "$mode")"
    printf '"type":"%s",' "$(report_upstream_json_escape "$report_type")"
    printf '"title":"%s",' "$(report_upstream_json_escape "$title")"
    printf '"upstream_repo":"%s",' "$(report_upstream_json_escape "$upstream_repo")"
    printf '"labels":['
    report_upstream_json_array "${labels[@]}"
    printf '],'
    printf '"preview_file":"%s",' "$(report_upstream_json_escape "$preview_file")"
    printf '"submitted":%s,' "$submitted"
    printf '"issue_number":"%s",' "$(report_upstream_json_escape "$issue_number")"
    printf '"issue_url":"%s",' "$(report_upstream_json_escape "$issue_url")"
    printf '"redaction_scan":"%s",' "$(report_upstream_json_escape "$redaction_scan")"
    printf '"installed_version_or_ref":"%s",' "$(report_upstream_json_escape "$installed_version_or_ref")"
    printf '"local_overrides_doc":"%s",' "$(report_upstream_json_escape "$local_overrides_doc")"
    printf '"action_taken":"%s",' "$(report_upstream_json_escape "$action_taken")"
    printf '"stop_reason":"%s"' "$(report_upstream_json_escape "$report_upstream_stop_reason")"
    printf '}\n'
  fi

  return "$command_status"
}

report_upstream_main "$@"
report_upstream_status=$?
return "$report_upstream_status" 2>/dev/null || exit "$report_upstream_status"
# repo-automation/bin/repo-automation-report-upstream EOF
