#!/usr/bin/env bash
# repo-automation/bin/repo-doctor

set -u
set -o pipefail

# shellcheck source=/dev/null
source "$(cd "$(dirname "$0")" && pwd)/../lib/common.sh"

repo_doctor_mode="summary"
repo_doctor_output_mode="summary"
repo_doctor_json=0
repo_doctor_json_level="warn"
repo_doctor_log_enabled=1
repo_doctor_log_file=""
repo_doctor_timeout_seconds=120
repo_doctor_skip_run_tests=0
repo_doctor_single_check=""
repo_doctor_stop_reason=""
repo_doctor_checks=()

repo_doctor_usage() {
  printf 'Usage: repo-automation/bin/repo-doctor [--help] [--summary] [--audit] [--explain] [--quiet] [--timeout=SECONDS] [--log-file=FILE] [--no-log] [--json] [--json-level=fail|warn|all] [--quick] [--full] [--no-run-tests] [--check=NAME]\n'
  printf 'Named checks: artifact-guard, git, config, scripts, json, tests, version, ci, automation-freshness, starter-template-readiness, docs, issue-templates\n'
}

repo_doctor_info() {
  [ "$repo_doctor_json" -eq 1 ] || repo_auto_info "$*"
}

repo_doctor_warn() {
  repo_auto_warn "$*"
}

repo_doctor_stop() {
  repo_doctor_stop_reason="$*"
  repo_auto_stop "$*"
  return 1
}

repo_doctor_timestamp() {
  date '+%Y-%m-%dT%H%M%S'
}

repo_doctor_json_escape() {
  local input="$1"
  input=${input//\\/\\\\}
  input=${input//\"/\\\"}
  input=${input//$'\n'/\\n}
  input=${input//$'\r'/\\r}
  input=${input//$'\t'/\\t}
  printf '%s' "$input"
}

repo_doctor_init_log() {
  local temp_root

  if [ "$repo_doctor_log_enabled" -ne 1 ]; then
    return 0
  fi

  if [ -z "$repo_doctor_log_file" ]; then
    temp_root="${TMPDIR:-$HOME/.cache}/repo-automation-template"
    mkdir -p "$temp_root" >/dev/null 2>&1 || {
      repo_doctor_log_enabled=0
      repo_doctor_log_file=""
      return 0
    }
    repo_doctor_log_file="$temp_root/repo-doctor-$(repo_doctor_timestamp).log"
  fi

  : >"$repo_doctor_log_file" 2>/dev/null || {
    repo_doctor_log_enabled=0
    repo_doctor_log_file=""
    return 0
  }
}

repo_doctor_log() {
  if [ "$repo_doctor_log_enabled" -eq 1 ] && [ -n "$repo_doctor_log_file" ]; then
    printf '%s\n' "$*" >>"$repo_doctor_log_file"
  fi
}

repo_doctor_add_check() {
  local name="$1"
  local status="$2"
  local message="$3"
  repo_doctor_checks+=("${name}|${status}|${message}")
  repo_doctor_log "${status^^}: ${name} - ${message}"
}

repo_doctor_status_weight() {
  case "$1" in
    fail) printf '3' ;;
    warn) printf '2' ;;
    pass) printf '1' ;;
    *) printf '0' ;;
  esac
}

repo_doctor_json_should_include() {
  local status="$1"
  case "$repo_doctor_json_level" in
    fail)
      [ "$status" = "fail" ]
      ;;
    warn)
      [ "$status" = "fail" ] || [ "$status" = "warn" ]
      ;;
    all)
      return 0
      ;;
  esac
}

repo_doctor_should_run_starter_template_readiness() {
  local config_path

  config_path="$(repo_auto_config_path)" || return 1
  [ -f "$config_path" ] || return 1

  if ! repo_auto_load_config >/dev/null 2>&1; then
    return 1
  fi

  [ "${CHECK_PROFILE_DEFAULT:-}" = "starter-template" ]
}

repo_doctor_check_is_registered() {
  case "$1" in
    artifact-guard|git|config|scripts|json|tests|version|ci|automation-freshness|starter-template-readiness|docs|issue-templates)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

repo_doctor_counts() {
  local pass_count=0
  local warn_count=0
  local fail_count=0
  local skipped_count=0
  local entry rest status

  for entry in "${repo_doctor_checks[@]}"; do
    rest="${entry#*|}"
    status="${rest%%|*}"
    case "$status" in
      pass) pass_count=$((pass_count + 1)) ;;
      warn) warn_count=$((warn_count + 1)) ;;
      fail) fail_count=$((fail_count + 1)) ;;
      *) skipped_count=$((skipped_count + 1)) ;;
    esac
  done

  printf '%s %s %s %s\n' "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
}

repo_doctor_print_json() {
  local overall_status="$1"
  local action_taken="$2"
  local pass_count="$3"
  local warn_count="$4"
  local fail_count="$5"
  local skipped_count="$6"
  local stop_reason="$7"
  local idx=0
  local entry
  local name
  local status
  local message
  local json_checks=""

  for entry in "${repo_doctor_checks[@]}"; do
    name="${entry%%|*}"
    rest="${entry#*|}"
    status="${rest%%|*}"
    message="${rest#*|}"
    if ! repo_doctor_json_should_include "$status"; then
      continue
    fi
    if [ "$idx" -gt 0 ]; then
      json_checks+=","
    fi
    json_checks+="{\"name\":\"$(repo_doctor_json_escape "$name")\",\"status\":\"$(repo_doctor_json_escape "$status")\",\"message\":\"$(repo_doctor_json_escape "$message")\"}"
    idx=$((idx + 1))
  done

  printf '{'
  printf '"script":"repo-doctor",'
  printf '"mode":"%s",' "$(repo_doctor_json_escape "$repo_doctor_mode")"
  printf '"overall_status":"%s",' "$(repo_doctor_json_escape "$overall_status")"
  printf '"checks":[%s],' "$json_checks"
  printf '"pass_count":%s,' "$pass_count"
  printf '"warn_count":%s,' "$warn_count"
  printf '"fail_count":%s,' "$fail_count"
  printf '"skipped_count":%s,' "$skipped_count"
  printf '"action_taken":"%s",' "$(repo_doctor_json_escape "$action_taken")"
  printf '"stop_reason":"%s",' "$(repo_doctor_json_escape "$stop_reason")"
  printf '"json_level":"%s",' "$(repo_doctor_json_escape "$repo_doctor_json_level")"
  printf '"log_file":"%s"' "$(repo_doctor_json_escape "$repo_doctor_log_file")"
  printf '}\n'
}

repo_doctor_check_git() {
  local repo_root current_branch dirty_state remote_name remote_url expected_remote
  repo_root="$(repo_auto_repo_root)" || {
    repo_doctor_add_check "git-repo" "fail" "not inside a git repository"
    return 1
  }

  current_branch="$(git branch --show-current 2>/dev/null || true)"
  if [ -z "$current_branch" ]; then
    repo_doctor_add_check "git-branch" "warn" "unable to determine current branch"
  else
    repo_doctor_add_check "git-branch" "pass" "current branch: $current_branch"
  fi

  dirty_state="$(git status --porcelain 2>/dev/null || true)"
  if [ -n "$dirty_state" ]; then
    repo_doctor_add_check "git-worktree" "warn" "working tree is dirty"
  else
    repo_doctor_add_check "git-worktree" "pass" "working tree is clean"
  fi

  remote_name="${REMOTE_NAME:-origin}"
  remote_url="$(git remote get-url "$remote_name" 2>/dev/null || true)"
  if [ -z "$remote_url" ]; then
    repo_doctor_add_check "git-remote-url" "fail" "missing remote URL for $remote_name"
    return 1
  fi
  repo_doctor_add_check "git-remote-url" "pass" "remote $remote_name URL detected"

  expected_remote="${EXPECTED_REMOTE_URL:-}"
  if [ -n "$expected_remote" ]; then
    if [ "$remote_url" = "$expected_remote" ]; then
      repo_doctor_add_check "git-remote-match" "pass" "remote URL matches expected config"
    else
      repo_doctor_add_check "git-remote-match" "fail" "remote URL does not match expected config"
      return 1
    fi
  else
    repo_doctor_add_check "git-remote-match" "warn" "expected remote URL not configured"
  fi

  return 0
}

repo_doctor_check_config() {
  local config_path
  config_path="$(repo_auto_config_path)" || {
    repo_doctor_add_check "config-path" "fail" "unable to resolve config path"
    return 1
  }

  if [ ! -f "$config_path" ]; then
    repo_doctor_add_check "config-exists" "fail" "missing .repo-automation.conf"
    return 1
  fi
  repo_doctor_add_check "config-exists" "pass" "config file exists"

  if ! repo_auto_secret_scan_file "$config_path"; then
    repo_doctor_add_check "config-secret-scan" "fail" "config secret scan failed"
    return 1
  fi
  repo_doctor_add_check "config-secret-scan" "pass" "config secret scan passed"

  if ! repo_auto_load_config >/dev/null; then
    repo_doctor_add_check "config-load" "fail" "config failed to load"
    return 1
  fi
  repo_doctor_add_check "config-load" "pass" "config loaded"

  if ! repo_auto_validate_required_config >/dev/null; then
    repo_doctor_add_check "config-validate" "fail" "required config validation failed"
    return 1
  fi
  repo_doctor_add_check "config-validate" "pass" "required config validation passed"
  return 0
}

repo_doctor_check_script_one() {
  local path="$1"
  local name="$2"

  if [ ! -f "$path" ]; then
    repo_doctor_add_check "$name-exists" "fail" "missing $path"
    return 1
  fi
  repo_doctor_add_check "$name-exists" "pass" "$path exists"

  if [ "$path" != "repo-automation/lib/common.sh" ] && [ ! -x "$path" ]; then
    repo_doctor_add_check "$name-executable" "fail" "$path is not executable"
    return 1
  fi
  if [ "$path" != "repo-automation/lib/common.sh" ]; then
    repo_doctor_add_check "$name-executable" "pass" "$path is executable"
  fi

  if bash -n "$path" >/dev/null 2>&1; then
    repo_doctor_add_check "$name-syntax" "pass" "bash syntax ok"
  else
    repo_doctor_add_check "$name-syntax" "fail" "bash syntax check failed"
    return 1
  fi
  return 0
}

repo_doctor_check_scripts() {
  local status=0
  repo_doctor_check_script_one "repo-automation/bin/branch-cleanup" "branch-cleanup" || status=1
  repo_doctor_check_script_one "repo-automation/bin/codex-slice-preflight" "codex-slice-preflight" || status=1
  repo_doctor_check_script_one "repo-automation/bin/pr-finish" "pr-finish" || status=1
  repo_doctor_check_script_one "repo-automation/bin/add-doc-pr" "add-doc-pr" || status=1
  if [ -f "repo-automation/bin/automation-freshness" ]; then
    repo_doctor_check_script_one "repo-automation/bin/automation-freshness" "automation-freshness" || status=1
  else
    repo_doctor_add_check "automation-freshness-exists" "skipped" "repo-automation/bin/automation-freshness missing"
  fi
  repo_doctor_check_script_one "repo-automation/bin/repo-automation-report-upstream" "report-upstream" || status=1
  repo_doctor_check_script_one "repo-automation/bin/repo-doctor" "repo-doctor" || status=1
  repo_doctor_check_script_one "repo-automation/bin/repo-automation-install" "repo-automation-install" || status=1
  repo_doctor_check_script_one "repo-automation/bin/failure-log" "failure-log" || status=1
  repo_doctor_check_script_one "repo-automation/bin/touched-files" "touched-files" || status=1
  repo_doctor_check_script_one "repo-automation/bin/ci-status" "ci-status" || status=1
  repo_doctor_check_script_one "repo-automation/bin/ci-watch" "ci-watch" || status=1
  repo_doctor_check_script_one "repo-automation/bin/status-packet" "status-packet" || status=1
  if repo_doctor_should_run_starter_template_readiness; then
    repo_doctor_check_script_one "repo-automation/bin/starter-template-ready" "starter-template-ready" || status=1
  fi
  repo_doctor_check_script_one "repo-automation/bin/run-tests" "run-tests" || status=1
  repo_doctor_check_script_one "repo-automation/lib/common.sh" "common-library" || status=1
  return "$status"
}

repo_doctor_root_artifact_guard_is_match() {
  local path="$1"

  case "$path" in
    .tmp-*|tmp-*|scratch.txt|touched.json|range.json|*.tmp|*.log)
      return 0
      ;;
    .cache|tmp|temp)
      [ -d "$path" ]
      return $?
      ;;
  esac

  return 1
}

repo_doctor_check_artifact_guard() {
  local status=0
  local path
  local display_path
  local artifacts=()

  while IFS= read -r path; do
    [ -n "$path" ] || continue
    if ! repo_doctor_root_artifact_guard_is_match "$path"; then
      continue
    fi
    if git ls-files --error-unmatch -- "$path" >/dev/null 2>&1; then
      continue
    fi
    display_path="$path"
    [ -d "$path" ] && display_path="$path/"
    artifacts+=("$display_path")
  done <<EOF
$(find . -mindepth 1 -maxdepth 1 -printf '%P\n' 2>/dev/null | LC_ALL=C sort)
EOF

  if [ "${#artifacts[@]}" -eq 0 ]; then
    repo_doctor_add_check "artifact-guard" "pass" "no repo-root temp or cache artifacts detected"
    return 0
  fi

  repo_doctor_add_check "artifact-guard" "fail" "repo-root artifacts detected: ${artifacts[*]}"
  return 1
}

repo_doctor_check_automation_freshness() {
  local status=0
  local freshness_json
  local temp_root="${TMPDIR:-$HOME/.cache}/repo-automation-template"

  if [ ! -f repo-automation/bin/automation-freshness ]; then
    repo_doctor_add_check "automation-freshness" "skipped" "repo-automation/bin/automation-freshness missing"
    return 0
  fi

  mkdir -p "$temp_root" >/dev/null 2>&1 || true
  freshness_json="$temp_root/repo-doctor-automation-freshness.json"

  if repo-automation/bin/automation-freshness --machine-json > "$freshness_json" 2>/dev/null; then
    :
  else
    status=1
  fi

  if [ ! -s "$freshness_json" ]; then
    repo_doctor_add_check "automation-freshness" "fail" "automation-freshness did not produce JSON output"
    rm -f "$freshness_json" >/dev/null 2>&1 || true
    return 1
  fi

  if command -v python >/dev/null 2>&1 && python -m json.tool "$freshness_json" >/dev/null 2>&1; then
    if python - "$freshness_json" <<'PY'
import json
import pathlib
import sys

data = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
sys.exit(0 if data.get("overall_status") == "pass" else 1)
PY
    then
      repo_doctor_add_check "automation-freshness" "pass" "automation manifest freshness passed"
    else
      repo_doctor_add_check "automation-freshness" "fail" "automation manifest freshness reported missing files"
      status=1
    fi
  else
    repo_doctor_add_check "automation-freshness" "fail" "automation-freshness JSON is not parseable"
    status=1
  fi

  rm -f "$freshness_json" >/dev/null 2>&1 || true
  return "$status"
}

repo_doctor_check_starter_template_readiness() {
  local status=0
  local readiness_json
  local readiness_message
  local temp_root="${TMPDIR:-$HOME/.cache}/repo-automation-template"

  if [ ! -x repo-automation/bin/starter-template-ready ]; then
    repo_doctor_add_check "starter-template-readiness" "fail" "repo-automation/bin/starter-template-ready missing"
    return 1
  fi

  mkdir -p "$temp_root" >/dev/null 2>&1 || true
  readiness_json="$temp_root/repo-doctor-starter-template-ready.json"

  if repo-automation/bin/starter-template-ready --check-current --machine-json > "$readiness_json" 2>/dev/null; then
    :
  else
    status=1
  fi

  if [ ! -s "$readiness_json" ]; then
    repo_doctor_add_check "starter-template-readiness" "fail" "starter-template-ready did not produce JSON output"
    rm -f "$readiness_json" >/dev/null 2>&1 || true
    return 1
  fi

  if command -v python >/dev/null 2>&1 && python -m json.tool "$readiness_json" >/dev/null 2>&1; then
    if readiness_message="$(python - "$readiness_json" <<'PY'
import json
import pathlib
import sys

data = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
if data.get("overall_status") == "pass":
    print("starter-template readiness passed")
    sys.exit(0)

print(data.get("stop_reason") or "starter-template readiness failed")
sys.exit(1)
PY
)"; then
      repo_doctor_add_check "starter-template-readiness" "pass" "$readiness_message"
    else
      repo_doctor_add_check "starter-template-readiness" "fail" "$readiness_message"
      status=1
    fi
  else
    repo_doctor_add_check "starter-template-readiness" "fail" "starter-template-ready JSON is not parseable"
    status=1
  fi

  rm -f "$readiness_json" >/dev/null 2>&1 || true
  return "$status"
}

repo_doctor_check_json_contracts() {
  local status=0
  local branch_json preflight_json
  local temp_root="${TMPDIR:-$HOME/.cache}/repo-automation-template"

  mkdir -p "$temp_root" >/dev/null 2>&1 || true
  branch_json="$temp_root/repo-doctor-branch-cleanup.json"
  preflight_json="$temp_root/repo-doctor-preflight.json"

  if repo-automation/bin/branch-cleanup --json --plan > "$branch_json" 2>/dev/null; then
    if command -v python >/dev/null 2>&1 && python -m json.tool "$branch_json" >/dev/null 2>&1; then
      repo_doctor_add_check "json-branch-cleanup" "pass" "branch-cleanup json parseable"
    elif command -v python >/dev/null 2>&1; then
      repo_doctor_add_check "json-branch-cleanup" "fail" "branch-cleanup json is not parseable"
      status=1
    else
      repo_doctor_add_check "json-branch-cleanup" "warn" "python missing; skipped parse check"
    fi
  else
    repo_doctor_add_check "json-branch-cleanup" "fail" "branch-cleanup json command failed"
    status=1
  fi

  if repo-automation/bin/codex-slice-preflight --json --check-only --branch feature/doctor-smoke > "$preflight_json" 2>/dev/null; then
    if command -v python >/dev/null 2>&1 && python -m json.tool "$preflight_json" >/dev/null 2>&1; then
      repo_doctor_add_check "json-preflight" "pass" "preflight json parseable"
    elif command -v python >/dev/null 2>&1; then
      repo_doctor_add_check "json-preflight" "fail" "preflight json is not parseable"
      status=1
    else
      repo_doctor_add_check "json-preflight" "warn" "python missing; skipped parse check"
    fi
  else
    repo_doctor_add_check "json-preflight" "fail" "preflight json command failed"
    status=1
  fi

  rm -f "$branch_json" "$preflight_json" >/dev/null 2>&1 || true
  return "$status"
}
repo_doctor_check_run_tests() {
  if [ "$repo_doctor_skip_run_tests" -eq 1 ]; then
    repo_doctor_add_check "run-tests" "warn" "repo-automation/bin/run-tests skipped"
    return 0
  fi

  if RUN_TESTS_SKIP_SMOKE=1 repo-automation/bin/run-tests --quiet --timeout "$repo_doctor_timeout_seconds" >/dev/null; then
    repo_doctor_add_check "run-tests" "pass" "repo-automation/bin/run-tests passed"
    return 0
  fi

  repo_doctor_add_check "run-tests" "fail" "repo-automation/bin/run-tests failed"
  return 1
}

repo_doctor_is_installed_target() {
  [ -f "repo-automation/docs/README.md" ] || return 1
  [ -f ".repo-automation.conf" ] || return 1
  return 0
}

repo_doctor_check_version_guard() {
  local config_path

  config_path="$(repo_auto_config_path)" || {
    repo_doctor_add_check "version-consistency" "fail" "unable to resolve config path"
    return 1
  }

  if [ ! -f "$config_path" ]; then
    repo_doctor_add_check "version-consistency" "skipped" "missing .repo-automation.conf"
    return 0
  fi

  if [ ! -f repo-automation/tests/version-consistency.sh ]; then
    repo_doctor_add_check "version-consistency-script" "fail" "repo-automation/tests/version-consistency.sh missing"
    return 1
  fi

  if repo_doctor_is_installed_target; then
    repo_doctor_add_check "version-consistency" "skipped" "installed downstream target uses repo-automation/docs/README.md provenance"
    return 0
  fi

  if repo-automation/tests/version-consistency.sh >/dev/null; then
    repo_doctor_add_check "version-consistency" "pass" "automation release version consistency guard passed"
    return 0
  fi

  repo_doctor_add_check "version-consistency" "fail" "automation release version consistency guard failed"
  return 1
}

repo_doctor_check_ci_permissions() {
  local workflow=".github/workflows/ci.yml"
  if [ ! -f "$workflow" ]; then
    repo_doctor_add_check "ci-workflow-exists" "fail" "missing $workflow"
    return 1
  fi
  repo_doctor_add_check "ci-workflow-exists" "pass" "ci workflow exists"

  if grep -Eq '^[[:space:]]*contents:[[:space:]]*read[[:space:]]*$' "$workflow"; then
    repo_doctor_add_check "ci-permissions-read" "pass" "ci workflow uses contents: read"
  else
    repo_doctor_add_check "ci-permissions-read" "fail" "ci workflow missing contents: read"
    return 1
  fi

  if grep -Eq '^[[:space:]]*(contents:[[:space:]]*write|pull-requests:[[:space:]]*write|issues:[[:space:]]*write)[[:space:]]*$' "$workflow"; then
    repo_doctor_add_check "ci-permissions-write" "fail" "ci workflow requests disallowed write permissions"
    return 1
  fi
  repo_doctor_add_check "ci-permissions-write" "pass" "ci workflow avoids disallowed write permissions"
  return 0
}

repo_doctor_check_docs_index() {
  local path="docs/INDEX.md"
  local status=0

  if [ ! -f "$path" ]; then
    repo_doctor_add_check "docs-index-exists" "fail" "missing docs/INDEX.md"
    return 1
  fi
  repo_doctor_add_check "docs-index-exists" "pass" "docs index exists"

  for needle in \
    "repo-automation/docs/branch-cleanup.md" \
    "repo-automation/docs/codex-slice-preflight.md" \
    "repo-automation/docs/pr-finish.md" \
    "repo-automation/docs/add-doc-pr.md" \
    "repo-automation/docs/repo-automation-report-upstream.md" \
    "repo-automation/docs/repo-doctor.md" \
    "repo-automation/docs/failure-log.md" \
    "repo-automation/docs/touched-files.md" \
    "repo-automation/docs/ci-status.md" \
    "repo-automation/docs/ci-watch.md" \
    "repo-automation/docs/status-packet.md" \
    "repo-automation/docs/managed-files.md" \
    "repo-automation/docs/repo-automation-install.md" \
    "repo-automation/docs/testing.md"
  do
    if grep -Fq "$needle" "$path"; then
      repo_doctor_add_check "docs-index-link-$needle" "pass" "docs index includes $needle"
    else
      repo_doctor_add_check "docs-index-link-$needle" "fail" "docs index missing $needle"
      status=1
    fi
  done
  return "$status"
}

repo_doctor_check_issue_templates() {
  local status=0
  if [ -f ".github/ISSUE_TEMPLATE/automation-bug.yml" ]; then
    repo_doctor_add_check "issue-template-bug" "pass" "automation bug template exists"
  else
    repo_doctor_add_check "issue-template-bug" "fail" "missing automation bug template"
    status=1
  fi

  if [ -f ".github/ISSUE_TEMPLATE/automation-feature.yml" ]; then
    repo_doctor_add_check "issue-template-feature" "pass" "automation feature template exists"
  else
    repo_doctor_add_check "issue-template-feature" "fail" "missing automation feature template"
    status=1
  fi
  return "$status"
}

repo_doctor_run_check() {
  local check_name="$1"
  case "$check_name" in
    artifact-guard) repo_doctor_check_artifact_guard ;;
    git) repo_doctor_check_git ;;
    config) repo_doctor_check_config ;;
    scripts) repo_doctor_check_scripts ;;
    json) repo_doctor_check_json_contracts ;;
    tests) repo_doctor_check_run_tests ;;
    version) repo_doctor_check_version_guard ;;
    ci) repo_doctor_check_ci_permissions ;;
    automation-freshness) repo_doctor_check_automation_freshness ;;
    starter-template-readiness) repo_doctor_check_starter_template_readiness ;;
    docs) repo_doctor_check_docs_index ;;
    issue-templates) repo_doctor_check_issue_templates ;;
    *)
      repo_doctor_stop "unknown check name: $check_name"
      return 1
      ;;
  esac
}

repo_doctor_print_human_summary() {
  local overall_status="$1"
  local pass_count="$2"
  local warn_count="$3"
  local fail_count="$4"
  local skipped_count="$5"
  local entry
  local name
  local status
  local message

  if [ "$repo_doctor_output_mode" != "quiet" ]; then
    printf 'RUNNING repo doctor...\n'
  fi

  if [ "$repo_doctor_output_mode" = "explain" ]; then
    for entry in "${repo_doctor_checks[@]}"; do
      name="${entry%%|*}"
      rest="${entry#*|}"
      status="${rest%%|*}"
      message="${rest#*|}"
      printf '%s: %s - %s\n' "${status^^}" "$name" "$message"
    done
  fi

  printf 'RESULT: pass=%s warn=%s fail=%s skipped=%s\n' \
    "$pass_count" "$warn_count" "$fail_count" "$skipped_count"

  if [ "$warn_count" -gt 0 ]; then
    printf 'WARN:\n'
    for entry in "${repo_doctor_checks[@]}"; do
      name="${entry%%|*}"
      rest="${entry#*|}"
      status="${rest%%|*}"
      if [ "$status" = "warn" ]; then
        printf -- '- %s\n' "$name"
      fi
    done
  fi

  if [ "$fail_count" -gt 0 ]; then
    printf 'FAIL:\n'
    for entry in "${repo_doctor_checks[@]}"; do
      name="${entry%%|*}"
      rest="${entry#*|}"
      status="${rest%%|*}"
      if [ "$status" = "fail" ]; then
        printf -- '- %s\n' "$name"
      fi
    done
  fi

  if [ "$repo_doctor_output_mode" != "quiet" ] && [ "$repo_doctor_log_enabled" -eq 1 ] && [ -n "$repo_doctor_log_file" ] && [ "$repo_doctor_json" -eq 0 ]; then
    printf 'Log: %s\n' "$repo_doctor_log_file"
  fi

  if [ "$warn_count" -gt 0 ] || [ "$fail_count" -gt 0 ]; then
    printf 'Next: repo-automation/bin/repo-doctor --explain\n'
  fi
}

repo_doctor_main() {
  local arg
  local command_status=0
  local overall_status="pass"
  local action_taken="read-only-diagnostics"
  local pass_count=0
  local warn_count=0
  local fail_count=0
  local skipped_count=0
  local status
  local checks_to_run=()
  local counts
  repo_doctor_checks=()

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --help)
        repo_doctor_usage
        return 0
        ;;
      --summary)
        repo_doctor_mode="summary"
        repo_doctor_output_mode="summary"
        ;;
      --explain)
        repo_doctor_mode="explain"
        repo_doctor_output_mode="explain"
        ;;
      --quiet)
        repo_doctor_mode="quiet"
        repo_doctor_output_mode="quiet"
        ;;
      --quick)
        repo_doctor_mode="quick"
        repo_doctor_skip_run_tests=1
        ;;
      --audit)
        repo_doctor_mode="audit"
        repo_doctor_skip_run_tests=0
        ;;
      --full)
        repo_doctor_mode="full"
        repo_doctor_skip_run_tests=0
        ;;
      --timeout=*)
        repo_doctor_timeout_seconds="${arg#--timeout=}"
        if [ -z "$repo_doctor_timeout_seconds" ]; then
          repo_doctor_stop "--timeout requires a value"
          return 1
        fi
        if ! repo_auto_is_positive_integer "$repo_doctor_timeout_seconds"; then
          repo_doctor_stop "invalid --timeout value: $repo_doctor_timeout_seconds"
          return 1
        fi
        ;;
      --timeout)
        shift
        if [ "$#" -eq 0 ]; then
          repo_doctor_stop "--timeout requires a value"
          return 1
        fi
        if repo_auto_is_positive_integer "$1"; then
          repo_doctor_timeout_seconds="$1"
        else
          repo_doctor_stop "invalid --timeout value: $1"
          return 1
        fi
        ;;
      --json)
        repo_doctor_json=1
        ;;
      --json-level=*)
        repo_doctor_json_level="${arg#--json-level=}"
        if [ -z "$repo_doctor_json_level" ]; then
          repo_doctor_stop "--json-level requires a value"
          return 1
        fi
        case "$repo_doctor_json_level" in
          fail|warn|all)
            ;;
          *)
            repo_doctor_stop "invalid --json-level value: $repo_doctor_json_level"
            return 1
            ;;
        esac
        ;;
      --json-level)
        shift
        if [ "$#" -eq 0 ]; then
          repo_doctor_stop "--json-level requires a value"
          return 1
        fi
        case "$1" in
          fail|warn|all)
            repo_doctor_json_level="$1"
            ;;
          *)
            repo_doctor_stop "invalid --json-level value: $1"
            return 1
            ;;
        esac
        ;;
      --log-file=*)
        repo_doctor_log_file="${arg#--log-file=}"
        if [ -z "$repo_doctor_log_file" ]; then
          repo_doctor_stop "--log-file requires a path"
          return 1
        fi
        repo_doctor_log_enabled=1
        ;;
      --log-file)
        shift
        if [ "$#" -eq 0 ]; then
          repo_doctor_stop "--log-file requires a path"
          return 1
        fi
        repo_doctor_log_file="$1"
        repo_doctor_log_enabled=1
        ;;
      --no-log)
        repo_doctor_log_enabled=0
        repo_doctor_log_file=""
        ;;
      --no-run-tests)
        repo_doctor_skip_run_tests=1
        ;;
      --check=*)
        repo_doctor_single_check="${arg#--check=}"
        if [ -z "$repo_doctor_single_check" ]; then
          repo_doctor_stop "--check requires a name"
          return 1
        fi
        ;;
      --check)
        shift
        if [ "$#" -eq 0 ]; then
          repo_doctor_stop "--check requires a name"
          return 1
        fi
        repo_doctor_single_check="$1"
        ;;
      *)
        repo_doctor_stop "unknown argument: $arg"
        return 1
        ;;
    esac
    shift
  done

  repo_doctor_init_log

  if [ "$command_status" -eq 0 ]; then
    repo_root="$(repo_auto_repo_root)" || command_status=1
  fi

  if [ "$command_status" -eq 0 ]; then
    cd "$repo_root" || {
      repo_doctor_stop "failed to enter repo root"
      command_status=1
    }
  fi

  if [ "$command_status" -eq 0 ] && [ -n "$repo_doctor_log_file" ]; then
    repo_doctor_log "RUNNING repo doctor..."
  fi

  if [ "$command_status" -eq 0 ]; then
    if [ -n "$repo_doctor_single_check" ]; then
      checks_to_run=("$repo_doctor_single_check")
      if ! repo_doctor_check_is_registered "$repo_doctor_single_check"; then
        repo_doctor_stop "unknown check name: $repo_doctor_single_check"
        command_status=1
      fi
    else
      if repo_doctor_is_installed_target; then
        checks_to_run=(artifact-guard git config scripts automation-freshness json tests version)
      else
        checks_to_run=(artifact-guard git config scripts automation-freshness json tests version ci docs issue-templates)
        if repo_doctor_should_run_starter_template_readiness; then
          checks_to_run=(artifact-guard git config scripts automation-freshness starter-template-readiness json tests version ci docs issue-templates)
        fi
      fi
    fi

    if [ "$command_status" -eq 0 ]; then
      for check_name in "${checks_to_run[@]}"; do
        repo_doctor_run_check "$check_name" || command_status=1
      done
    fi

  fi

  counts="$(repo_doctor_counts)"
  IFS=' ' read -r pass_count warn_count fail_count skipped_count <<EOF
$counts
EOF

  if [ "$fail_count" -gt 0 ] || [ "$command_status" -ne 0 ]; then
    overall_status="fail"
  elif [ "$warn_count" -gt 0 ]; then
    overall_status="warn"
  else
    overall_status="pass"
  fi

  if [ -n "$repo_doctor_stop_reason" ]; then
    if [ "$repo_doctor_json" -eq 1 ]; then
      repo_doctor_print_json \
        "fail" \
        "$action_taken" \
        "$pass_count" \
        "$warn_count" \
        "$fail_count" \
        "$skipped_count" \
        "$repo_doctor_stop_reason"
    fi
    return 1
  fi

  if [ "$repo_doctor_json" -eq 1 ]; then
    repo_doctor_print_json \
      "$overall_status" \
      "$action_taken" \
      "$pass_count" \
      "$warn_count" \
      "$fail_count" \
      "$skipped_count" \
      "$repo_doctor_stop_reason"
  else
    repo_doctor_print_human_summary \
      "$overall_status" \
      "$pass_count" \
      "$warn_count" \
      "$fail_count" \
      "$skipped_count" \
      repo_doctor_checks
  fi

  if [ "$fail_count" -gt 0 ] || [ "$command_status" -ne 0 ]; then
    return 1
  fi
  return 0
}

repo_doctor_main "$@"
# repo-automation/bin/repo-doctor EOF
