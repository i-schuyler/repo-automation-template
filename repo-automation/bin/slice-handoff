#!/usr/bin/env bash
# repo-automation/bin/slice-handoff

set -u
set -o pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
. "$script_dir/../lib/common.sh" || {
  printf 'STOP: failed to source shared library\n' >&2
  return 2 2>/dev/null || exit 2
}

slice_handoff_quiet=0
slice_handoff_file=""
slice_handoff_plan_only=0
slice_handoff_out_dir=""
slice_handoff_out_dir_abs=""
slice_handoff_out_dir_prompt=""
slice_handoff_out_dir_summary=""
slice_handoff_out_dir_pr_body=""
slice_handoff_branch=""
slice_handoff_title=""
slice_handoff_codex_profile=""
slice_handoff_commit_message=""
slice_handoff_submit_mode=""
slice_handoff_prompt_file=""
slice_handoff_pr_body_file=""
slice_handoff_repo_root="$(cd "$script_dir/../.." && pwd -P)"

slice_handoff_usage() {
  printf 'Usage: repo-automation/bin/slice-handoff --file=<path> --plan-only [--out-dir=<path>] [--quiet] [--help]\n'
}

slice_handoff_fail() {
  printf 'fail: %s\n' "$1" >&2
  printf 'fix: %s\n' "$2" >&2
}

slice_handoff_cleanup_temp_files() {
  if [ -n "$slice_handoff_prompt_file" ]; then
    rm -f -- "$slice_handoff_prompt_file" >/dev/null 2>&1 || true
  fi
  if [ -n "$slice_handoff_pr_body_file" ]; then
    rm -f -- "$slice_handoff_pr_body_file" >/dev/null 2>&1 || true
  fi
}

slice_handoff_cleanup_out_dir_temp_files() {
  local path=""

  for path in "$@"; do
    if [ -n "$path" ]; then
      rm -f -- "$path" >/dev/null 2>&1 || true
    fi
  done
}

slice_handoff_validate_file() {
  if [ -z "$slice_handoff_file" ]; then
    slice_handoff_fail "missing required --file" "use --file=<path> with a readable handoff file"
    return 1
  fi

  if [ ! -e "$slice_handoff_file" ]; then
    slice_handoff_fail "file does not exist: $slice_handoff_file" "provide an existing handoff file"
    return 1
  fi

  if [ -d "$slice_handoff_file" ]; then
    slice_handoff_fail "file is a directory: $slice_handoff_file" "provide a regular readable handoff file"
    return 1
  fi

  if [ ! -f "$slice_handoff_file" ]; then
    slice_handoff_fail "file is not a regular file: $slice_handoff_file" "provide a regular readable handoff file"
    return 1
  fi

  if [ ! -r "$slice_handoff_file" ]; then
    slice_handoff_fail "file is not readable: $slice_handoff_file" "fix file permissions or choose a readable handoff file"
    return 1
  fi

  return 0
}

slice_handoff_validate_handoff() {
  local validation_output=""

  validation_output="$(
    python3 - "$slice_handoff_file" "$slice_handoff_prompt_file" "$slice_handoff_pr_body_file" <<'PY'
from pathlib import Path
import re
import sys

def fail(reason: str, fix: str) -> None:
    print(f"fail: {reason}", file=sys.stderr)
    print(f"fix: {fix}", file=sys.stderr)
    raise SystemExit(1)

path = Path(sys.argv[1])
prompt_path = Path(sys.argv[2])
pr_body_path = Path(sys.argv[3])

try:
    text = path.read_text(encoding='utf-8')
except OSError as exc:
    fail(f"cannot read handoff file: {path}", f"fix file access and rerun slice-handoff ({exc})")

lines = text.splitlines()
try:
    slice_index = lines.index('# Slice Handoff')
except ValueError:
    fail('missing required heading: # Slice Handoff', 'add # Slice Handoff after the envelope')

try:
    prompt_index = lines.index('## Codex Prompt')
except ValueError:
    fail('missing required heading: ## Codex Prompt', 'add ## Codex Prompt under # Slice Handoff')

if prompt_index < slice_index:
    fail('invalid section order', 'place # Slice Handoff before ## Codex Prompt')

envelope = {}
for raw in lines[:slice_index]:
    line = raw.strip()
    if not line:
        continue
    if line.startswith('#'):
        fail('unexpected heading before # Slice Handoff', 'keep the envelope above # Slice Handoff and use key: value lines only')
    if ':' not in line:
        fail(f'invalid envelope line: {raw}', 'use key: value lines before # Slice Handoff')
    key, value = line.split(':', 1)
    key = key.strip()
    value = value.strip()
    if not key:
        fail('empty envelope key', 'use key: value lines before # Slice Handoff')
    envelope[key] = value

schema = envelope.get('schema', '')
if 'schema' not in envelope:
    fail('missing schema', 'set schema: repo-automation-slice-handoff/v1')
elif schema != 'repo-automation-slice-handoff/v1':
    fail('invalid schema', 'set schema: repo-automation-slice-handoff/v1')

branch = envelope.get('branch', '')
if not branch:
    fail('missing branch', 'set a non-empty branch in the envelope')
if branch == 'main' or branch.startswith('-') or '..' in branch or re.search(r'\s', branch) or not re.fullmatch(r'[A-Za-z0-9][A-Za-z0-9._/-]*', branch):
    fail(f'invalid branch: {branch}', 'use a conservative feature branch name without whitespace or shell metacharacters')

title = envelope.get('title', '')
if not title:
    fail('missing title', 'set a non-empty title in the envelope')

codex_profile = envelope.get('codex_profile', '')
if not codex_profile:
    fail('missing codex_profile', 'set codex_profile to default, lean, medium, high, repair, or review')
elif codex_profile not in {'default', 'lean', 'medium', 'high', 'repair', 'review'}:
    fail(f'invalid codex_profile: {codex_profile}', 'use one of default, lean, medium, high, repair, or review')

submit_mode = envelope.get('submit_mode', '')
if not submit_mode:
    fail('missing submit_mode', 'set submit_mode to none or repo-flow-submit-all')
elif submit_mode not in {'none', 'repo-flow-submit-all'}:
    fail(f'invalid submit_mode: {submit_mode}', 'use submit_mode: none or submit_mode: repo-flow-submit-all')

commit_message = envelope.get('commit_message', '')
if submit_mode == 'repo-flow-submit-all' and not commit_message:
    fail('missing commit_message', 'set commit_message when submit_mode is repo-flow-submit-all')

if '## PR Body' in lines[:prompt_index]:
    fail('invalid section order', 'place ## PR Body after ## Codex Prompt if submit_mode is repo-flow-submit-all')

body_index = None
for index in range(prompt_index + 1, len(lines)):
    if lines[index] == '## PR Body':
        body_index = index
        break

prompt_lines = lines[prompt_index + 1:body_index if body_index is not None else len(lines)]
prompt_text = '\n'.join(prompt_lines)
if not prompt_text.strip():
    fail('missing Codex Prompt payload', 'add prompt text under ## Codex Prompt')

blocked_phrases = [
    'use previous chat',
    'as discussed',
    'from above',
    'you know the context',
    'same as before',
    'approved in chat',
    'see attached',
    'use the uploaded file',
    'whatever chatgpt said',
    'choose the best architecture',
    'do the rest',
]
prompt_lower = prompt_text.lower()
for phrase in blocked_phrases:
    if phrase in prompt_lower:
        fail(f'unsafe placeholder text in Codex Prompt: {phrase}', 'replace the placeholder prompt with concrete slice instructions')

blocked_lifecycle = [
    'create a pr',
    'merge',
    'repo-flow submit',
    'branch:',
    'checkout',
]
for phrase in blocked_lifecycle:
    if phrase in prompt_lower:
        fail(f'Codex Prompt contains lifecycle instruction: {phrase}', 'remove execution and workflow instructions from the prompt')

if submit_mode == 'repo-flow-submit-all':
    if body_index is None:
        fail('missing ## PR Body', 'add ## PR Body when submit_mode is repo-flow-submit-all')
    pr_body_text = '\n'.join(lines[body_index + 1:])
    if not pr_body_text.strip():
        fail('missing PR body payload', 'add PR body text under ## PR Body')
    try:
        pr_body_path.write_text(pr_body_text + '\n', encoding='utf-8')
    except OSError as exc:
        fail('unable to write PR body temp file', f'fix TMPDIR access and rerun slice-handoff ({exc})')
else:
    pr_body_path.write_text('', encoding='utf-8')

try:
    prompt_path.write_text(prompt_text + '\n', encoding='utf-8')
except OSError as exc:
    fail('unable to write Codex prompt temp file', f'fix TMPDIR access and rerun slice-handoff ({exc})')

print(f'submit_mode={submit_mode}')
print(f'branch={branch}')
print(f'title={title}')
print(f'codex_profile={codex_profile}')
print(f'commit_message={commit_message}')
PY
  )" || return 1

  while IFS= read -r validation_line; do
    case "$validation_line" in
      submit_mode=*)
        slice_handoff_submit_mode="${validation_line#submit_mode=}"
        ;;
      branch=*)
        slice_handoff_branch="${validation_line#branch=}"
        ;;
      title=*)
        slice_handoff_title="${validation_line#title=}"
        ;;
      codex_profile=*)
        slice_handoff_codex_profile="${validation_line#codex_profile=}"
        ;;
      commit_message=*)
        slice_handoff_commit_message="${validation_line#commit_message=}"
        ;;
    esac
  done <<EOF
$validation_output
EOF

  if [ "$slice_handoff_submit_mode" = "repo-flow-submit-all" ]; then
    if ! "$script_dir/pr-body-check" --body-file="$slice_handoff_pr_body_file" >/dev/null; then
      return 1
    fi
  fi

  return 0
}

slice_handoff_main() {
  local arg=""

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --help)
        slice_handoff_usage
        return 0
        ;;
      --quiet)
        slice_handoff_quiet=1
        ;;
      --plan-only)
        slice_handoff_plan_only=1
        ;;
      --out-dir=*)
        slice_handoff_out_dir="${arg#--out-dir=}"
        if [ -z "$slice_handoff_out_dir" ]; then
          slice_handoff_fail "empty flag value: --out-dir" "use --out-dir=<path>"
          return 1
        fi
        ;;
      --out-dir)
        slice_handoff_fail "missing flag value: --out-dir" "use --out-dir=<path>"
        return 1
        ;;
      --file=*)
        slice_handoff_file="${arg#--file=}"
        if [ -z "$slice_handoff_file" ]; then
          slice_handoff_fail "empty flag value: --file" "use --file=<path>"
          return 1
        fi
        ;;
      --file)
        slice_handoff_fail "missing flag value: --file" "use --file=<path>"
        return 1
        ;;
      --execute)
        slice_handoff_fail "unsupported flag: --execute" "use --plan-only; execute mode is not implemented"
        return 1
        ;;
      --submit=*)
        slice_handoff_fail "unsupported flag: --submit" "slice-handoff only accepts --plan-only for now"
        return 1
        ;;
      --*)
        slice_handoff_fail "unknown flag: $arg" "run repo-automation/bin/slice-handoff --help"
        return 1
        ;;
      *)
        slice_handoff_fail "unknown argument: $arg" "run repo-automation/bin/slice-handoff --help"
        return 1
        ;;
    esac
    shift
  done

  if [ "$slice_handoff_plan_only" -ne 1 ]; then
    slice_handoff_fail "missing required --plan-only" "pass --plan-only to validate the handoff without executing it"
    return 1
  fi

  slice_handoff_validate_file || return 1

  mkdir -p "${TMPDIR:-$HOME/.cache}" || return 1
  slice_handoff_prompt_file="$(mktemp "${TMPDIR:-$HOME/.cache}/slice-handoff-codex-prompt.XXXXXX")" || return 1
  slice_handoff_pr_body_file="$(mktemp "${TMPDIR:-$HOME/.cache}/slice-handoff-pr-body.XXXXXX")" || return 1
  trap 'slice_handoff_cleanup_temp_files' EXIT INT TERM

  slice_handoff_validate_handoff || return 1

  if [ -n "$slice_handoff_out_dir" ]; then
    slice_handoff_out_dir_abs="$(
      python3 - "$slice_handoff_out_dir" "$slice_handoff_repo_root" <<'PY'
from pathlib import Path
import sys

out_dir = Path(sys.argv[1]).expanduser().resolve(strict=False)
repo_root = Path(sys.argv[2]).resolve(strict=True)

try:
    out_dir.relative_to(repo_root)
except ValueError:
    pass
else:
    print('fail: out-dir must be outside the repo root', file=sys.stderr)
    print('fix: choose a directory outside the current repo root', file=sys.stderr)
    raise SystemExit(1)

print(out_dir)
PY
    )" || return 1

    if ! mkdir -p "$slice_handoff_out_dir_abs"; then
      slice_handoff_fail "unable to create out-dir: $slice_handoff_out_dir_abs" "fix filesystem permissions or choose a writable directory outside the repo root"
      return 1
    fi

    slice_handoff_out_dir_prompt="$slice_handoff_out_dir_abs/codex-prompt.md"
    slice_handoff_out_dir_summary="$slice_handoff_out_dir_abs/slice-handoff-summary.txt"
    slice_handoff_out_dir_pr_body=""
    slice_handoff_out_dir_prompt_tmp=""
    slice_handoff_out_dir_summary_tmp=""
    slice_handoff_out_dir_pr_body_tmp=""

    if ! slice_handoff_out_dir_prompt_tmp="$(mktemp "$slice_handoff_out_dir_abs/.codex-prompt.XXXXXX")"; then
      slice_handoff_fail "unable to create codex prompt artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi
    if ! cp -- "$slice_handoff_prompt_file" "$slice_handoff_out_dir_prompt_tmp"; then
      slice_handoff_cleanup_out_dir_temp_files "$slice_handoff_out_dir_prompt_tmp"
      slice_handoff_fail "unable to write codex prompt artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi

    if [ "$slice_handoff_submit_mode" = "repo-flow-submit-all" ]; then
      slice_handoff_out_dir_pr_body="$slice_handoff_out_dir_abs/pr-body.md"
      if ! slice_handoff_out_dir_pr_body_tmp="$(mktemp "$slice_handoff_out_dir_abs/.pr-body.XXXXXX")"; then
        slice_handoff_cleanup_out_dir_temp_files "$slice_handoff_out_dir_prompt_tmp"
        slice_handoff_fail "unable to create PR body artifact" "fix filesystem permissions and rerun slice-handoff"
        return 1
      fi
      if ! cp -- "$slice_handoff_pr_body_file" "$slice_handoff_out_dir_pr_body_tmp"; then
        slice_handoff_cleanup_out_dir_temp_files "$slice_handoff_out_dir_prompt_tmp" "$slice_handoff_out_dir_pr_body_tmp"
        slice_handoff_fail "unable to write PR body artifact" "fix filesystem permissions and rerun slice-handoff"
        return 1
      fi
    fi

    if ! slice_handoff_out_dir_summary_tmp="$(mktemp "$slice_handoff_out_dir_abs/.slice-handoff-summary.XXXXXX")"; then
      slice_handoff_cleanup_out_dir_temp_files "$slice_handoff_out_dir_prompt_tmp" "$slice_handoff_out_dir_pr_body_tmp"
      slice_handoff_fail "unable to create summary artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi

    {
      printf 'schema=repo-automation-slice-handoff/v1\n'
      printf 'branch=%s\n' "$slice_handoff_branch"
      printf 'title=%s\n' "$slice_handoff_title"
      printf 'codex_profile=%s\n' "$slice_handoff_codex_profile"
      printf 'submit_mode=%s\n' "$slice_handoff_submit_mode"
      printf 'commit_message=%s\n' "$slice_handoff_commit_message"
      printf 'codex_prompt_path=%s\n' "$slice_handoff_out_dir_prompt"
      printf 'pr_body_path=%s\n' "$slice_handoff_out_dir_pr_body"
    } >"$slice_handoff_out_dir_summary_tmp" || {
      slice_handoff_cleanup_out_dir_temp_files "$slice_handoff_out_dir_prompt_tmp" "$slice_handoff_out_dir_pr_body_tmp" "$slice_handoff_out_dir_summary_tmp"
      slice_handoff_fail "unable to write summary artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    }

    if ! mv -f -- "$slice_handoff_out_dir_prompt_tmp" "$slice_handoff_out_dir_prompt"; then
      slice_handoff_cleanup_out_dir_temp_files "$slice_handoff_out_dir_prompt_tmp" "$slice_handoff_out_dir_pr_body_tmp" "$slice_handoff_out_dir_summary_tmp"
      slice_handoff_fail "unable to finalize codex prompt artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi

    if [ -n "$slice_handoff_out_dir_pr_body" ]; then
      if ! mv -f -- "$slice_handoff_out_dir_pr_body_tmp" "$slice_handoff_out_dir_pr_body"; then
        slice_handoff_cleanup_out_dir_temp_files "$slice_handoff_out_dir_pr_body_tmp" "$slice_handoff_out_dir_summary_tmp" "$slice_handoff_out_dir_prompt"
        slice_handoff_fail "unable to finalize PR body artifact" "fix filesystem permissions and rerun slice-handoff"
        return 1
      fi
    fi

    if ! mv -f -- "$slice_handoff_out_dir_summary_tmp" "$slice_handoff_out_dir_summary"; then
      slice_handoff_cleanup_out_dir_temp_files "$slice_handoff_out_dir_summary_tmp" "$slice_handoff_out_dir_prompt" "$slice_handoff_out_dir_pr_body"
      slice_handoff_fail "unable to finalize summary artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi
  fi

  if [ "$slice_handoff_quiet" -eq 0 ]; then
    printf 'pass\n'
    if [ -n "$slice_handoff_out_dir_abs" ]; then
      printf 'out_dir=%s\n' "$slice_handoff_out_dir_abs"
      printf 'codex_prompt_path=%s\n' "$slice_handoff_out_dir_prompt"
      if [ -n "$slice_handoff_out_dir_pr_body" ]; then
        printf 'pr_body_path=%s\n' "$slice_handoff_out_dir_pr_body"
      fi
      printf 'summary_path=%s\n' "$slice_handoff_out_dir_summary"
    fi
  fi
  return 0
}

slice_handoff_main "$@"
# repo-automation/bin/slice-handoff EOF
