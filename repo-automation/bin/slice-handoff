#!/usr/bin/env bash
# repo-automation/bin/slice-handoff

set -u
set -o pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
. "$script_dir/../lib/common.sh" || {
  printf 'STOP: failed to source shared library\n' >&2
  return 2 2>/dev/null || exit 2
}

slice_handoff_quiet=0
slice_handoff_file=""
slice_handoff_dry_run=0
slice_handoff_submit_requested=0
slice_handoff_out_dir=""
slice_handoff_out_dir_abs=""
slice_handoff_out_dir_prompt=""
slice_handoff_out_dir_summary=""
slice_handoff_out_dir_preview=""
slice_handoff_out_dir_pr_body=""
slice_handoff_out_dir_review_request=""
slice_handoff_branch=""
slice_handoff_title=""
slice_handoff_codex_profile=""
slice_handoff_commit_message=""
slice_handoff_submit_mode=""
slice_handoff_prompt_file=""
slice_handoff_pr_body_file=""
slice_handoff_review_request_file=""
slice_handoff_repo_root="$(cd "$script_dir/../.." && pwd -P)"

slice_handoff_usage() {
  printf 'Usage: repo-automation/bin/slice-handoff --file=<path> [--dry-run] [--submit] [--out-dir=<path>] [--quiet] [--help]\n'
}

slice_handoff_fail() {
  printf 'fail: %s\n' "$1" >&2
  printf 'fix: %s\n' "$2" >&2
}

slice_handoff_cleanup_temp_files() {
  if [ -n "$slice_handoff_prompt_file" ]; then
    rm -f -- "$slice_handoff_prompt_file" >/dev/null 2>&1 || true
  fi
  if [ -n "$slice_handoff_pr_body_file" ]; then
    rm -f -- "$slice_handoff_pr_body_file" >/dev/null 2>&1 || true
  fi
  if [ -n "$slice_handoff_review_request_file" ]; then
    rm -f -- "$slice_handoff_review_request_file" >/dev/null 2>&1 || true
  fi
}

slice_handoff_command_summary() {
  local arg=""
  local summary=""

  for arg in "$@"; do
    summary+="$(printf '%q ' "$arg")"
  done

  printf '%s' "${summary% }"
}

slice_handoff_write_atomic_text_file() {
  local path="$1"
  local tmp_dir=""
  local tmp_file=""

  tmp_dir="$(dirname "$path")"
  tmp_file="$(mktemp "$tmp_dir/.${path##*/}.XXXXXX")" || return 1
  if cat >"$tmp_file" && mv -f -- "$tmp_file" "$path"; then
    return 0
  fi
  rm -f -- "$tmp_file" >/dev/null 2>&1 || true
  return 1
}

slice_handoff_copy_atomic_file() {
  local source_path="$1"
  local target_path="$2"
  local tmp_dir=""
  local tmp_file=""

  tmp_dir="$(dirname "$target_path")"
  tmp_file="$(mktemp "$tmp_dir/.${target_path##*/}.XXXXXX")" || return 1
  if cp -- "$source_path" "$tmp_file" && mv -f -- "$tmp_file" "$target_path"; then
    return 0
  fi
  rm -f -- "$tmp_file" >/dev/null 2>&1 || true
  return 1
}

slice_handoff_json_value() {
  local file="$1"
  local key="$2"

  python3 - "$file" "$key" <<'PY'
from pathlib import Path
import json
import sys

path = Path(sys.argv[1])
key = sys.argv[2]
data = json.loads(path.read_text(encoding='utf-8'))
value = data.get(key)
if value is None:
    raise SystemExit(1)
if isinstance(value, bool):
    print('true' if value else 'false')
elif isinstance(value, (dict, list)):
    print(json.dumps(value, separators=(',', ':')))
else:
    print(value)
PY
}

slice_handoff_json_excerpt() {
  local file="$1"

  python3 - "$file" <<'PY'
from pathlib import Path
import json
import sys

path = Path(sys.argv[1])
data = json.loads(path.read_text(encoding='utf-8'))
parts = []
for key in ('stop_reason', 'reason', 'message'):
    value = data.get(key)
    if isinstance(value, str) and value.strip():
        parts.append(f'{key}={value.strip()}')
        break
cleanup = data.get('branch_cleanup_status')
if isinstance(cleanup, dict):
    for key in ('stop_reason', 'reason', 'message'):
        value = cleanup.get(key)
        if isinstance(value, str) and value.strip():
            parts.append(f'branch_cleanup_{key}={value.strip()}')
            break
if not parts:
    parts.append('stdout JSON did not include a stop_reason')
print(' | '.join(parts))
PY
}

slice_handoff_extract_final_summary_field() {
  local file="$1"
  local field="$2"

  python3 - "$file" "$field" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
field = sys.argv[2]
in_summary = False

try:
    lines = path.read_text(encoding='utf-8').splitlines()
except OSError:
    raise SystemExit(1)

for line in lines:
    if line == '===== FINAL SUMMARY =====':
        in_summary = True
        continue
    if in_summary and line == '===== END =====':
        break
    if in_summary and line.startswith(f'{field}='):
        print(line.split('=', 1)[1])
        raise SystemExit(0)

raise SystemExit(1)
PY
}

slice_handoff_extract_repo_flow_summary_value() {
  local field="$1"
  local path=""

  shift
  for path in "$@"; do
    [ -n "$path" ] || continue
    if value="$(slice_handoff_extract_final_summary_field "$path" "$field" 2>/dev/null)"; then
      printf '%s' "$value"
      return 0
    fi
  done

  return 1
}

slice_handoff_field_value() {
  local file="$1"
  local key="$2"

  awk -F= -v key="$key" '$1 == key { sub("^[^=]*=", "", $0); print $0; exit }' "$file"
}

slice_handoff_print_execution_blocker() {
  local step="$1"
  local command_summary="$2"
  local exit_code="$3"
  local stdout_path="$4"
  local stderr_path="$5"
  local excerpt="$6"

  printf 'fail: slice-handoff execution failed\n' >&2
  printf 'step=%s\n' "$step" >&2
  printf 'command=%s\n' "$command_summary" >&2
  printf 'exit_code=%s\n' "$exit_code" >&2
  printf 'stdout_path=%s\n' "$stdout_path" >&2
  printf 'stderr_path=%s\n' "$stderr_path" >&2
  printf 'excerpt=%s\n' "$excerpt" >&2
  printf 'fix=paste this blocker into ChatGPT\n' >&2
}

slice_handoff_write_execution_summary() {
  local run_dir="$1"
  local result="$2"
  local cleanup_json_path="$3"
  local cleanup_stdout_path="$4"
  local cleanup_stderr_path="$5"
  local preflight_json_path="$6"
  local preflight_stdout_path="$7"
  local preflight_stderr_path="$8"
  local codex_run_stdout_path="$9"
  local codex_run_stderr_path="${10}"
  local codex_run_summary_path="${11}"
  local codex_final_output_path="${12}"
  local mode="${13:-execution-preflight}"
  local next="${14:-codex-run not implemented in this slice}"
  local pr_body_check_stdout_path="${15:-}"
  local pr_body_check_stderr_path="${16:-}"
  local repo_flow_submit_stdout_path="${17:-}"
  local repo_flow_submit_stderr_path="${18:-}"

  {
    printf 'schema=repo-automation-slice-handoff-execution/v1\n'
    printf 'mode=%s\n' "$mode"
    printf 'branch=%s\n' "$slice_handoff_branch"
    printf 'title=%s\n' "$slice_handoff_title"
    printf 'codex_profile=%s\n' "$slice_handoff_codex_profile"
    printf 'submit_mode=%s\n' "$slice_handoff_submit_mode"
    printf 'preflight_repo_root=%s\n' "$slice_handoff_repo_root"
    printf 'run_dir=%s\n' "$run_dir"
    printf 'cleanup_json_path=%s\n' "$cleanup_json_path"
    printf 'cleanup_stdout_path=%s\n' "$cleanup_stdout_path"
    printf 'cleanup_stderr_path=%s\n' "$cleanup_stderr_path"
    printf 'preflight_json_path=%s\n' "$preflight_json_path"
    printf 'preflight_stdout_path=%s\n' "$preflight_stdout_path"
    printf 'preflight_stderr_path=%s\n' "$preflight_stderr_path"
    printf 'codex_run_stdout_path=%s\n' "$codex_run_stdout_path"
    printf 'codex_run_stderr_path=%s\n' "$codex_run_stderr_path"
    printf 'codex_run_summary_path=%s\n' "$codex_run_summary_path"
    printf 'codex_final_output_path=%s\n' "$codex_final_output_path"
    if [ -n "$pr_body_check_stdout_path$pr_body_check_stderr_path$repo_flow_submit_stdout_path$repo_flow_submit_stderr_path" ] || [ "$mode" = "execution-submit" ]; then
      printf 'pr_body_check_stdout_path=%s\n' "$pr_body_check_stdout_path"
      printf 'pr_body_check_stderr_path=%s\n' "$pr_body_check_stderr_path"
      printf 'repo_flow_submit_stdout_path=%s\n' "$repo_flow_submit_stdout_path"
      printf 'repo_flow_submit_stderr_path=%s\n' "$repo_flow_submit_stderr_path"
    fi
    printf 'result=%s\n' "$result"
    printf 'next=%s\n' "$next"
  } | slice_handoff_write_atomic_text_file "$run_dir/slice-handoff-execution-summary.txt"
}

slice_handoff_write_dry_run_preview() {
  local preview_tmp="$1"
  local preview_path="$2"
  local pr_body_path="$3"
  local submit_mode="$4"
  local planned_run_dir_root="${TMPDIR:-$HOME/.cache}/repo-automation/slice-handoff-runs"

  slice_handoff_write_argv_block() {
    local label="$1"
    shift
    printf '%s:\n' "$label"
    while [ "$#" -gt 0 ]; do
      printf '%s\n' "- $1"
      shift
    done
  }

  {
    printf 'dry_run_mode=enabled\n'
    printf 'branch=%s\n' "$slice_handoff_branch"
    printf 'title=%s\n' "$slice_handoff_title"
    printf 'codex_profile=%s\n' "$slice_handoff_codex_profile"
    printf 'submit_mode=%s\n' "$slice_handoff_submit_mode"
    printf 'commit_message=%s\n' "$slice_handoff_commit_message"
    printf 'codex_prompt_path=%s\n' "$slice_handoff_out_dir_prompt"
    if [ "$submit_mode" = "repo-flow-submit-all" ]; then
      printf 'pr_body_path=%s\n' "$pr_body_path"
    else
      printf 'pr_body_path=not_applicable\n'
    fi
    printf 'review_request_path=%s\n' "$slice_handoff_out_dir_review_request"
    printf 'summary_path=%s\n' "$slice_handoff_out_dir_summary"
    printf 'preview_path=%s\n' "$preview_path"
    printf 'planned_run_dir_root=%s\n' "$planned_run_dir_root"
    printf 'planned_active_run_dir=<active-run-dir>\n'
    printf 'planned_marker_file_name=.repo-automation-slice-run\n'
    printf '\nPlanned execution shapes\n'
    slice_handoff_write_argv_block \
      planned_run_dir_cleanup_argv \
      repo-automation/bin/slice-run-dir \
      --cleanup-stale \
      "--root=$planned_run_dir_root" \
      --max-age-days=7 \
      --keep=10 \
      "--preserve-path=<active-run-dir>" \
      --json
    slice_handoff_write_argv_block \
      planned_preflight_argv \
      repo-automation/bin/codex-slice-preflight \
      "--branch=$slice_handoff_branch" \
      --clean-test-cache \
      "--preserve-path=<active-run-dir>" \
      --json
    slice_handoff_write_argv_block \
      planned_codex_run_argv \
      repo-automation/bin/codex-run \
      "--prompt-file=<active-run-dir>/codex-prompt.md" \
      "--out-dir=<active-run-dir>/codex-run" \
      "--profile=$slice_handoff_codex_profile" \
      "--cd=$slice_handoff_repo_root"
    if [ "$submit_mode" = "repo-flow-submit-all" ]; then
      slice_handoff_write_argv_block \
        planned_pr_body_validation_argv \
        repo-automation/bin/pr-body-check \
        "--body-file=$pr_body_path"
      slice_handoff_write_argv_block \
        planned_repo_flow_submit_argv \
        repo-automation/bin/repo-flow \
        submit \
        --all \
        "--message=$slice_handoff_commit_message" \
        "--body-file=$pr_body_path" \
        --watch \
        --timeout=900 \
        --diagnose-on-fail \
        --explain
    else
    printf 'planned_pr_body_validation_argv=not_applicable\n'
    printf 'planned_repo_flow_submit_argv=not_applicable\n'
    fi
    printf '\nPlanned artifact/log/metadata paths\n'
    printf 'preflight_log_path=not_created_by_dry_run\n'
    printf 'codex_run_stdout_path=not_created_by_dry_run\n'
    printf 'codex_run_stderr_path=not_created_by_dry_run\n'
    printf 'codex_run_summary_path=not_created_by_dry_run\n'
    printf 'codex_final_output_path=not_written_by_dry_run\n'
    printf 'submit_log_path=not_created_by_dry_run\n'
    printf '\nExpected future final outcomes\n'
    if [ "$submit_mode" = "repo-flow-submit-all" ]; then
      printf 'expected_future_final_outcomes=blocker or PR URL / FINAL SUMMARY / review request\n'
    else
      printf 'expected_future_final_outcomes=blocker or review request\n'
    fi
  } >"$preview_tmp"
}

slice_handoff_cleanup_out_dir_temp_files() {
  local path=""

  for path in "$@"; do
    if [ -n "$path" ]; then
      rm -f -- "$path" >/dev/null 2>&1 || true
    fi
  done
}

slice_handoff_validate_file() {
  if [ -z "$slice_handoff_file" ]; then
    slice_handoff_fail "missing required --file" "use --file=<path> with a readable handoff file"
    return 1
  fi

  if [ ! -e "$slice_handoff_file" ]; then
    slice_handoff_fail "file does not exist: $slice_handoff_file" "provide an existing handoff file"
    return 1
  fi

  if [ -d "$slice_handoff_file" ]; then
    slice_handoff_fail "file is a directory: $slice_handoff_file" "provide a regular readable handoff file"
    return 1
  fi

  if [ ! -f "$slice_handoff_file" ]; then
    slice_handoff_fail "file is not a regular file: $slice_handoff_file" "provide a regular readable handoff file"
    return 1
  fi

  if [ ! -r "$slice_handoff_file" ]; then
    slice_handoff_fail "file is not readable: $slice_handoff_file" "fix file permissions or choose a readable handoff file"
    return 1
  fi

  return 0
}

slice_handoff_validate_handoff() {
  local validation_output=""

  validation_output="$(
    python3 - "$slice_handoff_file" "$slice_handoff_prompt_file" "$slice_handoff_pr_body_file" "$slice_handoff_review_request_file" <<'PY'
from pathlib import Path
import re
import sys

def fail(reason: str, fix: str) -> None:
    print(f"fail: {reason}", file=sys.stderr)
    print(f"fix: {fix}", file=sys.stderr)
    raise SystemExit(1)

def strip_list_marker(line: str) -> str:
    candidate = line.lstrip()
    if candidate.startswith(('- ', '* ', '+ ')):
        return candidate[2:]
    match = re.match(r'^\d+[.)]\s+(.*)$', candidate)
    if match:
        return match.group(1)
    return candidate

def find_section(lines, heading):
    try:
        return lines.index(heading)
    except ValueError:
        return None

def reject_lifecycle_instruction(line: str) -> None:
    normalized = strip_list_marker(line).strip().lower()
    if not normalized:
        return

    if normalized.startswith('out of scope:'):
        normalized = normalized[len('out of scope:'):].strip()
        if not normalized:
            return

    if normalized.startswith(('do not ', "don't ")):
        return

    checks = [
        (r'^(?:please\s+)?create a pr\b', 'create a pr'),
        (r'^(?:please\s+)?merge\b', 'merge'),
        (r'^(?:please\s+)?(?:(?:run|git)\s+)?(?:repo-automation/bin/)?repo-flow submit\b', 'repo-flow submit'),
        (r'^(?:please\s+)?(?:(?:git\s+)?checkout)\b', 'checkout'),
    ]
    for pattern, phrase in checks:
        if re.match(pattern, normalized):
            fail(f'Codex Prompt contains lifecycle instruction: {phrase}', 'remove execution and workflow instructions from the prompt')

    if re.match(r'^branch:\s+\S', normalized):
        fail('Codex Prompt contains lifecycle instruction: branch:', 'remove execution and workflow instructions from the prompt')

path = Path(sys.argv[1])
prompt_path = Path(sys.argv[2])
pr_body_path = Path(sys.argv[3])
review_request_path = Path(sys.argv[4])

try:
    text = path.read_text(encoding='utf-8')
except OSError as exc:
    fail(f"cannot read handoff file: {path}", f"fix file access and rerun slice-handoff ({exc})")

lines = text.splitlines()
try:
    slice_index = lines.index('# Slice Handoff')
except ValueError:
    fail('missing required heading: # Slice Handoff', 'add # Slice Handoff after the envelope')

try:
    prompt_index = lines.index('## Codex Prompt')
except ValueError:
    fail('missing required heading: ## Codex Prompt', 'add ## Codex Prompt under # Slice Handoff')

if prompt_index < slice_index:
    fail('invalid section order', 'place # Slice Handoff before ## Codex Prompt')

review_index = find_section(lines, '## PR Review Request')
body_index = find_section(lines, '## PR Body')
if review_index is not None and review_index < prompt_index:
    fail('invalid section order', 'place ## PR Review Request after ## Codex Prompt')
if body_index is not None and review_index is not None and review_index < body_index:
    fail('invalid section order', 'place ## PR Review Request after ## PR Body when submit_mode is repo-flow-submit-all')

envelope = {}
for raw in lines[:slice_index]:
    line = raw.strip()
    if not line:
        continue
    if line.startswith('#'):
        fail('unexpected heading before # Slice Handoff', 'keep the envelope above # Slice Handoff and use key: value lines only')
    if ':' not in line:
        fail(f'invalid envelope line: {raw}', 'use key: value lines before # Slice Handoff')
    key, value = line.split(':', 1)
    key = key.strip()
    value = value.strip()
    if not key:
        fail('empty envelope key', 'use key: value lines before # Slice Handoff')
    envelope[key] = value

schema = envelope.get('schema', '')
if 'schema' not in envelope:
    fail('missing schema', 'set schema: repo-automation-slice-handoff/v1')
elif schema != 'repo-automation-slice-handoff/v1':
    fail('invalid schema', 'set schema: repo-automation-slice-handoff/v1')

branch = envelope.get('branch', '')
if not branch:
    fail('missing branch', 'set a non-empty branch in the envelope')
if branch == 'main' or branch.startswith('-') or '..' in branch or re.search(r'\s', branch) or not re.fullmatch(r'[A-Za-z0-9][A-Za-z0-9._/-]*', branch):
    fail(f'invalid branch: {branch}', 'use a conservative feature branch name without whitespace or shell metacharacters')

title = envelope.get('title', '')
if not title:
    fail('missing title', 'set a non-empty title in the envelope')

codex_profile = envelope.get('codex_profile', '')
if not codex_profile:
    fail('missing codex_profile', 'set codex_profile to default, lean, medium, high, repair, or review')
elif codex_profile not in {'default', 'lean', 'medium', 'high', 'repair', 'review'}:
    fail(f'invalid codex_profile: {codex_profile}', 'use one of default, lean, medium, high, repair, or review')

submit_mode = envelope.get('submit_mode', '')
if not submit_mode:
    fail('missing submit_mode', 'set submit_mode to none or repo-flow-submit-all')
elif submit_mode not in {'none', 'repo-flow-submit-all'}:
    fail(f'invalid submit_mode: {submit_mode}', 'use submit_mode: none or submit_mode: repo-flow-submit-all')

commit_message = envelope.get('commit_message', '')
if submit_mode == 'repo-flow-submit-all' and not commit_message:
    fail('missing commit_message', 'set commit_message when submit_mode is repo-flow-submit-all')

if '## PR Body' in lines[:prompt_index]:
    fail('invalid section order', 'place ## PR Body after ## Codex Prompt if submit_mode is repo-flow-submit-all')

prompt_end = len(lines)
if body_index is not None:
    prompt_end = body_index
elif review_index is not None:
    prompt_end = review_index

prompt_lines = lines[prompt_index + 1:prompt_end]
prompt_text = '\n'.join(prompt_lines)
if not prompt_text.strip():
    fail('missing Codex Prompt payload', 'add prompt text under ## Codex Prompt')

blocked_phrases = [
    'use previous chat',
    'as discussed',
    'from above',
    'you know the context',
    'same as before',
    'approved in chat',
    'see attached',
    'use the uploaded file',
    'whatever chatgpt said',
    'choose the best architecture',
    'do the rest',
]
prompt_lower = prompt_text.lower()
for phrase in blocked_phrases:
    if phrase in prompt_lower:
        fail(f'unsafe placeholder text in Codex Prompt: {phrase}', 'replace the placeholder prompt with concrete slice instructions')

for raw_line in prompt_lines:
    reject_lifecycle_instruction(raw_line)

default_review_request = (
    'Please review this PR before merge:\n'
    '\n'
    '<PR_URL>\n'
    '\n'
    f'Slice: {title}\n'
    f'Branch: {branch}\n'
    '\n'
    'Review the changed files and any related docs, tests, metadata, command contracts, output contracts, and examples for drift.\n'
    '\n'
    'Return CLEAN, NEEDS REPAIR, BLOCKING, or UNCERTAIN. If repair is needed, describe one same-branch repair direction.'
)

if submit_mode == 'repo-flow-submit-all':
    if body_index is None:
      fail('missing ## PR Body', 'add ## PR Body when submit_mode is repo-flow-submit-all')
    pr_body_end = review_index if review_index is not None else len(lines)
    pr_body_text = '\n'.join(lines[body_index + 1:pr_body_end])
    if not pr_body_text.strip():
        fail('missing PR body payload', 'add PR body text under ## PR Body')
    try:
        pr_body_path.write_text(pr_body_text + '\n', encoding='utf-8')
    except OSError as exc:
        fail('unable to write PR body temp file', f'fix TMPDIR access and rerun slice-handoff ({exc})')
else:
  pr_body_path.write_text('', encoding='utf-8')

if review_index is not None:
    review_request_text = '\n'.join(lines[review_index + 1:])
    if not review_request_text.strip():
        fail('missing PR Review Request payload', 'add text under ## PR Review Request')
else:
    review_request_text = default_review_request

try:
    review_request_path.write_text(review_request_text + '\n', encoding='utf-8')
except OSError as exc:
  fail('unable to write PR review request temp file', f'fix TMPDIR access and rerun slice-handoff ({exc})')

try:
    prompt_path.write_text(prompt_text + '\n', encoding='utf-8')
except OSError as exc:
    fail('unable to write Codex prompt temp file', f'fix TMPDIR access and rerun slice-handoff ({exc})')

print(f'submit_mode={submit_mode}')
print(f'branch={branch}')
print(f'title={title}')
print(f'codex_profile={codex_profile}')
print(f'commit_message={commit_message}')
PY
  )" || return 1

  while IFS= read -r validation_line; do
    case "$validation_line" in
      submit_mode=*)
        slice_handoff_submit_mode="${validation_line#submit_mode=}"
        ;;
      branch=*)
        slice_handoff_branch="${validation_line#branch=}"
        ;;
      title=*)
        slice_handoff_title="${validation_line#title=}"
        ;;
      codex_profile=*)
        slice_handoff_codex_profile="${validation_line#codex_profile=}"
        ;;
      commit_message=*)
        slice_handoff_commit_message="${validation_line#commit_message=}"
        ;;
    esac
  done <<EOF
$validation_output
EOF

  return 0
}

slice_handoff_output_contract_blocker() {
  local step="$1"
  local command_summary="$2"
  local exit_code="$3"
  local stdout_path="$4"
  local stderr_path="$5"
  local excerpt="$6"

  slice_handoff_print_execution_blocker "$step" "$command_summary" "$exit_code" "$stdout_path" "$stderr_path" "$excerpt"
}

slice_handoff_validate_codex_run_output() {
  local command_summary="$1"
  local exit_code="$2"
  local stdout_path="$3"
  local stderr_path="$4"
  local codex_run_stdout_path="$5"
  local codex_run_stderr_path="$6"
  local codex_run_summary_path="$7"
  local codex_final_output_path="$8"

  if [ "$exit_code" -ne 0 ]; then
    local excerpt=""
    if [ -s "$stdout_path" ]; then
      excerpt="$(awk 'NF { print; count++; if (count == 4) exit }' "$stdout_path")"
    fi
    if [ -z "$excerpt" ] && [ -s "$stderr_path" ]; then
      excerpt="$(grep -E '^(fail:|warn:|STOP:|WARN:|ERROR:)' "$stderr_path" | head -n 4 | awk 'BEGIN{sep=""} {printf "%s%s", sep, $0; sep=" | "} END{print ""}')"
    fi
    if [ -z "$excerpt" ]; then
      excerpt="codex-run exited nonzero"
    fi
    slice_handoff_print_execution_blocker "codex-run" "$command_summary" "$exit_code" "$stdout_path" "$stderr_path" "$excerpt"
    return 1
  fi

  if ! grep -Fxq 'pass' "$stdout_path"; then
    slice_handoff_print_execution_blocker "codex-run-output-contract" "$command_summary" 0 "$stdout_path" "$stderr_path" "wrapper stdout missing pass"
    return 1
  fi
  if ! grep -Eq '^final_output_path=.+' "$stdout_path"; then
    slice_handoff_print_execution_blocker "codex-run-output-contract" "$command_summary" 0 "$stdout_path" "$stderr_path" "wrapper stdout missing final_output_path"
    return 1
  fi
  if ! grep -Eq '^summary_path=.+' "$stdout_path"; then
    slice_handoff_print_execution_blocker "codex-run-output-contract" "$command_summary" 0 "$stdout_path" "$stderr_path" "wrapper stdout missing summary_path"
    return 1
  fi

  if [ ! -s "$codex_final_output_path" ]; then
    slice_handoff_print_execution_blocker "codex-run-output-contract" "$command_summary" 0 "$stdout_path" "$stderr_path" "final output file is missing or empty"
    return 1
  fi

  if [ ! -s "$codex_run_summary_path" ]; then
    slice_handoff_print_execution_blocker "codex-run-output-contract" "$command_summary" 0 "$stdout_path" "$stderr_path" "summary file is missing or empty"
    return 1
  fi

  grep -Fxq 'script=codex-run' "$codex_run_summary_path" || {
    slice_handoff_print_execution_blocker "codex-run-output-contract" "$command_summary" 0 "$stdout_path" "$stderr_path" "summary missing script=codex-run"
    return 1
  }
  grep -Fxq 'result=pass' "$codex_run_summary_path" || {
    slice_handoff_print_execution_blocker "codex-run-output-contract" "$command_summary" 0 "$stdout_path" "$stderr_path" "summary missing result=pass"
    return 1
  }
  grep -Fxq 'exit_code=0' "$codex_run_summary_path" || {
    slice_handoff_print_execution_blocker "codex-run-output-contract" "$command_summary" 0 "$stdout_path" "$stderr_path" "summary missing exit_code=0"
    return 1
  }
  grep -Fxq 'final_output_status=present' "$codex_run_summary_path" || {
    slice_handoff_print_execution_blocker "codex-run-output-contract" "$command_summary" 0 "$stdout_path" "$stderr_path" "summary missing final_output_status=present"
    return 1
  }

  if [ "$(slice_handoff_field_value "$stdout_path" final_output_path)" != "$codex_final_output_path" ]; then
    slice_handoff_print_execution_blocker "codex-run-output-contract" "$command_summary" 0 "$stdout_path" "$stderr_path" "wrapper final_output_path did not match generated artifact"
    return 1
  fi
  if [ "$(slice_handoff_field_value "$stdout_path" summary_path)" != "$codex_run_summary_path" ]; then
    slice_handoff_print_execution_blocker "codex-run-output-contract" "$command_summary" 0 "$stdout_path" "$stderr_path" "wrapper summary_path did not match generated artifact"
    return 1
  fi

  return 0
}

slice_handoff_run_json_child() {
  local step="$1"
  local command_summary="$2"
  local expected_key="$3"
  local expected_value="${4:-}"
  local stdout_path="$5"
  local stderr_path="$6"
  shift 6

  local child_status=0
  if "$@" >"$stdout_path" 2>"$stderr_path"; then
    child_status=0
  else
    child_status=$?
  fi

  if ! python3 -m json.tool "$stdout_path" >/dev/null 2>&1; then
    slice_handoff_output_contract_blocker "$step" "$command_summary" "$child_status" "$stdout_path" "$stderr_path" "stdout was not valid JSON"
    return 1
  fi

  if [ "$child_status" -ne 0 ]; then
    local excerpt=""
    excerpt="$(slice_handoff_json_excerpt "$stdout_path" 2>/dev/null || true)"
    if [ -z "$excerpt" ] && [ -s "$stderr_path" ]; then
      excerpt="$(grep -E '^(fail:|warn:|STOP:|WARN:|ERROR:)' "$stderr_path" | head -n 4 | awk 'BEGIN{sep=""} {printf "%s%s", sep, $0; sep=" | "} END{print ""}')"
    fi
    if [ -z "$excerpt" ]; then
      excerpt="child exited nonzero"
    fi
    slice_handoff_output_contract_blocker "$step" "$command_summary" "$child_status" "$stdout_path" "$stderr_path" "$excerpt"
    return 1
  fi

  if [ -n "$expected_key" ]; then
    local observed_value=""
    if ! observed_value="$(slice_handoff_json_value "$stdout_path" "$expected_key")"; then
      slice_handoff_output_contract_blocker "$step" "$command_summary" "$child_status" "$stdout_path" "$stderr_path" "stdout JSON was missing required field: $expected_key"
      return 1
    fi
    if [ -n "$expected_value" ] && [ "$observed_value" != "$expected_value" ]; then
      slice_handoff_output_contract_blocker "$step" "$command_summary" "$child_status" "$stdout_path" "$stderr_path" "stdout JSON field $expected_key was $observed_value not $expected_value"
      return 1
    fi
  fi

  return 0
}

slice_handoff_prepare_public_artifacts() {
  local target_dir="$1"
  local include_preview="${2:-1}"
  local prompt_target="$target_dir/codex-prompt.md"
  local review_request_target="$target_dir/review-request.txt"
  local summary_target="$target_dir/slice-handoff-summary.txt"
  local preview_target="$target_dir/dry-run-preview.txt"
  local pr_body_target=""

  if ! slice_handoff_copy_atomic_file "$slice_handoff_prompt_file" "$prompt_target"; then
    slice_handoff_fail "unable to write codex prompt artifact" "fix filesystem permissions and rerun slice-handoff"
    return 1
  fi

  if [ "$slice_handoff_submit_mode" = "repo-flow-submit-all" ]; then
    pr_body_target="$target_dir/pr-body.md"
    if ! slice_handoff_copy_atomic_file "$slice_handoff_pr_body_file" "$pr_body_target"; then
      slice_handoff_fail "unable to write PR body artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi
  fi

  if ! slice_handoff_copy_atomic_file "$slice_handoff_review_request_file" "$review_request_target"; then
    slice_handoff_fail "unable to write review request artifact" "fix filesystem permissions and rerun slice-handoff"
    return 1
  fi

  if ! slice_handoff_write_atomic_text_file "$summary_target" <<EOF
schema=repo-automation-slice-handoff/v1
branch=$slice_handoff_branch
title=$slice_handoff_title
codex_profile=$slice_handoff_codex_profile
submit_mode=$slice_handoff_submit_mode
commit_message=$slice_handoff_commit_message
codex_prompt_path=$prompt_target
pr_body_path=$pr_body_target
review_request_path=$review_request_target
EOF
  then
    slice_handoff_fail "unable to write summary artifact" "fix filesystem permissions and rerun slice-handoff"
    return 1
  fi

  if [ "$include_preview" -eq 1 ]; then
    local preview_tmp=""
    preview_tmp="$(mktemp "$target_dir/.dry-run-preview.XXXXXX")" || return 1
    if ! slice_handoff_write_dry_run_preview "$preview_tmp" "$preview_target" "$pr_body_target" "$slice_handoff_submit_mode"; then
      rm -f -- "$preview_tmp" >/dev/null 2>&1 || true
      slice_handoff_fail "unable to write dry-run preview artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi
    if ! mv -f -- "$preview_tmp" "$preview_target"; then
      rm -f -- "$preview_tmp" >/dev/null 2>&1 || true
      slice_handoff_fail "unable to finalize dry-run preview artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi
  fi

  return 0
}

slice_handoff_run_execution_phase() {
  local create_stdout_tmp=""
  local create_stderr_tmp=""
  local cleanup_stdout_tmp=""
  local cleanup_stderr_tmp=""
  local create_stdout_path=""
  local create_stderr_path=""
  local cleanup_stdout_path=""
  local cleanup_stderr_path=""
  local preflight_stdout_path=""
  local preflight_stderr_path=""
  local codex_run_stdout_path=""
  local codex_run_stderr_path=""
  local codex_run_stdout_tmp=""
  local codex_run_stderr_tmp=""
  local cleanup_json_path=""
  local preflight_json_path=""
  local codex_run_summary_path=""
  local codex_run_out_dir=""
  local codex_final_output_path=""
  local active_run_dir=""
  local run_root=""
  local cleanup_command_summary=""
  local preflight_command_summary=""
  local create_command_summary=""
  local codex_run_command_summary=""
  local cleanup_phase_failed=0
  local preflight_phase_failed=0
  local codex_run_phase_failed=0
  local pr_body_check_stdout_tmp=""
  local pr_body_check_stderr_tmp=""
  local pr_body_check_stdout_path=""
  local pr_body_check_stderr_path=""
  local pr_body_check_command_summary=""
  local pr_body_check_phase_failed=0
  local repo_flow_submit_stdout_tmp=""
  local repo_flow_submit_stderr_tmp=""
  local repo_flow_submit_stdout_path=""
  local repo_flow_submit_stderr_path=""
  local repo_flow_submit_command_summary=""
  local repo_flow_submit_phase_failed=0
  local repo_flow_submit_url_or_stop=""

  cd "$slice_handoff_repo_root" || return 1

  create_stdout_tmp="$(mktemp "${TMPDIR:-$HOME/.cache}/slice-handoff-create.XXXXXX.stdout")" || return 1
  create_stderr_tmp="$(mktemp "${TMPDIR:-$HOME/.cache}/slice-handoff-create.XXXXXX.stderr")" || {
    rm -f -- "$create_stdout_tmp" >/dev/null 2>&1 || true
    return 1
  }

  create_stdout_path="$create_stdout_tmp"
  create_stderr_path="$create_stderr_tmp"
  create_command_summary="$(slice_handoff_command_summary repo-automation/bin/slice-run-dir --create "--branch=$slice_handoff_branch" --json)"

  if ! slice_handoff_run_json_child "run-dir-create" "$create_command_summary" run_dir "" "$create_stdout_path" "$create_stderr_path" \
    repo-automation/bin/slice-run-dir --create "--branch=$slice_handoff_branch" --json; then
    return 1
  fi

  active_run_dir="$(slice_handoff_json_value "$create_stdout_path" run_dir)" || {
    slice_handoff_output_contract_blocker "run-dir-create" "$create_command_summary" "0" "$create_stdout_path" "$create_stderr_path" "stdout JSON was missing required field: run_dir"
    return 1
  }
  run_root="$(slice_handoff_json_value "$create_stdout_path" root 2>/dev/null || true)"
  if [ -z "$run_root" ]; then
    run_root="${TMPDIR:-$HOME/.cache}/repo-automation/slice-handoff-runs"
  fi

  create_stdout_path="$active_run_dir/slice-run-dir-create.stdout"
  create_stderr_path="$active_run_dir/slice-run-dir-create.stderr"
  if ! mv -f -- "$create_stdout_tmp" "$create_stdout_path" || ! mv -f -- "$create_stderr_tmp" "$create_stderr_path"; then
    slice_handoff_print_execution_blocker "run-dir-create" "$create_command_summary" 1 "$create_stdout_path" "$create_stderr_path" "unable to finalize run-dir-create artifacts"
    return 1
  fi

  if ! cp -- "$create_stdout_path" "$active_run_dir/slice-run-dir-create.json"; then
    slice_handoff_print_execution_blocker "run-dir-create" "$create_command_summary" 1 "$create_stdout_path" "$create_stderr_path" "unable to copy create JSON artifact"
    return 1
  fi

  if ! slice_handoff_prepare_public_artifacts "$active_run_dir" 0; then
    return 1
  fi

  cleanup_stdout_tmp="$(mktemp "${TMPDIR:-$HOME/.cache}/slice-handoff-cleanup.XXXXXX.stdout")" || return 1
  cleanup_stderr_tmp="$(mktemp "${TMPDIR:-$HOME/.cache}/slice-handoff-cleanup.XXXXXX.stderr")" || {
    rm -f -- "$cleanup_stdout_tmp" >/dev/null 2>&1 || true
    return 1
  }
  cleanup_stdout_path="$active_run_dir/slice-run-dir-cleanup.stdout"
  cleanup_stderr_path="$active_run_dir/slice-run-dir-cleanup.stderr"
  cleanup_json_path="$active_run_dir/slice-run-dir-cleanup.json"
  cleanup_command_summary="$(slice_handoff_command_summary repo-automation/bin/slice-run-dir --cleanup-stale "--root=$run_root" --max-age-days=7 --keep=10 "--preserve-path=$active_run_dir" --apply --json)"

  if ! slice_handoff_run_json_child "run-dir-cleanup" "$cleanup_command_summary" "" "" "$cleanup_stdout_tmp" "$cleanup_stderr_tmp" \
    repo-automation/bin/slice-run-dir --cleanup-stale "--root=$run_root" --max-age-days=7 --keep=10 "--preserve-path=$active_run_dir" --apply --json; then
    cleanup_phase_failed=1
  fi

  if ! mv -f -- "$cleanup_stdout_tmp" "$cleanup_stdout_path" || ! mv -f -- "$cleanup_stderr_tmp" "$cleanup_stderr_path"; then
    slice_handoff_print_execution_blocker "run-dir-cleanup" "$cleanup_command_summary" 1 "$cleanup_stdout_path" "$cleanup_stderr_path" "unable to finalize run-dir-cleanup artifacts"
    return 1
  fi
  if ! cp -- "$cleanup_stdout_path" "$cleanup_json_path"; then
    slice_handoff_print_execution_blocker "run-dir-cleanup" "$cleanup_command_summary" 1 "$cleanup_stdout_path" "$cleanup_stderr_path" "unable to copy cleanup JSON artifact"
    return 1
  fi
  if [ "$cleanup_phase_failed" -ne 0 ]; then
    slice_handoff_write_execution_summary "$active_run_dir" "fail" "$cleanup_json_path" "$cleanup_stdout_path" "$cleanup_stderr_path" "" "" "" "" "" "" "" "execution-preflight" "codex-run not implemented in this slice" || true
    return 1
  fi
  preflight_stdout_path="$active_run_dir/preflight.stdout"
  preflight_stderr_path="$active_run_dir/preflight.stderr"
  preflight_json_path="$active_run_dir/preflight.json"
  preflight_command_summary="$(slice_handoff_command_summary repo-automation/bin/codex-slice-preflight --branch="$slice_handoff_branch" --clean-test-cache "--preserve-path=$active_run_dir" --json)"

  if ! (
    cd "$slice_handoff_repo_root" || return 1
    slice_handoff_run_json_child "preflight" "$preflight_command_summary" rc 0 "$preflight_stdout_path" "$preflight_stderr_path" \
      repo-automation/bin/codex-slice-preflight --branch="$slice_handoff_branch" --clean-test-cache "--preserve-path=$active_run_dir" --json
  ); then
    preflight_phase_failed=1
  fi

  if ! cp -- "$preflight_stdout_path" "$preflight_json_path"; then
    slice_handoff_print_execution_blocker "preflight" "$preflight_command_summary" 1 "$preflight_stdout_path" "$preflight_stderr_path" "unable to copy preflight JSON artifact"
    return 1
  fi
  if [ "$preflight_phase_failed" -ne 0 ]; then
    slice_handoff_write_execution_summary "$active_run_dir" "fail" "$cleanup_json_path" "$cleanup_stdout_path" "$cleanup_stderr_path" "$preflight_json_path" "$preflight_stdout_path" "$preflight_stderr_path" "" "" "" "" "execution-preflight" "codex-run not implemented in this slice" || true
    return 1
  fi

  codex_run_out_dir="$active_run_dir/codex-run"
  codex_run_stdout_path="$active_run_dir/codex-run.stdout"
  codex_run_stderr_path="$active_run_dir/codex-run.stderr"
  codex_run_summary_path="$codex_run_out_dir/codex-run-summary.txt"
  codex_final_output_path="$codex_run_out_dir/codex-final.txt"
  codex_run_stdout_tmp="$(mktemp "${TMPDIR:-$HOME/.cache}/slice-handoff-codex-run.XXXXXX.stdout")" || return 1
  codex_run_stderr_tmp="$(mktemp "${TMPDIR:-$HOME/.cache}/slice-handoff-codex-run.XXXXXX.stderr")" || {
    rm -f -- "$codex_run_stdout_tmp" >/dev/null 2>&1 || true
    return 1
  }
  codex_run_command_summary="$(slice_handoff_command_summary repo-automation/bin/codex-run "--prompt-file=$active_run_dir/codex-prompt.md" "--out-dir=$codex_run_out_dir" "--profile=$slice_handoff_codex_profile" "--cd=$slice_handoff_repo_root")"

  if ! (
    cd "$slice_handoff_repo_root" || return 1
    repo-automation/bin/codex-run "--prompt-file=$active_run_dir/codex-prompt.md" "--out-dir=$codex_run_out_dir" "--profile=$slice_handoff_codex_profile" "--cd=$slice_handoff_repo_root" >"$codex_run_stdout_tmp" 2>"$codex_run_stderr_tmp"
  ); then
    codex_run_phase_failed=1
  fi

  if ! mv -f -- "$codex_run_stdout_tmp" "$codex_run_stdout_path" || ! mv -f -- "$codex_run_stderr_tmp" "$codex_run_stderr_path"; then
    slice_handoff_print_execution_blocker "codex-run" "$codex_run_command_summary" 1 "$codex_run_stdout_path" "$codex_run_stderr_path" "unable to finalize codex-run artifacts"
    slice_handoff_write_execution_summary "$active_run_dir" "fail" "$cleanup_json_path" "$cleanup_stdout_path" "$cleanup_stderr_path" "$preflight_json_path" "$preflight_stdout_path" "$preflight_stderr_path" "$codex_run_stdout_path" "$codex_run_stderr_path" "$codex_run_summary_path" "$codex_final_output_path" "execution-codex-run" "repo-flow submit not implemented in this slice" || true
    return 1
  fi

  if [ "$codex_run_phase_failed" -ne 0 ]; then
    slice_handoff_write_execution_summary "$active_run_dir" "fail" "$cleanup_json_path" "$cleanup_stdout_path" "$cleanup_stderr_path" "$preflight_json_path" "$preflight_stdout_path" "$preflight_stderr_path" "$codex_run_stdout_path" "$codex_run_stderr_path" "$codex_run_summary_path" "$codex_final_output_path" "execution-codex-run" "repo-flow submit not implemented in this slice" || true
    slice_handoff_validate_codex_run_output "$codex_run_command_summary" 1 "$codex_run_stdout_path" "$codex_run_stderr_path" "$codex_run_stdout_path" "$codex_run_stderr_path" "$codex_run_summary_path" "$codex_final_output_path" || true
    return 1
  fi

  if ! slice_handoff_validate_codex_run_output "$codex_run_command_summary" 0 "$codex_run_stdout_path" "$codex_run_stderr_path" "$codex_run_stdout_path" "$codex_run_stderr_path" "$codex_run_summary_path" "$codex_final_output_path"; then
    slice_handoff_write_execution_summary "$active_run_dir" "fail" "$cleanup_json_path" "$cleanup_stdout_path" "$cleanup_stderr_path" "$preflight_json_path" "$preflight_stdout_path" "$preflight_stderr_path" "$codex_run_stdout_path" "$codex_run_stderr_path" "$codex_run_summary_path" "$codex_final_output_path" "execution-codex-run" "repo-flow submit not implemented in this slice" || true
    return 1
  fi

  if [ "$slice_handoff_submit_requested" -eq 1 ]; then
    pr_body_check_stdout_tmp="$(mktemp "${TMPDIR:-$HOME/.cache}/slice-handoff-pr-body-check.XXXXXX.stdout")" || return 1
    pr_body_check_stderr_tmp="$(mktemp "${TMPDIR:-$HOME/.cache}/slice-handoff-pr-body-check.XXXXXX.stderr")" || {
      rm -f -- "$pr_body_check_stdout_tmp" >/dev/null 2>&1 || true
      return 1
    }
    pr_body_check_stdout_path="$active_run_dir/pr-body-check.stdout"
    pr_body_check_stderr_path="$active_run_dir/pr-body-check.stderr"
    pr_body_check_command_summary="$(slice_handoff_command_summary repo-automation/bin/pr-body-check "--body-file=$active_run_dir/pr-body.md")"

    if ! (
      cd "$slice_handoff_repo_root" || return 1
      repo-automation/bin/pr-body-check "--body-file=$active_run_dir/pr-body.md" >"$pr_body_check_stdout_tmp" 2>"$pr_body_check_stderr_tmp"
    ); then
      pr_body_check_phase_failed=1
    fi

    if ! mv -f -- "$pr_body_check_stdout_tmp" "$pr_body_check_stdout_path" || ! mv -f -- "$pr_body_check_stderr_tmp" "$pr_body_check_stderr_path"; then
      slice_handoff_print_execution_blocker "pr-body-check" "$pr_body_check_command_summary" 1 "$pr_body_check_stdout_path" "$pr_body_check_stderr_path" "unable to finalize pr-body-check artifacts"
      slice_handoff_write_execution_summary "$active_run_dir" "fail" "$cleanup_json_path" "$cleanup_stdout_path" "$cleanup_stderr_path" "$preflight_json_path" "$preflight_stdout_path" "$preflight_stderr_path" "$codex_run_stdout_path" "$codex_run_stderr_path" "$codex_run_summary_path" "$codex_final_output_path" "execution-submit" "pr-body-check failed" "$pr_body_check_stdout_path" "$pr_body_check_stderr_path" "" "" || true
      return 1
    fi

    if [ "$pr_body_check_phase_failed" -ne 0 ]; then
      slice_handoff_write_execution_summary "$active_run_dir" "fail" "$cleanup_json_path" "$cleanup_stdout_path" "$cleanup_stderr_path" "$preflight_json_path" "$preflight_stdout_path" "$preflight_stderr_path" "$codex_run_stdout_path" "$codex_run_stderr_path" "$codex_run_summary_path" "$codex_final_output_path" "execution-submit" "pr-body-check failed" "$pr_body_check_stdout_path" "$pr_body_check_stderr_path" "" "" || true
      local pr_body_check_excerpt=""
      if [ -s "$pr_body_check_stderr_path" ]; then
        pr_body_check_excerpt="$(grep -E '^(fail:|warn:|STOP:|WARN:|ERROR:)' "$pr_body_check_stderr_path" | head -n 4 | awk 'BEGIN{sep=""} {printf "%s%s", sep, $0; sep=" | "} END{print ""}')"
      fi
      if [ -z "$pr_body_check_excerpt" ] && [ -s "$pr_body_check_stdout_path" ]; then
        pr_body_check_excerpt="$(awk 'NF { print; count++; if (count == 4) exit }' "$pr_body_check_stdout_path")"
      fi
      [ -n "$pr_body_check_excerpt" ] || pr_body_check_excerpt="pr-body-check exited nonzero"
      slice_handoff_print_execution_blocker "pr-body-check" "$pr_body_check_command_summary" 1 "$pr_body_check_stdout_path" "$pr_body_check_stderr_path" "$pr_body_check_excerpt"
      return 1
    fi

    repo_flow_submit_stdout_tmp="$(mktemp "${TMPDIR:-$HOME/.cache}/slice-handoff-repo-flow-submit.XXXXXX.stdout")" || return 1
    repo_flow_submit_stderr_tmp="$(mktemp "${TMPDIR:-$HOME/.cache}/slice-handoff-repo-flow-submit.XXXXXX.stderr")" || {
      rm -f -- "$repo_flow_submit_stdout_tmp" >/dev/null 2>&1 || true
      return 1
    }
    repo_flow_submit_stdout_path="$active_run_dir/repo-flow-submit.stdout"
    repo_flow_submit_stderr_path="$active_run_dir/repo-flow-submit.stderr"
    repo_flow_submit_command_summary="$(slice_handoff_command_summary repo-automation/bin/repo-flow submit --all "--message=$slice_handoff_commit_message" "--body-file=$active_run_dir/pr-body.md" --watch --timeout=900 --diagnose-on-fail --explain)"

    if ! (
      cd "$slice_handoff_repo_root" || return 1
      repo-automation/bin/repo-flow submit --all "--message=$slice_handoff_commit_message" "--body-file=$active_run_dir/pr-body.md" --watch --timeout=900 --diagnose-on-fail --explain >"$repo_flow_submit_stdout_tmp" 2>"$repo_flow_submit_stderr_tmp"
    ); then
      repo_flow_submit_phase_failed=1
    fi

    if ! mv -f -- "$repo_flow_submit_stdout_tmp" "$repo_flow_submit_stdout_path" || ! mv -f -- "$repo_flow_submit_stderr_tmp" "$repo_flow_submit_stderr_path"; then
      slice_handoff_print_execution_blocker "repo-flow-submit" "$repo_flow_submit_command_summary" 1 "$repo_flow_submit_stdout_path" "$repo_flow_submit_stderr_path" "unable to finalize repo-flow-submit artifacts"
      slice_handoff_write_execution_summary "$active_run_dir" "fail" "$cleanup_json_path" "$cleanup_stdout_path" "$cleanup_stderr_path" "$preflight_json_path" "$preflight_stdout_path" "$preflight_stderr_path" "$codex_run_stdout_path" "$codex_run_stderr_path" "$codex_run_summary_path" "$codex_final_output_path" "execution-submit" "repo-flow submit failed" "$pr_body_check_stdout_path" "$pr_body_check_stderr_path" "$repo_flow_submit_stdout_path" "$repo_flow_submit_stderr_path" || true
      return 1
    fi

    if [ "$repo_flow_submit_phase_failed" -ne 0 ]; then
      repo_flow_submit_url_or_stop="$(slice_handoff_extract_repo_flow_summary_value url_or_stop "$repo_flow_submit_stderr_path" "$repo_flow_submit_stdout_path" 2>/dev/null || true)"
      if [ -z "$repo_flow_submit_url_or_stop" ] && [ -s "$repo_flow_submit_stderr_path" ]; then
        repo_flow_submit_url_or_stop="$(grep -E '^(fail:|warn:|STOP:|WARN:|ERROR:)' "$repo_flow_submit_stderr_path" | head -n 4 | awk 'BEGIN{sep=""} {printf "%s%s", sep, $0; sep=" | "} END{print ""}')"
      fi
      [ -n "$repo_flow_submit_url_or_stop" ] || repo_flow_submit_url_or_stop="repo-flow submit exited nonzero"
      slice_handoff_write_execution_summary "$active_run_dir" "fail" "$cleanup_json_path" "$cleanup_stdout_path" "$cleanup_stderr_path" "$preflight_json_path" "$preflight_stdout_path" "$preflight_stderr_path" "$codex_run_stdout_path" "$codex_run_stderr_path" "$codex_run_summary_path" "$codex_final_output_path" "execution-submit" "repo-flow submit failed" "$pr_body_check_stdout_path" "$pr_body_check_stderr_path" "$repo_flow_submit_stdout_path" "$repo_flow_submit_stderr_path" || true
      slice_handoff_print_execution_blocker "repo-flow-submit" "$repo_flow_submit_command_summary" 1 "$repo_flow_submit_stdout_path" "$repo_flow_submit_stderr_path" "$repo_flow_submit_url_or_stop"
      return 1
    fi

    repo_flow_submit_url_or_stop="$(slice_handoff_extract_repo_flow_summary_value url_or_stop "$repo_flow_submit_stderr_path" "$repo_flow_submit_stdout_path" 2>/dev/null || true)"
    if ! slice_handoff_write_execution_summary "$active_run_dir" "pass" "$cleanup_json_path" "$cleanup_stdout_path" "$cleanup_stderr_path" "$preflight_json_path" "$preflight_stdout_path" "$preflight_stderr_path" "$codex_run_stdout_path" "$codex_run_stderr_path" "$codex_run_summary_path" "$codex_final_output_path" "execution-submit" "review PR before merge" "$pr_body_check_stdout_path" "$pr_body_check_stderr_path" "$repo_flow_submit_stdout_path" "$repo_flow_submit_stderr_path"; then
      slice_handoff_fail "unable to write execution summary" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi

    if [ "$slice_handoff_quiet" -eq 0 ]; then
      printf 'pass\n'
      printf 'mode=execution-submit\n'
      printf 'run_dir=%s\n' "$active_run_dir"
      printf 'branch=%s\n' "$slice_handoff_branch"
      printf 'preflight_status=pass\n'
      printf 'codex_status=pass\n'
      printf 'submit_status=pass\n'
      printf 'codex_final_output_path=%s\n' "$codex_final_output_path"
      if [ -n "$repo_flow_submit_url_or_stop" ]; then
        printf 'repo_flow_url_or_stop=%s\n' "$repo_flow_submit_url_or_stop"
      fi
      printf 'review_request_path=%s\n' "$active_run_dir/review-request.txt"
      printf 'next=review PR before merge\n'
    fi

    return 0
  fi

  if ! slice_handoff_write_execution_summary "$active_run_dir" "pass" "$cleanup_json_path" "$cleanup_stdout_path" "$cleanup_stderr_path" "$preflight_json_path" "$preflight_stdout_path" "$preflight_stderr_path" "$codex_run_stdout_path" "$codex_run_stderr_path" "$codex_run_summary_path" "$codex_final_output_path" "execution-codex-run" "repo-flow submit not implemented in this slice"; then
    slice_handoff_fail "unable to write execution summary" "fix filesystem permissions and rerun slice-handoff"
    return 1
  fi

  if [ "$slice_handoff_quiet" -eq 0 ]; then
    printf 'pass\n'
    printf 'mode=execution-codex-run\n'
    printf 'run_dir=%s\n' "$active_run_dir"
    printf 'branch=%s\n' "$slice_handoff_branch"
    printf 'preflight_status=pass\n'
    printf 'codex_status=pass\n'
    printf 'codex_final_output_path=%s\n' "$codex_final_output_path"
    printf 'next=repo-flow submit not implemented in this slice\n'
  fi

  return 0
}

slice_handoff_main() {
  local arg=""

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --help)
        slice_handoff_usage
        return 0
        ;;
      --quiet)
        slice_handoff_quiet=1
        ;;
      --plan-only)
        slice_handoff_fail "unsupported flag: --plan-only" "use --dry-run"
        return 1
        ;;
      --dry-run)
        slice_handoff_dry_run=1
        ;;
      --out-dir=*)
        slice_handoff_out_dir="${arg#--out-dir=}"
        if [ -z "$slice_handoff_out_dir" ]; then
          slice_handoff_fail "empty flag value: --out-dir" "use --out-dir=<path>"
          return 1
        fi
        ;;
      --out-dir)
        slice_handoff_fail "missing flag value: --out-dir" "use --out-dir=<path>"
        return 1
        ;;
      --file=*)
        slice_handoff_file="${arg#--file=}"
        if [ -z "$slice_handoff_file" ]; then
          slice_handoff_fail "empty flag value: --file" "use --file=<path>"
          return 1
        fi
        ;;
      --file)
        slice_handoff_fail "missing flag value: --file" "use --file=<path>"
        return 1
        ;;
      --execute)
        slice_handoff_fail "unsupported flag: --execute" "use the default execution mode without --execute"
        return 1
        ;;
      --submit)
        slice_handoff_submit_requested=1
        ;;
      --submit=*)
        slice_handoff_fail "unsupported flag: --submit" "use bare --submit with submit_mode: repo-flow-submit-all in the handoff envelope"
        return 1
        ;;
      --*)
        slice_handoff_fail "unknown flag: $arg" "run repo-automation/bin/slice-handoff --help"
        return 1
        ;;
      *)
        slice_handoff_fail "unknown argument: $arg" "run repo-automation/bin/slice-handoff --help"
        return 1
        ;;
    esac
    shift
  done

  slice_handoff_validate_file || return 1

  mkdir -p "${TMPDIR:-$HOME/.cache}" || return 1
  slice_handoff_prompt_file="$(mktemp "${TMPDIR:-$HOME/.cache}/slice-handoff-codex-prompt.XXXXXX")" || return 1
  slice_handoff_pr_body_file="$(mktemp "${TMPDIR:-$HOME/.cache}/slice-handoff-pr-body.XXXXXX")" || return 1
  slice_handoff_review_request_file="$(mktemp "${TMPDIR:-$HOME/.cache}/slice-handoff-review-request.XXXXXX")" || return 1
  trap 'slice_handoff_cleanup_temp_files' EXIT INT TERM

  slice_handoff_validate_handoff || return 1

  if [ "$slice_handoff_submit_requested" -eq 1 ] && [ "$slice_handoff_submit_mode" != "repo-flow-submit-all" ]; then
    slice_handoff_fail "--submit requires submit_mode: repo-flow-submit-all in the handoff envelope" "set submit_mode: repo-flow-submit-all or remove --submit"
    return 1
  fi

  if [ -n "$slice_handoff_out_dir" ]; then
    slice_handoff_out_dir_abs="$(
      python3 - "$slice_handoff_out_dir" "$slice_handoff_repo_root" <<'PY'
from pathlib import Path
import sys

out_dir = Path(sys.argv[1]).expanduser().resolve(strict=False)
repo_root = Path(sys.argv[2]).resolve(strict=True)

try:
    out_dir.relative_to(repo_root)
except ValueError:
    pass
else:
    print('fail: out-dir must be outside the repo root', file=sys.stderr)
    print('fix: choose a directory outside the current repo root', file=sys.stderr)
    raise SystemExit(1)

print(out_dir)
PY
    )" || return 1

    if ! mkdir -p "$slice_handoff_out_dir_abs"; then
      slice_handoff_fail "unable to create out-dir: $slice_handoff_out_dir_abs" "fix filesystem permissions or choose a writable directory outside the repo root"
      return 1
    fi

    slice_handoff_out_dir_prompt="$slice_handoff_out_dir_abs/codex-prompt.md"
    slice_handoff_out_dir_summary="$slice_handoff_out_dir_abs/slice-handoff-summary.txt"
    slice_handoff_out_dir_preview="$slice_handoff_out_dir_abs/dry-run-preview.txt"
    slice_handoff_out_dir_pr_body=""
    slice_handoff_out_dir_review_request="$slice_handoff_out_dir_abs/review-request.txt"
    slice_handoff_out_dir_prompt_tmp=""
    slice_handoff_out_dir_summary_tmp=""
    slice_handoff_out_dir_preview_tmp=""
    slice_handoff_out_dir_pr_body_tmp=""
    slice_handoff_out_dir_review_request_tmp=""

    if ! slice_handoff_out_dir_prompt_tmp="$(mktemp "$slice_handoff_out_dir_abs/.codex-prompt.XXXXXX")"; then
      slice_handoff_fail "unable to create codex prompt artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi
    if ! cp -- "$slice_handoff_prompt_file" "$slice_handoff_out_dir_prompt_tmp"; then
      slice_handoff_cleanup_out_dir_temp_files "$slice_handoff_out_dir_prompt_tmp"
      slice_handoff_fail "unable to write codex prompt artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi

    if [ "$slice_handoff_submit_mode" = "repo-flow-submit-all" ]; then
      slice_handoff_out_dir_pr_body="$slice_handoff_out_dir_abs/pr-body.md"
      if ! slice_handoff_out_dir_pr_body_tmp="$(mktemp "$slice_handoff_out_dir_abs/.pr-body.XXXXXX")"; then
        slice_handoff_cleanup_out_dir_temp_files "$slice_handoff_out_dir_prompt_tmp"
        slice_handoff_fail "unable to create PR body artifact" "fix filesystem permissions and rerun slice-handoff"
        return 1
      fi
      if ! cp -- "$slice_handoff_pr_body_file" "$slice_handoff_out_dir_pr_body_tmp"; then
        slice_handoff_cleanup_out_dir_temp_files "$slice_handoff_out_dir_prompt_tmp" "$slice_handoff_out_dir_pr_body_tmp"
        slice_handoff_fail "unable to write PR body artifact" "fix filesystem permissions and rerun slice-handoff"
        return 1
      fi
    fi

    if ! slice_handoff_out_dir_review_request_tmp="$(mktemp "$slice_handoff_out_dir_abs/.review-request.XXXXXX")"; then
      slice_handoff_cleanup_out_dir_temp_files \
        "$slice_handoff_out_dir_prompt_tmp" \
        "$slice_handoff_out_dir_pr_body_tmp" \
        "$slice_handoff_out_dir_prompt" \
        "$slice_handoff_out_dir_pr_body" \
        "$slice_handoff_out_dir_review_request"
      slice_handoff_fail "unable to create review request artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi
    if ! cp -- "$slice_handoff_review_request_file" "$slice_handoff_out_dir_review_request_tmp"; then
      slice_handoff_cleanup_out_dir_temp_files \
        "$slice_handoff_out_dir_prompt_tmp" \
        "$slice_handoff_out_dir_pr_body_tmp" \
        "$slice_handoff_out_dir_review_request_tmp" \
        "$slice_handoff_out_dir_prompt" \
        "$slice_handoff_out_dir_pr_body" \
        "$slice_handoff_out_dir_review_request"
      slice_handoff_fail "unable to write review request artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi

    if ! slice_handoff_out_dir_summary_tmp="$(mktemp "$slice_handoff_out_dir_abs/.slice-handoff-summary.XXXXXX")"; then
      slice_handoff_cleanup_out_dir_temp_files \
        "$slice_handoff_out_dir_prompt_tmp" \
        "$slice_handoff_out_dir_pr_body_tmp" \
        "$slice_handoff_out_dir_review_request_tmp" \
        "$slice_handoff_out_dir_prompt" \
        "$slice_handoff_out_dir_pr_body" \
        "$slice_handoff_out_dir_review_request"
      slice_handoff_fail "unable to create summary artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi

    if ! slice_handoff_out_dir_preview_tmp="$(mktemp "$slice_handoff_out_dir_abs/.dry-run-preview.XXXXXX")"; then
      slice_handoff_cleanup_out_dir_temp_files \
        "$slice_handoff_out_dir_prompt_tmp" \
        "$slice_handoff_out_dir_pr_body_tmp" \
        "$slice_handoff_out_dir_review_request_tmp" \
        "$slice_handoff_out_dir_summary_tmp" \
        "$slice_handoff_out_dir_prompt" \
        "$slice_handoff_out_dir_pr_body" \
        "$slice_handoff_out_dir_review_request"
      slice_handoff_fail "unable to create dry-run preview artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi

    if ! slice_handoff_write_dry_run_preview "$slice_handoff_out_dir_preview_tmp" "$slice_handoff_out_dir_preview" "$slice_handoff_out_dir_pr_body" "$slice_handoff_submit_mode"; then
      slice_handoff_cleanup_out_dir_temp_files \
        "$slice_handoff_out_dir_prompt_tmp" \
        "$slice_handoff_out_dir_pr_body_tmp" \
        "$slice_handoff_out_dir_review_request_tmp" \
        "$slice_handoff_out_dir_summary_tmp" \
        "$slice_handoff_out_dir_preview_tmp" \
        "$slice_handoff_out_dir_prompt" \
        "$slice_handoff_out_dir_pr_body" \
        "$slice_handoff_out_dir_review_request" \
        "$slice_handoff_out_dir_preview"
      slice_handoff_fail "unable to write dry-run preview artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi

    {
      printf 'schema=repo-automation-slice-handoff/v1\n'
      printf 'branch=%s\n' "$slice_handoff_branch"
      printf 'title=%s\n' "$slice_handoff_title"
      printf 'codex_profile=%s\n' "$slice_handoff_codex_profile"
      printf 'submit_mode=%s\n' "$slice_handoff_submit_mode"
      printf 'commit_message=%s\n' "$slice_handoff_commit_message"
      printf 'codex_prompt_path=%s\n' "$slice_handoff_out_dir_prompt"
      printf 'pr_body_path=%s\n' "$slice_handoff_out_dir_pr_body"
      printf 'review_request_path=%s\n' "$slice_handoff_out_dir_review_request"
    } >"$slice_handoff_out_dir_summary_tmp" || {
      slice_handoff_cleanup_out_dir_temp_files \
        "$slice_handoff_out_dir_prompt_tmp" \
        "$slice_handoff_out_dir_pr_body_tmp" \
        "$slice_handoff_out_dir_review_request_tmp" \
        "$slice_handoff_out_dir_summary_tmp" \
        "$slice_handoff_out_dir_preview_tmp" \
        "$slice_handoff_out_dir_prompt" \
        "$slice_handoff_out_dir_pr_body" \
        "$slice_handoff_out_dir_review_request"
      slice_handoff_fail "unable to write summary artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    }

    if ! mv -f -- "$slice_handoff_out_dir_prompt_tmp" "$slice_handoff_out_dir_prompt"; then
      slice_handoff_cleanup_out_dir_temp_files \
        "$slice_handoff_out_dir_prompt_tmp" \
        "$slice_handoff_out_dir_pr_body_tmp" \
        "$slice_handoff_out_dir_review_request_tmp" \
        "$slice_handoff_out_dir_summary_tmp" \
        "$slice_handoff_out_dir_preview_tmp" \
        "$slice_handoff_out_dir_prompt" \
        "$slice_handoff_out_dir_pr_body" \
        "$slice_handoff_out_dir_review_request"
      slice_handoff_fail "unable to finalize codex prompt artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi

    if [ -n "$slice_handoff_out_dir_pr_body" ]; then
      if ! mv -f -- "$slice_handoff_out_dir_pr_body_tmp" "$slice_handoff_out_dir_pr_body"; then
        slice_handoff_cleanup_out_dir_temp_files \
          "$slice_handoff_out_dir_prompt_tmp" \
          "$slice_handoff_out_dir_pr_body_tmp" \
          "$slice_handoff_out_dir_review_request_tmp" \
          "$slice_handoff_out_dir_summary_tmp" \
          "$slice_handoff_out_dir_preview_tmp" \
          "$slice_handoff_out_dir_prompt" \
          "$slice_handoff_out_dir_pr_body" \
          "$slice_handoff_out_dir_review_request"
        slice_handoff_fail "unable to finalize PR body artifact" "fix filesystem permissions and rerun slice-handoff"
        return 1
      fi
    fi

    if ! mv -f -- "$slice_handoff_out_dir_review_request_tmp" "$slice_handoff_out_dir_review_request"; then
      slice_handoff_cleanup_out_dir_temp_files \
        "$slice_handoff_out_dir_prompt_tmp" \
        "$slice_handoff_out_dir_pr_body_tmp" \
        "$slice_handoff_out_dir_review_request_tmp" \
        "$slice_handoff_out_dir_summary_tmp" \
        "$slice_handoff_out_dir_preview_tmp" \
        "$slice_handoff_out_dir_prompt" \
        "$slice_handoff_out_dir_pr_body" \
        "$slice_handoff_out_dir_review_request"
      slice_handoff_fail "unable to finalize review request artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi

    if ! mv -f -- "$slice_handoff_out_dir_summary_tmp" "$slice_handoff_out_dir_summary"; then
      slice_handoff_cleanup_out_dir_temp_files \
        "$slice_handoff_out_dir_prompt_tmp" \
        "$slice_handoff_out_dir_pr_body_tmp" \
        "$slice_handoff_out_dir_review_request_tmp" \
        "$slice_handoff_out_dir_summary_tmp" \
        "$slice_handoff_out_dir_preview_tmp" \
        "$slice_handoff_out_dir_prompt" \
        "$slice_handoff_out_dir_pr_body" \
        "$slice_handoff_out_dir_review_request" \
        "$slice_handoff_out_dir_preview" \
        "$slice_handoff_out_dir_summary"
      slice_handoff_fail "unable to finalize summary artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi

    if ! mv -f -- "$slice_handoff_out_dir_preview_tmp" "$slice_handoff_out_dir_preview"; then
      slice_handoff_cleanup_out_dir_temp_files \
        "$slice_handoff_out_dir_prompt_tmp" \
        "$slice_handoff_out_dir_pr_body_tmp" \
        "$slice_handoff_out_dir_review_request_tmp" \
        "$slice_handoff_out_dir_summary_tmp" \
        "$slice_handoff_out_dir_preview_tmp" \
        "$slice_handoff_out_dir_prompt" \
        "$slice_handoff_out_dir_pr_body" \
        "$slice_handoff_out_dir_review_request" \
        "$slice_handoff_out_dir_preview" \
        "$slice_handoff_out_dir_summary"
      slice_handoff_fail "unable to finalize dry-run preview artifact" "fix filesystem permissions and rerun slice-handoff"
      return 1
    fi
  fi

  if [ "$slice_handoff_dry_run" -eq 0 ]; then
    slice_handoff_run_execution_phase || return 1
    return 0
  fi

  if [ "$slice_handoff_quiet" -eq 0 ]; then
    printf 'pass\n'
    if [ -n "$slice_handoff_out_dir_abs" ]; then
      printf 'out_dir=%s\n' "$slice_handoff_out_dir_abs"
      printf 'codex_prompt_path=%s\n' "$slice_handoff_out_dir_prompt"
      printf 'preview_path=%s\n' "$slice_handoff_out_dir_preview"
      if [ -n "$slice_handoff_out_dir_pr_body" ]; then
        printf 'pr_body_path=%s\n' "$slice_handoff_out_dir_pr_body"
      fi
      printf 'review_request_path=%s\n' "$slice_handoff_out_dir_review_request"
      printf 'summary_path=%s\n' "$slice_handoff_out_dir_summary"
    fi
  fi
  return 0
}

slice_handoff_main "$@"
# repo-automation/bin/slice-handoff EOF
