#!/usr/bin/env bash
# repo-automation/bin/run-tests

set -u
set -o pipefail

# shellcheck source=/dev/null
source "$(cd "$(dirname "$0")" && pwd)/../lib/common.sh"

run_tests_mode="summary"
run_tests_run_mode="full"
run_tests_json=0
run_tests_json_level="warn"
run_tests_log_enabled=1
run_tests_log_file=""
run_tests_log_file_explicit=0
run_tests_clean_temp=1
run_tests_disk_diagnostic=0
run_tests_clean_stale_temp="${REPO_AUTOMATION_CLEAN_STALE_TEMP:-1}"
run_tests_stale_temp_hours="${REPO_AUTOMATION_STALE_TEMP_HOURS:-12}"
run_tests_df_bin="${RUN_TESTS_DF_BIN:-${REPO_AUTOMATION_DF_BIN:-df}}"
run_tests_timeout_seconds=120
run_tests_timeout_available=""
run_tests_timeout_warned=0
TEST_TEMP_ROOT="${TMPDIR:-$HOME/.cache}/repo-automation-template"
run_tests_temp_root=""
run_tests_disk_guard_checked=0
run_tests_disk_guard_used_percent=""
run_tests_disk_guard_available_percent=""
run_tests_disk_guard_available_bytes=""
run_tests_disk_guard_mountpoint=""
run_tests_disk_guard_filesystem=""
run_tests_disk_guard_low_bytes=1610612736
run_tests_temp_root_warn_kib=1048576
run_tests_start_line="RUNNING repo automation tests..."
run_tests_next_hint="Next: repo-automation/bin/run-tests --explain"
run_tests_checks=()
run_tests_changed_selected_subsets=()

run_tests_usage() {
  printf 'Usage: repo-automation/bin/run-tests [--summary] [--audit] [--smoke] [--docs] [--version] [--changed] [--explain] [--quiet] [--timeout=<seconds>] [--log-file=<path>] [--no-log] [--clean-temp|--no-clean-temp] [--disk-diagnostic] [--json] [--json-level=fail|warn|all] [--help]\n'
}

run_tests_timestamp() {
  date '+%Y-%m-%dT%H%M%S'
}

run_tests_ensure_temp_root() {
  mkdir -p "$TEST_TEMP_ROOT" >/dev/null 2>&1 || return 1
  if [ -z "$run_tests_temp_root" ]; then
    run_tests_temp_root="$TEST_TEMP_ROOT/run-tests-$(run_tests_timestamp)-$$"
  fi
  mkdir -p "$run_tests_temp_root" >/dev/null 2>&1
}

run_tests_path_is_under_root() {
  local path="$1"
  local root="$2"

  case "$path" in
    "$root"|"$root"/*)
      return 0
      ;;
  esac

  return 1
}

run_tests_is_non_negative_integer() {
  case "${1:-}" in
    ''|*[!0-9]*)
      return 1
      ;;
  esac

  return 0
}

run_tests_log_policy_value() {
  if [ "$run_tests_log_enabled" -ne 1 ] || [ -z "$run_tests_log_file" ]; then
    printf 'no-log\n'
    return 0
  fi

  if [ "$run_tests_log_file_explicit" -eq 1 ]; then
    printf 'explicit-log-file\n'
    return 0
  fi

  if [ "$run_tests_clean_temp" -eq 1 ]; then
    printf 'run-temp-cleaned-by-default\n'
  else
    printf 'run-temp-kept-by-request\n'
  fi
}

run_tests_log_status_value() {
  if [ "$run_tests_log_enabled" -ne 1 ] || [ -z "$run_tests_log_file" ]; then
    printf 'none\n'
    return 0
  fi

  if run_tests_log_will_be_cleaned; then
    printf 'cleaned\n'
    return 0
  fi

  printf 'path\n'
}

run_tests_log_file_value() {
  if [ "$(run_tests_log_status_value)" = "path" ]; then
    printf '%s\n' "$run_tests_log_file"
  else
    printf '\n'
  fi
}

run_tests_log_fix_value() {
  if [ "$(run_tests_log_status_value)" = "cleaned" ]; then
    printf 'use --log-file=<path> or --no-clean-temp for durable logs\n'
  else
    printf '\n'
  fi
}

run_tests_log_will_be_cleaned() {
  [ "$run_tests_clean_temp" -eq 1 ] || return 1
  [ "$run_tests_log_file_explicit" -eq 0 ] || return 1
  [ -n "$run_tests_log_file" ] || return 1
  [ -n "$run_tests_temp_root" ] || return 1
  run_tests_path_is_under_root "$run_tests_log_file" "$run_tests_temp_root"
}

run_tests_extract_log_excerpt() {
  local log_file="$1"
  local fail_line=""
  local start_line=""
  local end_line=""

  [ -f "$log_file" ] || return 1

  fail_line="$(
    grep -n -m 1 -E '^(fail|FAIL): ' "$log_file" | cut -d: -f1
  )"
  if [ -z "$fail_line" ]; then
    fail_line="$(
      grep -n -m 1 -E '^COMMAND: ' "$log_file" | cut -d: -f1
    )"
  fi
  [ -n "$fail_line" ] || return 1

  start_line=$((fail_line - 2))
  [ "$start_line" -lt 1 ] && start_line=1
  end_line=$((fail_line + 1))

  sed -n "${start_line},${end_line}p" "$log_file"
}

run_tests_prune_stale_temp_artifacts() {
  local path=""
  local stale_mtime_mins=""

  case "$run_tests_clean_stale_temp" in
    0)
      return 0
      ;;
  esac

  if ! repo_auto_is_positive_integer "$run_tests_stale_temp_hours"; then
    run_tests_stale_temp_hours=12
  fi

  stale_mtime_mins=$((run_tests_stale_temp_hours * 60))

  [ -d "$TEST_TEMP_ROOT" ] || return 0

  while IFS= read -r path; do
    [ -n "$path" ] || continue
    [ "$path" = "$run_tests_temp_root" ] && continue
    rm -rf -- "$path" >/dev/null 2>&1 || true
  done <<EOF
$(
  find "$TEST_TEMP_ROOT" -mindepth 1 -maxdepth 1 -mmin "+$stale_mtime_mins" 2>/dev/null | LC_ALL=C sort
)
EOF
}

run_tests_cleanup_temp_root() {
  local path=""
  local preserved_child=""

  [ "$run_tests_clean_temp" -eq 1 ] || return 0
  [ -n "$run_tests_temp_root" ] || return 0
  [ -d "$run_tests_temp_root" ] || return 0

  if [ "$run_tests_log_file_explicit" -eq 1 ] && run_tests_path_is_under_root "$run_tests_log_file" "$run_tests_temp_root"; then
    preserved_child="${run_tests_log_file#"$run_tests_temp_root"/}"
    preserved_child="${preserved_child%%/*}"
    while IFS= read -r path; do
      [ -n "$path" ] || continue
      [ "$path" = "$run_tests_temp_root/$preserved_child" ] && continue
      rm -rf -- "$path" >/dev/null 2>&1 || true
    done <<EOF
$(
      find "$run_tests_temp_root" -mindepth 1 -maxdepth 1 2>/dev/null | LC_ALL=C sort
)
EOF
  else
    rm -rf -- "$run_tests_temp_root" >/dev/null 2>&1 || true
  fi

  find "$TEST_TEMP_ROOT" -depth -type d -empty -exec rmdir -- {} + >/dev/null 2>&1 || true
  run_tests_prune_stale_temp_artifacts
  run_tests_cleanup_warn_if_large
}

run_tests_info() {
  [ "$run_tests_mode" = "explain" ] || [ "$run_tests_disk_diagnostic" -eq 1 ] || return 0
  printf 'INFO: %s\n' "$*" >&2
}

run_tests_cleanup_warn_if_large() {
  local total_kib=""

  [ "$run_tests_clean_temp" -eq 1 ] || return 0
  [ -d "$TEST_TEMP_ROOT" ] || return 0
  command -v du >/dev/null 2>&1 || return 0

  total_kib="$(du -sk "$TEST_TEMP_ROOT" 2>/dev/null | awk 'NR == 1 { print $1 }')"
  [ -n "$total_kib" ] || return 0
  if [ "$total_kib" -gt "$run_tests_temp_root_warn_kib" ]; then
    printf 'WARN: TEST_TEMP_ROOT still uses %s KiB after cleanup: %s\n' "$total_kib" "$TEST_TEMP_ROOT" >&2
  fi
}

run_tests_disk_guard_print_top_dirs() {
  local path

  [ -d "$TEST_TEMP_ROOT" ] || return 0
  command -v du >/dev/null 2>&1 || return 0

  printf 'INFO: top temp/cache dirs under %s\n' "$TEST_TEMP_ROOT" >&2
  while IFS= read -r path; do
    [ -n "$path" ] || continue
    du -sh "$path" 2>/dev/null || true
  done <<EOF | LC_ALL=C sort -hr | head -n 5 >&2
$(
  find "$TEST_TEMP_ROOT" -mindepth 1 -maxdepth 1 2>/dev/null | LC_ALL=C sort
)
EOF
}

run_tests_ensure_log_parent() {
  local log_parent

  if [ -z "$run_tests_log_file" ]; then
    return 1
  fi

  log_parent="$(dirname "$run_tests_log_file")"
  mkdir -p "$log_parent" >/dev/null 2>&1
}

run_tests_json_escape() {
  local input="$1"
  input=${input//\\/\\\\}
  input=${input//\"/\\\"}
  input=${input//$'\n'/\\n}
  input=${input//$'\r'/\\r}
  input=${input//$'\t'/\\t}
  printf '%s' "$input"
}

run_tests_disk_guard_collect() {
  local path="$1"
  local used_percent=""
  local available_percent=""
  local available_blocks=""
  local filesystem=""
  local use_percent=""
  local mountpoint=""
  local df_bin="${RUN_TESTS_DF_BIN:-${REPO_AUTOMATION_DF_BIN:-${run_tests_df_bin:-df}}}"

  if ! read -r filesystem _ _ available_blocks use_percent mountpoint <<EOF
$(LC_ALL=C "$df_bin" -Pk "$path" 2>/dev/null | sed -n '2p')
EOF
  then
    return 1
  fi

  run_tests_disk_guard_filesystem="${filesystem:-unknown}"
  run_tests_disk_guard_available_bytes=""
  run_tests_disk_guard_used_percent="${use_percent:-}"
  run_tests_disk_guard_mountpoint="${mountpoint:-$path}"

  available_blocks="${available_blocks:-}"
  used_percent="${run_tests_disk_guard_used_percent%\%}"
  if ! run_tests_is_non_negative_integer "$used_percent"; then
    return 1
  fi
  if ! run_tests_is_non_negative_integer "$available_blocks"; then
    return 1
  fi

  if [ "$used_percent" -gt 100 ]; then
    used_percent=100
  fi
  available_percent=$((100 - used_percent))
  run_tests_disk_guard_available_bytes=$((available_blocks * 1024))
  run_tests_disk_guard_used_percent="$used_percent"
  run_tests_disk_guard_available_percent="$available_percent"
  return 0
}

run_tests_disk_guard_check() {
  local guard_path="$1"

  run_tests_disk_guard_checked=1
  if ! run_tests_disk_guard_collect "$guard_path"; then
    return 0
  fi

  if [ "$run_tests_disk_guard_available_bytes" -lt "$run_tests_disk_guard_low_bytes" ]; then
    if [ "$run_tests_disk_diagnostic" -eq 1 ]; then
      run_tests_info "disk space: filesystem=${run_tests_disk_guard_filesystem:-unknown} mount=${run_tests_disk_guard_mountpoint:-$guard_path} used=${run_tests_disk_guard_used_percent}% available=${run_tests_disk_guard_available_percent}% free_bytes=${run_tests_disk_guard_available_bytes} path=$guard_path"
    fi
    run_tests_disk_guard_print_top_dirs
    run_tests_record_fail "disk space check" "available disk space below 1.5G (${run_tests_disk_guard_available_bytes} bytes free)"
    return 1
  fi

  if [ "$run_tests_disk_guard_available_percent" -lt 15 ]; then
    if [ "$run_tests_disk_diagnostic" -eq 1 ]; then
      run_tests_info "disk space: filesystem=${run_tests_disk_guard_filesystem:-unknown} mount=${run_tests_disk_guard_mountpoint:-$guard_path} used=${run_tests_disk_guard_used_percent}% available=${run_tests_disk_guard_available_percent}% free_bytes=${run_tests_disk_guard_available_bytes} path=$guard_path"
    fi
    run_tests_disk_guard_print_top_dirs
    run_tests_record_fail "disk space check" "available disk space below 15% (${run_tests_disk_guard_available_percent}% free)"
    return 1
  fi

  if [ "$run_tests_disk_diagnostic" -eq 1 ]; then
    run_tests_info "disk space: filesystem=${run_tests_disk_guard_filesystem:-unknown} mount=${run_tests_disk_guard_mountpoint:-$guard_path} used=${run_tests_disk_guard_used_percent}% available=${run_tests_disk_guard_available_percent}% free_bytes=${run_tests_disk_guard_available_bytes} path=$guard_path"
  fi

  return 0
}

run_tests_command_string() {
  local arg
  local quoted=""

  for arg in "$@"; do
    quoted+="$(printf '%q ' "$arg")"
  done

  printf '%s' "${quoted% }"
}

run_tests_timeout_supported() {
  if [ -n "$run_tests_timeout_available" ]; then
    [ "$run_tests_timeout_available" = "1" ]
    return $?
  fi

  if command -v timeout >/dev/null 2>&1; then
    run_tests_timeout_available=1
  else
    run_tests_timeout_available=0
  fi

  [ "$run_tests_timeout_available" = "1" ]
}

run_tests_timeout_warn_once() {
  if [ "$run_tests_timeout_warned" -eq 1 ]; then
    return 0
  fi

  run_tests_timeout_warned=1
  run_tests_record_warn "timeout support unavailable" "timeout command not found; running checks without per-check timeout guards"
}

run_tests_init_log() {
  if [ "$run_tests_log_enabled" -ne 1 ]; then
    return 0
  fi

  if [ -z "$run_tests_log_file" ]; then
    run_tests_log_file="$run_tests_temp_root/run-tests.log"
  fi

  run_tests_ensure_log_parent || {
    run_tests_log_enabled=0
    run_tests_log_file=""
    return 0
  }

  : >"$run_tests_log_file" 2>/dev/null || {
    run_tests_log_enabled=0
    run_tests_log_file=""
    return 0
  }
}

run_tests_log() {
  if [ "$run_tests_log_enabled" -eq 1 ] && [ -n "$run_tests_log_file" ]; then
    run_tests_ensure_log_parent || {
      run_tests_log_enabled=0
      run_tests_log_file=""
      return 0
    }
    printf '%s\n' "$*" >>"$run_tests_log_file"
  fi
}

run_tests_add_check() {
  local name="$1"
  local status="$2"
  local message="$3"
  local timed_out="${4:-0}"

  run_tests_checks+=("${name}|${status}|${timed_out}|${message}")
  run_tests_log "${status^^}: ${name} - ${message}"
}

run_tests_record_pass() {
  run_tests_add_check "$1" "pass" "$2" "0"
}

run_tests_record_warn() {
  run_tests_add_check "$1" "warn" "$2" "0"
}

run_tests_record_fail() {
  run_tests_add_check "$1" "fail" "$2" "${3:-0}"
}

run_tests_record_skip() {
  run_tests_add_check "$1" "skipped" "$2" "0"
}

run_tests_run_cmd() {
  local label="$1"
  shift
  local command_string
  local exit_code=0
  local timed_out=0
  local timeout_seconds="$run_tests_timeout_seconds"
  local use_timeout=0

  command_string="$(run_tests_command_string "$@")"
  run_tests_log "CHECK START: $label"
  run_tests_log "COMMAND: $command_string"

  if [ "$timeout_seconds" -gt 0 ] && run_tests_timeout_supported; then
    use_timeout=1
  elif [ "$timeout_seconds" -gt 0 ]; then
    run_tests_timeout_warn_once
  fi

  if [ "$run_tests_log_enabled" -eq 1 ] && [ -n "$run_tests_log_file" ]; then
    run_tests_ensure_log_parent || {
      run_tests_log_enabled=0
      run_tests_log_file=""
    }
  fi

  if [ "$run_tests_log_enabled" -eq 1 ] && [ -n "$run_tests_log_file" ]; then
    if [ "$use_timeout" -eq 1 ]; then
      timeout "${timeout_seconds}s" "$@" >>"$run_tests_log_file" 2>&1
      exit_code=$?
    else
      "$@" >>"$run_tests_log_file" 2>&1
      exit_code=$?
    fi
  else
    if [ "$use_timeout" -eq 1 ]; then
      timeout "${timeout_seconds}s" "$@" >/dev/null 2>&1
      exit_code=$?
    else
      "$@" >/dev/null 2>&1
      exit_code=$?
    fi
  fi

  if [ "$exit_code" -eq 0 ]; then
    run_tests_record_pass "$label" "passed"
    run_tests_log "CHECK END: $label"
    return 0
  fi

  if [ "$use_timeout" -eq 1 ] && [ "$exit_code" -eq 124 ]; then
    timed_out=1
    run_tests_record_fail "$label" "timed out after ${timeout_seconds}s" "$timed_out"
  else
    run_tests_record_fail "$label" "failed" "0"
  fi
  run_tests_log "CHECK END: $label"
  return 1
}

run_tests_extract_smoke_failure() {
  local output_file="$1"
  local fail_line=""
  local running_line=""

  if [ ! -f "$output_file" ]; then
    printf 'failed\n'
    return 0
  fi

  fail_line="$(
    awk '
      match($0, /^(fail|FAIL): /) {
        print substr($0, RLENGTH + 1)
        exit
      }
    ' "$output_file"
  )"
  if [ -n "$fail_line" ]; then
    printf '%s\n' "$fail_line"
    return 0
  fi

  running_line="$(sed -n 's/^RUNNING: //p' "$output_file" | tail -n 1)"
  if [ -n "$running_line" ]; then
    printf 'timed out during %s\n' "$running_line"
    return 0
  fi

  printf 'failed\n'
}

run_tests_print_smoke_failure_excerpt() {
  local output_file="$1"
  local fail_line=""
  local start_line=""
  local end_line=""

  if [ ! -f "$output_file" ]; then
    return 0
  fi

  fail_line="$(grep -n -m 1 -E '^(fail|FAIL): ' "$output_file" | cut -d: -f1)"
  if [ -z "$fail_line" ]; then
    return 0
  fi

  start_line="$fail_line"
  end_line=$((fail_line + 8))

  printf 'SMOKE EXCERPT:\n'
  sed -n "${start_line},${end_line}p" "$output_file"
}

run_tests_extract_log_first_failure() {
  local log_file="$1"
  local first_failure=""

  if [ -z "$log_file" ] || [ ! -f "$log_file" ]; then
    return 1
  fi

  first_failure="$(sed -n -E 's/^(fail|FAIL): //p' "$log_file" | head -n 1)"
  [ -n "$first_failure" ] || return 1

  printf '%s\n' "$first_failure"
}

run_tests_extract_log_command() {
  local log_file="$1"
  local command_line=""

  if [ -z "$log_file" ] || [ ! -f "$log_file" ]; then
    return 1
  fi

  command_line="$(sed -n 's/^COMMAND: //p' "$log_file" | head -n 1)"
  [ -n "$command_line" ] || return 1

  printf '%s\n' "$command_line"
}

run_tests_focus_command_from_log() {
  local first_failure="$1"
  local command_line="$2"

  case "$first_failure" in
    smoke:installer-contract*)
      printf 'repo-automation/tests/contracts/installer.sh --quiet\n'
      return 0
      ;;
    smoke:run-tests-contract*)
      printf 'repo-automation/tests/contracts/run-tests.sh --quiet\n'
      return 0
      ;;
  esac

  case "$command_line" in
    *repo-automation/tests/docs-check.sh*)
      printf 'repo-automation/tests/docs-check.sh --quiet\n'
      return 0
      ;;
    *repo-automation/tests/version-consistency.sh*)
      printf 'repo-automation/tests/version-consistency.sh --quiet\n'
      return 0
      ;;
    *repo-automation/tests/smoke.sh*)
      printf 'repo-automation/tests/smoke.sh --quiet\n'
      return 0
      ;;
  esac

  [ -n "$command_line" ] || return 1
  printf '%s\n' "$command_line"
}

run_tests_print_log_reference() {
  local log_file="$1"

  if [ -n "$log_file" ]; then
    printf 'log: %s\n' "$log_file"
  fi
}

run_tests_print_failure_fix_from_log() {
  local log_file="$1"
  local log_cleaned="${2:-0}"
  local first_failure=""
  local command_line=""
  local focused_command=""
  local excerpt=""

  if [ "$log_cleaned" -eq 1 ]; then
    excerpt="$(run_tests_extract_log_excerpt "$log_file" 2>/dev/null || true)"
    repo_auto_print_failure_footer \
      log cleaned \
      excerpt "$excerpt" \
      fix "use --log-file=<path> or --no-clean-temp for durable logs"
    return 0
  fi

  repo_auto_print_failure_footer log "$log_file"
  first_failure="$(run_tests_extract_log_first_failure "$log_file" 2>/dev/null || true)"
  command_line="$(run_tests_extract_log_command "$log_file" 2>/dev/null || true)"
  focused_command="$(run_tests_focus_command_from_log "$first_failure" "$command_line" 2>/dev/null || true)"

  if [ -n "$first_failure" ]; then
    printf 'first failure: %s\n' "$first_failure"
  fi

  if [ -n "$focused_command" ]; then
    repo_auto_print_failure_footer fix "inspect log and run focused check: $focused_command"
  else
    repo_auto_print_failure_footer fix "inspect log: $log_file"
  fi
}

run_tests_print_failure_fix() {
  local first_entry=""
  local name=""
  local rest=""
  local message=""

  if [ "$run_tests_mode" != "explain" ]; then
    repo_auto_print_failure_footer fix "$run_tests_next_hint"
    return 0
  fi

  if [ -n "$run_tests_log_file" ]; then
    repo_auto_print_failure_footer fix "inspect log: $run_tests_log_file"
    return 0
  fi

  first_entry="$(run_tests_first_entry_by_status fail 2>/dev/null || true)"
  if [ -n "$first_entry" ]; then
    name="${first_entry%%|*}"
    rest="${first_entry#*|}"
    rest="${rest#*|}"
    rest="${rest#*|}"
    message="$rest"
    if [ -n "$message" ] && [ "$message" != "failed" ]; then
      repo_auto_print_failure_footer fix "rerun $name directly after inspecting the failure details"
    else
      repo_auto_print_failure_footer fix "rerun $name directly"
    fi
    return 0
  fi

  repo_auto_print_failure_footer fix "inspect the failing test details above"
}

run_tests_first_entry_by_status() {
  local want_status="$1"
  local entry name status rest timed_out message

  for entry in "${run_tests_checks[@]}"; do
    name="${entry%%|*}"
    rest="${entry#*|}"
    status="${rest%%|*}"
    rest="${rest#*|}"
    timed_out="${rest%%|*}"
    message="${rest#*|}"
    if [ "$status" = "$want_status" ]; then
      printf '%s|%s|%s|%s\n' "$name" "$status" "$timed_out" "$message"
      return 0
    fi
  done

  return 1
}

run_tests_run_smoke() {
  local label="$1"
  shift
  local command_string
  local output_file
  local exit_code=0
  local timed_out=0
  local failure_message="failed"

  command_string="$(run_tests_command_string "$@")"
  output_file="$run_tests_temp_root/run-tests-smoke-$(run_tests_timestamp)-$$.log"

  run_tests_log "CHECK START: $label"
  run_tests_log "COMMAND: $command_string"

  if [ "$run_tests_timeout_seconds" -gt 0 ] && run_tests_timeout_supported; then
    timeout "${run_tests_timeout_seconds}s" "$@" >"$output_file" 2>&1
    exit_code=$?
  else
    if [ "$run_tests_timeout_seconds" -gt 0 ]; then
      run_tests_timeout_warn_once
    fi
    "$@" >"$output_file" 2>&1
    exit_code=$?
  fi

  if [ "$run_tests_log_enabled" -eq 1 ] && [ -n "$run_tests_log_file" ]; then
    run_tests_ensure_log_parent || {
      run_tests_log_enabled=0
      run_tests_log_file=""
    }
  fi

  if [ "$run_tests_log_enabled" -eq 1 ] && [ -n "$run_tests_log_file" ]; then
    cat "$output_file" >>"$run_tests_log_file"
  fi

  if [ "$exit_code" -eq 0 ]; then
    run_tests_record_pass "$label" "passed"
    run_tests_log "CHECK END: $label"
    rm -f "$output_file" >/dev/null 2>&1 || true
    return 0
  fi

  if [ "$exit_code" -eq 124 ] && [ "$run_tests_timeout_seconds" -gt 0 ] && run_tests_timeout_supported; then
    timed_out=1
  fi

  failure_message="$(run_tests_extract_smoke_failure "$output_file")"
  if [ "$timed_out" -eq 1 ] && [ "$failure_message" = "failed" ]; then
    failure_message="timed out after ${run_tests_timeout_seconds}s"
  fi

  run_tests_record_fail "$label" "$failure_message" "$timed_out"
  if [ "$run_tests_json" -eq 0 ]; then
    run_tests_print_smoke_failure_excerpt "$output_file"
  fi
  run_tests_log "CHECK END: $label"
  rm -f "$output_file" >/dev/null 2>&1 || true
  return 1
}

run_tests_counts() {


  local pass_count=0
  local warn_count=0
  local fail_count=0
  local skipped_count=0
  local entry status

  for entry in "${run_tests_checks[@]}"; do
    status="${entry#*|}"
    status="${status%%|*}"
    case "$status" in
      pass) pass_count=$((pass_count + 1)) ;;
      warn) warn_count=$((warn_count + 1)) ;;
      fail) fail_count=$((fail_count + 1)) ;;
      skipped) skipped_count=$((skipped_count + 1)) ;;
    esac
  done

  printf '%s %s %s %s\n' "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
}

run_tests_print_human() {
  local overall_status="$1"
  local pass_count="$2"
  local warn_count="$3"
  local fail_count="$4"
  local skipped_count="$5"
  local entry name status message timed_out rest first_entry

  if [ "$run_tests_mode" = "explain" ]; then
    printf 'TEST_TEMP_ROOT=%s\n' "$TEST_TEMP_ROOT"
    printf 'pass=%s warn=%s fail=%s skipped=%s\n' "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
    printf 'temp_cleanup=%s\n' "$([ "$run_tests_clean_temp" -eq 1 ] && printf enabled || printf disabled)"
    printf 'stale_temp_hours=%s\n' "$run_tests_stale_temp_hours"
    printf 'disk_guard=enabled\n'
    printf 'log_policy=%s\n' "$(run_tests_log_policy_value)"
    if [ "$run_tests_run_mode" = "changed" ]; then
      if [ "${#run_tests_changed_selected_subsets[@]}" -eq 0 ]; then
        printf 'Changed subsets: none\n'
      else
        printf 'Changed subsets: %s\n' "${run_tests_changed_selected_subsets[*]}"
      fi
    fi
  fi

  if [ "$run_tests_mode" = "explain" ]; then
    for entry in "${run_tests_checks[@]}"; do
      name="${entry%%|*}"
      rest="${entry#*|}"
      status="${rest%%|*}"
      rest="${rest#*|}"
      timed_out="${rest%%|*}"
      message="${rest#*|}"
      printf '%s: %s - %s\n' "${status^^}" "$name" "$message"
    done
  fi

  if [ "$fail_count" -gt 0 ]; then
    first_entry="$(run_tests_first_entry_by_status fail)"
    name="${first_entry%%|*}"
    rest="${first_entry#*|}"
    status="${rest%%|*}"
    rest="${rest#*|}"
    timed_out="${rest%%|*}"
    message="${rest#*|}"
    if [ -n "$message" ] && [ "$message" != "failed" ]; then
      repo_auto_print_failure_footer fail "$name - $message"
    else
      repo_auto_print_failure_footer fail "$name"
    fi
    if [ -n "$run_tests_log_file" ]; then
      if run_tests_log_will_be_cleaned; then
        run_tests_print_failure_fix_from_log "$run_tests_log_file" 1
      else
        run_tests_print_failure_fix_from_log "$run_tests_log_file" 0
      fi
    elif [ "$run_tests_mode" != "quiet" ]; then
      run_tests_print_failure_fix
    fi
    return 0
  fi

  if [ "$warn_count" -gt 0 ]; then
    first_entry="$(run_tests_first_entry_by_status warn)"
    name="${first_entry%%|*}"
    rest="${first_entry#*|}"
    status="${rest%%|*}"
    rest="${rest#*|}"
    timed_out="${rest%%|*}"
    message="${rest#*|}"
    if [ -n "$message" ]; then
      printf 'warn: %s\n' "$message"
    else
      printf 'warn: %s\n' "$name"
    fi
    return 0
  fi

  if [ "$run_tests_mode" != "quiet" ]; then
    printf 'pass\n'
  fi
}

run_tests_print_json() {

  local overall_status="$1"
  local pass_count="$2"
  local warn_count="$3"
  local fail_count="$4"
  local skipped_count="$5"
  local entry name status message timed_out rest json_checks=""
  local selected_json=""
  local first=1
  local first_selected=1
  local want_level="$run_tests_json_level"
  local timed_out_json
  local log_status=""
  local log_file=""
  local log_fix=""

  log_status="$(run_tests_log_status_value)"
  log_file="$(run_tests_log_file_value)"
  log_fix="$(run_tests_log_fix_value)"

  for entry in "${run_tests_checks[@]}"; do
    name="${entry%%|*}"
    rest="${entry#*|}"
    status="${rest%%|*}"
    rest="${rest#*|}"
    timed_out="${rest%%|*}"
    message="${rest#*|}"

    case "$want_level" in
      fail)
        [ "$status" = "fail" ] || continue
        ;;
      warn)
        [ "$status" = "fail" ] || [ "$status" = "warn" ] || continue
        ;;
      all)
        ;;
    esac

    if [ "$first" -eq 0 ]; then
      json_checks+=', '
    fi
    if [ "$timed_out" = "1" ]; then
      timed_out_json=true
    else
      timed_out_json=false
    fi
    json_checks+="{\"name\":\"$(run_tests_json_escape "$name")\","
    json_checks+="\"status\":\"$(run_tests_json_escape "$status")\","
    json_checks+="\"message\":\"$(run_tests_json_escape "$message")\","
    json_checks+="\"timed_out\":${timed_out_json}}"
    first=0
  done

  if [ "$run_tests_run_mode" = "changed" ]; then
    for entry in "${run_tests_changed_selected_subsets[@]}"; do
      if [ "$first_selected" -eq 0 ]; then
        selected_json+=', '
      fi
      selected_json+="\"$(run_tests_json_escape "$entry")\""
      first_selected=0
    done
  fi

  printf '{'
  printf '"script":"run-tests",'
  printf '"mode":"%s",' "$(run_tests_json_escape "$run_tests_mode")"
  printf '"overall_status":"%s",' "$(run_tests_json_escape "$overall_status")"
  printf '"pass_count":%s,' "$pass_count"
  printf '"warn_count":%s,' "$warn_count"
  printf '"fail_count":%s,' "$fail_count"
  printf '"skipped_count":%s,' "$skipped_count"
  printf '"json_level":"%s",' "$(run_tests_json_escape "$run_tests_json_level")"
  printf '"checks":[%s],' "$json_checks"
  if [ "$run_tests_run_mode" = "changed" ]; then
    printf '"selected_subsets":[%s],' "$selected_json"
  fi
  printf '"log_status":"%s",' "$(run_tests_json_escape "$log_status")"
  printf '"log_policy":"%s",' "$(run_tests_json_escape "$(run_tests_log_policy_value)")"
  printf '"log_file":"%s"' "$(run_tests_json_escape "$log_file")"
  if [ -n "$log_fix" ]; then
    printf ',"log_fix":"%s"' "$(run_tests_json_escape "$log_fix")"
  fi
  printf '}\n'
}

run_tests_collect_changed_files() {
  local changed_ref_name="$1"
  local -n changed_ref="$changed_ref_name"
  local path

  while IFS= read -r path; do
    [ -n "$path" ] && changed_ref+=("$path")
  done <<EOF
$(
  {
    git diff --name-only --cached --diff-filter=ACDMR
    git diff --name-only --diff-filter=ACDMR
    git ls-files --others --exclude-standard
  } | sed '/^$/d' | sort -u
)
EOF
}

run_tests_changed_needs_docs() {
  case "$1" in
    README.md|CHANGELOG.md|CONTRIBUTING.md|SUPPORT.md|docs/*|repo-automation/docs/*|.github/pull_request_template.md|.github/ISSUE_TEMPLATE/*)
      return 0
      ;;
  esac

  return 1
}

run_tests_changed_needs_version() {
  case "$1" in
    VERSION|README.md|CHANGELOG.md|docs/DECISIONS.md|docs/VERSIONING.md|examples/downstream/.repo-automation.conf.example|repo-automation/manifest.json|repo-automation/bin/repo-automation-install|repo-automation/tests/version-consistency.sh|repo-automation/bin/prepare-release)
      return 0
      ;;
  esac

  return 1
}

run_tests_changed_needs_smoke() {
  case "$1" in
    repo-automation/bin/*|repo-automation/lib/*|repo-automation/tests/*|repo-automation/manifest.json|.github/workflows/*)
      return 0
      ;;
  esac

  return 1
}

run_tests_print_results() {
  local status="${1:-0}"
  local counts
  local pass_count=0
  local warn_count=0
  local fail_count=0
  local skipped_count=0
  local overall_status="pass"

  counts="$(run_tests_counts)"
  IFS=' ' read -r pass_count warn_count fail_count skipped_count <<EOF
$counts
EOF

  if [ "$fail_count" -gt 0 ] || [ "$status" -ne 0 ]; then
    overall_status="fail"
  elif [ "$warn_count" -gt 0 ]; then
    overall_status="warn"
  fi

  if [ "$run_tests_json" -eq 1 ]; then
    run_tests_print_json "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
  else
    run_tests_print_human "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
  fi

  if [ "$fail_count" -gt 0 ] || [ "$status" -ne 0 ]; then
    return 1
  fi

  return 0
}

run_tests_finish() {
  local status="${1:-0}"
  local counts
  local pass_count=0
  local warn_count=0
  local fail_count=0
  local skipped_count=0
  local overall_status="pass"

  if [ "$run_tests_mode" = "explain" ]; then
    counts="$(run_tests_counts)"
    IFS=' ' read -r pass_count warn_count fail_count skipped_count <<EOF
$counts
EOF
    if [ "$fail_count" -gt 0 ] || [ "$status" -ne 0 ]; then
      overall_status="fail"
    elif [ "$warn_count" -gt 0 ]; then
      overall_status="warn"
    fi
    repo_auto_print_final_summary \
      "script=run-tests" \
      "mode=explain" \
      "rc=$status" \
      "url_or_stop=$overall_status" >&2
  fi

  return "$status"
}

run_tests_main() {
  local arg
  local status=0
  local repo_root
  local counts
  local pass_count=0
  local warn_count=0
  local fail_count=0
  local skipped_count=0
  local overall_status="pass"
  local timeout_value="$run_tests_timeout_seconds"

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --help)
        run_tests_usage
        return 0
        ;;
      --summary)
        run_tests_mode="summary"
        ;;
      --audit)
        run_tests_mode="audit"
        run_tests_run_mode="full"
        ;;
      --smoke)
        run_tests_run_mode="smoke"
        ;;
      --docs)
        run_tests_run_mode="docs"
        ;;
      --version)
        run_tests_run_mode="version"
        ;;
      --changed)
        run_tests_run_mode="changed"
        ;;
      --explain)
        run_tests_mode="explain"
        ;;
      --quiet)
        run_tests_mode="quiet"
        ;;
      --timeout=*)
        timeout_value="${arg#--timeout=}"
        if [ -z "$timeout_value" ]; then
          repo_auto_flag_error "empty flag value" "--timeout" "use --timeout=<seconds>" || return 1
          return 1
        fi
        if ! repo_auto_is_positive_integer "$timeout_value"; then
          repo_auto_stop "invalid --timeout value: $timeout_value"
          return 1
        fi
        ;;
      --timeout)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          repo_auto_flag_error "flag format not accepted" "--timeout" "use --timeout=<seconds>" || return 1
        else
          repo_auto_flag_error "missing flag value" "--timeout" "use --timeout=<seconds>" || return 1
        fi
        return 1
        ;;
      --log-file=*)
        run_tests_log_file="${arg#--log-file=}"
        if [ -z "$run_tests_log_file" ]; then
          repo_auto_flag_error "empty flag value" "--log-file" "use --log-file=<path>" || return 1
          return 1
        fi
        run_tests_log_file_explicit=1
        run_tests_log_enabled=1
        ;;
      --log-file)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          repo_auto_flag_error "flag format not accepted" "--log-file" "use --log-file=<path>" || return 1
        else
          repo_auto_flag_error "missing flag value" "--log-file" "use --log-file=<path>" || return 1
        fi
        return 1
        ;;
      --no-log)
        run_tests_log_enabled=0
        run_tests_log_file=""
        run_tests_log_file_explicit=0
        ;;
      --clean-temp)
        run_tests_clean_temp=1
        ;;
      --no-clean-temp)
        run_tests_clean_temp=0
        ;;
      --disk-diagnostic)
        run_tests_disk_diagnostic=1
        ;;
      --json)
        run_tests_json=1
        ;;
      --json-level=*)
        run_tests_json_level="${arg#--json-level=}"
        if [ -z "$run_tests_json_level" ]; then
          repo_auto_flag_error "empty flag value" "--json-level" "use --json-level=<fail|warn|all>" || return 1
          return 1
        fi
        case "$run_tests_json_level" in
          fail|warn|all)
            ;;
          *)
            repo_auto_stop "invalid --json-level value: $run_tests_json_level"
            return 1
            ;;
        esac
        ;;
      --json-level)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          repo_auto_flag_error "flag format not accepted" "--json-level" "use --json-level=<fail|warn|all>" || return 1
        else
          repo_auto_flag_error "missing flag value" "--json-level" "use --json-level=<fail|warn|all>" || return 1
        fi
        return 1
        ;;
      *)
        if [ "${arg#--}" != "$arg" ]; then
          repo_auto_flag_error "unknown flag" "$arg" "run repo-automation/bin/run-tests --help" || return 1
        else
          repo_auto_stop "unknown argument: $arg"
        fi
        return 1
        ;;
    esac
    shift
  done

  run_tests_timeout_seconds="$timeout_value"
  run_tests_ensure_temp_root || {
    run_tests_record_fail "prepare temp root" "failed"
    run_tests_print_results 1
    run_tests_finish 1
    return $?
  }
  run_tests_prune_stale_temp_artifacts
  trap 'run_tests_cleanup_temp_root' EXIT INT TERM
  run_tests_init_log

  repo_root="$(repo_auto_repo_root)" || {
    run_tests_record_fail "resolve repo root" "failed"
    counts="$(run_tests_counts)"
    IFS=' ' read -r pass_count warn_count fail_count skipped_count <<EOF
$counts
EOF
    overall_status="fail"
    if [ "$run_tests_json" -eq 1 ]; then
      run_tests_print_json "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
    else
      run_tests_print_human "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
    fi
    run_tests_finish 1
    return $?
  }

  cd "$repo_root" || {
    run_tests_record_fail "cd repo root" "failed"
    counts="$(run_tests_counts)"
    IFS=' ' read -r pass_count warn_count fail_count skipped_count <<EOF
$counts
EOF
    overall_status="fail"
    if [ "$run_tests_json" -eq 1 ]; then
      run_tests_print_json "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
    else
      run_tests_print_human "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
    fi
    run_tests_finish 1
    return $?
  }

  run_tests_log "$run_tests_start_line"

  if [ "$run_tests_timeout_seconds" -gt 0 ] && ! run_tests_timeout_supported; then
    run_tests_timeout_warn_once
  fi

  if [ "$run_tests_run_mode" = "full" ] && [ "$run_tests_disk_guard_checked" -eq 0 ]; then
    if ! run_tests_disk_guard_check "/"; then
      status=1
      run_tests_print_results "$status"
      run_tests_finish "$status"
      return $?
    fi
  fi

  if [ "$run_tests_run_mode" = "smoke" ]; then
    if [ "$run_tests_disk_guard_checked" -eq 0 ]; then
      if ! run_tests_disk_guard_check "/"; then
        status=1
        run_tests_print_results "$status"
        run_tests_finish "$status"
        return $?
      fi
    fi
    if [ "${RUN_TESTS_SKIP_SMOKE:-0}" = "1" ]; then
      run_tests_record_skip "repo-automation/tests/smoke.sh" "RUN_TESTS_SKIP_SMOKE=1"
    else
      run_tests_run_smoke "repo-automation/tests/smoke.sh" repo-automation/tests/smoke.sh || status=1
    fi
    run_tests_print_results "$status"
    run_tests_finish "$status"
    return $?
  fi

  if [ "$run_tests_run_mode" = "docs" ]; then
    run_tests_run_cmd "repo-automation/tests/docs-check.sh" repo-automation/tests/docs-check.sh || status=1
    run_tests_print_results "$status"
    run_tests_finish "$status"
    return $?
  fi

  if [ "$run_tests_run_mode" = "version" ]; then
    run_tests_run_cmd "repo-automation/tests/version-consistency.sh" repo-automation/tests/version-consistency.sh || status=1
    run_tests_print_results "$status"
    run_tests_finish "$status"
    return $?
  fi

  if [ "$run_tests_run_mode" = "changed" ]; then
    local -a changed_files=()
    local changed_file
    local run_tests_run_smoke_changed=0
    local run_tests_run_docs_changed=0
    local run_tests_run_version_changed=0
    local run_tests_run_smoke_selected=0
    local run_tests_run_unknown_changed=0

    run_tests_changed_selected_subsets=()

    if run_tests_collect_changed_files changed_files; then
      if [ "${#changed_files[@]}" -eq 0 ]; then
        run_tests_run_smoke_changed=1
      else
        for changed_file in "${changed_files[@]}"; do
          local matched=0
          if run_tests_changed_needs_docs "$changed_file"; then
            run_tests_run_docs_changed=1
            matched=1
          fi
          if run_tests_changed_needs_version "$changed_file"; then
            run_tests_run_version_changed=1
            matched=1
          fi
          if run_tests_changed_needs_smoke "$changed_file"; then
            run_tests_run_smoke_changed=1
            matched=1
          fi
          if [ "$matched" -eq 0 ]; then
            run_tests_run_unknown_changed=1
          fi
        done
      fi
    else
      run_tests_run_smoke_changed=1
    fi

    if [ "$run_tests_run_docs_changed" -eq 1 ]; then
      run_tests_changed_selected_subsets+=("docs")
    fi

    if [ "$run_tests_run_version_changed" -eq 1 ]; then
      run_tests_changed_selected_subsets+=("version")
    fi

    if [ "$run_tests_run_smoke_changed" -eq 1 ] || [ "$run_tests_run_unknown_changed" -eq 1 ]; then
      run_tests_changed_selected_subsets+=("smoke")
      run_tests_run_smoke_selected=1
    fi

    if [ "$run_tests_run_smoke_selected" -eq 1 ] && [ "$run_tests_disk_guard_checked" -eq 0 ]; then
      if ! run_tests_disk_guard_check "/"; then
        status=1
        run_tests_print_results "$status"
        run_tests_finish "$status"
        return $?
      fi
    fi

    if [ "$run_tests_run_smoke_selected" -eq 1 ]; then
      if [ "${RUN_TESTS_SKIP_SMOKE:-0}" = "1" ]; then
        run_tests_record_skip "repo-automation/tests/smoke.sh" "RUN_TESTS_SKIP_SMOKE=1"
      else
        run_tests_run_smoke "repo-automation/tests/smoke.sh" repo-automation/tests/smoke.sh || status=1
      fi
    fi

    if [ "$run_tests_run_docs_changed" -eq 1 ]; then
      run_tests_run_cmd "repo-automation/tests/docs-check.sh" repo-automation/tests/docs-check.sh || status=1
    fi

    if [ "$run_tests_run_version_changed" -eq 1 ]; then
      run_tests_run_cmd "repo-automation/tests/version-consistency.sh" repo-automation/tests/version-consistency.sh || status=1
    fi

    run_tests_print_results "$status"
    run_tests_finish "$status"
    return $?
  fi

  while IFS= read -r shell_path; do
    [ -n "$shell_path" ] || continue
    run_tests_run_cmd "bash syntax $shell_path" bash -n "$shell_path" || status=1
  done <<EOF
$(find repo-automation/bin repo-automation/lib repo-automation/tests -type f | LC_ALL=C sort)
EOF

  if command -v shellcheck >/dev/null 2>&1; then
    shellcheck_args=(-e SC2317)
    while IFS= read -r shell_path; do
      [ -n "$shell_path" ] || continue
      shellcheck_args+=("$shell_path")
    done <<EOF
$(find repo-automation/bin repo-automation/lib repo-automation/tests -type f | LC_ALL=C sort)
EOF
    run_tests_run_cmd "shellcheck repo-automation scripts and tests" shellcheck "${shellcheck_args[@]}" || status=1
  else
    run_tests_record_warn "shellcheck not installed locally; skipping shellcheck" "shellcheck unavailable"
  fi

  run_tests_run_cmd "repo-automation/bin/pr-finish --help" bash -c 'repo-automation/bin/pr-finish --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/add-doc-pr --help" bash -c 'repo-automation/bin/add-doc-pr --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/prepare-release --help" bash -c 'repo-automation/bin/prepare-release --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/repo-automation-report-upstream --help" bash -c 'repo-automation/bin/repo-automation-report-upstream --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/repo-doctor --help" bash -c 'repo-automation/bin/repo-doctor --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/failure-log --help" bash -c 'repo-automation/bin/failure-log --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/touched-files --help" bash -c 'repo-automation/bin/touched-files --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/ci-status --help" bash -c 'repo-automation/bin/ci-status --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/ci-watch --help" bash -c 'repo-automation/bin/ci-watch --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/ci-log-dump --help" bash -c 'repo-automation/bin/ci-log-dump --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/status-packet --help" bash -c 'repo-automation/bin/status-packet --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/post-codex-review --help" bash -c 'repo-automation/bin/post-codex-review --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/repo-automation-install --help" bash -c 'repo-automation/bin/repo-automation-install --help >/dev/null' || status=1
  if [ "${RUN_TESTS_SKIP_SMOKE:-0}" = "1" ]; then
    run_tests_record_skip "repo-automation/tests/smoke.sh" "RUN_TESTS_SKIP_SMOKE=1"
  else
    run_tests_run_smoke "repo-automation/tests/smoke.sh" repo-automation/tests/smoke.sh || status=1
  fi
  run_tests_run_cmd "repo-automation/tests/docs-check.sh" repo-automation/tests/docs-check.sh || status=1
  run_tests_run_cmd "repo-automation/tests/version-consistency.sh" repo-automation/tests/version-consistency.sh || status=1

  counts="$(run_tests_counts)"
  IFS=' ' read -r pass_count warn_count fail_count skipped_count <<EOF
$counts
EOF

  if [ "$fail_count" -gt 0 ] || [ "$status" -ne 0 ]; then
    overall_status="fail"
  elif [ "$warn_count" -gt 0 ]; then
    overall_status="warn"
  else
    overall_status="pass"
  fi

  if [ "$run_tests_json" -eq 1 ]; then
    run_tests_print_json       "$overall_status"       "$pass_count"       "$warn_count"       "$fail_count"       "$skipped_count"
  else
    run_tests_print_human       "$overall_status"       "$pass_count"       "$warn_count"       "$fail_count"       "$skipped_count"
  fi

  if [ "$fail_count" -gt 0 ] || [ "$status" -ne 0 ]; then
    run_tests_finish "$status"
    return $?
  fi
  run_tests_finish "$status"
  return $?
}

run_tests_main "$@"
# repo-automation/bin/run-tests EOF
