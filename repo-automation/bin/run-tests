#!/usr/bin/env bash
# repo-automation/bin/run-tests
# shellcheck disable=SC2034

set -u
set -o pipefail

# shellcheck source=/dev/null
source "$(cd "$(dirname "$0")" && pwd)/../lib/common.sh"
# shellcheck source=/dev/null
run_tests_routing_lib="$(cd "$(dirname "$0")" && pwd)/../lib/run-tests-routing.sh"
if [ ! -f "$run_tests_routing_lib" ]; then
  repo_auto_stop "missing required library: repo-automation/lib/run-tests-routing.sh"
  exit 1
fi
# shellcheck source=/dev/null
source "$run_tests_routing_lib"
unset run_tests_routing_lib
# shellcheck source=/dev/null
run_tests_temp_disk_lib="$(cd "$(dirname "$0")" && pwd)/../lib/temp-disk.sh"
if [ ! -f "$run_tests_temp_disk_lib" ]; then
  repo_auto_stop "missing required library: repo-automation/lib/temp-disk.sh"
  exit 1
fi
# shellcheck source=/dev/null
source "$run_tests_temp_disk_lib"
unset run_tests_temp_disk_lib
# shellcheck source=/dev/null
run_tests_failure_lib="$(cd "$(dirname "$0")" && pwd)/../lib/run-tests-failure.sh"
if [ ! -f "$run_tests_failure_lib" ]; then
  repo_auto_stop "missing required library: repo-automation/lib/run-tests-failure.sh"
  exit 1
fi
# shellcheck source=/dev/null
source "$run_tests_failure_lib"
unset run_tests_failure_lib
# shellcheck source=/dev/null
run_tests_results_lib="$(cd "$(dirname "$0")" && pwd)/../lib/run-tests-results.sh"
if [ ! -f "$run_tests_results_lib" ]; then
  repo_auto_stop "missing required library: repo-automation/lib/run-tests-results.sh"
  exit 1
fi
# shellcheck source=/dev/null
source "$run_tests_results_lib"
unset run_tests_results_lib
# shellcheck source=/dev/null
run_tests_json_lib="$(cd "$(dirname "$0")" && pwd)/../lib/run-tests-json.sh"
if [ ! -f "$run_tests_json_lib" ]; then
  repo_auto_stop "missing required library: repo-automation/lib/run-tests-json.sh"
  exit 1
fi
# shellcheck source=/dev/null
source "$run_tests_json_lib"
unset run_tests_json_lib

# shellcheck disable=SC2034
run_tests_timestamp() {
  run_tests_temp_disk_timestamp
}

# shellcheck disable=SC2034
run_tests_mode="summary"
run_tests_run_mode="full"
run_tests_json=0
run_tests_json_level="warn"
run_tests_log_enabled=1
run_tests_log_file=""
run_tests_log_file_explicit=0
run_tests_clean_temp=1
run_tests_disk_diagnostic=0
run_tests_clean_stale_temp=1
run_tests_stale_temp_hours=12
run_tests_df_bin="df"
run_tests_timeout_seconds=120
run_tests_smoke_timeout_seconds=300
run_tests_timeout_available=""
run_tests_timeout_warned=0
TEST_TEMP_ROOT=""
run_tests_temp_root=""
run_tests_disk_guard_checked=0
run_tests_disk_guard_used_percent=""
run_tests_disk_guard_available_percent=""
run_tests_disk_guard_available_bytes=""
run_tests_disk_guard_mountpoint=""
run_tests_disk_guard_filesystem=""
run_tests_disk_guard_low_bytes=1610612736
run_tests_disk_guard_low_percent=15
run_tests_disk_guard_path="/"
run_tests_temp_root_warn_kib=1048576
run_tests_start_line="RUNNING repo automation tests..."
run_tests_next_hint="Next: repo-automation/bin/run-tests --explain"
run_tests_checks=()
run_tests_changed_selected_subsets=()

: \
  "$run_tests_clean_stale_temp" \
  "$run_tests_df_bin" \
  "$run_tests_disk_guard_used_percent" \
  "$run_tests_disk_guard_available_percent" \
  "$run_tests_disk_guard_available_bytes" \
  "$run_tests_disk_guard_mountpoint" \
  "$run_tests_disk_guard_filesystem" \
  "$run_tests_disk_guard_low_bytes" \
  "$run_tests_disk_guard_low_percent" \
  "$run_tests_temp_root_warn_kib"

run_tests_usage() {
  printf 'Usage: repo-automation/bin/run-tests [--summary] [--audit] [--smoke] [--docs] [--version] [--changed] [--explain] [--quiet] [--timeout=<seconds>] [--smoke-timeout=<seconds>] [--log-file=<path>] [--no-log] [--clean-temp|--no-clean-temp] [--disk-diagnostic] [--json] [--json-level=fail|warn|all] [--help]\n'
}


run_tests_info() {
  [ "$run_tests_mode" = "explain" ] || [ "$run_tests_disk_diagnostic" -eq 1 ] || return 0
  printf 'INFO: %s\n' "$*" >&2
}

run_tests_command_string() {
  local arg
  local quoted=""

  for arg in "$@"; do
    quoted+="$(printf '%q ' "$arg")"
  done

  printf '%s' "${quoted% }"
}

run_tests_timeout_supported() {
  if [ -n "$run_tests_timeout_available" ]; then
    [ "$run_tests_timeout_available" = "1" ]
    return $?
  fi

  if command -v timeout >/dev/null 2>&1; then
    run_tests_timeout_available=1
  else
    run_tests_timeout_available=0
  fi

  [ "$run_tests_timeout_available" = "1" ]
}

run_tests_timeout_warn_once() {
  if [ "$run_tests_timeout_warned" -eq 1 ]; then
    return 0
  fi

  run_tests_timeout_warned=1
  run_tests_record_warn "timeout support unavailable" "timeout command not found; running checks without per-check timeout guards"
}

run_tests_init_log() {
  if [ "$run_tests_log_enabled" -ne 1 ]; then
    return 0
  fi

  if [ -z "$run_tests_log_file" ]; then
    run_tests_log_file="$run_tests_temp_root/run-tests.log"
  fi

  run_tests_ensure_log_parent || {
    run_tests_log_enabled=0
    run_tests_log_file=""
    return 0
  }

  : >"$run_tests_log_file" 2>/dev/null || {
    run_tests_log_enabled=0
    run_tests_log_file=""
    return 0
  }
}

run_tests_log() {
  if [ "$run_tests_log_enabled" -eq 1 ] && [ -n "$run_tests_log_file" ]; then
    run_tests_ensure_log_parent || {
      run_tests_log_enabled=0
      run_tests_log_file=""
      return 0
    }
    printf '%s\n' "$*" >>"$run_tests_log_file"
  fi
}

run_tests_run_cmd() {
  local label="$1"
  shift
  local command_string
  local exit_code=0
  local timed_out=0
  local timeout_seconds="$run_tests_timeout_seconds"
  local use_timeout=0

  command_string="$(run_tests_command_string "$@")"
  run_tests_log "CHECK START: $label"
  run_tests_log "COMMAND: $command_string"

  if [ "$timeout_seconds" -gt 0 ] && run_tests_timeout_supported; then
    use_timeout=1
  elif [ "$timeout_seconds" -gt 0 ]; then
    run_tests_timeout_warn_once
  fi

  if [ "$run_tests_log_enabled" -eq 1 ] && [ -n "$run_tests_log_file" ]; then
    run_tests_ensure_log_parent || {
      run_tests_log_enabled=0
      run_tests_log_file=""
    }
  fi

  if [ "$run_tests_log_enabled" -eq 1 ] && [ -n "$run_tests_log_file" ]; then
    if [ "$use_timeout" -eq 1 ]; then
      timeout "${timeout_seconds}s" "$@" >>"$run_tests_log_file" 2>&1
      exit_code=$?
    else
      "$@" >>"$run_tests_log_file" 2>&1
      exit_code=$?
    fi
  else
    if [ "$use_timeout" -eq 1 ]; then
      timeout "${timeout_seconds}s" "$@" >/dev/null 2>&1
      exit_code=$?
    else
      "$@" >/dev/null 2>&1
      exit_code=$?
    fi
  fi

  if [ "$exit_code" -eq 0 ]; then
    run_tests_record_pass "$label" "passed"
    run_tests_log "CHECK END: $label"
    return 0
  fi

  if [ "$use_timeout" -eq 1 ] && [ "$exit_code" -eq 124 ]; then
    timed_out=1
    run_tests_record_fail "$label" "timed out after ${timeout_seconds}s" "$timed_out"
  else
    run_tests_record_fail "$label" "failed" "0"
  fi
  run_tests_log "CHECK END: $label"
  return 1
}








run_tests_print_failure_fix() {
  local first_entry=""
  local name=""
  local rest=""
  local message=""

  if [ "$run_tests_mode" != "explain" ]; then
    repo_auto_print_failure_footer fix "$run_tests_next_hint"
    return 0
  fi

  if [ -n "$run_tests_log_file" ]; then
    repo_auto_print_failure_footer fix "inspect log: $run_tests_log_file"
    return 0
  fi

  first_entry="$(run_tests_first_entry_by_status fail 2>/dev/null || true)"
  if [ -n "$first_entry" ]; then
    name="${first_entry%%|*}"
    rest="${first_entry#*|}"
    rest="${rest#*|}"
    rest="${rest#*|}"
    message="$rest"
    if [ -n "$message" ] && [ "$message" != "failed" ]; then
      repo_auto_print_failure_footer fix "rerun $name directly after inspecting the failure details"
    elif [ "$name" = "shellcheck repo-automation scripts and tests" ]; then
      repo_auto_print_failure_footer fix "rerun repo-automation/bin/shellcheck-ci-parity"
    elif [ "$name" = "shellcheck path discovery" ]; then
      repo_auto_print_failure_footer fix "rerun repo-automation/bin/shellcheck-ci-parity --print-paths"
    else
      repo_auto_print_failure_footer fix "rerun $name directly"
    fi
    return 0
  fi

  repo_auto_print_failure_footer fix "inspect the failing test details above"
}

run_tests_run_smoke() {
  local label="$1"
  shift
  local command_string
  local output_file
  local exit_code=0
  local timed_out=0
  local timeout_seconds="$run_tests_smoke_timeout_seconds"
  local use_timeout=0
  local failure_message="failed"

  command_string="$(run_tests_command_string "$@")"
  output_file="$run_tests_temp_root/run-tests-smoke-$(run_tests_timestamp)-$$.log"

  run_tests_log "CHECK START: $label"
  run_tests_log "COMMAND: $command_string"

  if [ "$timeout_seconds" -gt 0 ] && run_tests_timeout_supported; then
    use_timeout=1
  elif [ "$timeout_seconds" -gt 0 ]; then
    run_tests_timeout_warn_once
  fi

  if [ "$use_timeout" -eq 1 ]; then
    timeout "${timeout_seconds}s" "$@" >"$output_file" 2>&1
    exit_code=$?
  else
    "$@" >"$output_file" 2>&1
    exit_code=$?
  fi

  if [ "$run_tests_log_enabled" -eq 1 ] && [ -n "$run_tests_log_file" ]; then
    run_tests_ensure_log_parent || {
      run_tests_log_enabled=0
      run_tests_log_file=""
    }
  fi

  if [ "$run_tests_log_enabled" -eq 1 ] && [ -n "$run_tests_log_file" ]; then
    cat "$output_file" >>"$run_tests_log_file"
  fi

  if [ "$exit_code" -eq 0 ]; then
    run_tests_record_pass "$label" "passed"
    run_tests_log "CHECK END: $label"
    rm -f "$output_file" >/dev/null 2>&1 || true
    return 0
  fi

  if [ "$use_timeout" -eq 1 ] && [ "$exit_code" -eq 124 ]; then
    timed_out=1
  fi

  if [ "$timed_out" -eq 1 ]; then
    failure_message="smoke suite timed out after ${timeout_seconds}s"
  else
    failure_message="$(run_tests_extract_smoke_failure "$output_file")"
  fi

  run_tests_record_fail "$label" "$failure_message" "$timed_out"
  if [ "$run_tests_json" -eq 0 ]; then
    run_tests_print_smoke_failure_excerpt "$output_file"
  fi
  run_tests_log "CHECK END: $label"
  rm -f "$output_file" >/dev/null 2>&1 || true
  return 1
}

run_tests_print_human() {
  local overall_status="$1"
  local pass_count="$2"
  local warn_count="$3"
  local fail_count="$4"
  local skipped_count="$5"
  local entry name status message timed_out rest first_entry

  if [ "$run_tests_mode" = "explain" ]; then
    printf 'TEST_TEMP_ROOT=%s\n' "$TEST_TEMP_ROOT"
    printf 'pass=%s warn=%s fail=%s skipped=%s\n' "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
    printf 'temp_cleanup=%s\n' "$([ "$run_tests_clean_temp" -eq 1 ] && printf enabled || printf disabled)"
    printf 'stale_temp_hours=%s\n' "$run_tests_stale_temp_hours"
    printf 'disk_guard=enabled\n'
    printf 'log_policy=%s\n' "$(run_tests_log_policy_value)"
    if [ "$run_tests_run_mode" = "changed" ]; then
      if [ "${#run_tests_changed_selected_subsets[@]}" -eq 0 ]; then
        printf 'Changed subsets: none\n'
      else
        printf 'Changed subsets: %s\n' "${run_tests_changed_selected_subsets[*]}"
      fi
    fi
  fi

  if [ "$run_tests_mode" = "explain" ]; then
    for entry in "${run_tests_checks[@]}"; do
      name="${entry%%|*}"
      rest="${entry#*|}"
      status="${rest%%|*}"
      rest="${rest#*|}"
      timed_out="${rest%%|*}"
      message="${rest#*|}"
      printf '%s: %s - %s\n' "${status^^}" "$name" "$message"
    done
  fi

  if [ "$fail_count" -gt 0 ]; then
    first_entry="$(run_tests_first_entry_by_status fail)"
    name="${first_entry%%|*}"
    rest="${first_entry#*|}"
    status="${rest%%|*}"
    rest="${rest#*|}"
    timed_out="${rest%%|*}"
    message="${rest#*|}"
    if [ -n "$message" ] && [ "$message" != "failed" ]; then
      repo_auto_print_failure_footer fail "$name - $message"
    else
      repo_auto_print_failure_footer fail "$name"
    fi
    if [ -n "$run_tests_log_file" ]; then
      if run_tests_log_will_be_cleaned; then
        run_tests_print_failure_fix_from_log "$run_tests_log_file" 1
      else
        run_tests_print_failure_fix_from_log "$run_tests_log_file" 0
      fi
    elif [ "$run_tests_mode" != "quiet" ]; then
      run_tests_print_failure_fix
    fi
    return 0
  fi

  if [ "$warn_count" -gt 0 ]; then
    first_entry="$(run_tests_first_entry_by_status warn)"
    name="${first_entry%%|*}"
    rest="${first_entry#*|}"
    status="${rest%%|*}"
    rest="${rest#*|}"
    timed_out="${rest%%|*}"
    message="${rest#*|}"
    if [ -n "$message" ]; then
      printf 'warn: %s\n' "$message"
    else
      printf 'warn: %s\n' "$name"
    fi
    return 0
  fi

  if [ "$run_tests_mode" != "quiet" ]; then
    printf 'pass\n'
  fi
}


run_tests_print_results() {
  local status="${1:-0}"
  local counts
  local pass_count=0
  local warn_count=0
  local fail_count=0
  local skipped_count=0
  local overall_status="pass"

  counts="$(run_tests_counts)"
  IFS=' ' read -r pass_count warn_count fail_count skipped_count <<EOF
$counts
EOF

  if [ "$fail_count" -gt 0 ] || [ "$status" -ne 0 ]; then
    overall_status="fail"
  elif [ "$warn_count" -gt 0 ]; then
    overall_status="warn"
  fi

  if [ "$run_tests_json" -eq 1 ]; then
    run_tests_print_json "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
  else
    run_tests_print_human "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
  fi

  if [ "$fail_count" -gt 0 ] || [ "$status" -ne 0 ]; then
    return 1
  fi

  return 0
}

run_tests_finish() {
  local status="${1:-0}"
  local counts
  local pass_count=0
  local warn_count=0
  local fail_count=0
  local skipped_count=0
  local overall_status="pass"

  if [ "$run_tests_mode" = "explain" ]; then
    counts="$(run_tests_counts)"
    IFS=' ' read -r pass_count warn_count fail_count skipped_count <<EOF
$counts
EOF
    if [ "$fail_count" -gt 0 ] || [ "$status" -ne 0 ]; then
      overall_status="fail"
    elif [ "$warn_count" -gt 0 ]; then
      overall_status="warn"
    fi
    repo_auto_print_final_summary \
      "script=run-tests" \
      "mode=explain" \
      "rc=$status" \
      "url_or_stop=$overall_status" >&2
  fi

  return "$status"
}

run_tests_source_optional_config() {
  local config_path="$1"
  local secret_scan_label="$2"
  local load_label="$3"
  local secret_scan_message="$4"
  local load_message="$5"

  if [ ! -f "$config_path" ]; then
    return 0
  fi

  if ! repo_auto_secret_scan_file "$config_path" >/dev/null 2>&1; then
    run_tests_record_fail "$secret_scan_label" "$secret_scan_message"
    return 1
  fi

  # shellcheck source=/dev/null
  if ! . "$config_path" >/dev/null 2>&1; then
    run_tests_record_fail "$load_label" "$load_message"
    return 1
  fi

  return 0
}

run_tests_main() {
  local arg
  local status=0
  local repo_root
  local counts
  local pass_count=0
  local warn_count=0
  local fail_count=0
  local skipped_count=0
  local overall_status="pass"
  local timeout_value="$run_tests_timeout_seconds"
  local timeout_explicit=0
  local smoke_timeout_value="$run_tests_smoke_timeout_seconds"
  local smoke_timeout_explicit=0
  local run_tests_env_REPO_AUTOMATION_TEST_TEMP_ROOT_set=0
  local run_tests_env_REPO_AUTOMATION_TEST_TEMP_ROOT=""
  local run_tests_env_REPO_AUTOMATION_CLEAN_STALE_TEMP_set=0
  local run_tests_env_REPO_AUTOMATION_CLEAN_STALE_TEMP=""
  local run_tests_env_REPO_AUTOMATION_STALE_TEMP_HOURS_set=0
  local run_tests_env_REPO_AUTOMATION_STALE_TEMP_HOURS=""
  local run_tests_env_REPO_AUTOMATION_RUN_TESTS_DISK_GUARD_PATH_set=0
  local run_tests_env_REPO_AUTOMATION_RUN_TESTS_DISK_GUARD_PATH=""
  local run_tests_env_REPO_AUTOMATION_RUN_TESTS_DISK_LOW_BYTES_set=0
  local run_tests_env_REPO_AUTOMATION_RUN_TESTS_DISK_LOW_BYTES=""
  local run_tests_env_REPO_AUTOMATION_RUN_TESTS_DISK_LOW_PERCENT_set=0
  local run_tests_env_REPO_AUTOMATION_RUN_TESTS_DISK_LOW_PERCENT=""
  local run_tests_env_REPO_AUTOMATION_RUN_TESTS_TEMP_WARN_KIB_set=0
  local run_tests_env_REPO_AUTOMATION_RUN_TESTS_TEMP_WARN_KIB=""
  local run_tests_env_RUN_TESTS_DF_BIN_set=0
  local run_tests_env_RUN_TESTS_DF_BIN=""
  local run_tests_env_REPO_AUTOMATION_DF_BIN_set=0
  local run_tests_env_REPO_AUTOMATION_DF_BIN=""

  if [ "${REPO_AUTOMATION_TEST_TEMP_ROOT+x}" = x ]; then
    run_tests_env_REPO_AUTOMATION_TEST_TEMP_ROOT_set=1
    run_tests_env_REPO_AUTOMATION_TEST_TEMP_ROOT="$REPO_AUTOMATION_TEST_TEMP_ROOT"
  fi
  if [ "${REPO_AUTOMATION_CLEAN_STALE_TEMP+x}" = x ]; then
    run_tests_env_REPO_AUTOMATION_CLEAN_STALE_TEMP_set=1
    run_tests_env_REPO_AUTOMATION_CLEAN_STALE_TEMP="$REPO_AUTOMATION_CLEAN_STALE_TEMP"
  fi
  if [ "${REPO_AUTOMATION_STALE_TEMP_HOURS+x}" = x ]; then
    run_tests_env_REPO_AUTOMATION_STALE_TEMP_HOURS_set=1
    run_tests_env_REPO_AUTOMATION_STALE_TEMP_HOURS="$REPO_AUTOMATION_STALE_TEMP_HOURS"
  fi
  if [ "${REPO_AUTOMATION_RUN_TESTS_DISK_GUARD_PATH+x}" = x ]; then
    run_tests_env_REPO_AUTOMATION_RUN_TESTS_DISK_GUARD_PATH_set=1
    run_tests_env_REPO_AUTOMATION_RUN_TESTS_DISK_GUARD_PATH="$REPO_AUTOMATION_RUN_TESTS_DISK_GUARD_PATH"
  fi
  if [ "${REPO_AUTOMATION_RUN_TESTS_DISK_LOW_BYTES+x}" = x ]; then
    run_tests_env_REPO_AUTOMATION_RUN_TESTS_DISK_LOW_BYTES_set=1
    run_tests_env_REPO_AUTOMATION_RUN_TESTS_DISK_LOW_BYTES="$REPO_AUTOMATION_RUN_TESTS_DISK_LOW_BYTES"
  fi
  if [ "${REPO_AUTOMATION_RUN_TESTS_DISK_LOW_PERCENT+x}" = x ]; then
    run_tests_env_REPO_AUTOMATION_RUN_TESTS_DISK_LOW_PERCENT_set=1
    run_tests_env_REPO_AUTOMATION_RUN_TESTS_DISK_LOW_PERCENT="$REPO_AUTOMATION_RUN_TESTS_DISK_LOW_PERCENT"
  fi
  if [ "${REPO_AUTOMATION_RUN_TESTS_TEMP_WARN_KIB+x}" = x ]; then
    run_tests_env_REPO_AUTOMATION_RUN_TESTS_TEMP_WARN_KIB_set=1
    run_tests_env_REPO_AUTOMATION_RUN_TESTS_TEMP_WARN_KIB="$REPO_AUTOMATION_RUN_TESTS_TEMP_WARN_KIB"
  fi
  if [ "${RUN_TESTS_DF_BIN+x}" = x ]; then
    run_tests_env_RUN_TESTS_DF_BIN_set=1
    run_tests_env_RUN_TESTS_DF_BIN="$RUN_TESTS_DF_BIN"
  fi
  if [ "${REPO_AUTOMATION_DF_BIN+x}" = x ]; then
    run_tests_env_REPO_AUTOMATION_DF_BIN_set=1
    run_tests_env_REPO_AUTOMATION_DF_BIN="$REPO_AUTOMATION_DF_BIN"
  fi

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --help)
        run_tests_usage
        return 0
        ;;
      --summary)
        run_tests_mode="summary"
        ;;
      --audit)
        run_tests_mode="audit"
        run_tests_run_mode="full"
        ;;
      --smoke)
        run_tests_run_mode="smoke"
        ;;
      --docs)
        run_tests_run_mode="docs"
        ;;
      --version)
        run_tests_run_mode="version"
        ;;
      --changed)
        run_tests_run_mode="changed"
        ;;
      --explain)
        run_tests_mode="explain"
        ;;
      --quiet)
        run_tests_mode="quiet"
        ;;
      --timeout=*)
        timeout_value="${arg#--timeout=}"
        if [ -z "$timeout_value" ]; then
          repo_auto_flag_error "empty flag value" "--timeout" "use --timeout=<seconds>" || return 1
          return 1
        fi
        if ! repo_auto_is_positive_integer "$timeout_value"; then
          repo_auto_stop "invalid --timeout value: $timeout_value"
          return 1
        fi
        timeout_explicit=1
        ;;
      --timeout)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          repo_auto_flag_error "flag format not accepted" "--timeout" "use --timeout=<seconds>" || return 1
        else
          repo_auto_flag_error "missing flag value" "--timeout" "use --timeout=<seconds>" || return 1
        fi
        return 1
        ;;
      --smoke-timeout=*)
        smoke_timeout_value="${arg#--smoke-timeout=}"
        if [ -z "$smoke_timeout_value" ]; then
          repo_auto_flag_error "empty flag value" "--smoke-timeout" "use --smoke-timeout=<seconds>" || return 1
          return 1
        fi
        if ! repo_auto_is_positive_integer "$smoke_timeout_value"; then
          repo_auto_stop "invalid --smoke-timeout value: $smoke_timeout_value"
          return 1
        fi
        smoke_timeout_explicit=1
        ;;
      --smoke-timeout)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          repo_auto_flag_error "flag format not accepted" "--smoke-timeout" "use --smoke-timeout=<seconds>" || return 1
        else
          repo_auto_flag_error "missing flag value" "--smoke-timeout" "use --smoke-timeout=<seconds>" || return 1
        fi
        return 1
        ;;
      --log-file=*)
        run_tests_log_file="${arg#--log-file=}"
        if [ -z "$run_tests_log_file" ]; then
          repo_auto_flag_error "empty flag value" "--log-file" "use --log-file=<path>" || return 1
          return 1
        fi
        run_tests_log_file_explicit=1
        run_tests_log_enabled=1
        ;;
      --log-file)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          repo_auto_flag_error "flag format not accepted" "--log-file" "use --log-file=<path>" || return 1
        else
          repo_auto_flag_error "missing flag value" "--log-file" "use --log-file=<path>" || return 1
        fi
        return 1
        ;;
      --no-log)
        run_tests_log_enabled=0
        run_tests_log_file=""
        run_tests_log_file_explicit=0
        : "$run_tests_log_file_explicit"
        ;;
      --clean-temp)
        run_tests_clean_temp=1
        ;;
      --no-clean-temp)
        run_tests_clean_temp=0
        ;;
      --disk-diagnostic)
        run_tests_disk_diagnostic=1
        ;;
      --json)
        run_tests_json=1
        ;;
      --json-level=*)
        run_tests_json_level="${arg#--json-level=}"
        if [ -z "$run_tests_json_level" ]; then
          repo_auto_flag_error "empty flag value" "--json-level" "use --json-level=<fail|warn|all>" || return 1
          return 1
        fi
        case "$run_tests_json_level" in
          fail|warn|all)
            ;;
          *)
            repo_auto_stop "invalid --json-level value: $run_tests_json_level"
            return 1
            ;;
        esac
        ;;
      --json-level)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          repo_auto_flag_error "flag format not accepted" "--json-level" "use --json-level=<fail|warn|all>" || return 1
        else
          repo_auto_flag_error "missing flag value" "--json-level" "use --json-level=<fail|warn|all>" || return 1
        fi
        return 1
        ;;
      *)
        if [ "${arg#--}" != "$arg" ]; then
          repo_auto_flag_error "unknown flag" "$arg" "run repo-automation/bin/run-tests --help" || return 1
        else
          repo_auto_stop "unknown argument: $arg"
        fi
        return 1
        ;;
    esac
    shift
  done

  repo_root="$(repo_auto_repo_root)" || {
    run_tests_record_fail "resolve repo root" "failed"
    counts="$(run_tests_counts)"
    IFS=' ' read -r pass_count warn_count fail_count skipped_count <<EOF
$counts
EOF
    overall_status="fail"
    if [ "$run_tests_json" -eq 1 ]; then
      run_tests_print_json "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
    else
      run_tests_print_human "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
    fi
    run_tests_finish 1
    return $?
  }

  if ! run_tests_source_optional_config \
    "$repo_root/.repo-automation.conf" \
    "config secret scan" \
    "config load" \
    "possible secret markers found in .repo-automation.conf" \
    "failed to source .repo-automation.conf"; then
    status=1
  fi
  if [ "$status" -eq 0 ]; then
    if ! run_tests_source_optional_config \
      "$repo_root/.repo-automation.local.conf" \
      "local config secret scan" \
      "local config load" \
      "possible secret markers found in .repo-automation.local.conf" \
      "failed to source .repo-automation.local.conf"; then
      status=1
    fi
  fi

  if [ "$status" -ne 0 ]; then
    counts="$(run_tests_counts)"
    IFS=' ' read -r pass_count warn_count fail_count skipped_count <<EOF
$counts
EOF
    overall_status="fail"
    if [ "$run_tests_json" -eq 1 ]; then
      run_tests_print_json "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
    else
      run_tests_print_human "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
    fi
    run_tests_finish 1
    return $?
  fi

  if [ "$run_tests_env_REPO_AUTOMATION_TEST_TEMP_ROOT_set" -eq 1 ]; then
    REPO_AUTOMATION_TEST_TEMP_ROOT="$run_tests_env_REPO_AUTOMATION_TEST_TEMP_ROOT"
  fi
  if [ "$run_tests_env_REPO_AUTOMATION_CLEAN_STALE_TEMP_set" -eq 1 ]; then
    REPO_AUTOMATION_CLEAN_STALE_TEMP="$run_tests_env_REPO_AUTOMATION_CLEAN_STALE_TEMP"
  fi
  if [ "$run_tests_env_REPO_AUTOMATION_STALE_TEMP_HOURS_set" -eq 1 ]; then
    REPO_AUTOMATION_STALE_TEMP_HOURS="$run_tests_env_REPO_AUTOMATION_STALE_TEMP_HOURS"
  fi
  if [ "$run_tests_env_REPO_AUTOMATION_RUN_TESTS_DISK_GUARD_PATH_set" -eq 1 ]; then
    REPO_AUTOMATION_RUN_TESTS_DISK_GUARD_PATH="$run_tests_env_REPO_AUTOMATION_RUN_TESTS_DISK_GUARD_PATH"
  fi
  if [ "$run_tests_env_REPO_AUTOMATION_RUN_TESTS_DISK_LOW_BYTES_set" -eq 1 ]; then
    REPO_AUTOMATION_RUN_TESTS_DISK_LOW_BYTES="$run_tests_env_REPO_AUTOMATION_RUN_TESTS_DISK_LOW_BYTES"
  fi
  if [ "$run_tests_env_REPO_AUTOMATION_RUN_TESTS_DISK_LOW_PERCENT_set" -eq 1 ]; then
    REPO_AUTOMATION_RUN_TESTS_DISK_LOW_PERCENT="$run_tests_env_REPO_AUTOMATION_RUN_TESTS_DISK_LOW_PERCENT"
  fi
  if [ "$run_tests_env_REPO_AUTOMATION_RUN_TESTS_TEMP_WARN_KIB_set" -eq 1 ]; then
    REPO_AUTOMATION_RUN_TESTS_TEMP_WARN_KIB="$run_tests_env_REPO_AUTOMATION_RUN_TESTS_TEMP_WARN_KIB"
  fi
  if [ "$run_tests_env_RUN_TESTS_DF_BIN_set" -eq 1 ]; then
    RUN_TESTS_DF_BIN="$run_tests_env_RUN_TESTS_DF_BIN"
  fi
  if [ "$run_tests_env_REPO_AUTOMATION_DF_BIN_set" -eq 1 ]; then
    REPO_AUTOMATION_DF_BIN="$run_tests_env_REPO_AUTOMATION_DF_BIN"
  fi
  if [ "$run_tests_env_REPO_AUTOMATION_TEST_TEMP_ROOT_set" -eq 0 ] && [ -z "${REPO_AUTOMATION_TEST_TEMP_ROOT:-}" ]; then
    unset REPO_AUTOMATION_TEST_TEMP_ROOT
  fi

  if ! run_tests_temp_disk_resolve_runtime_config; then
    run_tests_record_fail "resolve temp/disk config" "${run_tests_temp_disk_config_error:-failed}"
    counts="$(run_tests_counts)"
    IFS=' ' read -r pass_count warn_count fail_count skipped_count <<EOF
$counts
EOF
    overall_status="fail"
    if [ "$run_tests_json" -eq 1 ]; then
      run_tests_print_json "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
    else
      run_tests_print_human "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
    fi
    run_tests_finish 1
    return $?
  fi

  case "$run_tests_clean_stale_temp" in
    0|1)
      ;;
    *)
      run_tests_record_fail "resolve temp/disk config" "invalid REPO_AUTOMATION_CLEAN_STALE_TEMP value"
      counts="$(run_tests_counts)"
      IFS=' ' read -r pass_count warn_count fail_count skipped_count <<EOF
$counts
EOF
      overall_status="fail"
      if [ "$run_tests_json" -eq 1 ]; then
        run_tests_print_json "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
      else
        run_tests_print_human "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
      fi
      run_tests_finish 1
      return $?
      ;;
  esac

  run_tests_timeout_seconds="$timeout_value"
  if [ "$smoke_timeout_explicit" -eq 0 ] && [ "$timeout_explicit" -eq 1 ]; then
    smoke_timeout_value="$timeout_value"
  fi
  run_tests_smoke_timeout_seconds="$smoke_timeout_value"
  run_tests_ensure_temp_root || {
    run_tests_record_fail "prepare temp root" "failed"
    run_tests_print_results 1
    run_tests_finish 1
    return $?
  }
  run_tests_prune_stale_temp_artifacts
  trap 'run_tests_cleanup_temp_root' EXIT INT TERM
  run_tests_init_log

  cd "$repo_root" || {
    run_tests_record_fail "cd repo root" "failed"
    counts="$(run_tests_counts)"
    IFS=' ' read -r pass_count warn_count fail_count skipped_count <<EOF
$counts
EOF
    overall_status="fail"
    if [ "$run_tests_json" -eq 1 ]; then
      run_tests_print_json "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
    else
      run_tests_print_human "$overall_status" "$pass_count" "$warn_count" "$fail_count" "$skipped_count"
    fi
    run_tests_finish 1
    return $?
  }

  run_tests_log "$run_tests_start_line"

  if [ "$run_tests_timeout_seconds" -gt 0 ] && ! run_tests_timeout_supported; then
    run_tests_timeout_warn_once
  fi

  if [ "$run_tests_run_mode" = "full" ] && [ "$run_tests_disk_guard_checked" -eq 0 ]; then
    if ! run_tests_disk_guard_check "$run_tests_disk_guard_path"; then
      status=1
      run_tests_print_results "$status"
      run_tests_finish "$status"
      return $?
    fi
  fi

  if [ "$run_tests_run_mode" = "smoke" ]; then
    if [ "$run_tests_disk_guard_checked" -eq 0 ]; then
      if ! run_tests_disk_guard_check "$run_tests_disk_guard_path"; then
        status=1
        run_tests_print_results "$status"
        run_tests_finish "$status"
        return $?
      fi
    fi
    if [ "${RUN_TESTS_SKIP_SMOKE:-0}" = "1" ]; then
      run_tests_record_skip "repo-automation/tests/smoke.sh" "RUN_TESTS_SKIP_SMOKE=1"
    else
      run_tests_run_smoke "repo-automation/tests/smoke.sh" repo-automation/tests/smoke.sh || status=1
    fi
    run_tests_print_results "$status"
    run_tests_finish "$status"
    return $?
  fi

  if [ "$run_tests_run_mode" = "docs" ]; then
    run_tests_run_cmd "repo-automation/tests/docs-check.sh" repo-automation/tests/docs-check.sh || status=1
    run_tests_print_results "$status"
    run_tests_finish "$status"
    return $?
  fi

  if [ "$run_tests_run_mode" = "version" ]; then
    run_tests_run_cmd "repo-automation/tests/version-consistency.sh" repo-automation/tests/version-consistency.sh || status=1
    run_tests_print_results "$status"
    run_tests_finish "$status"
    return $?
  fi

  if [ "$run_tests_run_mode" = "changed" ]; then
    local -a changed_files=()
    local changed_file
    local run_tests_run_smoke_changed=0
    local run_tests_run_docs_changed=0
    local run_tests_run_version_changed=0
    local run_tests_run_smoke_selected=0
    local run_tests_run_unknown_changed=0

    run_tests_changed_selected_subsets=()

    if run_tests_collect_changed_files changed_files; then
      if [ "${#changed_files[@]}" -eq 0 ]; then
        run_tests_run_smoke_changed=1
      else
        for changed_file in "${changed_files[@]}"; do
          local matched=0
          if run_tests_changed_needs_docs "$changed_file"; then
            run_tests_run_docs_changed=1
            matched=1
          fi
          if run_tests_changed_needs_version "$changed_file"; then
            run_tests_run_version_changed=1
            matched=1
          fi
          if run_tests_changed_needs_smoke "$changed_file"; then
            run_tests_run_smoke_changed=1
            matched=1
          fi
          if [ "$matched" -eq 0 ]; then
            run_tests_run_unknown_changed=1
          fi
        done
      fi
    else
      run_tests_run_smoke_changed=1
    fi

    if [ "$run_tests_run_docs_changed" -eq 1 ]; then
      run_tests_changed_selected_subsets+=("docs")
    fi

    if [ "$run_tests_run_version_changed" -eq 1 ]; then
      run_tests_changed_selected_subsets+=("version")
    fi

    if [ "$run_tests_run_smoke_changed" -eq 1 ] || [ "$run_tests_run_unknown_changed" -eq 1 ]; then
      run_tests_changed_selected_subsets+=("smoke")
      run_tests_run_smoke_selected=1
    fi

    if [ "$run_tests_run_smoke_selected" -eq 1 ] && [ "$run_tests_disk_guard_checked" -eq 0 ]; then
      if ! run_tests_disk_guard_check "$run_tests_disk_guard_path"; then
        status=1
        run_tests_print_results "$status"
        run_tests_finish "$status"
        return $?
      fi
    fi

    if [ "$run_tests_run_smoke_selected" -eq 1 ]; then
      if [ "${RUN_TESTS_SKIP_SMOKE:-0}" = "1" ]; then
        run_tests_record_skip "repo-automation/tests/smoke.sh" "RUN_TESTS_SKIP_SMOKE=1"
      else
        run_tests_run_smoke "repo-automation/tests/smoke.sh" repo-automation/tests/smoke.sh || status=1
      fi
    fi

    if [ "$run_tests_run_docs_changed" -eq 1 ]; then
      run_tests_run_cmd "repo-automation/tests/docs-check.sh" repo-automation/tests/docs-check.sh || status=1
    fi

    if [ "$run_tests_run_version_changed" -eq 1 ]; then
      run_tests_run_cmd "repo-automation/tests/version-consistency.sh" repo-automation/tests/version-consistency.sh || status=1
    fi

    run_tests_print_results "$status"
    run_tests_finish "$status"
    return $?
  fi

  shellcheck_paths_file="$run_tests_temp_root/run-tests-shellcheck-paths-$$.txt"
  if repo-automation/bin/shellcheck-ci-parity --print-paths >"$shellcheck_paths_file" 2>/dev/null &&
    [ -s "$shellcheck_paths_file" ]; then
    while IFS= read -r shell_path; do
      [ -n "$shell_path" ] || continue
      run_tests_run_cmd "bash syntax $shell_path" bash -n "$shell_path" || status=1
    done < "$shellcheck_paths_file"

    if command -v shellcheck >/dev/null 2>&1; then
      shellcheck_args=(-e SC2317)
      while IFS= read -r shell_path; do
        [ -n "$shell_path" ] || continue
        shellcheck_args+=("$shell_path")
      done < "$shellcheck_paths_file"
      run_tests_run_cmd "shellcheck repo-automation scripts and tests" shellcheck "${shellcheck_args[@]}" || status=1
    else
      run_tests_record_warn "shellcheck not installed locally; skipping shellcheck" "shellcheck unavailable"
    fi
  else
    run_tests_record_fail "shellcheck path discovery" "failed" "0"
    status=1
  fi

  run_tests_run_cmd "repo-automation/bin/pr-finish --help" bash -c 'repo-automation/bin/pr-finish --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/add-doc-pr --help" bash -c 'repo-automation/bin/add-doc-pr --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/prepare-release --help" bash -c 'repo-automation/bin/prepare-release --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/repo-automation-report-upstream --help" bash -c 'repo-automation/bin/repo-automation-report-upstream --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/repo-doctor --help" bash -c 'repo-automation/bin/repo-doctor --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/failure-log --help" bash -c 'repo-automation/bin/failure-log --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/touched-files --help" bash -c 'repo-automation/bin/touched-files --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/ci-status --help" bash -c 'repo-automation/bin/ci-status --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/ci-watch --help" bash -c 'repo-automation/bin/ci-watch --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/ci-log-dump --help" bash -c 'repo-automation/bin/ci-log-dump --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/status-packet --help" bash -c 'repo-automation/bin/status-packet --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/post-codex-review --help" bash -c 'repo-automation/bin/post-codex-review --help >/dev/null' || status=1
  run_tests_run_cmd "repo-automation/bin/repo-automation-install --help" bash -c 'repo-automation/bin/repo-automation-install --help >/dev/null' || status=1
  if [ "${RUN_TESTS_SKIP_SMOKE:-0}" = "1" ]; then
    run_tests_record_skip "repo-automation/tests/smoke.sh" "RUN_TESTS_SKIP_SMOKE=1"
  else
    run_tests_run_smoke "repo-automation/tests/smoke.sh" repo-automation/tests/smoke.sh || status=1
  fi
  if [ "${RUN_TESTS_SKIP_SMOKE:-0}" != "1" ]; then
    run_tests_run_cmd "repo-automation/tests/docs-check.sh" repo-automation/tests/docs-check.sh || status=1
    run_tests_run_cmd "repo-automation/tests/version-consistency.sh" repo-automation/tests/version-consistency.sh || status=1
  fi

  counts="$(run_tests_counts)"
  IFS=' ' read -r pass_count warn_count fail_count skipped_count <<EOF
$counts
EOF

  if [ "$fail_count" -gt 0 ] || [ "$status" -ne 0 ]; then
    overall_status="fail"
  elif [ "$warn_count" -gt 0 ]; then
    overall_status="warn"
  else
    overall_status="pass"
  fi

  if [ "$run_tests_json" -eq 1 ]; then
    run_tests_print_json       "$overall_status"       "$pass_count"       "$warn_count"       "$fail_count"       "$skipped_count"
  else
    run_tests_print_human       "$overall_status"       "$pass_count"       "$warn_count"       "$fail_count"       "$skipped_count"
  fi

  if [ "$fail_count" -gt 0 ] || [ "$status" -ne 0 ]; then
    run_tests_finish "$status"
    return $?
  fi
  run_tests_finish "$status"
  return $?
}

run_tests_main "$@"
# repo-automation/bin/run-tests EOF
