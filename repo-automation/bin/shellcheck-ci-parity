#!/usr/bin/env bash
# repo-automation/bin/shellcheck-ci-parity

set -u
set -o pipefail

print_help() {
  printf 'Usage: repo-automation/bin/shellcheck-ci-parity [--help]\n'
  printf '\n'
  printf 'Run ShellCheck against the CI file set with the CI parity exclusion.\n'
}

flag_error() {
  local reason="$1"
  local flag="$2"
  local fix="$3"
  printf 'fail: %s\n' "$reason" >&2
  printf 'flag: %s\n' "$flag" >&2
  printf 'fix: %s\n' "$fix" >&2
  exit 1
}

for arg in "$@"; do
  case "$arg" in
    --help)
      print_help
      exit 0
      ;;
    -*)
      flag_error "unknown flag" "$arg" "run repo-automation/bin/shellcheck-ci-parity --help"
      ;;
    *)
      flag_error "unknown flag" "$arg" "run repo-automation/bin/shellcheck-ci-parity --help"
      ;;
  esac
done

repo_root="$(cd "$(dirname "$0")/../.." && pwd)"

if ! command -v shellcheck >/dev/null 2>&1; then
  printf 'STOP: shellcheck is required; pkg install shellcheck\n' >&2
  exit 1
fi

cd "$repo_root" || exit 1

shellcheck -e SC2317 \
  repo-automation/bin/branch-cleanup \
  repo-automation/bin/codex-slice-preflight \
  repo-automation/bin/post-codex-packet \
  repo-automation/bin/pr-finish \
  repo-automation/bin/add-doc-pr \
  repo-automation/bin/repo-automation-report-upstream \
  repo-automation/bin/repo-doctor \
  repo-automation/bin/repo-automation-install \
  repo-automation/bin/run-tests \
  repo-automation/tests/lib/*.sh \
  repo-automation/tests/docs-check.sh \
  repo-automation/tests/contracts/*.sh \
  repo-automation/tests/smoke.sh \
  repo-automation/tests/version-consistency.sh
