#!/usr/bin/env bash
# repo-automation/bin/ci-log-dump

set -u
set -o pipefail

# shellcheck source=/dev/null
source "$(cd "$(dirname "$0")" && pwd)/../lib/common.sh"

ci_log_dump_repo=""
ci_log_dump_pr=""
ci_log_dump_run_id=""
ci_log_dump_out_dir=""
ci_log_dump_tail_lines=160
ci_log_dump_failed_only=1
ci_log_dump_latest_failed=0
ci_log_dump_machine_json=0
ci_log_dump_quiet=0
ci_log_dump_explain=0
ci_log_dump_first_failure=0
ci_log_dump_first_failure_label=""
ci_log_dump_first_failure_excerpt=""
ci_log_dump_first_failure_recommended_fix=""
ci_log_dump_gh_failure_message=""
ci_log_dump_stop_reason=""
ci_log_dump_log_path=""
ci_log_dump_pr_head_branch=""
ci_log_dump_pr_head_sha=""
ci_log_dump_pr_lookup_modes=""
ci_log_dump_selected_run_id=""

ci_log_dump_print_final_summary() {
  local rc="${1:-0}"

  if [ "$ci_log_dump_explain" -ne 1 ] || [ "$ci_log_dump_machine_json" -eq 1 ]; then
    return 0
  fi

  repo_auto_print_final_summary \
    "script=ci-log-dump" \
    "rc=$rc" \
    "repo=${ci_log_dump_repo:-unknown}" \
    "pr=${ci_log_dump_pr:-none}" \
    "run_id=${ci_log_dump_run_id:-none}" \
    "log_path=${ci_log_dump_log_path:-none}" \
    "first_failure=${ci_log_dump_first_failure_label:-none}" \
    "url_or_stop=$(
      if [ -n "$ci_log_dump_stop_reason" ]; then
        printf 'STOP: %s' "$ci_log_dump_stop_reason"
      elif [ -n "$ci_log_dump_log_path" ]; then
        printf '%s' "$ci_log_dump_log_path"
      else
        printf 'none'
      fi
    )"
}

ci_log_dump_usage() {
  printf 'Usage: repo-automation/bin/ci-log-dump [--repo=<owner/repo>] [--pr=<number|current|latest>] [--run-id=<id>] [--out-dir=<path>] [--tail=<lines>] [--failed-only] [--latest-failed] [--first-failure] [--machine-json] [--quiet] [--explain] [--help]\n'
}

ci_log_dump_flag_error() {
  local reason="$1"
  local flag="$2"
  local fix="$3"

  printf 'fail: %s\n' "$reason" >&2
  printf 'flag: %s\n' "$flag" >&2
  printf 'fix: %s\n' "$fix" >&2
}

ci_log_dump_json_escape() {
  local input="$1"
  input=${input//\\/\\\\}
  input=${input//\"/\\\"}
  input=${input//$'\n'/\\n}
  input=${input//$'\r'/\\r}
  input=${input//$'\t'/\\t}
  printf '%s' "$input"
}

ci_log_dump_stop() {
  local message="$1"
  ci_log_dump_stop_reason="$message"

  if [ "$ci_log_dump_machine_json" -eq 1 ]; then
    printf '{'
    printf '"script":"ci-log-dump",'
    printf '"repo":"%s",' "$(ci_log_dump_json_escape "$ci_log_dump_repo")"
    printf '"pr":"%s",' "$(ci_log_dump_json_escape "$ci_log_dump_pr")"
    printf '"run_id":"%s",' "$(ci_log_dump_json_escape "$ci_log_dump_run_id")"
    printf '"out_dir":"%s",' "$(ci_log_dump_json_escape "$ci_log_dump_out_dir")"
    printf '"tail_lines":%s,' "$ci_log_dump_tail_lines"
    printf '"failed_only":%s,' "$ci_log_dump_failed_only"
    printf '"latest_failed":%s,' "$ci_log_dump_latest_failed"
    printf '"log_path":"",'
    printf '"file_size_bytes":0,'
    printf '"overall_status":"fail",'
    printf '"stop_reason":"%s",' "$(ci_log_dump_json_escape "$message")"
    printf '"first_failure_label":"",'
    printf '"first_failure_excerpt":"",'
    printf '"recommended_fix":"",'
    printf '"tail_excerpt":[]'
    printf '}\n'
  else
    printf 'STOP: %s\n' "$message" >&2
  fi
  return 1
}

ci_log_dump_repo_from_remote() {
  local remote_url
  local repo
  local host
  local path

  remote_url="$(git remote get-url origin 2>/dev/null || true)"
  case "$remote_url" in
    git@github.com:*)
      repo="${remote_url#git@github.com:}"
      ;;
    git@github*:*)
      host="${remote_url%%:*}"
      case "$host" in
        git@github|git@github-*|git@github.com|git@github.com-*)
          repo="${remote_url#*:}"
          ;;
        *)
          return 1
          ;;
      esac
      ;;
    https://github.com/*)
      repo="${remote_url#https://github.com/}"
      ;;
    http://github.com/*)
      repo="${remote_url#http://github.com/}"
      ;;
    ssh://git@github.com/*)
      repo="${remote_url#ssh://git@github.com/}"
      ;;
    ssh://git@github-*/*|ssh://git@github.com-*/*)
      path="${remote_url#ssh://git@}"
      repo="${path#*/}"
      ;;
    *)
      return 1
      ;;
  esac

  repo="${repo%.git}"
  repo="${repo%/}"
  case "$repo" in
    /*|*//*)
      return 1
      ;;
  esac
  case "$repo" in
    */*/*)
      return 1
      ;;
    */*)
      printf '%s\n' "$repo"
      return 0
      ;;
  esac
  return 1
}

ci_log_dump_default_out_dir() {
  local preferred="/storage/emulated/0/Documents/HeartloomVault/40_STAGING/log-dump"
  local fallback="${TMPDIR:-$HOME/.cache}/repo-automation-log-dump"

  if mkdir -p "$preferred" >/dev/null 2>&1; then
    printf '%s\n' "$preferred"
    return 0
  fi

  mkdir -p "$fallback" >/dev/null 2>&1 || return 1
  printf '%s\n' "$fallback"
}

ci_log_dump_require_gh() {
  if ! command -v gh >/dev/null 2>&1; then
    ci_log_dump_stop 'gh is required for ci-log-dump; install GitHub CLI and rerun'
    return 1
  fi
}

ci_log_dump_gh_excerpt() {
  local stderr_file="$1"
  local stdout_file="$2"

  if [ -s "$stderr_file" ]; then
    sed -n '1,3p' "$stderr_file" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g; s/[[:space:]]*$//'
    return 0
  fi

  if [ -s "$stdout_file" ]; then
    sed -n '1,3p' "$stdout_file" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g; s/[[:space:]]*$//'
    return 0
  fi

  printf 'no output'
}

ci_log_dump_gh_retryable_failure() {
  local stderr_file="$1"
  local stdout_file="$2"

  case "$(tr '\n' ' ' <"$stderr_file")" in
    *'TLS handshake timeout'*|*'timeout'*|*'timed out'*|*'connection reset'*|*'connection refused'*|*'temporary failure'*|*'Service Unavailable'*|*'Bad Gateway'*|*'Gateway Timeout'*|*'rate limit'*|*'EOF'*)
      return 0
      ;;
  esac

  if [ ! -s "$stdout_file" ] && [ ! -s "$stderr_file" ]; then
    return 0
  fi

  return 1
}

ci_log_dump_gh_output() {
  local operation="$1"
  local expect_json="$2"
  shift 2
  local attempt=1
  local attempts=3
  local gh_stdout
  local gh_stderr

  gh_stdout="$(mktemp "${TMPDIR:-$HOME/.cache}/ci-log-dump.XXXXXX")"
  gh_stderr="$(mktemp "${TMPDIR:-$HOME/.cache}/ci-log-dump.XXXXXX")"
  ci_log_dump_gh_failure_message=""

  while [ "$attempt" -le "$attempts" ]; do
    : >"$gh_stdout"
    : >"$gh_stderr"
    if "$@" >"$gh_stdout" 2>"$gh_stderr"; then
      if [ "$expect_json" -eq 1 ]; then
        if [ -s "$gh_stdout" ] && python3 - "$gh_stdout" >/dev/null 2>&1 <<'PY'; then
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
json.loads(path.read_text(encoding='utf-8'))
PY
          cat "$gh_stdout"
          rm -f "$gh_stdout" "$gh_stderr" >/dev/null 2>&1 || true
          return 0
        fi
      elif [ -s "$gh_stdout" ]; then
        cat "$gh_stdout"
        rm -f "$gh_stdout" "$gh_stderr" >/dev/null 2>&1 || true
        return 0
      fi
      if [ "$attempt" -lt "$attempts" ]; then
        attempt=$((attempt + 1))
        continue
      fi
    elif [ "$attempt" -lt "$attempts" ] && ci_log_dump_gh_retryable_failure "$gh_stderr" "$gh_stdout"; then
      attempt=$((attempt + 1))
      continue
    fi
    break
  done

  ci_log_dump_stop "BLOCKER: GitHub API failure while $operation after $attempts attempts: $(ci_log_dump_gh_excerpt "$gh_stderr" "$gh_stdout")"
  rm -f "$gh_stdout" "$gh_stderr" >/dev/null 2>&1 || true
  return 1
}

ci_log_dump_gh_optional_json() {
  local stdout_file="$1"
  shift

  : >"$stdout_file"
  if "$@" >"$stdout_file" 2>/dev/null && [ -s "$stdout_file" ] && python3 - "$stdout_file" >/dev/null 2>&1 <<'PY'; then
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
json.loads(path.read_text(encoding='utf-8'))
PY
    return 0
  fi

  : >"$stdout_file"
  return 1
}

ci_log_dump_pick_head_branch() {
  ci_log_dump_gh_output "resolving head branch for PR #$1" 0 gh pr view "$1" --repo "$ci_log_dump_repo" --json headRefName --jq '.headRefName'
}

ci_log_dump_pick_head_sha() {
  local pr_number="$1"
  local sha_file
  local sha=""

  sha_file="$(mktemp "${TMPDIR:-$HOME/.cache}/ci-log-dump.XXXXXX")"
  if gh pr view "$pr_number" --repo "$ci_log_dump_repo" --json headRefOid --jq '.headRefOid' >"$sha_file" 2>/dev/null; then
    sha="$(sed -n '1p' "$sha_file" | tr -d '[:space:]')"
  fi
  rm -f "$sha_file" >/dev/null 2>&1 || true
  printf '%s' "$sha"
}

ci_log_dump_record_lookup_mode() {
  local mode="$1"
  if [ -z "$ci_log_dump_pr_lookup_modes" ]; then
    ci_log_dump_pr_lookup_modes="$mode"
  else
    ci_log_dump_pr_lookup_modes="$ci_log_dump_pr_lookup_modes,$mode"
  fi
}

ci_log_dump_pick_run_id_from_json() {
  local runs_file="$1"
  local expected_sha="$2"
  local expected_branch="$3"
  local expected_event="$4"

  python3 - "$runs_file" "$expected_sha" "$expected_branch" "$expected_event" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
expected_sha = sys.argv[2]
expected_branch = sys.argv[3]
expected_event = sys.argv[4]
items = json.loads(path.read_text(encoding='utf-8'))
matches = []
for item in items:
    if item.get('conclusion') != 'failure':
        continue
    if expected_sha:
        item_sha = str(item.get('headSha', ''))
        if item_sha and item_sha != expected_sha:
            continue
    if expected_branch and str(item.get('headBranch', '')) != expected_branch:
        continue
    if expected_event and str(item.get('event', '')) != expected_event:
        continue
    matches.append(item)
if matches:
    print(str(max(matches, key=lambda item: item.get('createdAt', '')).get('databaseId', '')))
PY
}

ci_log_dump_pick_run_id_for_branch() {
  local branch_name="$1"
  local event_name="$2"
  local expected_sha="${3:-}"
  local gh_output

  gh_output="$(ci_log_dump_gh_output "listing failed runs for branch $branch_name ($event_name)" 1 gh run list --repo "$ci_log_dump_repo" --branch "$branch_name" --event "$event_name" --status failure --limit 50 --json databaseId,conclusion,createdAt,event,headBranch,headSha,status,workflowName)" || return 1
  GH_OUTPUT_JSON="$gh_output" python3 - "$expected_sha" "$branch_name" "$event_name" <<'PY'
import json
import os
import sys

expected_sha = sys.argv[1]
expected_branch = sys.argv[2]
expected_event = sys.argv[3]
items = json.loads(os.environ.get('GH_OUTPUT_JSON', '[]'))
matches = []
for item in items:
    if item.get('conclusion') != 'failure':
        continue
    item_sha = str(item.get('headSha', ''))
    if expected_sha and item_sha and item_sha != expected_sha:
        continue
    if expected_branch and str(item.get('headBranch', '')) != expected_branch:
        continue
    if expected_event and str(item.get('event', '')) != expected_event:
        continue
    matches.append(item)
print(str(max(matches, key=lambda item: item.get('createdAt', '')).get('databaseId', '')) if matches else '')
PY
}

ci_log_dump_pick_latest_failed_run() {
  local gh_output

  gh_output="$(ci_log_dump_gh_output "listing latest failed runs for repository $ci_log_dump_repo" 1 gh run list --repo "$ci_log_dump_repo" --status failure --limit 100 --json databaseId,conclusion,createdAt,event,headBranch,status,workflowName)" || return 1
  printf '%s' "$gh_output" | python3 -c 'import json,sys; items=json.load(sys.stdin); failed=[item for item in items if item.get("conclusion")=="failure"]; print(max(failed, key=lambda item: item.get("createdAt","")).get("databaseId","") if failed else "")'
}

ci_log_dump_pick_run_id_for_pr() {
  local pr_number="$1"
  local run_id=""
  local runs_file

  ci_log_dump_selected_run_id=""
  ci_log_dump_pr_lookup_modes=""
  ci_log_dump_pr_head_branch="$(ci_log_dump_pick_head_branch "$pr_number" 2>/dev/null || true)"
  [ -n "$ci_log_dump_pr_head_branch" ] || return 1

  ci_log_dump_pr_head_sha="$(ci_log_dump_pick_head_sha "$pr_number" 2>/dev/null || true)"

  if [ -n "$ci_log_dump_pr_head_sha" ]; then
    runs_file="$(mktemp "${TMPDIR:-$HOME/.cache}/ci-log-dump.XXXXXX")"
    ci_log_dump_record_lookup_mode "sha-pull_request"
    if ci_log_dump_gh_optional_json "$runs_file" gh run list --repo "$ci_log_dump_repo" --commit "$ci_log_dump_pr_head_sha" --event pull_request --status failure --limit 50 --json databaseId,conclusion,createdAt,event,headBranch,headSha,status,workflowName; then
      run_id="$(ci_log_dump_pick_run_id_from_json "$runs_file" "$ci_log_dump_pr_head_sha" "" pull_request)"
    fi
    rm -f "$runs_file" >/dev/null 2>&1 || true
    [ -n "$run_id" ] && {
      ci_log_dump_selected_run_id="$run_id"
      return 0
    }
  fi

  ci_log_dump_record_lookup_mode "branch-pull_request"
  run_id="$(ci_log_dump_pick_run_id_for_branch "$ci_log_dump_pr_head_branch" pull_request "$ci_log_dump_pr_head_sha")" || return 1
  [ -n "$run_id" ] && {
    ci_log_dump_selected_run_id="$run_id"
    return 0
  }

  if [ -n "$ci_log_dump_pr_head_sha" ]; then
    runs_file="$(mktemp "${TMPDIR:-$HOME/.cache}/ci-log-dump.XXXXXX")"
    ci_log_dump_record_lookup_mode "sha-any"
    if ci_log_dump_gh_optional_json "$runs_file" gh run list --repo "$ci_log_dump_repo" --commit "$ci_log_dump_pr_head_sha" --status failure --limit 100 --json databaseId,conclusion,createdAt,event,headBranch,headSha,status,workflowName; then
      run_id="$(ci_log_dump_pick_run_id_from_json "$runs_file" "$ci_log_dump_pr_head_sha" "" "")"
    fi
    rm -f "$runs_file" >/dev/null 2>&1 || true
    [ -n "$run_id" ] && {
      ci_log_dump_selected_run_id="$run_id"
      return 0
    }

    runs_file="$(mktemp "${TMPDIR:-$HOME/.cache}/ci-log-dump.XXXXXX")"
    ci_log_dump_record_lookup_mode "repo-failed-head-sha"
    if ci_log_dump_gh_optional_json "$runs_file" gh run list --repo "$ci_log_dump_repo" --status failure --limit 100 --json databaseId,conclusion,createdAt,event,headBranch,headSha,status,workflowName; then
      run_id="$(ci_log_dump_pick_run_id_from_json "$runs_file" "$ci_log_dump_pr_head_sha" "" "")"
    fi
    rm -f "$runs_file" >/dev/null 2>&1 || true
    [ -n "$run_id" ] && {
      ci_log_dump_selected_run_id="$run_id"
      return 0
    }
  fi

  return 0
}

ci_log_dump_pr_no_run_message() {
  local branch_status="unresolved"
  local sha_status="unresolved"
  local modes="${ci_log_dump_pr_lookup_modes:-none}"

  if [ -n "$ci_log_dump_pr_head_branch" ]; then
    branch_status="resolved:$ci_log_dump_pr_head_branch"
  fi
  if [ -n "$ci_log_dump_pr_head_sha" ]; then
    sha_status="resolved:$ci_log_dump_pr_head_sha"
  fi

  printf 'no failed run found for PR #%s (head_branch=%s; head_sha=%s; lookup_modes_tried=%s)' "$ci_log_dump_pr" "$branch_status" "$sha_status" "$modes"
}

ci_log_dump_tail_excerpt() {
  tail -n "$ci_log_dump_tail_lines" "$1"
}

ci_log_dump_first_failure_details() {
  local log_path="$1"
  local parsed
  local label=""
  local excerpt=""
  local fix=""

parsed="$(python3 - "$log_path" <<'PY'
import json
import pathlib
import re
import sys

path = pathlib.Path(sys.argv[1])
raw_lines = path.read_text(encoding='utf-8', errors='replace').splitlines()
ansi = re.compile(r'\x1b\[[0-9;]*[A-Za-z]')
lines = [ansi.sub('', line) for line in raw_lines]

def compact(text):
    return re.sub(r'\s+', ' ', text).strip()

def actionable(line):
    lower = line.lower()
    if '\x1b[36;1m' in line or '^[[36;1m' in line or '##[group]Run ' in line:
        return False
    if re.search(r'\bSC\d{4}\b', line):
        return True
    if re.search(r'(?i)(^|[\s:])(fail|error|stop|first failure):', line):
        return True
    if '##[error]' in lower:
        return True
    return False

def find(patterns, candidates):
    for index, line in candidates:
        for label, pattern, fix in patterns:
            if pattern.search(line):
                print(json.dumps({
                    'label': label,
                    'excerpt': compact(line),
                    'fix': fix,
                }))
                return True
    return False

taxonomy = [
    ('fail: github-access', re.compile(r'(?i)(GitHub API failure|gh auth|TLS handshake timeout|rate limit|connection refused|connection reset|network is unreachable|temporary failure|Service Unavailable|Bad Gateway|Gateway Timeout|could not resolve host|EOF)'), 'check gh auth status and your network, then rerun'),
    ('fail: shellcheck', re.compile(r'(?i)(\bshellcheck[: ]|\bSC\d{4}\b|fail: shellcheck)'), 'run shellcheck on the reported file and line'),
    ('fail: docs-check', re.compile(r'(?i)(\bdocs-check\b|broken link|missing doc|docs/INDEX\.md|documentation)'), 'fix the broken doc or index entry, then rerun docs-check'),
    ('fail: version-consistency', re.compile(r'(?i)(\bversion-consistency\b|version mismatch|\bVERSION\b|REPO_AUTOMATION_VERSION|INSTALLED_VERSION_OR_REF)'), 'update the versioned files together, then rerun version-consistency'),
    ('fail: managed-files', re.compile(r'(?i)(\bmanaged-files\b|managed file|managed-file|manifest|installer coverage)'), 'fix the managed-file inventory, then rerun managed-file-check'),
    ('fail: contract/smoke', re.compile(r'(?i)(\bcontract\b|smoke:\S+)'), 'rerun the named contract or smoke test'),
    ('fail: run-tests', re.compile(r'(?i)(\brun-tests\b|test failed)'), 'inspect the failing test slice, then rerun that test'),
    ('fail: generic-ci', re.compile(r'(?i)(^|[\s:])(FAIL|ERROR|STOP): '), 'capture the failing step and classify it manually'),
]

actionable_lines = [(index, line) for index, line in enumerate(lines) if actionable(line)]
search_lines = actionable_lines if actionable_lines else list(enumerate(lines))

if not find(taxonomy, search_lines):
    fallback_patterns = [
        ('fail: unknown-ci', re.compile(r'(?i)^(FAIL|ERROR|STOP): '), 'capture the failing step and classify it manually'),
    ]
    if not find(fallback_patterns, search_lines):
        if lines:
            print(json.dumps({
                'label': 'fail: unknown-ci',
                'excerpt': compact(lines[-1]),
                'fix': 'capture the failing step and classify it manually',
            }))
        else:
            print(json.dumps({
                'label': 'fail: unknown-ci',
                'excerpt': '',
                'fix': 'capture the failing step and classify it manually',
            }))
PY
)"

  label="$(printf '%s' "$parsed" | python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("label",""))')"
  excerpt="$(printf '%s' "$parsed" | python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("excerpt",""))')"
  fix="$(printf '%s' "$parsed" | python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("fix",""))')"

  ci_log_dump_first_failure_label="$label"
  ci_log_dump_first_failure_excerpt="$excerpt"
  ci_log_dump_first_failure_recommended_fix="$fix"
}

ci_log_dump_print_json() {
  local log_path="$1"
  local size_bytes="$2"
  local run_id="$3"
  local line
  local excerpt=""
  local first=1

  while IFS= read -r line; do
    if [ "$first" -eq 0 ]; then
      excerpt+=','
    fi
    excerpt+="\"$(ci_log_dump_json_escape "$line")\""
    first=0
  done <<EOF_EXCERPT
$(ci_log_dump_tail_excerpt "$log_path")
EOF_EXCERPT

  printf '{'
  printf '"script":"ci-log-dump",'
  printf '"repo":"%s",' "$(ci_log_dump_json_escape "$ci_log_dump_repo")"
  printf '"pr":"%s",' "$(ci_log_dump_json_escape "$ci_log_dump_pr")"
  printf '"run_id":"%s",' "$(ci_log_dump_json_escape "$run_id")"
  printf '"out_dir":"%s",' "$(ci_log_dump_json_escape "$ci_log_dump_out_dir")"
  printf '"tail_lines":%s,' "$ci_log_dump_tail_lines"
  printf '"failed_only":%s,' "$ci_log_dump_failed_only"
  printf '"latest_failed":%s,' "$ci_log_dump_latest_failed"
  printf '"log_path":"%s",' "$(ci_log_dump_json_escape "$log_path")"
  printf '"file_size_bytes":%s,' "$size_bytes"
  printf '"overall_status":"pass",'
  printf '"stop_reason":"",'
  if [ "$ci_log_dump_first_failure" -eq 1 ]; then
    printf '"first_failure_label":"%s",' "$(ci_log_dump_json_escape "$ci_log_dump_first_failure_label")"
    printf '"first_failure_excerpt":"%s",' "$(ci_log_dump_json_escape "$ci_log_dump_first_failure_excerpt")"
    printf '"recommended_fix":"%s",' "$(ci_log_dump_json_escape "$ci_log_dump_first_failure_recommended_fix")"
  else
    printf '"first_failure_label":"",'
    printf '"first_failure_excerpt":"",'
    printf '"recommended_fix":"",'
  fi
  printf '"tail_excerpt":[%s]' "$excerpt"
  printf '}\n'
}

ci_log_dump_main() {
  local arg
  local worktree_root
  local target_repo
  local run_id
  local log_path
  local size_bytes
  local gh_log_file

  trap 'ci_log_dump_print_final_summary "$?"' EXIT

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --help)
        ci_log_dump_usage
        return 0
        ;;
      --repo=*)
        ci_log_dump_repo="${arg#--repo=}"
        if [ -z "$ci_log_dump_repo" ]; then
          ci_log_dump_flag_error "empty flag value" "--repo" "use --repo=<owner/repo>"
          return 1
        fi
        ;;
      --repo)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          ci_log_dump_flag_error "flag format not accepted" "--repo" "use --repo=<owner/repo>"
        else
          ci_log_dump_flag_error "missing flag value" "--repo" "use --repo=<owner/repo>"
        fi
        return 1
        ;;
      --pr=*)
        ci_log_dump_pr="${arg#--pr=}"
        if [ -z "$ci_log_dump_pr" ]; then
          ci_log_dump_flag_error "empty flag value" "--pr" "use --pr=<number>"
          return 1
        fi
        if ! repo_auto_is_positive_integer "$ci_log_dump_pr"; then
          ci_log_dump_stop "invalid --pr value: $ci_log_dump_pr"
          return 1
        fi
        ;;
      --pr)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          ci_log_dump_flag_error "flag format not accepted" "--pr" "use --pr=<number>"
        else
          ci_log_dump_flag_error "missing flag value" "--pr" "use --pr=<number>"
        fi
        return 1
        ;;
      --run-id=*)
        ci_log_dump_run_id="${arg#--run-id=}"
        if [ -z "$ci_log_dump_run_id" ]; then
          ci_log_dump_flag_error "empty flag value" "--run-id" "use --run-id=<id>"
          return 1
        fi
        if ! repo_auto_is_positive_integer "$ci_log_dump_run_id"; then
          ci_log_dump_stop "invalid --run-id value: $ci_log_dump_run_id"
          return 1
        fi
        ;;
      --run-id)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          ci_log_dump_flag_error "flag format not accepted" "--run-id" "use --run-id=<id>"
        else
          ci_log_dump_flag_error "missing flag value" "--run-id" "use --run-id=<id>"
        fi
        return 1
        ;;
      --out-dir=*)
        ci_log_dump_out_dir="${arg#--out-dir=}"
        if [ -z "$ci_log_dump_out_dir" ]; then
          ci_log_dump_flag_error "empty flag value" "--out-dir" "use --out-dir=<path>"
          return 1
        fi
        ;;
      --out-dir)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          ci_log_dump_flag_error "flag format not accepted" "--out-dir" "use --out-dir=<path>"
        else
          ci_log_dump_flag_error "missing flag value" "--out-dir" "use --out-dir=<path>"
        fi
        return 1
        ;;
      --tail=*)
        ci_log_dump_tail_lines="${arg#--tail=}"
        if [ -z "$ci_log_dump_tail_lines" ]; then
          ci_log_dump_flag_error "empty flag value" "--tail" "use --tail=<lines>"
          return 1
        fi
        if ! repo_auto_is_positive_integer "$ci_log_dump_tail_lines"; then
          ci_log_dump_stop "invalid --tail value: $ci_log_dump_tail_lines"
          return 1
        fi
        ;;
      --tail)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          ci_log_dump_flag_error "flag format not accepted" "--tail" "use --tail=<lines>"
        else
          ci_log_dump_flag_error "missing flag value" "--tail" "use --tail=<lines>"
        fi
        return 1
        ;;
      --failed-only)
        ci_log_dump_failed_only=1
        ;;
      --latest-failed)
        ci_log_dump_latest_failed=1
        ;;
      --first-failure)
        ci_log_dump_first_failure=1
        ;;
      --first-failure=*)
        ci_log_dump_flag_error "flag format not accepted" "--first-failure" "use --first-failure"
        return 1
        ;;
      --machine-json)
        ci_log_dump_machine_json=1
        ;;
      --quiet)
        ci_log_dump_quiet=1
        ;;
      --explain)
        ci_log_dump_explain=1
        ;;
      *)
        if [ "${arg#--}" != "$arg" ]; then
          ci_log_dump_flag_error "unknown flag" "$arg" "run repo-automation/bin/ci-log-dump --help"
        else
          ci_log_dump_stop "unknown argument: $arg"
        fi
        return 1
        ;;
    esac
    shift
  done

  worktree_root="$(git rev-parse --show-toplevel 2>/dev/null || printf '%s\n' "$PWD")"
  if [ -z "$ci_log_dump_repo" ]; then
    target_repo="$(ci_log_dump_repo_from_remote)" || {
      ci_log_dump_stop 'unable to infer --repo from origin remote; pass --repo=<owner/repo>'
      return 1
    }
    ci_log_dump_repo="$target_repo"
  fi

  if [ -z "$ci_log_dump_out_dir" ]; then
    ci_log_dump_out_dir="$(ci_log_dump_default_out_dir)" || {
      ci_log_dump_stop 'unable to select an output directory'
      return 1
    }
  fi

  ci_log_dump_require_gh || return 1

  if [ -n "$ci_log_dump_run_id" ]; then
    run_id="$ci_log_dump_run_id"
  elif [ "$ci_log_dump_latest_failed" -eq 1 ]; then
    run_id="$(ci_log_dump_pick_latest_failed_run)" || {
      if [ -n "$ci_log_dump_gh_failure_message" ]; then
        ci_log_dump_stop "$ci_log_dump_gh_failure_message"
      else
        ci_log_dump_stop "no failed run found for repository $ci_log_dump_repo"
      fi
      return 1
    }
    [ -n "$run_id" ] || {
      ci_log_dump_stop "no failed run found for repository $ci_log_dump_repo"
      return 1
    }
  elif [ -n "$ci_log_dump_pr" ]; then
    ci_log_dump_pick_run_id_for_pr "$ci_log_dump_pr" || {
      if [ -n "$ci_log_dump_gh_failure_message" ]; then
        ci_log_dump_stop "$ci_log_dump_gh_failure_message"
      else
        ci_log_dump_stop "unable to resolve head branch for PR #$ci_log_dump_pr"
      fi
      return 1
    }
    run_id="$ci_log_dump_selected_run_id"
    [ -n "$run_id" ] || {
      ci_log_dump_stop "$(ci_log_dump_pr_no_run_message)"
      return 1
    }
  else
    target_repo="$(git -C "$worktree_root" branch --show-current 2>/dev/null || true)"
    [ -n "$target_repo" ] || {
      ci_log_dump_stop 'unable to determine current branch; pass --pr or --run-id'
      return 1
    }
    run_id="$(ci_log_dump_pick_run_id_for_branch "$target_repo" push)" || {
      if [ -n "$ci_log_dump_gh_failure_message" ]; then
        ci_log_dump_stop "$ci_log_dump_gh_failure_message"
      else
        ci_log_dump_stop 'no failed run found for the current branch'
      fi
      return 1
    }
  fi
  ci_log_dump_run_id="$run_id"

  gh_log_file="$(mktemp "${TMPDIR:-$HOME/.cache}/ci-log-dump.XXXXXX")"
  if [ "$ci_log_dump_failed_only" -eq 1 ]; then
    if ! ci_log_dump_gh_output "fetching failed log for run $run_id" 0 gh run view "$run_id" --repo "$ci_log_dump_repo" --log-failed >"$gh_log_file"; then
      if [ "$ci_log_dump_machine_json" -eq 1 ] && [ -s "$gh_log_file" ]; then
        cat "$gh_log_file"
      fi
      rm -f "$gh_log_file" >/dev/null 2>&1 || true
      return 1
    fi
  else
    if ! ci_log_dump_gh_output "fetching log for run $run_id" 0 gh run view "$run_id" --repo "$ci_log_dump_repo" --log >"$gh_log_file"; then
      if [ "$ci_log_dump_machine_json" -eq 1 ] && [ -s "$gh_log_file" ]; then
        cat "$gh_log_file"
      fi
      rm -f "$gh_log_file" >/dev/null 2>&1 || true
      return 1
    fi
  fi

  mkdir -p "$ci_log_dump_out_dir" >/dev/null 2>&1 || {
    rm -f "$gh_log_file" >/dev/null 2>&1 || true
    ci_log_dump_stop "unable to create output directory: $ci_log_dump_out_dir"
    return 1
  }

  log_path="$ci_log_dump_out_dir/actions_run_${run_id}_$(date +%Y%m%d-%H%M%S).log"
  ci_log_dump_log_path="$log_path"
  cat "$gh_log_file" >"$log_path"
  size_bytes="$(wc -c <"$log_path" | tr -d '[:space:]')"
  rm -f "$gh_log_file" >/dev/null 2>&1 || true

  if [ "$ci_log_dump_machine_json" -eq 1 ]; then
    if [ "$ci_log_dump_first_failure" -eq 1 ]; then
      ci_log_dump_first_failure_details "$log_path"
    fi
    ci_log_dump_print_json "$log_path" "$size_bytes" "$run_id"
  else
    if [ "$ci_log_dump_quiet" -eq 1 ]; then
      :
    elif [ "$ci_log_dump_explain" -eq 1 ]; then
      printf 'Target repo: %s\n' "$ci_log_dump_repo"
      if [ -n "$ci_log_dump_pr" ]; then
        printf 'PR number: %s\n' "$ci_log_dump_pr"
      fi
      printf 'Run id: %s\n' "$run_id"
      printf 'Saved log path: %s\n' "$log_path"
      printf 'File size: %s bytes\n' "$size_bytes"
      if [ "$ci_log_dump_first_failure" -eq 1 ]; then
        ci_log_dump_first_failure_details "$log_path"
        printf 'First failure label: %s\n' "$ci_log_dump_first_failure_label"
        printf 'First failure excerpt: %s\n' "$ci_log_dump_first_failure_excerpt"
        printf 'Recommended fix: %s\n' "$ci_log_dump_first_failure_recommended_fix"
      else
        printf 'Tail excerpt:\n'
        ci_log_dump_tail_excerpt "$log_path"
      fi
    else
      printf '%s\n' "$log_path"
    fi
  fi
}

ci_log_dump_main "$@"
# repo-automation/bin/ci-log-dump EOF
