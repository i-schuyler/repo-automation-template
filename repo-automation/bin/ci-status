#!/usr/bin/env bash
# repo-automation/bin/ci-status

set -u
set -o pipefail

# shellcheck source=/dev/null
source "$(cd "$(dirname "$0")" && pwd)/../lib/common.sh"

ci_status_pr=""
ci_status_branch=""
ci_status_json=0
ci_status_machine_json=0
ci_status_quiet=0
ci_status_explain=0
ci_status_summary_json=""
ci_status_overall_status=""
ci_status_expected_head_sha="${CI_STATUS_EXPECTED_HEAD_SHA:-}"

ci_status_usage() {
  printf 'Usage: repo-automation/bin/ci-status [--pr=<number> | --branch=<name>] [--json] [--machine-json] [--quiet] [--explain] [--help]\n'
}

ci_status_flag_error() {
  local reason="$1"
  local flag="$2"
  local fix="$3"

  printf 'fail: %s\n' "$reason" >&2
  printf 'flag: %s\n' "$flag" >&2
  printf 'fix: %s\n' "$fix" >&2
}

ci_status_json_escape() {
  local input="$1"
  input=${input//\\/\\\\}
  input=${input//"/\\"}
  input=${input//$'\n'/\\n}
  input=${input//$'\r'/\\r}
  input=${input//$'\t'/\\t}
  printf '%s' "$input"
}

ci_status_status_from_checks() {
  local checks_file="$1"
  python3 - "$checks_file" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
items = json.loads(path.read_text(encoding='utf-8'))
counts = {'pass': 0, 'fail': 0, 'pending': 0, 'skipping': 0, 'cancel': 0}
for item in items:
    bucket = item.get('bucket', '')
    if bucket in counts:
        counts[bucket] += 1
if counts['fail'] or counts['cancel']:
    overall = 'fail'
elif counts['pending']:
    overall = 'pending'
elif counts['pass'] or counts['skipping']:
    overall = 'pass'
else:
    overall = 'warn'
print(json.dumps({'overall_status': overall, 'checks': items, 'bucket_counts': counts}))
PY
}

ci_status_status_from_runs() {
  local runs_file="$1"
  local expected_head_sha="$2"
  python3 - "$runs_file" "$expected_head_sha" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
expected_head_sha = sys.argv[2]
items = json.loads(path.read_text(encoding='utf-8'))
pending_states = {'queued', 'in_progress', 'requested', 'waiting', 'pending', 'action_required'}
blocked_states = {'failure', 'cancelled', 'canceled', 'timed_out', 'timeout'}
matching = []
for item in items:
    if expected_head_sha and str(item.get('headSha', '')) != expected_head_sha:
        continue
    matching.append(item)

latest = matching[0] if matching else {}
status = latest.get('status', '')
conclusion = latest.get('conclusion', '')
if expected_head_sha and not matching:
    overall = 'pending'
elif not items:
    overall = 'warn'
elif status in pending_states:
    overall = 'pending'
elif conclusion in {'success', 'neutral', 'skipped'}:
    overall = 'pass'
elif conclusion in blocked_states or status == 'completed':
    overall = 'fail'
else:
    overall = 'warn'
print(json.dumps({'overall_status': overall, 'latest_run': latest, 'matching_run_count': len(matching), 'run_count': len(items), 'head_sha': expected_head_sha}))
PY
}

ci_status_head_sha_for_pr() {
  local pr_number="$1"
  local current_head_sha=""

  current_head_sha="$(gh pr view "$pr_number" --json headRefOid --jq '.headRefOid' 2>/dev/null || true)"
  if [ -n "$ci_status_expected_head_sha" ]; then
    printf '%s' "$ci_status_expected_head_sha"
  else
    printf '%s' "$current_head_sha"
  fi
}

ci_status_check_auth() {
  if ! command -v gh >/dev/null 2>&1; then
    repo_auto_stop 'gh is required for ci-status; install GitHub CLI and rerun'
    return 1
  fi

  if ! gh auth status --active --hostname github.com >/dev/null 2>&1; then
    repo_auto_stop 'gh is not authenticated for github.com; run gh auth login and rerun'
    return 1
  fi
}

ci_status_load_pr() {
  local pr_number="$1"
  local checks_file
  local stderr_file
  local rc=0
  local summary_json
  local head_sha=""
  local head_branch=""

  checks_file="$(mktemp "${TMPDIR:-$HOME/.cache}/ci-status-checks.XXXXXX")"
  stderr_file="$(mktemp "${TMPDIR:-$HOME/.cache}/ci-status-checks-stderr.XXXXXX")"

  head_sha="$(ci_status_head_sha_for_pr "$pr_number")"
  head_branch="$(gh pr view "$pr_number" --json headRefName --jq '.headRefName' 2>/dev/null || true)"

  if [ -z "$head_branch" ]; then
    ci_status_summary_json="$(python3 - "$pr_number" "$head_sha" <<'PY'
import json
import sys

pr_number = sys.argv[1]
head_sha = sys.argv[2]
print(json.dumps({'overall_status': 'pending', 'latest_run': {}, 'matching_run_count': 0, 'run_count': 0, 'head_sha': head_sha, 'script': 'ci-status', 'machine_json': True, 'mode': 'pr', 'pr': pr_number, 'branch': ''}))
PY
)"
    ci_status_overall_status="pending"
    rm -f "$checks_file" "$stderr_file" >/dev/null 2>&1 || true
    return 0
  fi

  if [ -n "$head_sha" ]; then
    gh run list --branch "$head_branch" --limit 20 --json attempt,conclusion,createdAt,databaseId,displayTitle,event,headBranch,headSha,name,number,startedAt,status,updatedAt,url,workflowName >"$checks_file" 2>"$stderr_file"
    rc=$?
  else
    gh pr checks "$pr_number" --json bucket,name,state,workflow,description,link,startedAt,completedAt,event >"$checks_file" 2>"$stderr_file"
    rc=$?
  fi

  if [ "$rc" -eq 4 ]; then
    rm -f "$checks_file" "$stderr_file" >/dev/null 2>&1 || true
    repo_auto_stop 'gh authentication failed for ci-status; run gh auth status and gh auth login'
    return 1
  fi

  if [ "$rc" -ne 0 ] && [ "$rc" -ne 8 ]; then
    if grep -Eqi 'could not resolve to a Pull Request|pull request not found|not found' "$stderr_file" 2>/dev/null; then
      rm -f "$checks_file" "$stderr_file" >/dev/null 2>&1 || true
      repo_auto_stop "no pull request found for #$pr_number; use --branch=NAME or open the PR first"
      return 1
    fi
    if grep -Eqi 'dial tcp|no such host|connection refused|i/o timeout|network is unreachable|offline' "$stderr_file" 2>/dev/null; then
      rm -f "$checks_file" "$stderr_file" >/dev/null 2>&1 || true
      repo_auto_stop 'GitHub access failed for ci-status; check your network and rerun'
      return 1
    fi
    rm -f "$checks_file" "$stderr_file" >/dev/null 2>&1 || true
    repo_auto_stop "gh pr checks failed for #$pr_number"
    return 1
  fi

  if [ ! -s "$checks_file" ]; then
    ci_status_summary_json="$(python3 - "$pr_number" "$head_sha" <<'PY'
import json
import sys

pr_number = sys.argv[1]
head_sha = sys.argv[2]
print(json.dumps({'overall_status': 'pending', 'latest_run': {}, 'matching_run_count': 0, 'run_count': 0, 'head_sha': head_sha, 'script': 'ci-status', 'machine_json': True, 'mode': 'pr', 'pr': pr_number, 'branch': ''}))
PY
)"
    ci_status_overall_status="pending"
    rm -f "$checks_file" "$stderr_file" >/dev/null 2>&1 || true
    return 0
  fi

  if [ -n "$head_sha" ]; then
    summary_json="$(ci_status_status_from_runs "$checks_file" "$head_sha")" || {
      rm -f "$checks_file" "$stderr_file" >/dev/null 2>&1 || true
      repo_auto_stop "unable to parse ci status runs for #$pr_number"
      return 1
    }
  else
    summary_json="$(ci_status_status_from_checks "$checks_file")" || {
      rm -f "$checks_file" "$stderr_file" >/dev/null 2>&1 || true
      repo_auto_stop "unable to parse ci status checks for #$pr_number"
      return 1
    }
  fi

  ci_status_summary_json="$(python3 - "$summary_json" "$pr_number" <<'PY'
import json
import sys

summary = json.loads(sys.argv[1])
pr_number = sys.argv[2]
summary.update({'script': 'ci-status', 'machine_json': True, 'mode': 'pr', 'pr': pr_number, 'branch': ''})
print(json.dumps(summary))
PY
)"
  ci_status_overall_status="$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("overall_status","fail"))' "$ci_status_summary_json")"
  rm -f "$checks_file" "$stderr_file" >/dev/null 2>&1 || true
}

ci_status_load_branch() {
  local branch_name="$1"
  local pr_lookup_file
  local runs_file
  local stderr_file
  local pr_number=""
  local rc=0
  local summary_json
  local head_sha=""

  pr_lookup_file="$(mktemp "${TMPDIR:-$HOME/.cache}/ci-status-pr.XXXXXX")"
  runs_file="$(mktemp "${TMPDIR:-$HOME/.cache}/ci-status-runs.XXXXXX")"
  stderr_file="$(mktemp "${TMPDIR:-$HOME/.cache}/ci-status-runs-stderr.XXXXXX")"

  if gh pr list --head "$branch_name" --state all --limit 1 --json number,title,state,url,headRefName,baseRefName >"$pr_lookup_file" 2>/dev/null; then
    pr_number="$(python3 - "$pr_lookup_file" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
items = json.loads(path.read_text(encoding='utf-8'))
if items:
    print(items[0].get('number', ''))
PY
)"
  fi

  rm -f "$pr_lookup_file" >/dev/null 2>&1 || true

  if [ -n "$pr_number" ]; then
    head_sha="$(ci_status_head_sha_for_pr "$pr_number")"
    ci_status_load_pr "$pr_number"
    return $?
  fi

  gh run list --branch "$branch_name" --limit 1 --json attempt,conclusion,createdAt,databaseId,displayTitle,event,headBranch,headSha,name,number,startedAt,status,updatedAt,url,workflowName >"$runs_file" 2>"$stderr_file"
  rc=$?

  if [ "$rc" -eq 4 ]; then
    rm -f "$runs_file" "$stderr_file" >/dev/null 2>&1 || true
    repo_auto_stop 'gh authentication failed for ci-status; run gh auth status and gh auth login'
    return 1
  fi

  if [ "$rc" -ne 0 ]; then
    if grep -Eqi 'dial tcp|no such host|connection refused|i/o timeout|network is unreachable|offline' "$stderr_file" 2>/dev/null; then
      rm -f "$runs_file" "$stderr_file" >/dev/null 2>&1 || true
      repo_auto_stop 'GitHub access failed for ci-status; check your network and rerun'
      return 1
    fi
    rm -f "$runs_file" "$stderr_file" >/dev/null 2>&1 || true
    repo_auto_stop "gh run list failed for branch $branch_name"
    return 1
  fi

  if [ ! -s "$runs_file" ] || grep -q '^\[\]' "$runs_file" 2>/dev/null; then
    rm -f "$runs_file" "$stderr_file" >/dev/null 2>&1 || true
    repo_auto_stop "no pull request or workflow run found for branch $branch_name"
    return 1
  fi

  summary_json="$(ci_status_status_from_runs "$runs_file" "$head_sha")" || {
    rm -f "$runs_file" "$stderr_file" >/dev/null 2>&1 || true
    repo_auto_stop "unable to parse ci status runs for branch $branch_name"
    return 1
  }

  ci_status_summary_json="$(python3 - "$summary_json" "$branch_name" <<'PY'
import json
import sys

summary = json.loads(sys.argv[1])
branch_name = sys.argv[2]
summary.update({'script': 'ci-status', 'machine_json': True, 'mode': 'branch', 'pr': '', 'branch': branch_name})
print(json.dumps(summary))
PY
)"
  ci_status_overall_status="$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]).get("overall_status","fail"))' "$ci_status_summary_json")"
  rm -f "$runs_file" "$stderr_file" >/dev/null 2>&1 || true
}

ci_status_collect() {
  if [ -n "$ci_status_pr" ]; then
    ci_status_load_pr "$ci_status_pr" || return 1
  elif [ -n "$ci_status_branch" ]; then
    ci_status_load_branch "$ci_status_branch" || return 1
  else
    repo_auto_stop 'provide --pr=NUMBER or --branch=NAME'
    return 1
  fi
}

ci_status_print_human() {
  local mode="$1"
  python3 - "$ci_status_summary_json" "$mode" <<'PY'
import json
import sys

summary = json.loads(sys.argv[1])
mode = summary.get('mode', '')
output_mode = sys.argv[2]
overall = summary.get('overall_status', 'fail')
if output_mode == 'explain':
    if mode == 'pr':
        print(f"Target: PR #{summary.get('pr', '')}")
        print(f"Overall status: {overall}")
        print('Checks:')
        for item in summary.get('checks', []):
            print(f"- {item.get('name', '')}: {item.get('bucket', '')}")
    else:
        print(f"Target: branch {summary.get('branch', '')}")
        print(f"Overall status: {overall}")
        print('Latest run:')
        run = summary.get('latest_run', {})
        if not run:
            print('- none')
        else:
            pieces = [f"#{run.get('number', '')}", run.get('name', ''), run.get('status', ''), run.get('conclusion', '')]
            print('- ' + ' '.join(piece for piece in pieces if piece).strip())
    raise SystemExit(0)

if overall == 'pass':
    print('pass')
elif overall == 'pending':
    print('wait')
elif overall == 'warn':
    print('warn', file=sys.stderr)
else:
    reason = summary.get('stop_reason', '') or 'ci status failed'
    print(f'fail: {reason}', file=sys.stderr)
PY
}

ci_status_print_json() {
  printf '%s\n' "$ci_status_summary_json"
}

ci_status_main() {
  local arg

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --help)
        ci_status_usage
        return 0
        ;;
      --pr=*)
        ci_status_pr="${arg#--pr=}"
        if [ -z "$ci_status_pr" ]; then
          ci_status_flag_error "empty flag value" "--pr" "use --pr=<number>"
          return 1
        fi
        if ! repo_auto_is_positive_integer "$ci_status_pr"; then
          repo_auto_stop "invalid --pr value: $ci_status_pr"
          return 1
        fi
        ;;
      --pr)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          ci_status_flag_error "flag format not accepted" "--pr" "use --pr=<number>"
        else
          ci_status_flag_error "missing flag value" "--pr" "use --pr=<number>"
        fi
        return 1
        ;;
      --branch=*)
        ci_status_branch="${arg#--branch=}"
        if [ -z "$ci_status_branch" ]; then
          ci_status_flag_error "empty flag value" "--branch" "use --branch=<name>"
          return 1
        fi
        if ! repo_auto_validate_branch_name "$ci_status_branch"; then
          repo_auto_stop "invalid --branch value: $ci_status_branch"
          return 1
        fi
        ;;
      --branch)
        if [ "$#" -gt 1 ] && [ "${2#-}" = "$2" ]; then
          ci_status_flag_error "flag format not accepted" "--branch" "use --branch=<name>"
        else
          ci_status_flag_error "missing flag value" "--branch" "use --branch=<name>"
        fi
        return 1
        ;;
      --machine-json)
        ci_status_machine_json=1
        ;;
      --json)
        ci_status_json=1
        ;;
      --quiet)
        ci_status_quiet=1
        ;;
      --explain)
        ci_status_explain=1
        ;;
      *)
        if [ "${arg#--}" != "$arg" ]; then
          ci_status_flag_error "unknown flag" "$arg" "run repo-automation/bin/ci-status --help"
        else
          repo_auto_stop "unknown argument: $arg"
        fi
        return 1
        ;;
    esac
    shift
  done

  if [ -n "$ci_status_pr" ] && [ -n "$ci_status_branch" ]; then
    repo_auto_stop 'use only one of --pr=NUMBER or --branch=NAME'
    return 1
  fi

  ci_status_check_auth || return 1
  ci_status_collect || return 1

  if [ "$ci_status_json" -eq 1 ] || [ "$ci_status_machine_json" -eq 1 ]; then
    ci_status_print_json
  else
    if [ "$ci_status_quiet" -eq 1 ] && [ "$(printf '%s' "$ci_status_summary_json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("overall_status","fail"))')" = "pass" ]; then
      return 0
    fi
    if [ "$ci_status_explain" -eq 1 ]; then
      ci_status_print_human explain
    else
      ci_status_print_human summary
    fi
  fi

  if [ "${ci_status_overall_status:-fail}" = "fail" ]; then
    return 1
  fi

  return 0
}

ci_status_main "$@"
# repo-automation/bin/ci-status EOF
